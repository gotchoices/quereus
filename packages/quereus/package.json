{
  "name": "@quereus/quereus",
  "version": "4.3.1",
  "type": "module",
  "description": "Pure TypeScript SQL engine — no WASM, no native bindings. Runs in browsers, Node.js, React Native, edge workers, and anywhere JS runs.",
  "keywords": [
    "sql",
    "database",
    "typescript",
    "embedded-database",
    "browser-database",
    "virtual-table",
    "in-memory-database",
    "local-first",
    "offline-first",
    "query-engine",
    "sql-engine",
    "async",
    "cross-platform",
    "react-native",
    "edge-computing",
    "no-wasm",
    "sqlite-alternative"
  ],
  "publisher": "Got Choices Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/quereus.git",
    "directory": "packages/quereus"
  },
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./parser": {
      "types": "./dist/src/parser/index.d.ts",
      "import": "./dist/src/parser/index.js"
    },
    "./emit": {
      "types": "./dist/src/emit/index.d.ts",
      "import": "./dist/src/emit/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "doc": "npx typedoc -out doc src",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' && tsc -p tsconfig.test.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test:all": "cd ../.. && node --import ./packages/quereus/register.mjs node_modules/mocha/bin/mocha.js \"packages/quereus/test/**/*.spec.ts\" --colors",
    "test": "node test-runner.mjs",
    "test:store": "node test-runner.mjs --store",
    "test:fork-strict": "node test-runner.mjs --fork-strict",
    "test:full": "yarn test && yarn test:store",
    "test:coverage": "c8 --exclude 'test/**' --exclude 'bench/**' --exclude 'dist/**' --reporter text --reporter html node test-runner.mjs",
    "test:single": "cd ../.. && node --import ./packages/quereus/register.mjs node_modules/mocha/bin/mocha.js --bail",
    "test:plans": "cd ../.. && node --import ./packages/quereus/register.mjs node_modules/mocha/bin/mocha.js \"packages/quereus/test/plan/**/*.spec.ts\" --colors",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "bench": "node bench/run.mjs",
    "mutation:subsystem": "node mutation-subsystem.mjs"
  },
  "devDependencies": {
    "@quereus/plugin-leveldb": "workspace:^",
    "@quereus/plugin-loader": "*",
    "@quereus/store": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.8.0",
    "mocha": "^11.7.6",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "fast-json-patch": "^3.1.1",
    "inheritree": "^0.4.0",
    "moat-maker": "^2.2.0",
    "temporal-polyfill": "^0.3.0",
    "uint8arrays": "^6.1.1"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
