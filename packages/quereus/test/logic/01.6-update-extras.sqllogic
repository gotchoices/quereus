-- adapted from SQLite test/update.test, test/update2.test
-- UPDATE feature variants beyond the simple form covered in 01-basic / 42-returning.
-- Quereus has no rowids, no UPDATE LIMIT/ORDER BY, no INDEXED BY.

-- ===================================
-- 1. UPDATE all rows (no WHERE)
-- ===================================

create table all_rows (id integer primary key, status text);
insert into all_rows values (1, 'pending'), (2, 'pending'), (3, 'pending');

update all_rows set status = 'complete';

select count(*) as cnt from all_rows where status = 'complete';
→ [{"cnt":3}]

drop table all_rows;

-- ===================================
-- 2. UPDATE with subquery in SET (scalar subquery)
-- ===================================

create table src_lookup (id integer primary key, val text);
create table tgt_lookup (id integer primary key, name text null);
insert into src_lookup values (1, 'alpha'), (2, 'beta');
insert into tgt_lookup values (1, null), (2, null);

update tgt_lookup set name = (select val from src_lookup where src_lookup.id = tgt_lookup.id);
select id, name from tgt_lookup order by id;
→ [{"id":1,"name":"alpha"},{"id":2,"name":"beta"}]

drop table tgt_lookup;
drop table src_lookup;

-- ===================================
-- 3. UPDATE with multiple columns in SET, mixed expressions
-- ===================================

create table multi_set (id integer primary key, x integer, y integer);
insert into multi_set values (1, 10, 20), (2, 30, 40);

update multi_set set x = x + 1, y = y * 2 where id = 1;

select id, x, y from multi_set order by id;
→ [{"id":1,"x":11,"y":40},{"id":2,"x":30,"y":40}]

drop table multi_set;

-- ===================================
-- 4. UPDATE with column-list assignment from subquery: (a, b) = (select x, y)
-- ===================================

create table col_list (id integer primary key, a text, b text);
insert into col_list values (1, 'x', 'y');

-- column-list SET assignment is not supported by the parser
update col_list set (a, b) = (select 'new_a', 'new_b') where id = 1;
-- error: Expected column name

drop table col_list;

-- ===================================
-- 5. UPDATE with NOT condition in WHERE
-- ===================================

create table neg_pred (id integer primary key, n integer);
insert into neg_pred values (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

update neg_pred set n = 0 where not (id <= 3);

select id, n from neg_pred order by id;
→ [{"id":1,"n":10},{"id":2,"n":20},{"id":3,"n":30},{"id":4,"n":0},{"id":5,"n":0}]

drop table neg_pred;

-- ===================================
-- 6. UPDATE with OR conditions in WHERE
-- ===================================

create table or_pred (id integer primary key, a integer, b integer);
insert into or_pred values (1, 5, 100), (2, 10, 50), (3, 50, 5), (4, 1, 1);

update or_pred set a = a + 1000 where a > 8 or b > 80;

select id, a from or_pred order by id;
→ [{"id":1,"a":1005},{"id":2,"a":1010},{"id":3,"a":1050},{"id":4,"a":1}]

drop table or_pred;

-- ===================================
-- 7. UPDATE on PRIMARY KEY column (key change)
-- ===================================

create table pk_change (id integer primary key, name text);
insert into pk_change values (1, 'one'), (2, 'two');

update pk_change set id = 99 where name = 'two';

select id, name from pk_change order by id;
→ [{"id":1,"name":"one"},{"id":99,"name":"two"}]

drop table pk_change;

-- ===================================
-- 8. UPDATE assigning the same column twice is rejected (no silent last-wins)
-- ===================================

create table dup_set (id integer primary key, b integer);
insert into dup_set values (1, 10);

update dup_set set b = 1, b = 2 where id = 1;
-- error: duplicate assignment

-- the rejected UPDATE made no change.
select id, b from dup_set order by id;
→ [{"id":1,"b":10}]

drop table dup_set;
