-- null-edge-cases.sqllogic - Systematic NULL behavior tests across SQL positions

-- =============================================================================
-- Setup
-- =============================================================================

create table n1 (id integer primary key, val integer null, txt text null);
insert into n1 values (1, 10, 'a'), (2, null, 'b'), (3, 30, null), (4, null, null);

-- =============================================================================
-- NULL in join keys
-- =============================================================================

create table n2 (id integer primary key, ref integer null);
insert into n2 values (1, 10), (2, null), (3, 30);

-- INNER JOIN: NULL keys should NOT match
select n1.id, n1.val, n2.id, n2.ref from n1 inner join n2 on n1.val = n2.ref order by n1.id;
→ [{"id":1,"val":10,"id:1":1,"ref":10},{"id":3,"val":30,"id:1":3,"ref":30}]

-- LEFT JOIN: rows with null val get null on right side
select n1.id, n1.val, n2.id, n2.ref from n1 left join n2 on n1.val = n2.ref order by n1.id;
→ [{"id":1,"val":10,"id:1":1,"ref":10},{"id":2,"val":null,"id:1":null,"ref":null},{"id":3,"val":30,"id:1":3,"ref":30},{"id":4,"val":null,"id:1":null,"ref":null}]

-- Both sides NULL: verify NULLs don't join (NULL ≠ NULL)
select count(*) as cnt from n1 inner join n2 on n1.val = n2.ref;
→ [{"cnt":2}]

drop table n2;

-- =============================================================================
-- NULL in GROUP BY key
-- =============================================================================

-- NULLs grouped together into one group (NULLs first in default ordering)
select val, count(*) as cnt from n1 group by val order by val;
→ [{"val":null,"cnt":2},{"val":10,"cnt":1},{"val":30,"cnt":1}]

-- =============================================================================
-- NULL in ORDER BY
-- =============================================================================

-- Default ASC: NULLs come first
select id, val from n1 order by val, id;
→ [{"id":2,"val":null},{"id":4,"val":null},{"id":1,"val":10},{"id":3,"val":30}]

-- NULLS FIRST explicit (same as default ASC)
select id, val from n1 order by val nulls first, id;
→ [{"id":2,"val":null},{"id":4,"val":null},{"id":1,"val":10},{"id":3,"val":30}]

-- NULLS LAST moves NULLs to end
select id, val from n1 order by val nulls last, id;
→ [{"id":1,"val":10},{"id":3,"val":30},{"id":2,"val":null},{"id":4,"val":null}]

-- DESC with NULLS FIRST on text column
select id, txt from n1 order by txt desc nulls first, id;
→ [{"id":3,"txt":null},{"id":4,"txt":null},{"id":2,"txt":"b"},{"id":1,"txt":"a"}]

-- DESC with NULLS LAST moves NULLs to end
select id, val from n1 order by val desc nulls last, id;
→ [{"id":3,"val":30},{"id":1,"val":10},{"id":2,"val":null},{"id":4,"val":null}]

-- DESC with NULLS LAST on text column
select id, txt from n1 order by txt desc nulls last, id;
→ [{"id":2,"txt":"b"},{"id":1,"txt":"a"},{"id":3,"txt":null},{"id":4,"txt":null}]

-- =============================================================================
-- NULL in CASE WHEN
-- =============================================================================

-- NULL condition is falsy → else branch
select case when null then 'yes' else 'no' end as r;
→ [{"r":"no"}]

-- IS NULL in CASE WHEN
select id, case when val is null then 'missing' else 'present' end as status from n1 order by id;
→ [{"id":1,"status":"present"},{"id":2,"status":"missing"},{"id":3,"status":"present"},{"id":4,"status":"missing"}]

-- Simple CASE: NULL ≠ NULL so 'no match'
select case null when null then 'match' else 'no match' end as r;
→ [{"r":"no match"}]

-- CASE with NULL result branch
select id, case when id = 2 then null else val end as r from n1 order by id;
→ [{"id":1,"r":10},{"id":2,"r":null},{"id":3,"r":30},{"id":4,"r":null}]

-- =============================================================================
-- NULL in IN list and as IN operand
-- =============================================================================

-- NULL in IN list doesn't match NULL vals; only exact matches
select id, val from n1 where val in (10, null, 30) order by id;
→ [{"id":1,"val":10},{"id":3,"val":30}]

-- NOT IN with NULL in list: returns no rows
-- val NOT IN (10, NULL) → val<>10 AND val<>NULL → unknown for all non-10 values
select id, val from n1 where val not in (10, null) order by id;
→ []

-- NULL as IN operand: always unknown
select * from n1 where null in (1, 2, 3);
→ []

-- =============================================================================
-- NULL in aggregate arguments
-- =============================================================================

-- count(col) skips NULLs
select count(val) as cnt from n1;
→ [{"cnt":2}]

-- count(*) counts all rows
select count(*) as cnt from n1;
→ [{"cnt":4}]

-- sum skips NULLs
select sum(val) as s from n1;
→ [{"s":40}]

-- avg skips NULLs (40/2 = 20)
select avg(val) as a from n1;
→ [{"a":20}]

-- min skips NULLs
select min(val) as mn from n1;
→ [{"mn":10}]

-- max skips NULLs
select max(val) as mx from n1;
→ [{"mx":30}]

-- group_concat skips NULLs
select group_concat(txt, ',') as g from n1;
→ [{"g":"a,b"}]

-- =============================================================================
-- NULL in window functions
-- =============================================================================

-- PARTITION BY groups NULLs together
select id, val, row_number() over (partition by val order by id) as rn from n1 order by id;
→ [{"id":1,"val":10,"rn":1},{"id":2,"val":null,"rn":1},{"id":3,"val":30,"rn":1},{"id":4,"val":null,"rn":2}]

-- RANK with NULLs: null vals get same rank
select id, val, rank() over (order by val) as rnk from n1 order by id;
→ [{"id":1,"val":10,"rnk":3},{"id":2,"val":null,"rnk":1},{"id":3,"val":30,"rnk":4},{"id":4,"val":null,"rnk":1}]

-- =============================================================================
-- NULL in COALESCE chains
-- =============================================================================

select coalesce(null) as r;
→ [{"r":null}]

select coalesce(null, null, null) as r;
→ [{"r":null}]

select coalesce(null, null, 'found') as r;
→ [{"r":"found"}]

-- Per-row cascade: first non-null wins
select id, coalesce(val, txt, 'default') as r from n1 order by id;
→ [{"id":1,"r":10},{"id":2,"r":"b"},{"id":3,"r":30},{"id":4,"r":"default"}]

-- =============================================================================
-- NULL with every comparison operator
-- =============================================================================

select null = null as r;
→ [{"r":null}]

select null <> null as r;
→ [{"r":null}]

select null < 1 as r;
→ [{"r":null}]

select null > 1 as r;
→ [{"r":null}]

select null <= 1 as r;
→ [{"r":null}]

select null >= 1 as r;
→ [{"r":null}]

select null is null as r;
→ [{"r":true}]

select null is not null as r;
→ [{"r":false}]

select 1 is null as r;
→ [{"r":false}]

select 1 is not null as r;
→ [{"r":true}]

-- =============================================================================
-- NULL in DISTINCT
-- =============================================================================

-- NULLs are equal for DISTINCT: only one NULL in output
select distinct val from n1 order by val;
→ [{"val":null},{"val":10},{"val":30}]

-- =============================================================================
-- NULL in subqueries
-- =============================================================================

-- EXISTS with subquery returning null row: true (row exists, value doesn't matter)
select exists (select null) as r;
→ [{"r":true}]

-- Scalar subquery returning null
select (select null) as r;
→ [{"r":null}]

-- IN with null subquery result: unknown
select 1 in (select null) as r;
→ [{"r":null}]

-- =============================================================================
-- Cleanup
-- =============================================================================

drop table n1;
