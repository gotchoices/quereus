-- adapted from SQLite test/aggnested.test
-- Aggregates of aggregates via subquery / CTE composition. SQL forbids direct
-- nesting (sum(sum(x)) is illegal), so the legal pattern is to compute one
-- aggregate in a derived table and apply another in the outer query.

create table na (id integer primary key, grp text, val integer);
insert into na values
  (1, 'a', 10),
  (2, 'a', 20),
  (3, 'b', 30),
  (4, 'b', 40),
  (5, 'c', 50);

-- Derived table aggregate, outer aggregate over it
select sum(s) as grand_total, max(s) as biggest_grp, min(s) as smallest_grp
from (select grp, sum(val) as s from na group by grp);
→ [{"grand_total":150,"biggest_grp":70,"smallest_grp":30}]

-- avg of per-group sums
select avg(s) as mean_grp_total
from (select grp, sum(val) as s from na group by grp);
→ [{"mean_grp_total":50}]

-- count of distinct group totals (over the per-group aggregate)
select count(distinct s) as distinct_totals
from (select grp, sum(val) as s from na group by grp);
→ [{"distinct_totals":3}]

-- CTE producing per-group aggregate, outer query aggregates over it
with grp_sums as (select grp, sum(val) as s from na group by grp)
select count(*) as num_groups, sum(s) as total, max(s) as max_total
from grp_sums;
→ [{"num_groups":3,"total":150,"max_total":70}]

-- CTE with WHERE filter applied between aggregation levels
with grp_stats as (
  select grp, sum(val) as s, count(*) as cnt from na group by grp
)
select sum(s) as total_kept
from grp_stats where cnt > 1;
→ [{"total_kept":100}]

-- HAVING inside a derived-table feeding an outer aggregate filters groups correctly.
-- Group sums: a=30, b=70, c=50; threshold > 35 keeps b and c → outer sum = 120.
select sum(s) as total_above_threshold
from (select grp, sum(val) as s from na group by grp having sum(val) > 35);
→ [{"total_above_threshold":120}]

-- Two-level nesting: aggregate of an aggregate of an aggregate
select avg(g) as avg_grp_total from (
  select grp, sum(v) as g from (
    select grp, sum(val) as v from na group by grp
  ) group by grp
);
→ [{"avg_grp_total":50}]

drop table na;

-- Correlated subquery with aggregate inside outer aggregate
-- Outer aggregate counts groups whose subquery aggregate exceeds a threshold.
create table nb (id integer primary key, grp text, val integer);
insert into nb values
  (1, 'a', 10),
  (2, 'a', 20),
  (3, 'b', 30),
  (4, 'c', 5);

-- Number of groups whose own sum exceeds a fixed threshold
select count(*) as big_groups from (
  select grp, sum(val) as s from nb group by grp
) where s >= 25;
→ [{"big_groups":2}]

drop table nb;
