-- Table-level `PRIMARY KEY (...) ON CONFLICT <action>` directive. Mirrors 29.1
-- (column-level) but exercises the constraint on a composite PK declared as a
-- table-level constraint, which previously parsed correctly but had its
-- `ON CONFLICT` action silently dropped (resolving to ABORT).

-- ===================================
-- 1. PRIMARY KEY (...) ON CONFLICT IGNORE — duplicate insert silently dropped
-- ===================================

create table tpk_ignore (a integer, b integer, v text, primary key (a, b) on conflict ignore);
insert into tpk_ignore values (1, 1, 'first');

insert into tpk_ignore values (1, 1, 'second');

select a, b, v from tpk_ignore;
→ [{"a":1,"b":1,"v":"first"}]

drop table tpk_ignore;

-- ===================================
-- 2. PRIMARY KEY (...) ON CONFLICT REPLACE — duplicate insert silently replaces
-- ===================================

create table tpk_replace (a integer, b integer, v text, primary key (a, b) on conflict replace);
insert into tpk_replace values (1, 1, 'first');

insert into tpk_replace values (1, 1, 'second');

select a, b, v from tpk_replace;
→ [{"a":1,"b":1,"v":"second"}]

drop table tpk_replace;

-- ===================================
-- 3. PRIMARY KEY (...) ON CONFLICT FAIL — duplicate insert errors
-- ===================================

create table tpk_fail (a integer, b integer, v text, primary key (a, b) on conflict fail);
insert into tpk_fail values (1, 1, 'first');

insert into tpk_fail values (1, 1, 'second');
-- error: UNIQUE constraint failed

-- The original row is still there; the conflicting insert errored out.
select a, b, v from tpk_fail;
→ [{"a":1,"b":1,"v":"first"}]

drop table tpk_fail;

-- ===================================
-- 4. PRIMARY KEY (...) ON CONFLICT ROLLBACK — duplicate insert errors
-- ===================================
-- The per-constraint ROLLBACK action surfaces as a constraint failure at the
-- helper layer (statement aborts). Translation into a tx-wide rollback of the
-- enclosing transaction would require additional runtime wiring beyond the
-- schema-build + helper scope of this change; see implementer notes.

create table tpk_rb (a integer, b integer, v text, primary key (a, b) on conflict rollback);
insert into tpk_rb values (1, 1, 'first');

insert into tpk_rb values (1, 1, 'second');
-- error: UNIQUE constraint failed

select a, b, v from tpk_rb;
→ [{"a":1,"b":1,"v":"first"}]

drop table tpk_rb;

-- ===================================
-- 5. Statement-level OR clause overrides table-level ON CONFLICT directive
-- ===================================

create table tpk_override (a integer, b integer, v text, primary key (a, b) on conflict ignore);
insert into tpk_override values (1, 1, 'first');

-- statement-level OR ABORT must beat the table-level IGNORE directive.
insert or abort into tpk_override values (1, 1, 'second');
-- error: UNIQUE constraint failed

-- only the original row remains
select a, b, v from tpk_override;
→ [{"a":1,"b":1,"v":"first"}]

drop table tpk_override;

-- ===================================
-- 6. UPDATE path honors table-level PRIMARY KEY ON CONFLICT REPLACE
-- ===================================

create table tpk_upd_replace (a integer, b integer, v text, primary key (a, b) on conflict replace);
insert into tpk_upd_replace values (1, 1, 'a'), (2, 2, 'b');

-- No OR clause on UPDATE — table-level REPLACE should apply.
update tpk_upd_replace set a = 2, b = 2 where a = 1 and b = 1;

select a, b, v from tpk_upd_replace order by a, b;
→ [{"a":2,"b":2,"v":"a"}]

drop table tpk_upd_replace;

-- ===================================
-- 7. UPDATE path honors table-level PRIMARY KEY ON CONFLICT IGNORE
-- ===================================

create table tpk_upd_ignore (a integer, b integer, v text, primary key (a, b) on conflict ignore);
insert into tpk_upd_ignore values (1, 1, 'a'), (2, 2, 'b');

update tpk_upd_ignore set a = 2, b = 2 where a = 1 and b = 1;

select a, b, v from tpk_upd_ignore order by a, b;
→ [{"a":1,"b":1,"v":"a"},{"a":2,"b":2,"v":"b"}]

drop table tpk_upd_ignore;
