-- adapted from SQLite test/window1.test, test/window4.test, test/window9.test
-- Named window definitions via the WINDOW clause; Quereus does not yet
-- support window-name references. Document the rejection.

create table nw (id integer primary key, val integer, grp text);
insert into nw values (1, 10, 'A'), (2, 20, 'A');

select id, val, grp,
       row_number() over w as rn
from nw window w as (partition by grp order by id) order by id;
-- error: Window name references are not yet supported

drop table nw;
