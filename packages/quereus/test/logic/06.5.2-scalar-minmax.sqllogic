-- adapted from SQLite test/minmax.test
-- Scalar MIN(x, y, ...) / MAX(x, y, ...) — distinguished from single-arg aggregates by arity.
-- Quereus does not currently implement multi-argument scalar min/max; only the
-- single-arg aggregate forms exist. Document the rejection.

select min(10, 20);
-- error: Function not found: min/2

select max(10, 20);
-- error: Function not found: max/2

select min(10, 20, 5);
-- error: Function not found: min/3

select max(10, 20, 5);
-- error: Function not found: max/3
