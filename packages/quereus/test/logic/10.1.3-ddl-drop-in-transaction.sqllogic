-- Dropping a UNIQUE index / constraint inside an open transaction must stop enforcing it
-- for the rest of that transaction.
--
-- A `TransactionLayer` freezes its schema at construction and enforces UNIQUE off that frozen
-- schema, so a `drop index` / `alter table … drop constraint` that ran after the layer forked
-- used to keep rejecting rows against a constraint that no longer exists. The manager now hands
-- the post-drop schema to every open layer (`adoptSchemaOnOpenLayers` → `TransactionLayer.adoptSchema`,
-- which now also removes the dropped index), so enforcement stops immediately.
--
-- Runs against every backend (memory, store). Each statement is its own block so an expected
-- failure is attributed to exactly one statement. The memory-only savepoint quirk (DROP is not
-- undone by `rollback to savepoint`) is pinned separately in
-- 10.1.3.1-ddl-drop-savepoint-memory.sqllogic — store implements savepoint/DDL differently.

-- ===================================
-- 1. drop index on a unique index inside a transaction stops enforcing it
-- ===================================

create table drop_tx_a (id integer primary key, v text);
-- run
create unique index drop_tx_a_ix on drop_tx_a (v);
-- run
begin;
-- run
insert into drop_tx_a values (1, 'a');
-- run
drop index drop_tx_a_ix;
-- run

-- The unique index is gone, so a colliding row is now accepted mid-transaction.
insert into drop_tx_a values (2, 'a');
-- run
commit;
-- run

select id, v from drop_tx_a order by id;
→ [{ "id": 1, "v": "a" }, { "id": 2, "v": "a" }]

-- After commit the constraint is genuinely gone: a fresh duplicate is still accepted.
insert into drop_tx_a values (3, 'a');
-- run

select count(*) as cnt from drop_tx_a;
→ [{ "cnt": 3 }]

-- ===================================
-- 2. alter table … drop constraint unique inside a transaction stops enforcing it
-- ===================================

create table drop_tx_b (id integer primary key, v text, constraint drop_tx_b_u unique (v));
-- run
begin;
-- run
insert into drop_tx_b values (1, 'a');
-- run
alter table drop_tx_b drop constraint drop_tx_b_u;
-- run

-- The unique constraint is gone, so a colliding row is now accepted mid-transaction.
insert into drop_tx_b values (2, 'a');
-- run
commit;
-- run

select id, v from drop_tx_b order by id;
→ [{ "id": 1, "v": "a" }, { "id": 2, "v": "a" }]

-- After commit the constraint is genuinely gone: a fresh duplicate is still accepted.
insert into drop_tx_b values (3, 'a');
-- run

select count(*) as cnt from drop_tx_b;
→ [{ "cnt": 3 }]

-- ===================================
-- 3. Dropping one unique index leaves a sibling unique index still enforced
-- ===================================

create table drop_tx_c (id integer primary key, v text, w text);
-- run
create unique index drop_tx_c_v on drop_tx_c (v);
-- run
create unique index drop_tx_c_w on drop_tx_c (w);
-- run
begin;
-- run
insert into drop_tx_c values (1, 'a', 'x');
-- run
drop index drop_tx_c_v;
-- run

-- The dropped index no longer blocks a duplicate v.
insert into drop_tx_c values (2, 'a', 'y');
-- run

-- The sibling index on w is untouched and still rejects a duplicate w.
insert into drop_tx_c values (3, 'b', 'x');
-- error: UNIQUE constraint failed
commit;
-- run

select id, v, w from drop_tx_c order by id;
→ [{ "id": 1, "v": "a", "w": "x" }, { "id": 2, "v": "a", "w": "y" }]

-- Cleanup
drop table drop_tx_a;
-- run
drop table drop_tx_b;
-- run
drop table drop_tx_c;
-- run
