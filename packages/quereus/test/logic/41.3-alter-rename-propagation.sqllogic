-- adapted from SQLite test/alter.test and test/altertab.test
-- RENAME TABLE / RENAME COLUMN must propagate into dependent objects:
-- views, CHECK constraints, FOREIGN KEY references, indexes, CTEs in views.

-- ===================================
-- 1. RENAME TABLE referenced by a CHECK constraint
-- ===================================

create table t_chk (id integer primary key, v integer not null);
alter table t_chk add constraint c1 check ((select count(*) from t_chk) >= 0);

alter table t_chk rename to t_chk2;

insert into t_chk2 values (1, 10);

select count(*) as cnt from t_chk2;
→ [{"cnt":1}]

drop table t_chk2;

-- ===================================
-- 2. RENAME TABLE referenced by a partial-index WHERE clause
-- ===================================

create table t_pidx (id integer primary key, v integer not null);
create index ix_t_pidx on t_pidx(v) where v > 0;

alter table t_pidx rename to t_pidx2;

insert into t_pidx2 values (1, 5), (2, -1);

select v from t_pidx2 where v > 0 order by v;
→ [{"v":5}]

drop table t_pidx2;

-- ===================================
-- 2b. RENAME TABLE with a table-qualified partial-index WHERE
-- ===================================
-- The stored predicate qualifier must follow the rename (catalog DDL would
-- otherwise persist `... ON t_pidxq2 ... WHERE t_pidxq.v > 0`).

create table t_pidxq (id integer primary key, v integer not null);
create index ix_t_pidxq on t_pidxq(v) where t_pidxq.v > 0;

alter table t_pidxq rename to t_pidxq2;

insert into t_pidxq2 values (1, 5), (2, -1);

select v from t_pidxq2 where v > 0 order by v;
→ [{"v":5}]

drop table t_pidxq2;

-- ===================================
-- 2c. RENAME COLUMN referenced by a partial-index WHERE
-- ===================================
-- The stored predicate must rewrite `v` → `w`; the index keeps maintaining
-- (and excluding out-of-scope rows) under the new column name.

create table t_pidxc (id integer primary key, v integer not null);
create index ix_t_pidxc on t_pidxc(v) where v > 0;

alter table t_pidxc rename column v to w;

insert into t_pidxc values (1, 5), (2, -1);

select w from t_pidxc where w > 0 order by w;
→ [{"w":5}]

drop table t_pidxc;

-- ===================================
-- 3. RENAME TABLE referenced by a FOREIGN KEY in another table
-- ===================================

pragma foreign_keys = true;

create table parent_t (id integer primary key, name text);
create table child_t (id integer primary key, pid integer not null references parent_t(id) on delete restrict on update restrict);

insert into parent_t values (1, 'p');
insert into child_t values (10, 1);

-- Force a checkpoint here so the deferred FK check from the legitimate insert
-- evaluates against the still-current parent_t before we rename it.
select count(*) as cnt from child_t;
→ [{"cnt":1}]

alter table parent_t rename to parent_t2;

select count(*) as cnt from parent_t2;
→ [{"cnt":1}]

-- FK still enforced under new parent name (bad pid → fail at commit)
insert into child_t values (11, 99);
-- error: CHECK constraint failed: _fk_child_t

-- valid child reference still works under the new parent name
insert into child_t values (12, 1);

select count(*) as cnt from child_t;
→ [{"cnt":2}]

drop table child_t;
drop table parent_t2;

-- ===================================
-- 4. RENAME TABLE referenced inside a view's SELECT
-- ===================================

create table tv_src (id integer primary key, name text);
insert into tv_src values (1, 'a');

create view vv as select id, name from tv_src;

alter table tv_src rename to tv_src2;

select * from vv;
→ [{"id":1,"name":"a"}]

drop view vv;
drop table tv_src2;

-- ===================================
-- 5. RENAME COLUMN propagates into a view's projection / WHERE
-- ===================================

create table t_vc (id integer primary key, old_n text);
insert into t_vc values (1, 'a'), (2, 'b');

create view v_vc as select id, old_n from t_vc where old_n is not null;

alter table t_vc rename column old_n to new_n;

select * from v_vc order by id;
→ [{"id":1,"new_n":"a"},{"id":2,"new_n":"b"}]

drop view v_vc;
drop table t_vc;

-- ===================================
-- 6. RENAME COLUMN referenced inside a CTE in a view
-- ===================================

create table t_cte (id integer primary key, k integer not null);
insert into t_cte values (1, 10), (2, 20);

create view v_cte as with c as (select k from t_cte) select k from c;

alter table t_cte rename column k to kk;

select * from v_cte order by kk;
→ [{"kk":10},{"kk":20}]

drop view v_cte;
drop table t_cte;

-- ===================================
-- 6a. Aliased CTE projection does NOT propagate
-- ===================================

create table t_a (id integer primary key, k integer not null);
insert into t_a values (1, 10);

create view v_a as with c as (select k as kk_alias from t_a) select kk_alias from c;

alter table t_a rename column k to kk;

select * from v_a;
→ [{"kk_alias":10}]

drop view v_a;
drop table t_a;

-- ===================================
-- 6b. Explicit CTE column list stops propagation
-- ===================================

create table t_x (id integer primary key, k integer not null);
insert into t_x values (1, 5);

create view v_cl as with c(x) as (select k from t_x) select x from c;

alter table t_x rename column k to kk;

select * from v_cl;
→ [{"x":5}]

drop view v_cl;
drop table t_x;

-- ===================================
-- 6c. Multi-CTE chain propagates through every link
-- ===================================

create table t_chain (id integer primary key, k integer not null);
insert into t_chain values (1, 7), (2, 8);

create view v_chain as with a as (select k from t_chain), b as (select k from a) select k from b;

alter table t_chain rename column k to kk;

select * from v_chain order by kk;
→ [{"kk":7},{"kk":8}]

drop view v_chain;
drop table t_chain;

-- ===================================
-- 6d. CTE inside a subquery in the view body
-- ===================================

create table t_sub (id integer primary key, k integer not null);
insert into t_sub values (1, 42);

create view v_sub as select * from (with c as (select k from t_sub) select k from c) s;

alter table t_sub rename column k to kk;

select * from v_sub;
→ [{"kk":42}]

drop view v_sub;
drop table t_sub;

-- ===================================
-- 6e. CTE body using select * (star passthrough)
-- ===================================

create table t_star (id integer primary key, k integer not null);
insert into t_star values (1, 99);

create view v_star as with c as (select * from t_star) select k from c;

alter table t_star rename column k to kk;

select kk from v_star;
→ [{"kk":99}]

drop view v_star;
drop table t_star;

-- ===================================
-- 6f. Qualified outer reference to an exposing CTE
-- ===================================

create table t_q (id integer primary key, k integer not null);
insert into t_q values (1, 5);

create view v_q as with c as (select k from t_q) select c.k from c;

alter table t_q rename column k to kk;

select * from v_q;
→ [{"kk":5}]

drop view v_q;
drop table t_q;

-- ===================================
-- 6g. CTE shadowing the renamed table by name (non-exposing)
-- ===================================
-- The outer FROM refers to the CTE, not the real table; the rename must NOT
-- rewrite the unqualified `k` in the outer SELECT into `kk`.

create table t_shadow (id integer primary key, k integer not null);
insert into t_shadow values (1, 100);

create view v_shadow as with t_shadow as (select 0 as k) select k from t_shadow;

alter table t_shadow rename column k to kk;

select * from v_shadow;
→ [{"k":0}]

drop view v_shadow;
drop table t_shadow;

-- ===================================
-- 6h. Aliased shadowing CTE — qualified ref resolves to CTE column
-- ===================================
-- `from t_shadow2 as a` where `t_shadow2` is a non-exposing shadowing CTE:
-- the qualified `a.k` resolves to the CTE column and must NOT be rewritten.

create table t_shadow2 (id integer primary key, k integer not null);
insert into t_shadow2 values (1, 100);

create view v_shadow2 as with t_shadow2 as (select 0 as k) select a.k from t_shadow2 as a;

alter table t_shadow2 rename column k to kk;

select * from v_shadow2;
→ [{"k":0}]

drop view v_shadow2;
drop table t_shadow2;

-- ===================================
-- 6i. Sibling-CTE shadowing inside a multi-WITH
-- ===================================
-- The second sibling shadows the renamed table by name; its body sees the
-- first sibling (also a CTE). Outer ref must NOT rewrite to `kk`.

create table t_sib (id integer primary key, k integer not null);
insert into t_sib values (1, 999);

create view v_sib as with a as (select 0 as k), t_sib as (select k from a) select k from t_sib;

alter table t_sib rename column k to kk;

select * from v_sib;
→ [{"k":0}]

drop view v_sib;
drop table t_sib;

-- ===================================
-- 6j. Recursive CTE shadowing the renamed table — no column list
-- ===================================
-- The recursive step's `from t_rec` is a self-reference to the CTE, not
-- the renamed real table. Without pre-registering the CTE name for
-- `with recursive`, the inner `select k+1 from t_rec where k < 3` would
-- mis-bind `t_rec` as the renamed table and rewrite the unqualified `k`s
-- to `kk`, corrupting the recursive step.

create table t_rec (id integer primary key, k integer not null);
insert into t_rec values (1, 0);

create view v_rec as
  with recursive t_rec as (
    select 0 as k
    union all
    select k+1 from t_rec where k < 3
  ) select k from t_rec;

alter table t_rec rename column k to kk;

select k from v_rec order by k;
→ [{"k":0},{"k":1},{"k":2},{"k":3}]

drop view v_rec;
drop table t_rec;

-- ===================================
-- 6k. Recursive CTE shadowing the renamed table — explicit column list
-- ===================================
-- Same shape as 6j with an explicit column list `t_rec_cl(k)`. The
-- column-list short-circuits exposure analysis; the recursive
-- self-reference inside the body must still resolve to the CTE.

create table t_rec_cl (id integer primary key, k integer not null);
insert into t_rec_cl values (1, 0);

create view v_rec_cl as
  with recursive t_rec_cl(k) as (
    select 0
    union all
    select k+1 from t_rec_cl where k < 3
  ) select k from t_rec_cl;

alter table t_rec_cl rename column k to kk;

select k from v_rec_cl order by k;
→ [{"k":0},{"k":1},{"k":2},{"k":3}]

drop view v_rec_cl;
drop table t_rec_cl;

-- ===================================
-- 6l. Sibling recursive CTEs where one sibling shadows the renamed table
-- ===================================
-- Two siblings inside a `with recursive`: the first is a regular CTE, the
-- second has the same name as the renamed table and self-references in its
-- recursive step. Pre-registration must happen per-iteration so the second
-- sibling's body sees itself (not the renamed real table).

create table t_rsib (id integer primary key, k integer not null);
insert into t_rsib values (1, 0);

create view v_rsib as
  with recursive a as (select 0 as k),
                  t_rsib as (
                    select k from a
                    union all
                    select k+1 from t_rsib where k < 2
                  )
  select k from t_rsib;

alter table t_rsib rename column k to kk;

select k from v_rsib order by k;
→ [{"k":0},{"k":1},{"k":2}]

drop view v_rsib;
drop table t_rsib;

-- ===================================
-- 6m. Non-exposing shadowing CTE — unaliased qualified ref
-- ===================================
-- `from t_shadow3` is a non-exposing shadowing CTE; the qualified
-- `t_shadow3.k` resolves to the CTE column and must NOT be rewritten,
-- even though the qualifier textually matches the renamed table.

create table t_shadow3 (id integer primary key, k integer not null);
insert into t_shadow3 values (1, 100);

create view v_shadow3 as
  with t_shadow3 as (select 0 as k) select t_shadow3.k from t_shadow3;

alter table t_shadow3 rename column k to kk;

select * from v_shadow3;
→ [{"k":0}]

drop view v_shadow3;
drop table t_shadow3;

-- ===================================
-- 6n. Sibling shadowing CTE — qualified ref
-- ===================================
-- A sibling CTE with the renamed table's name shadows the real table;
-- a qualified ref against the shadowing source name must not rewrite.

create table t_sib2 (id integer primary key, k integer not null);
insert into t_sib2 values (1, 999);

create view v_sib2 as
  with a as (select 0 as k), t_sib2 as (select k from a)
  select t_sib2.k from t_sib2;

alter table t_sib2 rename column k to kk;

select * from v_sib2;
→ [{"k":0}]

drop view v_sib2;
drop table t_sib2;

-- ===================================
-- 6o. Recursive shadowing CTE — qualified ref in recursive step
-- ===================================
-- Inside the recursive step, qualified `t_rec2.k` refers to the CTE
-- (pre-registered for `with recursive`), not the renamed real table.

create table t_rec2 (id integer primary key, k integer not null);
insert into t_rec2 values (1, 0);

create view v_rec2 as
  with recursive t_rec2 as (
    select 0 as k
    union all
    select t_rec2.k+1 from t_rec2 where t_rec2.k < 3
  ) select k from t_rec2;

alter table t_rec2 rename column k to kk;

select k from v_rec2 order by k;
→ [{"k":0},{"k":1},{"k":2},{"k":3}]

drop view v_rec2;
drop table t_rec2;

-- ===================================
-- 6p. Non-exposing shadowing CTE — alias equals the table name
-- ===================================
-- `from t_self as t_self` with a non-exposing shadowing CTE: the alias
-- text matches the renamed table name. The qualifier resolves to the
-- CTE row source via the alias, so `t_self.k` must NOT be rewritten.

create table t_self (id integer primary key, k integer not null);
insert into t_self values (1, 100);

create view v_self as
  with t_self as (select 0 as k) select t_self.k from t_self as t_self;

alter table t_self rename column k to kk;

select * from v_self;
→ [{"k":0}]

drop view v_self;
drop table t_self;

-- ===================================
-- 7. RENAME COLUMN referenced inside an index expression
-- ===================================

-- Quereus doesn't support indices on expressions yet; rename propagation tested elsewhere
create table t_idxc (id integer primary key, v integer not null);
create index ix_idxc on t_idxc(v + 1);
-- error: not supported

drop table if exists t_idxc;

-- ===================================
-- 8. Aliased renamed table inside a view body
-- ===================================

create table tv_src3 (id integer primary key, name text);
insert into tv_src3 values (1, 'a'), (2, 'b');

create view va as select x.id, x.name from tv_src3 as x;

alter table tv_src3 rename to tv_src3_renamed;

select * from va order by id;
→ [{"id":1,"name":"a"},{"id":2,"name":"b"}]

drop view va;
drop table tv_src3_renamed;

-- ===================================
-- 9. Renaming a table referenced by a CHECK on a different table
-- ===================================

create table a_smoke (id integer primary key);
create table b_smoke (id integer primary key, check ((select count(*) from a_smoke) >= 0));

alter table a_smoke rename to a_smoke2;

insert into b_smoke values (1);

select count(*) as cnt from b_smoke;
→ [{"cnt":1}]

drop table b_smoke;
drop table a_smoke2;

-- ===================================
-- 10. Renaming a column referenced by another table's CHECK
-- ===================================

create table p_col (id integer primary key, k integer not null);
insert into p_col values (1, 1);

create table c_col (
  id integer primary key,
  check ((select count(*) from p_col where p_col.k > 0) >= 0)
);

alter table p_col rename column k to kk;

insert into c_col values (1);

select count(*) as cnt from c_col;
→ [{"cnt":1}]

drop table c_col;
drop table p_col;

-- ===================================
-- 10b. Renaming a column referenced by the same table's column-level CHECK
-- ===================================

create table t_cchk (id integer primary key, v integer check (v > 0));

alter table t_cchk rename column v to vv;

-- The CHECK must still enforce after the rename. Pre-fix this trips
-- "Column not found: v" at plan time; post-fix the CHECK rewrites to
-- (vv > 0) and the negative insert is rejected as a CHECK violation.
insert into t_cchk values (1, -5);
-- error: CHECK constraint failed

-- Valid insert succeeds against the renamed column.
insert into t_cchk values (2, 7);

select count(*) as cnt from t_cchk;
→ [{"cnt":1}]

drop table t_cchk;

-- Same shape, but the CHECK is table-level *and unqualified*:
-- the AST is still produced with col.table === undefined.
create table t_tchk (id integer primary key, v integer, check (v > 0));

alter table t_tchk rename column v to vv;

insert into t_tchk values (1, -5);
-- error: CHECK constraint failed

insert into t_tchk values (2, 7);

select count(*) as cnt from t_tchk;
→ [{"cnt":1}]

drop table t_tchk;

-- ===================================
-- 11. Renaming a column propagates into another table's FK referencedColumnNames
-- ===================================

pragma foreign_keys = true;

create table p_fk (k integer primary key, v text);
create table c_fk (id integer primary key, pk integer not null references p_fk(k) on delete restrict on update restrict);

insert into p_fk values (1, 'a');
insert into c_fk values (10, 1);

-- Force a checkpoint so the existing deferred FK check resolves against the
-- still-current parent column name before we rename it.
select count(*) as cnt from c_fk;
→ [{"cnt":1}]

alter table p_fk rename column k to kk;

-- FK still enforced under new parent column name
insert into c_fk values (11, 99);
-- error: CHECK constraint failed: _fk_c_fk

-- Valid child reference still works
insert into c_fk values (12, 1);

select count(*) as cnt from c_fk;
→ [{"cnt":2}]

drop table c_fk;
drop table p_fk;

-- ===================================
-- 12. Inner non-exposing CTE shadows an outer exposing CTE (precedence)
-- ===================================
-- The outer WITH declares an exposing same-name CTE (its body projects
-- the renamed column). A nested subquery has its own WITH that declares
-- a non-exposing same-name CTE. The subquery's `from t_nest` must bind
-- to the inner non-exposing CTE (innermost wins), and its `t_nest.k`
-- must NOT rewrite to `t_nest.kk`.

create table t_nest (id integer primary key, k integer not null);
insert into t_nest values (1, 100);

create view v_nest as
  with t_nest as (select t_nest.k from t_nest)
  select x from (
    with t_nest as (select 0 as k)
    select t_nest.k as x from t_nest
  ) s;

alter table t_nest rename column k to kk;

select * from v_nest;
→ [{"x":0}]

drop view v_nest;
drop table t_nest;

-- ===================================
-- 13. Shadowing CTE inside a derived-table subquery — unqualified ref
-- ===================================
-- Outer FROM has the renamed real table (so the outer frame's `unaliased`
-- has it). A nested derived-table subquery introduces a same-name
-- non-exposing CTE; the inner unqualified `k` must resolve to the inner
-- CTE row source, not to the outer real-table binding, and therefore
-- must NOT rewrite.

create table t_exb (id integer primary key, k integer not null);
insert into t_exb values (1, 50);

create view v_exb as
  select t_exb.k as outer_k, s.inner_k
  from t_exb
  cross join (with t_exb as (select 0 as k) select k as inner_k from t_exb) s;

alter table t_exb rename column k to kk;

select * from v_exb;
→ [{"outer_k":50,"inner_k":0}]

drop view v_exb;
drop table t_exb;

-- ===================================
-- 14. Nested alias rebinding — inner alias shadows outer same-letter alias
-- ===================================
-- Outer `from t_alia as a` binds `a` to the renamed table. A subquery
-- has `from t_alia_other as a` — its inner `a` rebinds to a different
-- table. The qualified `a.k` inside the subquery refers to t_alia_other,
-- so it must NOT rewrite to `a.kk`.

create table t_alia (id integer primary key, k integer not null);
create table t_alia_other (id integer primary key, k integer not null);
insert into t_alia values (1, 10);
insert into t_alia_other values (2, 20);

create view v_alia as
  select (select a.k from t_alia_other as a where a.id = 2) as inner_k
  from t_alia as a;

alter table t_alia rename column k to kk;

select * from v_alia;
→ [{"inner_k":20}]

drop view v_alia;
drop table t_alia;
drop table t_alia_other;

-- ===================================
-- 15. CHECK subquery with like-named column on another table — unqualified
-- ===================================
-- The CHECK body has `(select min(v) from t_chksub_u) > 0`. The inner `v`
-- legitimately binds to `t_chksub_u.v` — the inner FROM exposes a
-- like-named column. Without the schema-aware shadowing check the
-- CHECK-seed binding to `t_chksub.v` would capture the unqualified ref
-- and rewrite it to `vv`, leaving the CHECK referencing a non-existent
-- column on `t_chksub_u`.

create table t_chksub_u (id integer primary key, v integer);
insert into t_chksub_u values (1, 5);

create table t_chksub (id integer primary key, v integer,
                       check ((select min(v) from t_chksub_u) > 0));

alter table t_chksub rename column v to vv;

insert into t_chksub values (1, 10);

select count(*) as cnt from t_chksub;
→ [{"cnt":1}]

drop table t_chksub;
drop table t_chksub_u;

-- ===================================
-- 16. CHECK subquery with correlated outer ref — owner column legitimately captured
-- ===================================
-- The other table doesn't expose `v`, so the unqualified `v` inside the
-- subquery is a correlated outer ref to `t_corr.v`. The walk falls past
-- the inner frame (callback returns false for `t_corr_u`) and the seed
-- captures the ref — so the rewrite to `vv` must happen.

create table t_corr_u (id integer primary key);
create table t_corr (id integer primary key, v integer,
                     check ((select count(*) from t_corr_u where t_corr_u.id < v) >= 0));

alter table t_corr rename column v to vv;

insert into t_corr values (1, 10);

select count(*) as cnt from t_corr;
→ [{"cnt":1}]

drop table t_corr;
drop table t_corr_u;

-- (Case 17 from the ticket — CTE-shadow inside a CHECK subquery — is
-- impossible to construct: Quereus's parser only accepts `(SELECT ...)`
-- as a scalar subquery, not `(WITH … SELECT …)`. The CTE-shadow path is
-- already covered by cases 6f, 6g, 6m, 6n, 12, and 13 in the non-CHECK
-- propagation path.)

-- ===================================
-- 18. RENAME COLUMN rewrites a view's `insert defaults` target
-- ===================================
-- The dominant clause use case: the defaulted NOT NULL column is projected
-- away, so the body rewrite alone never touches the view — the clause rewrite
-- must both fire (clause-only change still propagates) and rewrite
-- `created` → `created_at`, or the write-through errors with
-- "'insert defaults (created = …)' names column 'created'".

create table t_vd (id integer primary key, name text, created integer not null);
create view v_vd as select id, name from t_vd insert defaults (created = 99);

alter table t_vd rename column created to created_at;

insert into v_vd values (1, 'x');

select id, name, created_at from t_vd;
→ [{"id":1,"name":"x","created_at":99}]

-- insertability derivation reads the rewritten clause from the catalog
select is_insertable_into from view_info('v_vd');
→ [{"is_insertable_into":"YES"}]

drop view v_vd;
drop table t_vd;

-- ===================================
-- 19. RENAME TO of a table referenced inside an `insert defaults` expr subquery
-- ===================================
-- The clause expr is appended to VALUES rows, so it cannot reference base
-- columns at top level — but a subquery inside it can reference any table.
-- Pre-fix the stale reference errored "Table 'aud_t' not found".

create table aud_t (c integer primary key);
insert into aud_t values (5);

create table t_vd2 (id integer primary key, ts integer not null);
create view v_vd2 as select id from t_vd2 insert defaults (ts = (select max(c) from aud_t));

alter table aud_t rename to aud_t2;

insert into v_vd2 values (10);

select id, ts from t_vd2;
→ [{"id":10,"ts":5}]

drop view v_vd2;
drop table t_vd2;
drop table aud_t2;

-- ===================================
-- 20. RENAME COLUMN inside an `insert defaults` expr subquery
-- ===================================
-- The renamed table is NOT a FROM table of the view, so the clause's expr gets
-- the plain scope-aware walk — the subquery's `c` must still rewrite to `c2`.

create table aud_c (c integer primary key);
insert into aud_c values (7);

create table t_vd3 (id integer primary key, ts integer not null);
create view v_vd3 as select id from t_vd3 insert defaults (ts = (select max(c) from aud_c));

alter table aud_c rename column c to c2;

insert into v_vd3 values (11);

select id, ts from t_vd3;
→ [{"id":11,"ts":7}]

drop view v_vd3;
drop table t_vd3;
drop table aud_c;

-- ===================================
-- 21. RENAME COLUMN hitting both a view's body and its `insert defaults` target
-- ===================================
-- The defaulted column is also projected, so one rename rewrites the body
-- projection AND the clause target; inserting with a column list omits it and
-- the default lands under the new name.

create table t_vd4 (id integer primary key, v integer not null);
create view v_vd4 as select id, v from t_vd4 insert defaults (v = 42);

alter table t_vd4 rename column v to w;

insert into v_vd4 (id) values (1);

select id, w from t_vd4;
→ [{"id":1,"w":42}]

select id, w from v_vd4;
→ [{"id":1,"w":42}]

drop view v_vd4;
drop table t_vd4;
