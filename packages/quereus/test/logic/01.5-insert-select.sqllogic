-- adapted from SQLite test/insert2.test, test/insert4.test, test/insert5.test
-- INSERT ... SELECT variants beyond the simple form covered in 01-basic and 13-cte.
-- Quereus has no rowids and NOT NULL by default; subagent reports flagged
-- column-reordering, compound select, JOIN, GROUP BY, DISTINCT, LIMIT,
-- self-reference and view-mediated INSERT...SELECT as uncovered scenarios.

-- ===================================
-- 1. INSERT ... SELECT with column reordering / partial mapping
-- ===================================

create table src_basic (a integer primary key, b text null, c integer null);
create table dst_basic (a integer primary key, b text null, c integer null);

insert into src_basic values (1, 'x', 10), (2, 'y', 20);

-- target column list reorders columns relative to SELECT projection
insert into dst_basic (c, a) select c, a from src_basic;

select a, b, c from dst_basic order by a;
→ [{"a":1,"b":null,"c":10},{"a":2,"b":null,"c":20}]

drop table dst_basic;
drop table src_basic;

-- ===================================
-- 2. INSERT ... SELECT with GROUP BY aggregation
-- ===================================

create table events (id integer primary key, grp text, n integer);
insert into events values (1, 'A', 10), (2, 'A', 5), (3, 'B', 20);

create table summary (grp text primary key, total integer);
insert into summary (grp, total) select grp, sum(n) from events group by grp;

select grp, total from summary order by grp;
→ [{"grp":"A","total":15},{"grp":"B","total":20}]

drop table summary;
drop table events;

-- ===================================
-- 3. INSERT ... SELECT with compound (UNION ALL, EXCEPT)
-- ===================================

create table s1 (id integer primary key, val text);
create table s2 (id integer primary key, val text);
insert into s1 values (1, 'apple'), (2, 'banana');
insert into s2 values (2, 'banana'), (3, 'cherry');

create table u_dst (id integer primary key, val text);

insert into u_dst (id, val) select id, val from s1 union all select id + 100, val from s2;
select id, val from u_dst order by id;
→ [{"id":1,"val":"apple"},{"id":2,"val":"banana"},{"id":102,"val":"banana"},{"id":103,"val":"cherry"}]

drop table u_dst;

create table e_dst (id integer primary key, val text);
insert into e_dst (id, val) select id, val from s1 except select id, val from s2;
select id, val from e_dst order by id;
→ [{"id":1,"val":"apple"}]

drop table e_dst;
drop table s2;
drop table s1;

-- ===================================
-- 4. INSERT ... SELECT from JOIN (LEFT JOIN with NULL padding)
-- ===================================

create table l (id integer primary key, val text);
create table r (id integer primary key, left_id integer, info text);
insert into l values (1, 'a'), (2, 'b');
insert into r values (10, 1, 'x');

create table joined (id integer primary key, val text, info text null);

insert into joined (id, val, info)
   select l.id, l.val, r.info from l left join r on l.id = r.left_id;

select id, val, info from joined order by id;
→ [{"id":1,"val":"a","info":"x"},{"id":2,"val":"b","info":null}]

drop table joined;
drop table r;
drop table l;

-- ===================================
-- 5. INSERT ... SELECT with DISTINCT (suppress duplicates)
-- ===================================

create table dup_src (id integer primary key, x integer, y integer);
insert into dup_src values (1, 1, 10), (2, 1, 10), (3, 2, 20);

create table dup_dst (x integer, y integer, primary key (x, y));
insert into dup_dst select distinct x, y from dup_src;

select x, y from dup_dst order by x, y;
→ [{"x":1,"y":10},{"x":2,"y":20}]

drop table dup_dst;
drop table dup_src;

-- ===================================
-- 6. INSERT ... SELECT with LIMIT
-- ===================================

create table lim_src (id integer primary key, val integer);
create table lim_dst (id integer primary key, val integer);

insert into lim_src values (1, 100), (2, 200), (3, 300);
insert into lim_dst select id, val from lim_src order by id limit 2;

select id, val from lim_dst order by id;
→ [{"id":1,"val":100},{"id":2,"val":200}]

drop table lim_dst;
drop table lim_src;

-- ===================================
-- 7. INSERT ... SELECT self-referential (insert from same table)
-- ===================================

create table doubler (id integer primary key, val integer);
insert into doubler values (1, 10), (2, 20);

insert into doubler (id, val) select id + 100, val * 2 from doubler;

select id, val from doubler order by id;
→ [{"id":1,"val":10},{"id":2,"val":20},{"id":101,"val":20},{"id":102,"val":40}]

drop table doubler;

-- ===================================
-- 7b. INSERT ... SELECT self-referential, mid-transaction (after prior writes)
-- ===================================
-- Same shape as section 7, but wrapped in BEGIN ... COMMIT with a seeding
-- INSERT VALUES so the connection's pendingTransactionLayer is non-null when
-- the self-ref INSERT runs. This exercises the eager savepoint-snapshot
-- branch in MemoryTableConnection.createSavepoint: without the readLayer
-- swap, the SELECT iterator and the INSERT mutate the same BTree and the
-- new rows feed back into the SELECT (halloween), causing val*2 to keep
-- doubling row by row until Number.isSafeInteger rejects it.

create table doubler_tx (id integer primary key, val integer);

begin;
insert into doubler_tx values (1, 10), (2, 20);
insert into doubler_tx (id, val) select id + 100, val * 2 from doubler_tx;
commit;

select id, val from doubler_tx order by id;
→ [{"id":1,"val":10},{"id":2,"val":20},{"id":101,"val":20},{"id":102,"val":40}]

drop table doubler_tx;

-- ===================================
-- 8. INSERT ... SELECT through a view of the target table
-- ===================================

create table v_target (id integer primary key, name text);
insert into v_target values (1, 'Alice'), (2, 'Bob');

create view v_target_v as select id, name from v_target where id > 0;

insert into v_target (id, name) select id + 10, name || '_v' from v_target_v;

select id, name from v_target order by id;
→ [{"id":1,"name":"Alice"},{"id":2,"name":"Bob"},{"id":11,"name":"Alice_v"},{"id":12,"name":"Bob_v"}]

drop view v_target_v;
drop table v_target;

-- ===================================
-- 9. INSERT ... SELECT with CHECK constraint enforcement on target
-- ===================================

create table chk_src (a integer, b integer);
create table chk_dst (a integer, b integer check (b > a));
insert into chk_src values (10, 20), (30, 25);

-- only the row that satisfies CHECK should be admitted; the other should error
insert into chk_dst select a, b from chk_src where b > a;
select a, b from chk_dst order by a;
→ [{"a":10,"b":20}]

-- attempting to insert the violating row directly errors
insert into chk_dst select a, b from chk_src where a = 30;
-- error: CHECK constraint failed

drop table chk_dst;
drop table chk_src;

-- ===================================
-- 10. INSERT ... SELECT with correlated subquery in WHERE referencing target
-- ===================================

create table self_ref (id integer primary key, val integer);
insert into self_ref values (1, 10), (2, 20), (3, 30);

insert into self_ref (id, val)
   select id + 100, 99 from self_ref where id in (select id from self_ref where val > 15);

select id, val from self_ref order by id;
→ [{"id":1,"val":10},{"id":2,"val":20},{"id":3,"val":30},{"id":102,"val":99},{"id":103,"val":99}]

drop table self_ref;

-- ===================================
-- 11. Duplicate column in the INSERT column list is rejected (no silent
--     last-wins / confusing shape). PostgreSQL rejects this as
--     "column \"a\" specified more than once". See ticket
--     insert-family-duplicate-column-targets-silent-last-wins.
-- ===================================

create table dup_cols (a integer primary key, b integer null);

insert into dup_cols (a, a) values (1, 2);
-- error: specified more than once

-- case-insensitive duplicate is also rejected.
insert into dup_cols (a, b, A) values (1, 2, 3);
-- error: specified more than once

-- the rejected inserts made no change.
select a, b from dup_cols order by a;
→ []

-- false-positive guard: the check keys on exact-name collision, so a legitimate
-- distinct-column list still works — including columns that merely share a prefix.
create table prefix_cols (ab integer primary key, abc integer null);
insert into prefix_cols (ab, abc) values (1, 2);
select ab, abc from prefix_cols order by ab;
→ [{"ab":1,"abc":2}]
drop table prefix_cols;

drop table dup_cols;
