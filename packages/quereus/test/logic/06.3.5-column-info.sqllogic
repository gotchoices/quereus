-- 06.3.5-column-info.sqllogic — column_info(name) per-column updateability surface.
-- The column-granular companion to view_info(): docs/view-updateability.md
-- § Information Schema Surface (information_schema.columns.is_updatable).
-- Columns: schema, name, cid, column_name, is_updatable ('YES'/'NO'),
-- base_table, base_column (both null for a read-only column). Resolves either a
-- base table or a plain view; throws not-found when neither matches.

-- ===================================================================
-- Base table, all columns updatable: every non-generated base column is a
-- trivially-updatable base write target tracing to itself.
-- ===================================================================

create table t (id integer primary key, name text);

select cid, column_name, is_updatable, base_table, base_column from column_info('t');
→ [{"cid":0,"column_name":"id","is_updatable":"YES","base_table":"t","base_column":"id"},{"cid":1,"column_name":"name","is_updatable":"YES","base_table":"t","base_column":"name"}]

select schema, name from column_info('t');
→ [{"schema":"main","name":"t"},{"schema":"main","name":"t"}]

-- Cardinality: one row per column.
select count(*) as c from column_info('t');
→ [{"c":2}]

-- ===================================================================
-- Base table with a generated column: the generated column is read-only
-- (computed lineage) with null base trace; the rest are updatable.
-- ===================================================================

create table g (id integer primary key, a integer, b integer generated always as (a + 1));
select cid, column_name, is_updatable, base_table, base_column from column_info('g');
→ [{"cid":0,"column_name":"id","is_updatable":"YES","base_table":"g","base_column":"id"},{"cid":1,"column_name":"a","is_updatable":"YES","base_table":"g","base_column":"a"},{"cid":2,"column_name":"b","is_updatable":"NO","base_table":null,"base_column":null}]

-- ===================================================================
-- Identity view: both columns updatable, tracing to the base table.
-- ===================================================================

create view v_identity as select id, name from t;
select cid, column_name, is_updatable, base_table, base_column from column_info('v_identity');
→ [{"cid":0,"column_name":"id","is_updatable":"YES","base_table":"t","base_column":"id"},{"cid":1,"column_name":"name","is_updatable":"YES","base_table":"t","base_column":"name"}]

select schema, name from column_info('v_identity');
→ [{"schema":"main","name":"v_identity"},{"schema":"main","name":"v_identity"}]

-- ===================================================================
-- Rename view: the alias renames the OUTPUT column (column_name), the trace
-- keeps the underlying base column (base_column).
-- ===================================================================

create view v_rename as select id as user_id, name as full_name from t;
select cid, column_name, is_updatable, base_table, base_column from column_info('v_rename');
→ [{"cid":0,"column_name":"user_id","is_updatable":"YES","base_table":"t","base_column":"id"},{"cid":1,"column_name":"full_name","is_updatable":"YES","base_table":"t","base_column":"name"}]

-- ===================================================================
-- Computed column among passthroughs: the passthrough column is updatable, the
-- computed expression column is read-only with null trace.
-- ===================================================================

create view cv as select name, name || '!' as banner from t;
select cid, column_name, is_updatable, base_table, base_column from column_info('cv');
→ [{"cid":0,"column_name":"name","is_updatable":"YES","base_table":"t","base_column":"name"},{"cid":1,"column_name":"banner","is_updatable":"NO","base_table":null,"base_column":null}]

-- ===================================================================
-- Multi-source inner join: each output column traces to its own source base
-- table; all updatable. (cid/note from ms_child, label from ms_parent.)
-- ===================================================================

create table ms_parent (pid integer primary key, label text);
create table ms_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ms_parent(pid));
create view ms_jv as
    select c.cid as cid, c.note as note, p.label as label
    from ms_child c join ms_parent p on p.pid = c.pref;
select cid, column_name, is_updatable, base_table, base_column from column_info('ms_jv');
→ [{"cid":0,"column_name":"cid","is_updatable":"YES","base_table":"ms_child","base_column":"cid"},{"cid":1,"column_name":"note","is_updatable":"YES","base_table":"ms_child","base_column":"note"},{"cid":2,"column_name":"label","is_updatable":"YES","base_table":"ms_parent","base_column":"label"}]

-- ===================================================================
-- Wholly read-only bodies: every output column is_updatable='NO' with null
-- trace. Unlike view_info's single conservative row, column_info still emits
-- one row per output column.
-- ===================================================================

create view values_v as values (1, 2), (3, 4);
select cid, is_updatable, base_table, base_column from column_info('values_v');
→ [{"cid":0,"is_updatable":"NO","base_table":null,"base_column":null},{"cid":1,"is_updatable":"NO","base_table":null,"base_column":null}]

create view agg_v as select count(*) as n from t;
select cid, column_name, is_updatable, base_table, base_column from column_info('agg_v');
→ [{"cid":0,"column_name":"n","is_updatable":"NO","base_table":null,"base_column":null}]

-- ===================================================================
-- Outer-join body: every column reports is_updatable='NO' with null trace,
-- mirroring view_info's Divergence 2 gate. An outer join wraps the non-preserved
-- side `null-extended`; collectInnerJoinSources rejects the WHOLE join (both
-- sides), so propagate() accepts no write through the view. column_info must NOT
-- unwrap `null-extended` and over-report a preserved-side column as 'YES' — it
-- short-circuits the same body deriveViewInfo does. Both the preserved-side
-- columns (aid, av) and the null-extended column (bv) read 'NO'.
-- ===================================================================

create table oj_a (aid integer primary key, av text);
create table oj_b (bid integer primary key, bv text);
create view oj_left as
    select a.aid as aid, a.av as av, b.bv as bv
    from oj_a a left join oj_b b on b.bid = a.aid;
select cid, column_name, is_updatable, base_table, base_column from column_info('oj_left');
→ [{"cid":0,"column_name":"aid","is_updatable":"NO","base_table":null,"base_column":null},{"cid":1,"column_name":"av","is_updatable":"NO","base_table":null,"base_column":null},{"cid":2,"column_name":"bv","is_updatable":"NO","base_table":null,"base_column":null}]

-- Surface agrees with propagate(): a mutation through the outer-join view is rejected.
update oj_left set av = 'z' where aid = 1;
-- error: cannot write through view

-- ===================================================================
-- Unknown name throws (mirrors table_info's required-target posture).
-- ===================================================================

select * from column_info('nope');
-- error: not found
