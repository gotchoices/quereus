-- adapted from SQLite test/createtab.test
-- CREATE TABLE syntax edge cases not covered by 10.1-ddl-lifecycle / 10.2-column-features.

-- ===================================
-- 1. Untyped columns: SQLite-specific dynamic typing.
-- Deleted: Quereus has strict typed columns; untyped declarations don't apply.
-- ===================================

-- ===================================
-- 2. CREATE TABLE while iterating an existing table
-- ===================================
-- Cursor-stability across DDL: a new table must be createable while a cursor
-- on a different table is open / a prior CTE-like read pipeline is in flight.

create table cs1 (id integer primary key, v text);
insert into cs1 values (1, 'aaa'), (2, 'bbb'), (3, 'ccc'), (4, 'ddd');

-- Iterate via CTE, then create another table; both should work
with iter as (select id from cs1)
select count(*) as cnt from iter;
→ [{"cnt":4}]

create table cs2 (id integer primary key, v text);
insert into cs2 values (1, 'one'), (2, 'two');

select count(*) as cnt from cs1;
→ [{"cnt":4}]

select count(*) as cnt from cs2;
→ [{"cnt":2}]

-- Several CREATE TABLE in sequence
create table cs3 (id integer primary key);
create table cs4 (id integer primary key);

select name from schema() where type = 'table' and name like 'cs_' order by name;
→ [{"name":"cs1"},{"name":"cs2"},{"name":"cs3"},{"name":"cs4"}]

drop table cs1;
drop table cs2;
drop table cs3;
drop table cs4;

-- ===================================
-- 3. Duplicate column in UNIQUE: SQLite-specific rejection.
-- Deleted: Quereus does not specifically reject duplicate columns in UNIQUE.
-- ===================================
