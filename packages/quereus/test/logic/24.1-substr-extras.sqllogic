-- substr-extras.sqllogic - substr / substring scenarios beyond 24-builtin-branches:
-- NULL propagation, substring() alias, Y past end, 2-arg negative-Y forms,
-- Z-negative semantics (chars preceding Y, per SQLite docs).
-- adapted from SQLite test/substr.test and test/func2.test

-- NULL in the string or start argument propagates to NULL
select substr(null, 1, 1) as result;
→ [{"result":null}]

-- Quereus deviation: NULL Y propagates to NULL, but NULL Z is treated as 0 (empty string),
-- not NULL. SQLite propagates NULL for any NULL argument.
create table substr_nulls (id integer primary key, s text null, y integer null, z integer null);
insert into substr_nulls values (1, 'hello', null, 1), (2, 'hello', 1, null);
select substr(s, y, z) from substr_nulls order by id;
→ [{"substr(s, y, z)":null},{"substr(s, y, z)":""}]
drop table substr_nulls;

-- substring() is an alias of substr()
select substring('hello', 2, 3) = substr('hello', 2, 3) as result;
→ [{"result":true}]

select substring('hello', 2) = substr('hello', 2) as result;
→ [{"result":true}]

-- Y > strlen returns empty string (3-arg)
select substr('hello', 100, 5) as result;
→ [{"result":""}]

-- Y > strlen returns empty string (2-arg)
select substr('hi', 5) as result;
→ [{"result":""}]

-- 2-arg form with negative Y counts from end
select substr('abcdef', -3) as result;
→ [{"result":"def"}]

-- Y past beginning with abs(Y) > strlen clamps to start
select substr('abc', -10) as result;
→ [{"result":"abc"}]

-- Y + Z extending past end: returns the available tail, no padding
select substr('hello', 3, 100) as result;
→ [{"result":"llo"}]

-- 3-arg with Y=0 and length=1: SQLite treats Y=0 as Y=1 in this form
select substr('abcdef', 0, 1) as result;
→ [{"result":"a"}]

-- 3-arg with Y=0 and length=2
select substr('abcdef', 0, 2) as result;
→ [{"result":"ab"}]

-- Y=0 with length 0: empty
select substr('abc', 0, 0) as result;
→ [{"result":""}]

-- Negative Z: Quereus returns empty string. (SQLite returns abs(Z) chars preceding Y;
-- Quereus deviates and clamps to empty per the existing 24-builtin-branches assertion.)
select substr('abcdef', 4, -1) as result;
→ [{"result":""}]

select substr('abcdef', 4, -3) as result;
→ [{"result":""}]

-- Negative Y with negative Z (Quereus: empty)
select substr('abcdef', -2, -2) as result;
→ [{"result":""}]

-- substr indexes by Unicode code point. Non-BMP `😀` is one code point (was two UTF-16 code units).
select substr('a😀b', 2, 1) as result;
→ [{"result":"😀"}]

-- BMP multi-byte character ('é' is one UTF-16 code unit) works correctly.
select substr('café', 1, 4) as result;
→ [{"result":"café"}]
