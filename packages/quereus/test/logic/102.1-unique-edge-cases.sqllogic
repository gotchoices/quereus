-- adapted from SQLite test/unique.test, test/unique2.test
-- UNIQUE constraint scenarios beyond 102-unique-constraints.sqllogic.

-- ===================================
-- 1. COLLATE with the LOWERCASE spelling `nocase` is rejected at DDL.
--    This is NOT "UNIQUE doesn't support collation" — it is a collation-name
--    case-sensitivity quirk: `validateColumnSchema` checks the requested name
--    against `TEXT_TYPE.supportedCollations = ['BINARY','NOCASE','RTRIM']` with a
--    case-sensitive `includes`, so lowercase `nocase` fails to match and is
--    rejected with a message that happens to contain "not supported". The
--    canonical UPPERCASE `NOCASE` is accepted, and UNIQUE over a `collate NOCASE`
--    column now enforces case-insensitively (auto-index + every conflict
--    validator honor the column collation — see
--    unique-constraint-honors-column-collation, regression-tested in
--    102.2-unique-collation.sqllogic). Normalizing the lowercase spelling is a
--    separate, still-open concern, so these blocks keep asserting the current
--    rejection of the lowercase form.
-- ===================================

create table t_uci (id integer primary key, email text collate nocase unique);
-- error: not supported

drop table if exists t_uci;

-- composite UNIQUE with the lowercase `nocase` spelling on a TEXT member is
-- rejected the same way (same collation-name case-sensitivity quirk)
create table t_uci2 (
	id integer primary key,
	a text collate nocase,
	b text,
	unique (a, b)
);
-- error: not supported

drop table if exists t_uci2;

-- ===================================
-- 2. UNIQUE constraint error message identifies the violated column
-- ===================================

create table t_ue (id integer primary key, email text unique, code text unique);
insert into t_ue values (1, 'a@x', 'AAA');

-- conflict on email reports email
insert into t_ue values (2, 'a@x', 'BBB');
-- error: t_ue (email)

-- conflict on code reports code
insert into t_ue values (3, 'b@x', 'AAA');
-- error: t_ue (code)

drop table t_ue;

-- composite UNIQUE error names the offending column(s)
create table t_uec (id integer primary key, a text, b text, unique (a, b));
insert into t_uec values (1, 'x', 'y');

insert into t_uec values (2, 'x', 'y');
-- error: t_uec

drop table t_uec;

-- ===================================
-- 3. CREATE UNIQUE INDEX rejected when data already has duplicates
-- ===================================

create table u2_a (k text primary key, x text not null);
insert into u2_a values ('r1', 'dup'), ('r2', 'dup');

create unique index u2_a_x on u2_a(x);
-- error: UNIQUE

-- after dedup, the index creates fine and rejects new duplicates
delete from u2_a where k = 'r2';

create unique index u2_a_x on u2_a(x);

insert into u2_a values ('r3', 'dup');
-- error: UNIQUE

drop table u2_a;

-- post-hoc CREATE UNIQUE INDEX on already-unique data subsequently rejects
-- inserts that would violate the new unique constraint. Use `-- run` markers
-- to run each step as its own implicit transaction; otherwise the CREATE
-- UNIQUE INDEX would land in the same implicit transaction as the prior
-- INSERTs, whose rows live in an uncommitted layer that the index's seed
-- scan does not see (a known schema-change-mid-transaction limitation).
create table u2_b (k integer primary key, x text not null);
-- run
insert into u2_b values (1, 'a'), (2, 'b');
-- run
create unique index u2_b_x on u2_b(x);
-- run

insert into u2_b values (3, 'a');
-- error: UNIQUE

drop table u2_b;

-- nullable indexed columns: multiple NULL allowed
create table u2_c (k integer primary key, y text null, z text null);
insert into u2_c values (1, null, null), (2, null, null);

create unique index u2_c_yz on u2_c(y, z);

select count(*) as cnt from u2_c;
→ [{"cnt":2}]

drop table u2_c;

-- ===================================
-- 4. PRIMARY KEY / UNIQUE referencing non-existent column rejected at DDL
-- ===================================

create table u2_bad1 (a integer not null, b integer not null, primary key (nope));
-- error:

drop table if exists u2_bad1;

create table u2_bad2 (id integer primary key, a integer not null, unique (missing));
-- error:

drop table if exists u2_bad2;

create table u2_bad3 (id integer primary key, b integer not null);
create unique index u2_bad3_idx on u2_bad3(no_such_col);
-- error: not found

drop table u2_bad3;
