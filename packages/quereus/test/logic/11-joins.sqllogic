-- joins.sqllogic - Testing JOIN clauses

-- Setup tables
CREATE TABLE t_left (id INTEGER PRIMARY KEY, val_l TEXT);
CREATE TABLE t_right (id INTEGER PRIMARY KEY, val_r TEXT, left_id INTEGER);

INSERT INTO t_left VALUES (1, 'L1'), (2, 'L2'), (3, 'L3');
INSERT INTO t_right VALUES (10, 'R1', 1), (20, 'R2', 2), (40, 'R4', 4);

-- INNER JOIN
SELECT l.id, l.val_l, r.id, r.val_r FROM t_left l JOIN t_right r ON l.id = r.left_id ORDER BY l.id;
→ [{"id":1,"val_l":"L1","id:1":10,"val_r":"R1"},{"id":2,"val_l":"L2","id:1":20,"val_r":"R2"}]

-- INNER JOIN with aliases
SELECT l.id as left_id, r.id as right_id FROM t_left l JOIN t_right r ON l.id = r.left_id ORDER BY left_id;
→ [{"left_id":1,"right_id":10},{"left_id":2,"right_id":20}]

-- LEFT JOIN
SELECT l.id, l.val_l, r.id, r.val_r FROM t_left l LEFT JOIN t_right r ON l.id = r.left_id ORDER BY l.id;
→ [{"id":1,"val_l":"L1","id:1":10,"val_r":"R1"},{"id":2,"val_l":"L2","id:1":20,"val_r":"R2"},{"id":3,"val_l":"L3","id:1":null,"val_r":null}]

-- CROSS JOIN
SELECT count(*) FROM t_left CROSS JOIN t_right;
→ [{"count(*)":9}]
SELECT l.id, r.id FROM t_left l CROSS JOIN t_right r ORDER BY l.id, r.id LIMIT 2;
→ [{"id":1,"id:1":10},{"id":1,"id:1":20}]

-- JOIN with WHERE clause
SELECT l.id, r.val_r FROM t_left l JOIN t_right r ON l.id = r.left_id WHERE r.id = 10;
→ [{"id":1,"val_r":"R1"}]

-- Multiple JOINs (requires a third table setup)
CREATE TABLE t_extra (id INTEGER PRIMARY KEY, right_id INTEGER, val_e TEXT);
INSERT INTO t_extra VALUES (100, 10, 'E1'), (200, 20, 'E2');
SELECT l.id, r.id, e.id FROM t_left l JOIN t_right r ON l.id = r.left_id JOIN t_extra e ON r.id = e.right_id ORDER BY l.id;
→ [{"id":1,"id:1":10,"id:2":100},{"id":2,"id:1":20,"id:2":200}]

DROP TABLE t_extra;
-- run

-- RIGHT JOIN: every right row appears; r.id=40 (left_id=4) has no left match → null-left.
SELECT l.id, r.id FROM t_left l RIGHT JOIN t_right r ON l.id = r.left_id ORDER BY r.id;
→ [{"id":1,"id:1":10},{"id":2,"id:1":20},{"id":null,"id:1":40}]

-- FULL JOIN: matched rows plus l.id=3 (no right) null-right and r.id=40 (no left) null-left.
SELECT l.id, r.id FROM t_left l FULL JOIN t_right r ON l.id = r.left_id ORDER BY coalesce(l.id, r.id);
→ [{"id":1,"id:1":10},{"id":2,"id:1":20},{"id":3,"id:1":null},{"id":null,"id:1":40}]

DROP TABLE t_left;
DROP TABLE t_right;

-- ===================================================================
-- Join elimination - FK→PK
-- Regression coverage for rule-join-elimination: rewritten plans must
-- produce the same rows as the un-rewritten queries.
-- ===================================================================

CREATE TABLE je_customers (id INTEGER PRIMARY KEY, name TEXT, region TEXT);
CREATE TABLE je_orders (
    order_id INTEGER PRIMARY KEY,
    customer_id INTEGER NOT NULL REFERENCES je_customers(id),
    total REAL
);

INSERT INTO je_customers VALUES (1, 'Acme', 'EU'), (2, 'Beta', 'US');
INSERT INTO je_orders VALUES (10, 1, 99.0), (11, 2, 49.5), (12, 1, 12.0);

-- LEFT JOIN eliminable: no right-side columns selected
SELECT order_id, total FROM je_orders LEFT JOIN je_customers ON je_orders.customer_id = je_customers.id ORDER BY order_id;
→ [{"order_id":10,"total":99.0},{"order_id":11,"total":49.5},{"order_id":12,"total":12.0}]

-- INNER JOIN eliminable: NOT NULL FK
SELECT order_id FROM je_orders JOIN je_customers ON je_orders.customer_id = je_customers.id ORDER BY order_id;
→ [{"order_id":10},{"order_id":11},{"order_id":12}]

-- Eliminable view: outer query selects only FK-side columns
CREATE VIEW je_order_view AS
  SELECT o.order_id, o.total, c.name AS cust_name
  FROM je_orders o LEFT JOIN je_customers c ON o.customer_id = c.id;

SELECT order_id, total FROM je_order_view ORDER BY order_id;
→ [{"order_id":10,"total":99.0},{"order_id":11,"total":49.5},{"order_id":12,"total":12.0}]

DROP VIEW je_order_view;
DROP TABLE je_orders;
DROP TABLE je_customers;
