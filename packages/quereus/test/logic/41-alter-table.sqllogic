-- ALTER TABLE operations: RENAME TABLE, RENAME COLUMN, ADD COLUMN, DROP COLUMN

-- ===================================
-- 1. ADD COLUMN (test first as simplest)
-- ===================================

create table t_addcol (id integer primary key, name text);
insert into t_addcol values (1, 'Alice'), (2, 'Bob');

-- Add column with NULL default (implicit)
alter table t_addcol add column age integer null;

-- Existing rows should get NULL for the new column
select * from t_addcol order by id;
→ [{"id": 1, "name": "Alice", "age": null}, {"id": 2, "name": "Bob", "age": null}]

-- Can insert with new column
insert into t_addcol values (3, 'Charlie', 30);

select * from t_addcol where id = 3;
→ [{"id": 3, "name": "Charlie", "age": 30}]

-- Add column with DEFAULT value
alter table t_addcol add column status text default 'active';

select status from t_addcol where id = 1;
→ [{"status": "active"}]

-- Cannot add duplicate column
alter table t_addcol add column name text;
-- error: already exists

-- Cannot add PRIMARY KEY column
alter table t_addcol add column pk integer primary key;
-- error: PRIMARY KEY

drop table t_addcol;

-- ===================================
-- 2. DROP COLUMN
-- ===================================

create table t_dropcol (id integer primary key, name text, extra text);
insert into t_dropcol values (1, 'Alice', 'x'), (2, 'Bob', 'y');

alter table t_dropcol drop column extra;

-- Remaining columns should work
select * from t_dropcol order by id;
→ [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}]

-- Cannot drop PK column
alter table t_dropcol drop column id;
-- error: PRIMARY KEY

-- Cannot drop non-existent column
alter table t_dropcol drop column nonexistent;
-- error: not found

drop table t_dropcol;

-- ===================================
-- 3. RENAME COLUMN
-- ===================================

create table t_colrename (id integer primary key, old_name text);
insert into t_colrename values (1, 'hello'), (2, 'world');

alter table t_colrename rename column old_name to new_name;

-- New column name should work
select new_name from t_colrename where id = 1;
→ [{"new_name": "hello"}]

-- Data preserved
select * from t_colrename order by id;
→ [{"id": 1, "new_name": "hello"}, {"id": 2, "new_name": "world"}]

-- Cannot rename to existing column name
alter table t_colrename rename column new_name to id;
-- error: already exists

-- Cannot rename non-existent column
alter table t_colrename rename column nonexistent to something;
-- error: not found

drop table t_colrename;

-- ===================================
-- 4. RENAME TABLE
-- ===================================

create table t_rename (id integer primary key, val text);
insert into t_rename values (1, 'a'), (2, 'b');
alter table t_rename rename to t_renamed;
-- run

-- Old name should no longer work
select * from t_rename;
-- error: not found

-- New name should work and data preserved
select * from t_renamed order by id;
→ [{"id": 1, "val": "a"}, {"id": 2, "val": "b"}]

-- Can insert into renamed table
insert into t_renamed values (3, 'c');

select count(*) as cnt from t_renamed;
→ [{"cnt": 3}]

-- Cannot rename to existing table
create table t_conflict (x integer);
-- run

alter table t_renamed rename to t_conflict;
-- error: already exists

drop table t_renamed;
drop table t_conflict;

-- ===================================
-- 5. ADD COLUMN with NOT NULL + DEFAULT
-- ===================================

create table t_notnull (id integer primary key);
insert into t_notnull values (1), (2);
-- run

-- NOT NULL without DEFAULT should fail (table has rows)
alter table t_notnull add column required text not null;
-- error: NOT NULL

-- Error message should name the column and qualified table
alter table t_notnull add column rank integer not null;
-- error: 'rank'

alter table t_notnull add column rank integer not null;
-- error: main.t_notnull

-- NOT NULL with DEFAULT should succeed
alter table t_notnull add column required text not null default 'default_val';

select required from t_notnull where id = 1;
→ [{"required": "default_val"}]

-- NULL (no DEFAULT) on non-empty table is allowed
alter table t_notnull add column nickname text null;
select nickname from t_notnull where id = 1;
→ [{"nickname": null}]

drop table t_notnull;

-- NOT NULL without DEFAULT is allowed on an empty table
create table t_notnull_empty (id integer primary key, name text);
alter table t_notnull_empty add column rank integer not null;
insert into t_notnull_empty values (1, 'Alice', 10);
select * from t_notnull_empty;
→ [{"id": 1, "name": "Alice", "rank": 10}]
drop table t_notnull_empty;

-- ===================================
-- 6. Combined operations
-- ===================================

create table t_combined (id integer primary key, a text, b text);
insert into t_combined values (1, 'x', 'y');

-- Add column, rename it, then use it
alter table t_combined add column c integer null;

alter table t_combined rename column c to score;

insert into t_combined values (2, 'p', 'q', 100);

select id, score from t_combined order by id;
→ [{"id": 1, "score": null}, {"id": 2, "score": 100}]

-- Drop original column
alter table t_combined drop column b;

select * from t_combined order by id;
→ [{"id": 1, "a": "x", "score": null}, {"id": 2, "a": "p", "score": 100}]

-- Rename table
alter table t_combined rename to t_final;

select * from t_final where id = 2;
→ [{"id": 2, "a": "p", "score": 100}]

drop table t_final;
