-- in-value-list.sqllogic - `WHERE col IN (<value-list>)` set-membership regression.
--
-- Regression for the memory-vtab IN multi-seek (plan=5): a duplicate literal
-- multiplied matching rows (bag, not set) and a NULL list element fell through
-- to a full-index walk (spurious non-matching rows). The fix lives in
-- scanLayer's multi-seek branch (src/vtab/memory/layer/scan-layer.ts): skip
-- NULL/NULL-containing seek keys and dedup yielded rows by primary key.
--
-- These assertions are pure set-membership (counts + exact rows), so they hold
-- on both the memory module (multi-seek path, indexed columns) and the store
-- module (residual scalar IN filter). Indexed columns below force the multi-seek
-- path under the default memory module; the non-indexed table exercises the
-- residual-filter path in the same run.

create table t (k integer primary key, v integer unique);
insert into t values (1, 5), (2, 7);

-- ===== Single-value baseline (correct before and after the fix) =====

select k, v from t where v in (5);
→ [{"k":1,"v":5}]

-- ===== Single-value NULL equality (plan=2 point-seek) returns zero rows =====
-- `col = null` is UNKNOWN ⇒ no rows. Regression for the point-seek branch of
-- scanLayer, where a NULL equality key fell through to the full-index walk and
-- returned every row (fix/in-null-equality-returns-all-rows). Covers the unique
-- secondary index (v) and the primary key (k) on the memory module, plus the
-- residual-filter path on the store module.

select k, v from t where v in (null);
→ []

select k, v from t where v = null;
→ []

select k, v from t where k = null;
→ []

select k, v from t where k in (null);
→ []

-- ===== (a) Duplicate literal must not multiply the matching row =====

select k, v from t where v in (5, 5);
→ [{"k":1,"v":5}]

-- ===== (b) NULL element contributes no match (no full-scan fallthrough) =====

select k, v from t where v in (5, null);
→ [{"k":1,"v":5}]

-- ===== (c) Duplicates and NULL combined =====

select k, v from t where v in (5, null, 5, 9);
→ [{"k":1,"v":5}]

select v from t where v in (5, 5, 9);
→ [{"v":5}]

-- A duplicate that matches no row stays empty (not a spurious full scan).
select k, v from t where v in (9, 9, null) order by k;
→ []

-- Two distinct matching values, each duplicated → each row exactly once.
select k, v from t where v in (5, 5, 7, 7) order by k;
→ [{"k":1,"v":5},{"k":2,"v":7}]

-- ===== (d) IN on the PRIMARY KEY column (also multi-seeks) =====

select k, v from t where k in (1, 1, 2, null) order by k;
→ [{"k":1,"v":5},{"k":2,"v":7}]

select k from t where k in (1, 2, 2) order by k;
→ [{"k":1},{"k":2}]

-- ===== (f) Same WHERE with and without DISTINCT must agree =====

select v from t where v in (5, null, 5, 9);
→ [{"v":5}]

select distinct v from t where v in (5, null, 5, 9);
→ [{"v":5}]

select distinct k, v from t where v in (5, 5, 7, 7) order by k;
→ [{"k":1,"v":5},{"k":2,"v":7}]

drop table t;

-- ===== Fuzz counterexample shape: REAL UNIQUE index, 0 / NULL / dup / 820 =====

create table t1 (id integer primary key, c_real2 real unique);
insert into t1 values (1, 0.0), (2, 820.0), (3, -79.79), (4, 100.0);

-- Exactly the rows whose c_real2 ∈ {0, 820}, once each — no duplicate-0 row,
-- no spurious -79.79/100 row from the NULL element.
select id, c_real2 from t1 where c_real2 in (0, null, 0, 820) order by id;
→ [{"id":1,"c_real2":0},{"id":2,"c_real2":820}]

select distinct id, c_real2 from t1 where c_real2 in (0, null, 0, 820) order by id;
→ [{"id":1,"c_real2":0},{"id":2,"c_real2":820}]

drop table t1;

-- ===== (e) Composite-index IN (cross-product) with a duplicate and a NULL =====

create table c (id integer primary key, a integer, b integer);
create index idx_ab on c(a, b);
insert into c values (1, 1, 10), (2, 1, 20), (3, 2, 10), (4, 2, 20);

-- Cross-product (a∈{1,1} × b∈{10,null}): the NULL-bearing tuples drop, the
-- (1,10) duplicate collapses → a single row.
select id from c where a in (1, 1) and b in (10, null) order by id;
→ [{"id":1}]

-- Duplicate values on both columns must not multiply matches.
select id from c where a in (1, 2, 2) and b in (10, 20, 20) order by id;
→ [{"id":1},{"id":2},{"id":3},{"id":4}]

-- Duplicate + NULL collapsing to a two-row subset.
select id from c where a in (1, 1, 2) and b in (10, null) order by id;
→ [{"id":1},{"id":3}]

select distinct id from c where a in (1, 1, 2) and b in (10, null) order by id;
→ [{"id":1},{"id":3}]

drop table c;

-- ===== Non-indexed column: residual scalar IN filter path =====
-- w has no index, so IN stays a residual InNode filter rather than a multi-seek.
-- Duplicates/NULL must behave identically: each base row tested once.

create table t2 (k integer primary key, w integer);
insert into t2 values (1, 5), (2, 7), (3, 5);

select k, w from t2 where w in (5, 5) order by k;
→ [{"k":1,"w":5},{"k":3,"w":5}]

select k, w from t2 where w in (5, null) order by k;
→ [{"k":1,"w":5},{"k":3,"w":5}]

select distinct w from t2 where w in (5, null, 5, 9) order by w;
→ [{"w":5}]

drop table t2;
