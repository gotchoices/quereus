-- adapted from SQLite test/gencol1.test
-- Generated-column scenarios beyond 41-generated-columns.sqllogic.

-- ===================================
-- 1. Chain — generated column referencing another generated column
-- ===================================

create table t_chain (
	id integer primary key,
	a integer not null,
	m integer generated always as (a * 2) stored,
	w integer generated always as (m * 5) stored
);

insert into t_chain (id, a) values (1, 3);

select a, m, w from t_chain where id = 1;
→ [{"a":3,"m":6,"w":30}]

update t_chain set a = 4 where id = 1;

select a, m, w from t_chain where id = 1;
→ [{"a":4,"m":8,"w":40}]

drop table t_chain;

-- ===================================
-- 1b. Reverse-declaration-order chain — `w` declared before its dependency `m`
-- ===================================

create table t_chain_rev (
	id integer primary key,
	a integer not null,
	w integer generated always as (m * 5) stored,
	m integer generated always as (a * 2) stored
);

insert into t_chain_rev (id, a) values (1, 3);

select a, m, w from t_chain_rev where id = 1;
→ [{"a":3,"m":6,"w":30}]

update t_chain_rev set a = 4 where id = 1;

select a, m, w from t_chain_rev where id = 1;
→ [{"a":4,"m":8,"w":40}]

drop table t_chain_rev;

-- ===================================
-- 2. Generated column used in WHERE / ORDER BY / GROUP BY
-- ===================================

create table t_q (
	id integer primary key,
	a integer not null,
	b integer not null,
	s integer generated always as (a + b) stored
);

insert into t_q (id, a, b) values (1, 1, 2), (2, 3, 1), (3, 2, 2);

-- WHERE on generated column
select id from t_q where s = 4 order by id;
→ [{"id":2},{"id":3}]

-- GROUP BY on generated column
select s, count(*) as n from t_q group by s order by s;
→ [{"s":3,"n":1},{"s":4,"n":2}]

-- ORDER BY on generated column
select id, s from t_q order by s desc, id;
→ [{"id":2,"s":4},{"id":3,"s":4},{"id":1,"s":3}]

drop table t_q;

-- ===================================
-- 3. Type coercion via generated column
-- ===================================

create table t_typed (
	id integer primary key,
	c any null,
	t text generated always as (typeof(c)) stored
);

insert into t_typed (id, c) values (1, 5), (2, 'abc'), (3, 5.5), (4, null);

select id, t from t_typed order by id;
→ [{"id":1,"t":"integer"},{"id":2,"t":"text"},{"id":3,"t":"real"},{"id":4,"t":"null"}]

drop table t_typed;

-- ===================================
-- 4. Generated column with UNIQUE constraint
-- ===================================

create table t_u (
	id integer primary key,
	a integer not null,
	b integer generated always as (a * 10) stored unique
);

insert into t_u (id, a) values (1, 1), (2, 2);

-- duplicate generated value should violate UNIQUE
insert into t_u (id, a) values (3, 1);
-- error: UNIQUE

drop table t_u;

-- ===================================
-- 5. Generated column as PRIMARY KEY
-- ===================================

create table t_pk (
	a integer not null,
	k integer generated always as (a + 100) stored primary key
);

insert into t_pk (a) values (1);

-- duplicate generated PK value should fail
insert into t_pk (a) values (1);
-- error:

select k from t_pk;
→ [{"k":101}]

drop table t_pk;
