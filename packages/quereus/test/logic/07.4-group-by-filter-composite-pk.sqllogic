-- Regression: streaming aggregate must not leak a yielded group's
-- representative-row context across the next child pull.
--
-- A grouped StreamAggregate yields the just-finished group with that group's
-- representative SOURCE row installed in the runtime context (for HAVING /
-- correlated reads / projection). Those descriptors are built from the source's
-- attribute IDs — the SAME IDs a streaming child Filter publishes for its own
-- row. If the aggregate leaves them live while it pulls the next input row, the
-- Filter directly below resolves its predicate columns through the aggregate's
-- STALE representative row instead of the child's current row, so the WHERE
-- predicate is evaluated against the wrong values and effectively dropped.
--
-- Shape that triggers it (StreamAggregate, no interposed Sort, standalone Filter
-- directly below):
--   * composite PK (d, r) so the IndexScan is already ordered for GROUP BY d
--     => StreamAggregate is chosen with no Sort (a Sort would drain the child),
--   * filter on a non-leading PK column (r) absent from GROUP BY => cannot seek,
--     => the predicate stays a standalone Filter node right under the aggregate.
--
-- Without the fix, the row pulled immediately AFTER a group boundary is filtered
-- against the previous group's stale representative row, so a row that should be
-- dropped is wrongly folded into the new group.

create table bt (d integer, r integer, total integer null, primary key (d, r));
insert into bt values
  (1, 10, 150),
  (1, 20, null),
  (2, 10, 7),
  (2, 20, 3),
  (3, 10, 1),
  (3, 20, 99);

-- PRIMARY BUG: equality filter on the non-leading composite-PK column.
-- d=2 is the tell: only (2,10,7) matches r=10, so sum is 7 (NOT 7+3=10).
-- d=3 likewise: only (3,10,1) matches, so sum is 1 (NOT 1+99=100).
-- d=1 reads 150 either way (its dropped row (1,20,null) contributes null to sum).
select d, sum(total) as s from bt where r = 10 group by d order by d;
→ [{"d":1,"s":150},{"d":2,"s":7},{"d":3,"s":1}]

-- RANGE filter (no constant-pin / attributeDefaults surface): same expected rows,
-- proving the fix is not specific to the r=const shape.
select d, sum(total) as s from bt where r > 9 and r < 11 group by d order by d;
→ [{"d":1,"s":150},{"d":2,"s":7},{"d":3,"s":1}]

-- count(*) catches the wrong-keep directly: under the bug d=2/d=3 would each see
-- a second (wrongly-kept) row. Correct count is 1 per group. count(col) likewise.
select d, count(*) as c, count(total) as ct from bt where r = 10 group by d order by d;
→ [{"d":1,"c":1,"ct":1},{"d":2,"c":1,"ct":1},{"d":3,"c":1,"ct":1}]

-- DISTINCT aggregate under the same shape — exercises the per-group distinct-tree
-- reset adjacent to the edited code. A wrongly-kept post-boundary row would inflate
-- the distinct sum (d=2 -> 10, d=3 -> 100). Correct values match sum(total).
select d, sum(distinct total) as sd from bt where r = 10 group by d order by d;
→ [{"d":1,"sd":150},{"d":2,"sd":7},{"d":3,"sd":1}]

-- HAVING over the filtered rollup — confirms the representative-row context is still
-- readable during the yield, and the filtered sums feed HAVING correctly. Only d=1
-- exceeds 100 once the bug-kept rows are excluded.
select d, sum(total) as s from bt where r = 10 group by d having sum(total) > 100 order by d;
→ [{"d":1,"s":150}]

-- DROPPED-FIRST-ROW-OF-A-LATER-GROUP: filter r=20 keeps (1,20,null),(2,20,3),(3,20,99).
-- Under the bug the boundary's stale r=20 wrongly passes (3,10,1) (whose real r=10
-- should be dropped), inflating d=3 to 100. Correct d=3 is 99. d=1 is null (its only
-- kept row has total null) — also exercises sum-over-all-null.
select d, sum(total) as s from bt where r = 20 group by d order by d;
→ [{"d":1,"s":null},{"d":2,"s":3},{"d":3,"s":99}]

-- ORDER BY downstream of the aggregate (desc): consumer reads aggregate output
-- after the generator resumes; must stay correct and ordered.
select d, sum(total) as s from bt where r = 10 group by d order by d desc;
→ [{"d":3,"s":1},{"d":2,"s":7},{"d":1,"s":150}]

-- Empty result / zero matching rows.
select d, sum(total) as s from bt where r = 99 group by d order by d;
→ []

-- CONTROL: scalar aggregate (no GROUP BY) — separate code branch, never interleaved
-- with a yielded-group context. 150 + 7 + 1 = 158.
select sum(total) as s from bt where r = 10;
→ [{"s":158}]

-- CONTROL: plain projection (no aggregate at all) — the Filter standing alone must
-- still reject the r=20 rows. Locks that the filter itself is correct.
select d, r, total from bt where r = 10 order by d;
→ [{"d":1,"r":10,"total":150},{"d":2,"r":10,"total":7},{"d":3,"r":10,"total":1}]

drop table bt;

-- CONTROL: single-column-PK analogue. Filtering on the PK column (k) is a seek, so
-- there is NO standalone Filter under the aggregate — the interleaving hazard cannot
-- arise. Must remain correct.
create table sp (k integer primary key, total integer);
insert into sp values (1, 10), (2, 20), (3, 30);

select k, sum(total) as s from sp where k >= 2 group by k order by k;
→ [{"k":2,"s":20},{"k":3,"s":30}]

drop table sp;

-- CONTROL: HashAggregate path. With PK on id, GROUP BY d is unsorted, so the planner
-- picks HashAggregate (it drains the child fully before yielding any group, so no
-- interleaving). Same logical query as the primary case — assert it stays correct,
-- don't assume. ORDER BY d makes the (unordered) hash output deterministic.
create table ht (id integer primary key, d integer, r integer, total integer null);
insert into ht values
  (1, 1, 10, 150),
  (2, 1, 20, null),
  (3, 2, 10, 7),
  (4, 2, 20, 3),
  (5, 3, 10, 1),
  (6, 3, 20, 99);

select d, sum(total) as s from ht where r = 10 group by d order by d;
→ [{"d":1,"s":150},{"d":2,"s":7},{"d":3,"s":1}]

select d, count(*) as c, sum(total) as s from ht where r = 20 group by d order by d;
→ [{"d":1,"c":1,"s":null},{"d":2,"c":1,"s":3},{"d":3,"c":1,"s":99}]

drop table ht;
