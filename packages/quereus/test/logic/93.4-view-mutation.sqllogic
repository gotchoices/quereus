-- View updateability — Phase 1 + 1b working cases.
-- Single-source projection-and-filter views are writeable; writes route to the
-- base table. See docs/view-updateability.md.

-- ===================================
-- GreenMen: constant-FD default from the selection predicate (select *)
-- ===================================

create table Men (Name text primary key, Color text);
create view GreenMen as select * from Men where Color = 'green';

insert into GreenMen (Name) values ('Bob');

select * from Men order by Name;
→ [{"Name":"Bob","Color":"green"}]

select * from GreenMen order by Name;
→ [{"Name":"Bob","Color":"green"}]

-- ===================================
-- AdultsBare: constant-FD default for a projected-away column
-- ===================================

create table Adults (Name text primary key, Age integer, Country text);
create view AdultsBare as select Name, Age from Adults where Country = 'US';

insert into AdultsBare values ('Bob', 30);

select * from Adults order by Name;
→ [{"Name":"Bob","Age":30,"Country":"US"}]

select * from AdultsBare order by Name;
→ [{"Name":"Bob","Age":30}]

-- ===================================
-- Base-column default survives projection
-- ===================================

create table u (id integer primary key, name text default 'unknown');
create view uv as select id from u;

insert into uv values (5);

select * from u order by id;
→ [{"id":5,"name":"unknown"}]

-- ===================================
-- Rename projection
-- ===================================

create table users (id integer primary key, name text);
create view RV as select id as user_id, name as full_name from users;

insert into RV (user_id, full_name) values (1, 'Bob');

select * from users order by id;
→ [{"id":1,"name":"Bob"}]

select * from RV order by user_id;
→ [{"user_id":1,"full_name":"Bob"}]

-- ===================================
-- Filter pass-through delete
-- ===================================

create table acct (id integer primary key, active integer, label text);
insert into acct values (5, 1, 'a'), (6, 0, 'b'), (7, 1, 'c');
create view ActiveUsers as select * from acct where active = 1;

delete from ActiveUsers where id = 5;

select id, active, label from acct order by id;
→ [{"id":6,"active":0,"label":"b"},{"id":7,"active":1,"label":"c"}]

-- ===================================
-- Filter pass-through update (the selection predicate is conjoined into WHERE)
-- ===================================

-- id=7 is visible (active=1): the update applies.
update ActiveUsers set label = 'C' where id = 7;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- id=6 is NOT visible (active=0): the conjoined predicate matches no base row.
update ActiveUsers set label = 'X' where id = 6;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- ===================================
-- Aliased base table + alias-qualified filter/projection: the alias qualifier
-- is normalized away when threading the body predicate into the base statement.
-- ===================================

create table al (id integer primary key, active integer, label text);
insert into al values (1, 1, 'a'), (2, 0, 'b'), (3, 1, 'c');
create view AliasView as select x.id as aid, x.label as alabel from al as x where x.active = 1;

-- visible row (active=1): update applies through the alias-qualified predicate.
update AliasView set alabel = 'Z' where aid = 1;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

-- invisible row (active=0): conjoined alias predicate matches no base row.
update AliasView set alabel = 'X' where aid = 2;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

delete from AliasView where aid = 3;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"}]

-- ===================================
-- Phase 1b: per-statement mutation context threaded through the view
-- (one captured value stamped onto every row of the statement).
-- ===================================

create table evt (id integer primary key, created integer default now_ms) using memory with context (now_ms integer);
create view evt_v as select id from evt;

insert into evt_v with context now_ms = 12345 values (1), (2);

select * from evt order by id;
→ [{"id":1,"created":12345},{"id":2,"created":12345}]

-- ===================================
-- Phase 2: Multi-source key-preserving inner join — update / delete write-through.
-- The body is a two-table inner equi-join; writes route per owning base side via
-- a subquery over the join body (the row-identifying predicate). The owning side
-- can be the table whose PK the projection hides (ms_parent below).
-- See docs/view-updateability.md § Inner Join, § Multi-Base-Table Mutations.
-- ===================================

create table ms_parent (pid integer primary key, label text);
create table ms_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ms_parent(pid));
insert into ms_parent values (10, 'P10'), (20, 'P20');
insert into ms_child values (1, 10, 'a'), (2, 10, 'b'), (3, 20, 'c');

create view ms_jv as
    select c.cid as cid, c.note as note, p.label as label
    from ms_child c join ms_parent p on p.pid = c.pref;

-- read-through over the join
select * from ms_jv order by cid;
→ [{"cid":1,"note":"a","label":"P10"},{"cid":2,"note":"b","label":"P10"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE routed to the child side only (note is owned by ms_child).
update ms_jv set note = 'A' where cid = 1;
select cid, pref, note from ms_child order by cid;
→ [{"cid":1,"pref":10,"note":"A"},{"cid":2,"pref":10,"note":"b"},{"cid":3,"pref":20,"note":"c"}]

-- UPDATE routed to the parent side (label is owned by ms_parent, whose PK is
-- hidden by the projection — identified through the join). cid=1 joins pid=10.
update ms_jv set label = 'P10x' where cid = 1;
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20"}]

-- the parent update is visible to every child row joining pid=10.
select * from ms_jv order by cid;
→ [{"cid":1,"note":"A","label":"P10x"},{"cid":2,"note":"b","label":"P10x"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE touching BOTH sides -> two ordered base ops (FK-parent before FK-child).
update ms_jv set note = 'C', label = 'P20x' where cid = 3;
select cid, note from ms_child order by cid;
→ [{"cid":1,"note":"A"},{"cid":2,"note":"b"},{"cid":3,"note":"C"}]
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20x"}]

-- DELETE routes to the FK-many (child) side by default; the parent stays in place.
delete from ms_jv where cid = 2;
select cid from ms_child order by cid;
→ [{"cid":1},{"cid":3}]
select pid from ms_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- the deleted child row is gone from the view.
select cid from ms_jv order by cid;
→ [{"cid":1},{"cid":3}]

-- BOTH-sides update predicated on the FK-PARENT's reassigned column, NO RETURNING —
-- the base-decomposition ordering clash. The FK-parent op runs first and rewrites
-- `label`; a live re-query of the join body would then find no 'P10' row, so the
-- FK-child op's identifying subquery would match nothing and silently drop the child
-- update. The up-front identity capture pins children 1,2 before any base op mutates,
-- so BOTH sides land. See view-mutation-multisource-both-sides-predicate-clash.
create table pc_parent (pid integer primary key, label text);
create table pc_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references pc_parent(pid));
insert into pc_parent values (10, 'P10'), (20, 'P20');
insert into pc_child values (1, 10, 'a'), (2, 10, 'a'), (3, 20, 'b');
create view pc_jv as
    select c.cid as cid, c.note as note, p.label as label
    from pc_child c join pc_parent p on p.pid = c.pref;

update pc_jv set note = 'B', label = 'PY' where label = 'P10';
-- children 1,2 (pref 10) get note 'B'; parent 10 gets label 'PY' — neither dropped.
select cid, note from pc_child order by cid;
→ [{"cid":1,"note":"B"},{"cid":2,"note":"B"},{"cid":3,"note":"b"}]
select pid, label from pc_parent order by pid;
→ [{"pid":10,"label":"PY"},{"pid":20,"label":"P20"}]
select cid, note, label from pc_jv order by cid;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":2,"note":"B","label":"PY"},{"cid":3,"note":"b","label":"P20"}]

-- BOTH-sides predicate clash through a view whose BODY carries its own WHERE.
-- The capture's identifying predicate is (user WHERE ∧ body WHERE), evaluated
-- BEFORE any base op mutates, so the body filter applies to the pre-mutation image.
-- bw_child 2 is hidden (active=0) yet shares parent pid 10 with the visible cid 1:
-- the capture pins per-CHILD-PK (only cid 1), so the FK-parent op rewriting `label`
-- on pid 10 leaves cid 2's note untouched even though both children share that parent.
create table bw_parent (pid integer primary key, label text);
create table bw_child (cid integer primary key, pref integer, note text, active integer,
    foreign key (pref) references bw_parent(pid));
insert into bw_parent values (10, 'P10'), (20, 'P20');
insert into bw_child values (1, 10, 'a', 1), (2, 10, 'a', 0), (3, 20, 'b', 1);
create view bw_jv as
    select c.cid as cid, c.note as note, p.label as label
    from bw_child c join bw_parent p on p.pid = c.pref
    where c.active = 1;

update bw_jv set note = 'B', label = 'PY' where label = 'P10';
-- Visible row matching label='P10' is only cid 1; cid 2 (active=0) is outside the
-- body filter so it is not captured and keeps note 'a'.
select cid, note from bw_child order by cid;
→ [{"cid":1,"note":"B"},{"cid":2,"note":"a"},{"cid":3,"note":"b"}]
select pid, label from bw_parent order by pid;
→ [{"pid":10,"label":"PY"},{"pid":20,"label":"P20"}]
select cid, note, label from bw_jv order by cid;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":3,"note":"b","label":"P20"}]

-- ===================================
-- Multi-source rejections (still diagnosed-and-rejected this phase).
-- ===================================

-- A computed (non-invertible) join column is read-only.
create view ms_jv_c as
    select c.cid as cid, p.label || '!' as banner
    from ms_child c join ms_parent p on p.pid = c.pref;
update ms_jv_c set banner = 'z' where cid = 1;
-- error: read-only

-- RETURNING through a multi-source (join) delete is SHIPPED. The view row spans
-- both base tables, so it is produced by a re-query of the view captured BEFORE
-- the base delete fires; the deleted view-projected row is returned. (cid=1 joins
-- pid=10 → label 'P10x' from the earlier parent update; note 'A' from the child
-- update.)
delete from ms_jv where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10x"}]

-- ===================================
-- Phase 2: adversarial coverage (qualifier rewriting, body-WHERE conjunction,
-- column-list overrides, and the remaining shape rejections).
-- ===================================

create table ax_parent (pid integer primary key, pv integer);
create table ax_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ax_parent(pid));
insert into ax_parent values (10, 100), (20, 200);
insert into ax_child values (1, 10, 'a'), (2, 20, 'b');

-- Swapped projection: the view column `pv` maps to the CHILD pk (ax_child.cid)
-- and the view column `cid` maps to the PARENT value (ax_parent.pv). A write must
-- route by lineage, not by name. `where cid = 100` filters on ax_parent.pv=100.
create view ax_swap as
    select p.pv as cid, c.cid as pv from ax_child c join ax_parent p on p.pid = c.pref;
select * from ax_swap order by pv;
→ [{"cid":100,"pv":1},{"cid":200,"pv":2}]
update ax_swap set pv = 7 where cid = 100;
select cid, pref from ax_child order by cid;
→ [{"cid":2,"pref":20},{"cid":7,"pref":10}]
select pid, pv from ax_parent order by pid;
→ [{"pid":10,"pv":100},{"pid":20,"pv":200}]

-- View-name-qualified predicate (jv.col) resolves to the base term.
create view ax_q as select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_q set note = 'z' where ax_q.cid = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"b"},{"cid":7,"note":"z"}]

-- The view body's own WHERE is conjoined: a predicate-less write only touches the
-- rows the body exposes (children whose parent pv > 150, i.e. pref = 20).
create view ax_filt as
    select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref where p.pv > 150;
select cid from ax_filt order by cid;
→ [{"cid":2}]
update ax_filt set note = 'F';
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"z"}]

-- Explicit view column-list override (create view v (a,b) as ...): writes route by
-- the override name to the underlying lineage.
create view ax_named (k, n) as select c.cid, c.note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_named set n = 'g' where k = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"g"}]

-- Composite-PK side -> rejected (identifying predicate needs a single-column key).
create table ax_comp (c1 integer, c2 integer, pref integer, note text,
    primary key (c1, c2), foreign key (pref) references ax_parent(pid));
create view ax_jv_comp as
    select x.c1 as c1, x.note as note, p.pv as pv from ax_comp x join ax_parent p on p.pid = x.pref;
update ax_jv_comp set note = 'q' where c1 = 1;
-- error: cannot write through

-- Cross-source SET value (assign a column from the other base table) -> rejected.
create view ax_jv_x as
    select c.cid as cid, c.note as note, p.pv as pv from ax_child c join ax_parent p on p.pid = c.pref;
update ax_jv_x set note = pv where cid = 2;
-- error: cannot write through

-- Self-join body -> rejected.
create table ax_emp (id integer primary key, mgr integer, v integer);
create view ax_self as select e.id as id, m.v as mv from ax_emp e join ax_emp m on m.id = e.mgr;
update ax_self set mv = 9 where id = 1;
-- error: cannot write through

-- Three-table join -> rejected.
create table ax_b (bid integer primary key, v integer);
create view ax_three as
    select c.cid as cid, p.pv as pv, b.v as bv
    from ax_child c join ax_parent p on p.pid = c.pref join ax_b b on b.bid = c.cid;
update ax_three set pv = 9 where cid = 2;
-- error: cannot write through

-- DELETE through a join with no provable FK and no resolving tag -> ambiguous
-- under the default lenient policy (a delete_via / target override resolves it,
-- exercised in the override-surface section below).
create table ax_x (xid integer primary key, v integer);
create table ax_y (yid integer primary key, v integer);
insert into ax_x values (1, 5);
insert into ax_y values (5, 9);
create view ax_nofk as select x.xid as xid, y.yid as yid from ax_x x join ax_y y on y.yid = x.v;
delete from ax_nofk where xid = 1;
-- error: cannot delete through view

-- ===================================
-- Phase 3.4: the `quereus.update.*` tag override surface.
-- target / exclude / delete_via / policy / default_for — read + site-validated
-- through the typed reserved-tag registry, merged statement-over-view.
-- See docs/view-updateability.md § Tags: The Override Surface.
-- ===================================

-- --- default_for: statement-level omitted-insert default (single-source) ---
create table df_t (id integer primary key, created integer, note text);
create view df_v as select id, note from df_t;

-- `created` is projected away by the view; the statement-level default_for tag
-- supplies it (ahead of the base column's own default).
insert into df_v with tags ("quereus.update.default_for.created" = '777') values (5, 'x');
select * from df_t order by id;
→ [{"id":5,"created":777,"note":"x"}]

-- --- default_for: view-level default, overridden statement-over-view ---
create table df2 (id integer primary key, created integer);
create view df2_v as select id from df2 with tags ("quereus.update.default_for.created" = '111');

-- view-level default_for supplies the omitted column.
insert into df2_v values (1);
select * from df2 order by id;
→ [{"id":1,"created":111}]

-- statement-level default_for overrides the view-level one for this statement.
insert into df2_v with tags ("quereus.update.default_for.created" = '222') values (2);
select * from df2 order by id;
→ [{"id":1,"created":111},{"id":2,"created":222}]

-- a default_for naming a column that is neither a view nor a base column -> error.
insert into df2_v with tags ("quereus.update.default_for.nope" = '0') values (3);
-- error: not a column

-- --- target / exclude: narrow a multi-source delete to one side ---
create table tg_x (xid integer primary key, v integer, lx text);
create table tg_y (yid integer primary key, ly text);
insert into tg_x values (1, 5, 'x1'), (2, 6, 'x2');
insert into tg_y values (5, 'y5'), (6, 'y6');
create view tg_jv as
    select x.xid as xid, x.lx as lx, y.ly as ly from tg_x x join tg_y y on y.yid = x.v;
select * from tg_jv order by xid;
→ [{"xid":1,"lx":"x1","ly":"y5"},{"xid":2,"lx":"x2","ly":"y6"}]

-- target narrows the (no-FK ambiguous) delete to tg_x: only tg_x loses the row.
delete from tg_jv with tags ("quereus.update.target" = 'tg_x') where xid = 1;
select xid from tg_x order by xid;
→ [{"xid":2}]
select yid from tg_y order by yid;
→ [{"yid":5},{"yid":6}]

-- exclude tg_x routes the same shape to the OTHER side (tg_y); xid=2 joins y.yid=6.
delete from tg_jv with tags ("quereus.update.exclude" = 'tg_x') where xid = 2;
select yid from tg_y order by yid;
→ [{"yid":5}]
select xid from tg_x order by xid;
→ [{"xid":2}]

-- target naming a table not in the join -> sited tag-target-not-found.
delete from tg_jv with tags ("quereus.update.target" = 'nope') where xid = 2;
-- error: not a base table of the join

-- target/exclude excluding a side an UPDATE assigns -> structured conflict.
update tg_jv with tags ("quereus.update.exclude" = 'tg_x') set lx = 'z' where xid = 2;
-- error: excludes that table

-- --- delete_via: pick the deletion side explicitly ---
create table dv_l (lid integer primary key, v integer);
create table dv_r (rid integer primary key, w integer);
insert into dv_l values (1, 5), (2, 6);
insert into dv_r values (5, 50), (6, 60);
create view dv_jv as select l.lid as lid, r.rid as rid from dv_l l join dv_r r on r.rid = l.v;

-- delete_via='left_delete' picks the left join source (dv_l); dv_r is untouched.
delete from dv_jv with tags ("quereus.update.delete_via" = 'left_delete') where lid = 1;
select lid from dv_l order by lid;
→ [{"lid":2}]
select rid from dv_r order by rid;
→ [{"rid":5},{"rid":6}]

-- delete_via='parent' picks the FK-parent side; ON DELETE CASCADE removes the child.
create table dvp_parent (pid integer primary key, lbl text);
create table dvp_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references dvp_parent(pid) on delete cascade);
insert into dvp_parent values (10, 'P10'), (20, 'P20');
insert into dvp_child values (1, 10, 'a'), (2, 20, 'b');
create view dvp_jv as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from dvp_child c join dvp_parent p on p.pid = c.pref;
delete from dvp_jv with tags ("quereus.update.delete_via" = 'parent') where cid = 1;
select pid from dvp_parent order by pid;
→ [{"pid":20}]
select cid from dvp_child order by cid;
→ [{"cid":2}]

-- --- policy: strict refuses to guess; lenient auto-routes (FK-child default) ---
create table pol_parent (pid integer primary key, lbl text);
create table pol_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references pol_parent(pid));
insert into pol_parent values (10, 'P10'), (20, 'P20');
insert into pol_child values (1, 10, 'a'), (2, 20, 'b');

-- lenient (default): the FK join delete auto-routes to the FK-child side.
create view pol_lenient as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from pol_child c join pol_parent p on p.pid = c.pref;
delete from pol_lenient where cid = 1;
select cid from pol_child order by cid;
→ [{"cid":2}]
select pid from pol_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- strict (view-level policy tag): the same delete is rejected — strict will not
-- guess the deletion side even when an FK proves one.
create view pol_strict as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from pol_child c join pol_parent p on p.pid = c.pref
    with tags ("quereus.update.policy" = 'strict');
delete from pol_strict where cid = 2;
-- error: policy

-- an explicit target (narrowing to one side) resolves the strict ambiguity.
delete from pol_strict with tags ("quereus.update.target" = 'pol_child') where cid = 2;
select cid from pol_child order by cid;
→ []

-- --- sited diagnostics for malformed reserved tags ---

-- unknown reserved key on a DML statement -> sited error.
update tg_jv with tags ("quereus.update.taget" = 'tg_x') set lx = 'z' where xid = 2;
-- error: unknown reserved tag

-- mis-sited reserved key on a DML statement (policy is view-DDL-only) -> error.
delete from tg_jv with tags ("quereus.update.policy" = 'strict') where xid = 2;
-- error: not allowed

-- unknown reserved key declared on the VIEW DDL -> surfaces (sited) at mutation.
create table bvu (id integer primary key, x integer);
create view bvu_v as select id from bvu with tags ("quereus.update.taget" = 'bvu');
insert into bvu_v values (1);
-- error: unknown reserved tag

-- ===================================
-- Phase 3.4: adversarial edges (review pass) — precedence, conflicting tags,
-- the except-only delete_via value on a join, and the single-source no-op.
-- ===================================

-- --- default_for precedence: an explicit supply of the column wins ---
-- The view projects `created`, so a statement that supplies it explicitly must
-- override the view-level default_for; an omitted insert still takes the default.
create table dfp (id integer primary key, created integer);
create view dfp_v as select id, created from dfp
    with tags ("quereus.update.default_for.created" = '111');
insert into dfp_v (id, created) values (1, 999);
insert into dfp_v (id) values (2);
select * from dfp order by id;
→ [{"id":1,"created":999},{"id":2,"created":111}]

-- --- delete_via='right_insert' is an except-only value -> rejected for a join ---
delete from dv_jv with tags ("quereus.update.delete_via" = 'right_insert') where lid = 2;
-- error: except

-- --- target + delete_via that disagree -> structured tag-conflict ---
-- target pins dv_r, but delete_via='left_delete' picks dv_l (excluded) -> conflict.
delete from dv_jv with tags ("quereus.update.target" = 'dv_r', "quereus.update.delete_via" = 'left_delete') where lid = 2;
-- error: excludes it

-- --- single-source view carrying a routing tag: a documented no-op ---
-- target/exclude only narrow a multi-source base set; on a single-source view the
-- tag is inert and an unknown name is NOT existence-checked (per the contract).
create table sst (id integer primary key, note text);
create view sst_v as select id, note from sst
    with tags ("quereus.update.target" = 'not_a_real_table');
insert into sst_v values (1, 'a');
select * from sst order by id;
→ [{"id":1,"note":"a"}]

-- ===================================
-- View-column references nested inside subquery / exists / in-subquery operands
-- of a user predicate (or assigned value) are descended into and rewritten to
-- their base-term lineage — scope-aware, so a subquery-local same-named column is
-- left alone and an unresolvable source is rejected, not silently mis-bound.
-- See docs/view-updateability.md § Selection.
-- ===================================

-- --- (a) the repro: a correlated view-column ref inside EXISTS, over a base table
--         that ALSO has a same-named base column (silent-mis-bind hazard) ---
-- The view renames base `lbl` to the view column `note`; base table `sq_c` also
-- has a literal `note` column. `note` inside EXISTS is the VIEW column (= base
-- `lbl`); it must substitute to `lbl`, not re-bind to base `sq_c.note`.
create table sq_c (cid integer primary key, note text, lbl text);
create table sq_other (k text);
insert into sq_c values (1, 'BASE_NOTE_1', 'LBL_1'), (2, 'BASE_NOTE_2', 'LBL_2');
insert into sq_other values ('LBL_1');
create view sq_jv as select cid as cid, lbl as note from sq_c;

update sq_jv set note = 'CHANGED' where exists (select 1 from sq_other o where o.k = note);
-- cid=1 (lbl LBL_1, present in sq_other) matches -> its `lbl` becomes CHANGED; the
-- silent no-op (predicate re-bound to base `note`, absent from sq_other) is gone.
select cid, note, lbl from sq_c order by cid;
→ [{"cid":1,"note":"BASE_NOTE_1","lbl":"CHANGED"},{"cid":2,"note":"BASE_NOTE_2","lbl":"LBL_2"}]
-- the write is visible through the view (view col `note` = base `lbl`).
select * from sq_jv order by cid;
→ [{"cid":1,"note":"CHANGED"},{"cid":2,"note":"LBL_2"}]

-- --- (b) a correlated view-column ref inside an in (select ... where ...) ---
-- `category` is the view column (= base `grp`); referenced unqualified inside the
-- IN-subquery (whose source has no same-named column) it correlates to the outer
-- view row and must substitute to `grp`.
create table sq_in_t (id integer primary key, grp text, mark text);
create table sq_in_map (g text, allowed_id integer);
insert into sq_in_t values (1, 'G1', 'x'), (2, 'G2', 'y'), (3, 'G1', 'z');
insert into sq_in_map values ('G1', 1), ('G1', 3);
create view sq_in_v as select id as id, grp as category, mark as mark from sq_in_t;

update sq_in_v set mark = 'M' where id in (select allowed_id from sq_in_map where g = category);
select id, grp, mark from sq_in_t order by id;
→ [{"id":1,"grp":"G1","mark":"M"},{"id":2,"grp":"G2","mark":"y"},{"id":3,"grp":"G1","mark":"M"}]

-- --- (c) a subquery-local same-named column must NOT be substituted ---
-- The view renames base `lbl` to view column `note`; the subquery source
-- `sq_sh_src` has its OWN `note` column. `note` inside `in (select note from
-- sq_sh_src)` is sq_sh_src.note (subquery-local) — it must stay local. The
-- top-level left `note` is the view column and substitutes to base `lbl`.
create table sq_sh_t (tid integer primary key, lbl text, payload text);
create table sq_sh_src (note text);
insert into sq_sh_t values (1, 'L1', 'p1'), (2, 'L2', 'p2');
insert into sq_sh_src values ('L1');
create view sq_sh_v as select tid as tid, lbl as note, payload as payload from sq_sh_t;

update sq_sh_v set payload = 'P' where note in (select note from sq_sh_src);
-- lbl in ('L1') -> only tid=1; if the inner `note` had been wrongly substituted to
-- `lbl`, the subquery `select lbl from sq_sh_src` would not even resolve.
select tid, lbl, payload from sq_sh_t order by tid;
→ [{"tid":1,"lbl":"L1","payload":"P"},{"tid":2,"lbl":"L2","payload":"p2"}]

-- --- (d) a subquery referencing NO view column still works unchanged ---
create table sq_none_t (id integer primary key, val text);
create table sq_none_ok (flag integer);
insert into sq_none_t values (1, 'a'), (2, 'b');
insert into sq_none_ok values (1);
create view sq_none_v as select id as id, val as val from sq_none_t;

update sq_none_v set val = 'Z' where exists (select 1 from sq_none_ok where flag = 1);
select id, val from sq_none_t order by id;
→ [{"id":1,"val":"Z"},{"id":2,"val":"Z"}]

-- --- (e1) multi-source join view: a view-col ref nested in a subquery in the user
--          WHERE is routed to the correct (alias-qualified) base term ---
-- `label` is owned by the parent side (p.label); referenced inside EXISTS it
-- substitutes to `p.label`, correlating to the join body of the identifying
-- subquery. The update routes to the child side (note is owned by sq_jc).
create table sq_jp (pid integer primary key, label text);
create table sq_jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references sq_jp(pid));
create table sq_allow (lab text);
insert into sq_jp values (10, 'P10'), (20, 'P20');
insert into sq_jc values (1, 10, 'a'), (2, 20, 'b'), (3, 10, 'c');
insert into sq_allow values ('P10');
create view sq_jv2 as select c.cid as cid, c.note as note, p.label as label
    from sq_jc c join sq_jp p on p.pid = c.pref;

update sq_jv2 set note = 'HIT' where exists (select 1 from sq_allow where lab = label);
select cid, note from sq_jc order by cid;
→ [{"cid":1,"note":"HIT"},{"cid":2,"note":"b"},{"cid":3,"note":"HIT"}]

-- --- (e2) multi-source: a view-col ref nested in a subquery in a SET value ---
-- The SET value is a correlated scalar subquery keyed on the OWNING-side view
-- column `note` (= c.note); the descent substitutes it to `c.note` and the
-- owning-side qualifier is stripped through the subquery so it correlates to the
-- target row of the lowered child UPDATE.
create table sq_e2_jp (pid integer primary key, label text);
create table sq_e2_jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references sq_e2_jp(pid));
create table sq_e2_lookup (k text, v text);
insert into sq_e2_jp values (10, 'P10');
insert into sq_e2_jc values (1, 10, 'a'), (2, 10, 'b');
insert into sq_e2_lookup values ('a', 'AA'), ('b', 'BB');
create view sq_e2_v as select c.cid as cid, c.note as note, p.label as label
    from sq_e2_jc c join sq_e2_jp p on p.pid = c.pref;

update sq_e2_v set note = (select v from sq_e2_lookup where k = note) where cid = 1;
select cid, note from sq_e2_jc order by cid;
→ [{"cid":1,"note":"AA"},{"cid":2,"note":"b"}]

-- --- (f) conservative reject: a `select *` subquery source can't be resolved, so
--         a nested unqualified view-column ref can't be proven correlated ---
create table sq_f_t (id integer primary key, lbl text);
create table sq_f_aux (x text);
insert into sq_f_t values (1, 'L1');
insert into sq_f_aux values ('L1');
create view sq_f_v as select id as id, lbl as tag from sq_f_t;

update sq_f_v set tag = 'X' where exists (select 1 from (select * from sq_f_aux) as s where s.x = tag);
-- error: cannot write through

-- a table-valued-function subquery source is unresolvable the same way -> reject.
update sq_f_v set tag = 'X' where exists (select 1 from table_info('sq_f_t') as ti where ti.name = tag);
-- error: cannot write through

-- --- (g) the substituted base term itself collides with a subquery-local source ---
-- The view renames base `lbl` to view column `note`; the EXISTS subquery FROM
-- (p1_aux) ALSO has an `lbl` column. `note` is the view column = base `p1_t.lbl`,
-- correlated to the outer row. An UNQUALIFIED substituted base term (`lbl`) inside
-- the subquery would re-bind to p1_aux.lbl (innermost scope) — making the predicate
-- the uncorrelated p1_aux.k = p1_aux.lbl, true for the ('Q','Q') row, so EVERY outer
-- row would pass (a silent wrong write). Single-source descent qualifies the term to
-- p1_t.lbl, so the predicate is the correlated p1_aux.k = p1_t.lbl -> only row 1.
create table p1_t (id integer primary key, lbl text);
create table p1_aux (k text, lbl text);
insert into p1_t values (1, 'A'), (2, 'B');
insert into p1_aux values ('A', 'X'), ('Q', 'Q');
create view p1_v as select id as id, lbl as note from p1_t;

update p1_v set note = 'CHANGED' where exists (select 1 from p1_aux where k = note);
select id, lbl from p1_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (h) `where lbl = note`: the literal base name AND the substituted term collide ---
-- The literal `lbl` binds the subquery-local p2_aux.lbl (it is not a view column,
-- so it is never substituted); `note` is the view column = base p2_t.lbl. Without
-- qualification both collapse to p2_aux.lbl, making the predicate the always-true
-- p2_aux.lbl = p2_aux.lbl. The substituted term is qualified to p2_t.lbl, so the
-- predicate is the correlated p2_aux.lbl = p2_t.lbl -> only the matching row 1.
create table p2_t (id integer primary key, lbl text);
create table p2_aux (k text, lbl text);
insert into p2_t values (1, 'A'), (2, 'B');
insert into p2_aux values ('A', 'A'), ('Q', 'Q');
create view p2_v as select id as id, lbl as note from p2_t;

update p2_v set note = 'CHANGED' where exists (select 1 from p2_aux where lbl = note);
select id, lbl from p2_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (i) negative control on the BASE name: a bare base-name ref to a genuine
--          subquery-local source must STAY local (analogous to (c), on `lbl`) ---
-- The view renames base `lbl` to `note`; the EXISTS subquery source nc_src has its
-- OWN `lbl` column plus an `ok` flag. The bare `lbl` inside the subquery is
-- nc_src.lbl (never a view column, so never substituted/qualified); `note` is the
-- view column, qualified to the correlated nc_t.lbl. The predicate selects the
-- nc_src row whose lbl matches the outer row and tests its `ok`. If the fix wrongly
-- qualified the local `lbl` to nc_t.lbl, the predicate would degrade to the
-- always-true nc_t.lbl = nc_t.lbl and ok = 1 -> both rows would write.
create table nc_t (id integer primary key, lbl text);
create table nc_src (lbl text, ok integer);
insert into nc_t values (1, 'L1'), (2, 'L2');
insert into nc_src values ('L1', 1), ('L2', 0);
create view nc_v as select id as id, lbl as note from nc_t;

update nc_v set note = 'CHANGED' where exists (select 1 from nc_src where lbl = note and ok = 1);
select id, lbl from nc_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"L2"}]

-- --- (j) DELETE descent: same collision as (g) on the delete path ---
-- The delete rewrite threads the same base-table qualifier into the subquery
-- descent. The view renames base `lbl` to `note`; the EXISTS subquery FROM
-- (d1_aux) ALSO has an `lbl`. Without qualification the substituted base term
-- would re-bind to d1_aux.lbl, making the predicate the uncorrelated
-- d1_aux.k = d1_aux.lbl (true for ('Q','Q')) -> every outer row would delete (a
-- silent wrong delete). Qualified to d1_t.lbl, only the matching row 1 deletes.
create table d1_t (id integer primary key, lbl text);
create table d1_aux (k text, lbl text);
insert into d1_t values (1, 'A'), (2, 'B');
insert into d1_aux values ('A', 'X'), ('Q', 'Q');
create view d1_v as select id as id, lbl as note from d1_t;

delete from d1_v where exists (select 1 from d1_aux where k = note);
select id, lbl from d1_t order by id;
→ [{"id":2,"lbl":"B"}]

-- --- (k) computed lineage whose base term is itself a correlated subquery, the
--          DEEP collision: the substituted term must be qualified INSIDE its own
--          nested subquery, not just at its top level ---
-- The view column `note` is a correlated scalar subquery (select x from cv_oth
-- where fk = id); its correlation `id` is cv_base.id. Referenced inside the user
-- EXISTS subquery `select 1 from cv_src where tag = note` — and cv_src ALSO has an
-- `id` column — a SHALLOW qualifier left the lineage's own inner `id` unqualified,
-- so it re-bound to cv_src.id (=99); cv_oth has no fk=99, so `note` evaluated NULL
-- and the EXISTS was false for EVERY outer row (a silent no-op). The deep
-- scope-aware qualifier rewrites the term to (select x from cv_oth where fk =
-- cv_base.id), correlating to the outer target row regardless of the user FROM.
create table cv_base (id integer primary key, lbl text);
create table cv_oth (fk integer, x text);
create table cv_src (id integer, tag text);
insert into cv_base values (1, 'A'), (2, 'B');
insert into cv_oth values (1, 'AA'), (2, 'BB');
insert into cv_src values (99, 'AA');
create view cv_v as select id as id, lbl as lbl,
    (select x from cv_oth where fk = id) as note from cv_base;

update cv_v set lbl = 'CHANGED' where exists (select 1 from cv_src where tag = note);
-- cv_base.id=1 -> note 'AA', present in cv_src -> row 1 writes; id=2 -> 'BB', absent -> kept.
select id, lbl from cv_base order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (l) negative control — no over-qualify ---
-- Same computed-lineage view, but the user subquery FROM (cv_ok) has NO `id`, so
-- it does NOT shadow the lineage's correlation column. The lineage's genuinely-
-- local `fk` / `x` (owned by cv_oth, shadowed inside the lineage subquery, and not
-- base columns of cv_base) must stay local — if the deep qualifier wrongly
-- qualified them to cv_base.fk / cv_base.x the subquery would error (cv_base has no
-- such columns) or mis-evaluate. cv_ok holds only the row-1 match.
create table cv_ok (tag text);
insert into cv_ok values ('AA');

update cv_v set lbl = 'OK' where exists (select 1 from cv_ok where tag = note);
select id, lbl from cv_base order by id;
→ [{"id":1,"lbl":"OK"},{"id":2,"lbl":"B"}]

-- --- (m) DELETE variant — the delete path threads the same deep qualifier ---
-- The (k) repro shape on the delete path, confirming rewriteViewDelete threads the
-- correlation qualifier through its subquery descent too. Only row 1 deletes.
create table cd_base (id integer primary key, lbl text);
create table cd_oth (fk integer, x text);
create table cd_src (id integer, tag text);
insert into cd_base values (1, 'A'), (2, 'B');
insert into cd_oth values (1, 'AA'), (2, 'BB');
insert into cd_src values (99, 'AA');
create view cd_v as select id as id, lbl as lbl,
    (select x from cd_oth where fk = id) as note from cd_base;

delete from cd_v where exists (select 1 from cd_src where tag = note);
select id, lbl from cd_base order by id;
→ [{"id":2,"lbl":"B"}]

-- --- (n) lineage-subquery taint reject — unresolvable FROM *inside* the computed
--          lineage term itself (distinct from blocks (e)/(f), which taint the USER
--          subquery). The deep correlation-qualifier descends into the lineage
--          subquery and must prove which names its own FROM introduces in order to
--          know whether the bare `id` correlates out to the base row. The nested
--          `(select * from cn_oth)` source makes those names unresolvable, so the
--          qualifier rejects loudly rather than guess and risk a silent wrong write.
create table cn_base (id integer primary key, lbl text);
create table cn_oth (fk integer, x text);
create table cn_src (id integer, tag text);
insert into cn_base values (1, 'A');
create view cn_v as select id as id, lbl as lbl,
    (select x from (select * from cn_oth) as s where s.fk = id) as note from cn_base;

update cn_v set lbl = 'X' where exists (select 1 from cn_src where tag = note);
-- error: not statically resolvable

-- --- (o) the deep qualifier's SHADOW logic, isolated from its base-column gate ---
-- Blocks (k)/(l)/(m) only ever exercise the base-column GATE: the lineage subquery's
-- local columns (cv_oth.fk / .x) are excluded from qualification simply because they
-- are not columns of the base table. The `shadowed`-set accumulation inside
-- qualifyCorrelatedBaseRefsQuery is only the *deciding* factor when a lineage-local
-- column name ALSO collides with a base column name — then the base-column gate alone
-- would wrongly qualify it, and only the shadow set keeps it local. Here so_oth has
-- its own `id` (colliding with so_base.id). The lineage `(select x from so_oth where
-- link = k and id = 1)` filters so_oth by its OWN id (=1) and correlates on `k`. The
-- shadow set must keep `id` bound to so_oth.id (local literal filter) while qualifying
-- only `k` to so_base.k. If `id` were (wrongly) qualified to so_base.id, the local
-- `id = 1` filter would vanish (becoming the per-row-constant so_base.id = 1) and the
-- subquery would select so_oth's first link-matching row ('Q') instead of 'P' — so the
-- EXISTS against so_src(tag='P') would no longer match row 1. Asserts row 1 writes.
create table so_base (id integer primary key, k integer, lbl text);
create table so_oth (id integer, link integer, x text);
create table so_src (id integer, tag text);
insert into so_base values (1, 10, 'A'), (2, 20, 'B');
insert into so_oth values (3, 10, 'Q'), (1, 10, 'P');
insert into so_src values (99, 'P');
create view so_v as select id as id, k as k, lbl as lbl,
    (select x from so_oth where link = k and id = 1) as note from so_base;

update so_v set lbl = 'HIT' where exists (select 1 from so_src where tag = note);
-- base row1 (k=10): so_oth where link=10 and so_oth.id=1 -> 'P', matches so_src -> writes.
-- base row2 (k=20): no link=20 row -> note NULL -> kept.
select id, lbl from so_base order by id;
→ [{"id":1,"lbl":"HIT"},{"id":2,"lbl":"B"}]

-- ===================================
-- Phase 2b: Multi-source key-preserving inner-join INSERT (shared-surrogate
-- envelope). The shared join key is not a view column, so an insert mints a
-- surrogate ONCE per produced logical row at the envelope and threads the one
-- captured value into both base inserts (so the branches agree on identity).
-- Sides are written FK-parent-before-FK-child. See docs/view-updateability.md
-- § Inner Join (Inserts), § Mutation Context (the worked example + cadences).
-- ===================================

-- --- (a) the worked example: two base tables sharing a surrogate `rid` the view
--         hides; one minted `rid` per row, shared across both base inserts ---
create table u_core (rid integer primary key, name text);
create table u_contact (rid integer primary key, email text);
create view appuser as
    select c.name as name, k.email as email
    from u_core c join u_contact k on k.rid = c.rid;

insert into appuser (name, email) values ('Ada', 'ada@x.io'), ('Lin', 'lin@x.io');

-- Exactly one generation per row (rid 1 then 2), shared across both base inserts
-- of that row, distinct across rows.
select rid, name from u_core order by rid;
→ [{"rid":1,"name":"Ada"},{"rid":2,"name":"Lin"}]
select rid, email from u_contact order by rid;
→ [{"rid":1,"email":"ada@x.io"},{"rid":2,"email":"lin@x.io"}]

-- The write is visible through the view.
select name, email from appuser order by name;
→ [{"name":"Ada","email":"ada@x.io"},{"name":"Lin","email":"lin@x.io"}]

-- --- (b) the surrogate mints above existing keys; FK-parent inserted before the
--         FK-child, so the child's shared key references a parent that exists ---
create table msi_parent (pp integer primary key, pv integer null);
create table msi_child (cc integer primary key, pr integer null, cv integer null,
    foreign key (pr) references msi_parent(pp));
create view msi_jv as
    select c.cc as cc, c.cv as cv, p.pv as pv
    from msi_child c join msi_parent p on p.pp = c.pr;
-- a pre-existing parent so the minted surrogate must clear it.
insert into msi_parent values (40, 400);

insert into msi_jv (cc, cv, pv) values (1, 11, 111);
-- minted pp = max(40)+1 = 41, shared as msi_child.pr.
select pp, pv from msi_parent order by pp;
→ [{"pp":40,"pv":400},{"pp":41,"pv":111}]
select cc, pr, cv from msi_child order by cc;
→ [{"cc":1,"pr":41,"cv":11}]
select cc, cv, pv from msi_jv order by cc;
→ [{"cc":1,"cv":11,"pv":111}]

-- a multi-row insert mints a DISTINCT surrogate per row, each shared across both sides.
insert into msi_jv (cc, cv, pv) values (2, 22, 222), (3, 33, 333);
select pp, pv from msi_parent order by pp;
→ [{"pp":40,"pv":400},{"pp":41,"pv":111},{"pp":42,"pv":222},{"pp":43,"pv":333}]
select cc, pr, cv from msi_child order by cc;
→ [{"cc":1,"pr":41,"cv":11},{"cc":2,"pr":42,"cv":22},{"cc":3,"pr":43,"cv":33}]

-- --- (c) directly-supplied shared key: the view exposes the join key, so no
--         surrogate is minted — the supplied value threads to both sides ---
create table dk_a (k integer primary key, av text);
create table dk_b (k integer primary key, bv text);
create view dk_v as select m.k as k, m.av as av, s.bv as bv
    from dk_a m join dk_b s on s.k = m.k;

insert into dk_v (k, av, bv) values (7, 'a7', 'b7'), (9, 'a9', 'b9');
select k, av from dk_a order by k;
→ [{"k":7,"av":"a7"},{"k":9,"av":"a9"}]
select k, bv from dk_b order by k;
→ [{"k":7,"bv":"b7"},{"k":9,"bv":"b9"}]
select k, av, bv from dk_v order by k;
→ [{"k":7,"av":"a7","bv":"b7"},{"k":9,"av":"a9","bv":"b9"}]

-- --- (d) a NOT NULL base column with no default and no supplied value -> rejected ---
create table nd_main (k integer primary key, must_have text not null);
create table nd_side (k integer primary key, sv text);
create view nd_v as select m.k as k, s.sv as sv from nd_main m join nd_side s on s.k = m.k;
insert into nd_v (sv) values ('x');
-- error: no default

-- --- (e) a computed (non-invertible) target column is not insertable ---
create table cm_a (k integer primary key, av integer);
create table cm_b (k integer primary key, bv integer);
create view cm_v as select a.k as k, a.av + 1 as bumped, b.bv as bv
    from cm_a a join cm_b b on b.k = a.k;
insert into cm_v (bumped, bv) values (5, 6);
-- error: non-invertible

-- --- (f) the shared key exposed by more than one view column (both sides of the
--         equi-join key) is over-specified: an insert cannot honor divergent
--         supplied values, so it is rejected rather than silently dropping one ---
create table bk_a (k integer primary key, av text);
create table bk_b (k integer primary key, bv text);
create view bk_v as select a.k as ka, b.k as kb, a.av as av, b.bv as bv
    from bk_a a join bk_b b on b.k = a.k;
insert into bk_v (ka, kb, av, bv) values (5, 7, 'a', 'b');
-- error: shared join key is exposed by more than one view column

-- ===================================
-- RETURNING through a view (single- and multi-source).
-- The returned rows are projected through the VIEW's column list (not the base
-- tables'), evaluated against the post-mutation base state — so a computed view
-- column re-evaluates against the post-mutation base values, a renamed view column
-- keeps its view-spelling, and `returning *` expands to the view's columns.
-- See docs/view-updateability.md § `returning` Clauses.
-- ===================================

-- --- (a) single-source: rename + computed view columns, all three ops ---
-- empv renames base id/name, exposes base rate, and a computed `doubled` = rate*2.
create table emp (id integer primary key, name text, rate integer);
create view empv as
    select id as eid, name as ename, rate as ratev, rate * 2 as doubled from emp;
-- run

-- INSERT returns the view-projected NEW row; `doubled` evaluated post-insert.
insert into empv (eid, ename, ratev) values (1, 'Ann', 5)
    returning eid, ename, ratev, doubled;
→ [{"eid":1,"ename":"Ann","ratev":5,"doubled":10}]

-- UPDATE returns the view-projected NEW row; `doubled` re-evaluated post-update.
update empv set ratev = 7 where eid = 1 returning eid, ratev, doubled;
→ [{"eid":1,"ratev":7,"doubled":14}]

-- a multi-row insert returns one row per inserted row, in insertion order; the
-- computed column is evaluated per row.
insert into empv (eid, ename, ratev) values (2, 'B', 1), (3, 'C', 2)
    returning eid, doubled;
→ [{"eid":2,"doubled":2},{"eid":3,"doubled":4}]

-- DELETE returns the view-projected OLD (deleted) row; computed col over OLD vals.
delete from empv where eid = 1 returning eid, ename, doubled;
→ [{"eid":1,"ename":"Ann","doubled":14}]

-- the surviving rows confirm only eid=1 was deleted.
select eid, ratev from empv order by eid;
→ [{"eid":2,"ratev":1},{"eid":3,"ratev":2}]

-- --- (b) single-source filter view: a selection-predicate default appears in
--         RETURNING (the appended constant is part of the inserted NEW row), and
--         `returning *` expands to the view's column list ---
create table men2 (name text primary key, color text);
create view greenmen2 as select name, color from men2 where color = 'green';
-- run

insert into greenmen2 (name) values ('Bob') returning name, color;
→ [{"name":"Bob","color":"green"}]

insert into greenmen2 (name) values ('Carl') returning *;
→ [{"name":"Carl","color":"green"}]

-- --- (c) multi-source inner-join: update/delete RETURNING returns the joined,
--         view-projected rows (a re-query of the view; update reads the
--         post-mutation image, delete captures the pre-delete image) ---
create table rp (pid integer primary key, label text);
create table rc (cid integer primary key, pref integer, note text,
    foreign key (pref) references rp(pid));
insert into rp values (10, 'P10'), (20, 'P20');
insert into rc values (1, 10, 'a'), (2, 20, 'b');
create view rjoin as
    select c.cid as cid, c.note as note, p.label as label
    from rc c join rp p on p.pid = c.pref;
-- run

-- update a child-owned column; the returned view row reflects the post-update note.
update rjoin set note = 'A' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10"}]

-- update a parent-owned column (label is owned by rp, whose PK the projection
-- hides — identified through the join); the returned view row reflects it.
update rjoin set label = 'P20x' where cid = 2 returning cid, note, label;
→ [{"cid":2,"note":"b","label":"P20x"}]

-- update touching BOTH sides; the re-query returns the fully post-mutation row.
update rjoin set note = 'Z', label = 'P10z' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"Z","label":"P10z"}]

-- `returning *` through the join view expands to the view's columns.
delete from rjoin where cid = 1 returning *;
→ [{"cid":1,"note":"Z","label":"P10z"}]

-- the delete removed only the cid=1 child row; cid=2 remains.
select cid, note, label from rjoin order by cid;
→ [{"cid":2,"note":"b","label":"P20x"}]

-- --- (d) multi-source update RETURNING where the predicate filters on a column the
--         update rewrites — per-row identity capture (the changed rows no longer
--         match the predicate, but their captured identity does). Two children per
--         parent so a parent-side update returns multiple rows; ascending memory-vtab
--         scan order is deterministic. See docs/view-updateability.md § `returning`.
create table rp2 (pid integer primary key, label text);
create table rc2 (cid integer primary key, pref integer, note text,
    foreign key (pref) references rp2(pid));
insert into rp2 values (10, 'P10'), (20, 'P20');
insert into rc2 values (1, 10, 'a'), (2, 10, 'a'), (3, 20, 'b');
create view rjoin2 as
    select c.cid as cid, c.note as note, p.label as label
    from rc2 c join rp2 p on p.pid = c.pref;
-- run

-- predicate on the rewritten CHILD column: cid 1,2 (note='a') update to 'A'.
update rjoin2 set note = 'A' where note = 'a' returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10"},{"cid":2,"note":"A","label":"P10"}]

-- predicate on a PARENT-owned column the update rewrites (label='P10' → pid 10 →
-- children 1,2). Parent label becomes 'PX'; both children re-projected.
update rjoin2 set label = 'PX' where label = 'P10' returning cid, note, label;
→ [{"cid":1,"note":"A","label":"PX"},{"cid":2,"note":"A","label":"PX"}]

-- BOTH sides assigned (child note + parent label), predicated on the PARENT's
-- reassigned column (`label = 'PX'`) — the clash this fix closes. The FK-parent op
-- rewrites `label` before the FK-child op's identifying subquery runs, so a live
-- re-query of the join body would find no 'PX' row and the child side would silently
-- no-op; the up-front identity capture pins cid 1,2 so BOTH per-side ops land and the
-- re-query re-projects the fully post-mutation rows.
update rjoin2 set note = 'B', label = 'PY' where label = 'PX' returning cid, note, label;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":2,"note":"B","label":"PY"}]

-- BOTH sides assigned, predicated on the CHILD column the update also rewrites
-- (`note = 'B'` → 'C', plus `label` → 'PZ'); the capture identifies cid 1,2 the same
-- way regardless of which side's reassigned column the predicate filters on.
update rjoin2 set note = 'C', label = 'PZ' where note = 'B' returning cid, note, label;
→ [{"cid":1,"note":"C","label":"PZ"},{"cid":2,"note":"C","label":"PZ"}]

-- `returning *` through the join update, single-side child predicate-clash.
update rjoin2 set note = 'E' where note = 'C' returning *;
→ [{"cid":1,"note":"E","label":"PZ"},{"cid":2,"note":"E","label":"PZ"}]

-- --- (e) multi-source update RETURNING edge cases: push-out-of-filter (NEW
--         semantics), renamed + computed view columns through the capture re-query
--         projection, and empty-match. See docs/view-updateability.md § `returning`.

-- push-out-of-filter: a join view WITH a body WHERE. An update that moves a row
-- OUT of the view's filter must still be RETURNED (the capture matches by identity,
-- not the now-stale predicate — single-source NEW semantics; the re-query does not
-- re-apply the body/user WHERE).
create table fp (pid integer primary key, label text);
create table fc (cid integer primary key, pref integer, note text,
    foreign key (pref) references fp(pid));
insert into fp values (10, 'P10');
insert into fc values (1, 10, 'keep'), (2, 10, 'keep');
create view fjoin as
    select c.cid as cid, c.note as note, p.label as label
    from fc c join fp p on p.pid = c.pref where c.note = 'keep';
-- run

update fjoin set note = 'gone' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"gone","label":"P10"}]

-- the row is now out of the view filter (note != 'keep'), so the view no longer
-- shows it; only cid=2 remains visible.
select cid, note, label from fjoin order by cid;
→ [{"cid":2,"note":"keep","label":"P10"}]

-- renamed (id←cid, quantity←qty, label←lbl) + computed (dbl = qty*2) view columns
-- surface under their VIEW spelling, computed re-evaluated post-update.
create table rp3 (pid integer primary key, lbl text);
create table rc3 (cid integer primary key, pref integer, qty integer,
    foreign key (pref) references rp3(pid));
insert into rp3 values (10, 'P10');
insert into rc3 values (1, 10, 5);
create view rjoin3 as
    select c.cid as id, c.qty as quantity, c.qty * 2 as dbl, p.lbl as label
    from rc3 c join rp3 p on p.pid = c.pref;
-- run

update rjoin3 set quantity = 8 where id = 1 returning id, quantity, dbl, label;
→ [{"id":1,"quantity":8,"dbl":16,"label":"P10"}]

-- empty match returns an empty set (EXISTS over zero captured identities), not an error.
update rjoin3 set quantity = 9 where id = 999 returning id, quantity;
→ []

-- ===================================
-- Top-level view-column scope (the encapsulation guard). A `where` / `set` /
-- `returning` reference must name a column the VIEW exposes; a base-only column the
-- view projects away must NOT silently resolve against the underlying base table.
-- See docs/view-updateability.md § Selection (Top-level view-column scope).
-- ===================================

create table t3 (id integer primary key, shown text not null, secret text);
create view sv as select id, shown from t3;          -- view exposes only (id, shown)
insert into t3 values (1, 'a', 'classified-1'), (2, 'b', 'classified-2');

-- (1) RETURNING leak: `secret` is a base-only column projected away by the view.
insert into sv (id, shown) values (3, 'g') returning id, secret;
-- error: not a column of the view

-- (2) WHERE leak: filtering on the projected-away base column.
update sv set shown = 'X' where secret = 'classified-2';
-- error: not a column of the view

-- (3) SET leak: assigning the projected-away base column.
update sv set secret = 'leaked' where id = 1;
-- error: not a column of the view

-- view-qualified reference to a projected-away base column rejects too.
update sv set shown = 'X' where sv.secret = 'classified-2';
-- error: not a column of the view

-- positive: where / set / returning on real view columns still succeed.
update sv set shown = 'Y' where id = 1 returning id, shown;
→ [{"id":1,"shown":"Y"}]
delete from sv where shown = 'b' returning id;
→ [{"id":2}]
select id, shown, secret from t3 order by id;
→ [{"id":1,"shown":"Y","secret":"classified-1"}]

-- renamed view column: the view spelling `note` is accepted; the base spelling
-- `label` is rejected (a renamed column's only legal reference is its view name).
create table pt (id integer primary key, label text);
insert into pt values (1, 'L1'), (2, 'L2');
create view pv as select id, label as note from pt;

update pv set note = 'L1x' where note = 'L1' returning id, note;
→ [{"id":1,"note":"L1x"}]

-- the base spelling `label` is not a view column -> rejected on where / set / returning.
update pv set note = 'Z' where label = 'L2';
-- error: not a column of the view
update pv set label = 'Z' where id = 2;
-- error: not a column of the view
insert into pv (id, note) values (3, 'L3') returning id, label;
-- error: not a column of the view

-- computed view column: it IS a view column, so `returning <computed>` reads it,
-- but `set <computed>` still yields the existing no-inverse diagnostic (NOT the
-- unknown-view-column guard — the column exists, it is just not writable).
create table ct (id integer primary key, qty integer);
insert into ct values (1, 5);
create view cvv as select id, qty, qty * 2 as dbl from ct;

update cvv set qty = 7 where id = 1 returning id, qty, dbl;
→ [{"id":1,"qty":7,"dbl":14}]
update cvv set dbl = 99 where id = 1;
-- error: read-only

-- parity: a multi-source (join) view rejects an unknown top-level column the SAME
-- way (the guard reads consistently across the single- and multi-source spines).
create table jp (pid integer primary key, plabel text);
create table jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references jp(pid));
insert into jp values (10, 'P10');
insert into jc values (1, 10, 'a');
create view jvscope as select c.cid as cid, c.note as note from jc c join jp p on p.pid = c.pref;

-- `plabel` is a base column owned by jp but projected away — not a view column.
update jvscope set note = 'X' where plabel = 'P10';
-- error: not a column of the view
delete from jvscope where plabel = 'P10';
-- error: not a column of the view
-- a SET target that is not a view column at all (vs. a computed one) -> same guard.
update jvscope set plabel = 'Z' where cid = 1;
-- error: not a column of the view

-- a multi-source UPDATE … RETURNING projecting a base-only column (the re-query
-- projects over the join body) is guarded the same way.
update jvscope set note = 'Y' where cid = 1 returning cid, plabel;
-- error: not a column of the view
