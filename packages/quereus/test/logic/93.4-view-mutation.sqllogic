-- View updateability — Phase 1 + 1b working cases.
-- Single-source projection-and-filter views are writeable; writes route to the
-- base table. See docs/view-updateability.md.

-- ===================================
-- GreenMen: constant-FD default from the selection predicate (select *)
-- ===================================

create table Men (Name text primary key, Color text);
create view GreenMen as select * from Men where Color = 'green';

insert into GreenMen (Name) values ('Bob');

select * from Men order by Name;
→ [{"Name":"Bob","Color":"green"}]

select * from GreenMen order by Name;
→ [{"Name":"Bob","Color":"green"}]

-- ===================================
-- AdultsBare: constant-FD default for a projected-away column
-- ===================================

create table Adults (Name text primary key, Age integer, Country text);
create view AdultsBare as select Name, Age from Adults where Country = 'US';

insert into AdultsBare values ('Bob', 30);

select * from Adults order by Name;
→ [{"Name":"Bob","Age":30,"Country":"US"}]

select * from AdultsBare order by Name;
→ [{"Name":"Bob","Age":30}]

-- ===================================
-- Base-column default survives projection
-- ===================================

create table u (id integer primary key, name text default 'unknown');
create view uv as select id from u;

insert into uv values (5);

select * from u order by id;
→ [{"id":5,"name":"unknown"}]

-- ===================================
-- Rename projection
-- ===================================

create table users (id integer primary key, name text);
create view RV as select id as user_id, name as full_name from users;

insert into RV (user_id, full_name) values (1, 'Bob');

select * from users order by id;
→ [{"id":1,"name":"Bob"}]

select * from RV order by user_id;
→ [{"user_id":1,"full_name":"Bob"}]

-- ===================================
-- Single-source INVERSE-profile column write-through. `bp = b + 1` is a
-- non-identity invertible projection of iv_t.b; the single-source UPDATE path now
-- consumes the threaded `inverse` (parity with the multi-source join path), so
-- `update v set bp = 9` lowers to `set b = 9 - 1`, storing iv_t.b = 8, and the view
-- reads back bp = 9. An `opaque` computed column (`substr(s,1,1)` — string functions
-- carry no inverse profile) stays read-only, and the inverse column is NOT insertable
-- (an UPDATE-only claim). This matches the static column_info/view_info
-- is_updatable='YES'. See docs/view-updateability.md § Scalar Invertibility.
-- ===================================

create table iv_t (id integer primary key, b integer null, s text);
insert into iv_t values (1, 7, 'hello'), (2, 20, 'world');
create view iv_v as select id, b + 1 as bp, substr(s, 1, 1) as s1 from iv_t;

-- read-through: bp = b + 1, s1 = first char.
select id, bp, s1 from iv_v order by id;
→ [{"id":1,"bp":8,"s1":"h"},{"id":2,"bp":21,"s1":"w"}]

-- UPDATE the inverse column: `bp = 9` lowers to `b = 9 - 1`, storing iv_t.b = 8.
update iv_v set bp = 9 where id = 1;
select id, b, s from iv_t order by id;
→ [{"id":1,"b":8,"s":"hello"},{"id":2,"b":20,"s":"world"}]

-- the write reads back through the forward transform: bp = 8 + 1 = 9.
select id, bp from iv_v order by id;
→ [{"id":1,"bp":9},{"id":2,"bp":21}]

-- the inverse is applied AFTER base-term substitution: `bp = id + 100` (id is a view
-- column) lowers to `b = (id + 100) - 1`, so for id=2 it stores b = 101.
update iv_v set bp = id + 100 where id = 2;
select id, b from iv_t order by id;
→ [{"id":1,"b":8},{"id":2,"b":101}]

-- the opaque computed column stays read-only (a string fn has no inverse profile).
update iv_v set s1 = 'X' where id = 1;
-- error: read-only

-- INSERT admits the inverse-ABSENT subset (identity + passthrough) but NOT an inverse
-- column: an explicit insert of the inverse `bp` is rejected (non-insertable even though
-- is_updatable='YES' — the envelope would store the value raw, with no hook to invert it).
insert into iv_v (id, bp) values (3, 5);
-- error: non-invertible

-- ===================================
-- Conflicting base-column assignments. An UPDATE that lands two SET targets on one
-- base column is rejected unconditionally (no value-agreement softening), whether
-- the duplication is direct, via an inverse-vs-base pair (`b`, `b+1 as bp`), or via a
-- duplicate rename (`b`, `b as b2`). The single-source spine surfaces a view-aware
-- message naming BOTH colliding view columns; the multi-source (join) spine falls
-- back to the base builder's generic "duplicate assignment" backstop (which sees only
-- base names). See docs/view-updateability.md § Diagnostics.
-- ===================================

create table cfl_t (id integer primary key, b integer null);
insert into cfl_t values (1, 99), (2, 50);

-- inverse-vs-base: `b` and `b + 1 as bp` both lower to base column b.
create view cfl_inv as select id, b, b + 1 as bp from cfl_t;
update cfl_inv set b = 5, bp = 100 where id = 1;
-- error: both target base column

-- the rejected UPDATE made no change (b stays 99, not last-wins 99 or 5).
select id, b from cfl_t order by id;
→ [{"id":1,"b":99},{"id":2,"b":50}]

-- duplicate rename: `b` and `b as b2` both lower to base column b.
create view cfl_dup as select id, b, b as b2 from cfl_t;
update cfl_dup set b = 1, b2 = 2 where id = 1;
-- error: both target base column

-- same-value collision still rejects (documents the no-softening semantics).
update cfl_dup set b = 5, b2 = 5 where id = 1;
-- error: both target base column

-- INSERT analogue: cfl_dup's `b` and `b2` both lower to base column b, so an
-- insert supplying both lands a duplicate base column in the single-source
-- spine's rewritten column list. It re-plans through the base builder and is
-- rejected by the generic "specified more than once" backstop (which names the
-- base column) — the INSERT dual of the multi-source UPDATE fallback above. See
-- ticket insert-family-duplicate-column-targets-silent-last-wins.
insert into cfl_dup (id, b, b2) values (3, 5, 6);
-- error: specified more than once

-- the rejected insert made no change (no id=3 row).
select id, b from cfl_t order by id;
→ [{"id":1,"b":99},{"id":2,"b":50}]

-- multi-source (join) same-side collision: `note` and `note collate nocase as note2`
-- both own the child base column note. The join spine routes both to the child's
-- per-base UPDATE, which the base builder re-plans and rejects via the generic backstop.
create table cfl_p (pid integer primary key, label text);
create table cfl_c (cid integer primary key, pref integer, note text,
    foreign key (pref) references cfl_p(pid));
insert into cfl_p values (1, 'p1');
insert into cfl_c values (10, 1, 'alpha');
create view cfl_jv as
    select c.cid as cid, c.note as note, c.note collate nocase as note2
    from cfl_c c join cfl_p p on p.pid = c.pref;
update cfl_jv set note = 'x', note2 = 'y' where cid = 10;
-- error: duplicate assignment

-- ===================================
-- Single-source PASSTHROUGH-profile column write-through. `bc = b collate nocase`
-- and `nc = cast(n as integer)` (a no-op cast, same logical type) are identity-ON-VALUE
-- projections of pt_t's base columns. The single-source UPDATE path routes the FULL
-- writable-base set (identity + passthrough + inverse), so `update v set bc = V` lowers to
-- `set b = V`, storing the value VERBATIM (no inverse to apply), and the view reads it back
-- through the value-preserving transform. INSERT now consults the same writable-site map and
-- ALSO admits a passthrough column (stored verbatim) — aligning the single-source spine up to
-- the multi-source contract. An `opaque` computed column (`b || '!'` — concat carries no
-- inverse profile) stays read-only AND non-insertable. This matches the static
-- column_info/view_info is_updatable='YES'. See docs/view-updateability.md § Scalar Invertibility.
-- ===================================

create table pt_t (id integer primary key, b text null, n integer null);
insert into pt_t values (1, 'hi', 5), (2, 'world', 20);
create view pt_v2 as select id, b collate nocase as bc, cast(n as integer) as nc, b || '!' as bo from pt_t;

-- read-through: bc = b, nc = n, bo = b || '!'.
select id, bc, nc, bo from pt_v2 order by id;
→ [{"id":1,"bc":"hi","nc":5,"bo":"hi!"},{"id":2,"bc":"world","nc":20,"bo":"world!"}]

-- UPDATE the collate passthrough: `bc = 'yo'` lowers to `b = 'yo'`, stored verbatim.
update pt_v2 set bc = 'yo' where id = 1;
select id, b, n from pt_t order by id;
→ [{"id":1,"b":"yo","n":5},{"id":2,"b":"world","n":20}]

-- UPDATE the no-op-cast passthrough: `nc = 99` lowers to `n = 99`, stored verbatim.
update pt_v2 set nc = 99 where id = 2;
select id, b, n from pt_t order by id;
→ [{"id":1,"b":"yo","n":5},{"id":2,"b":"world","n":99}]

-- the writes read back through the value-preserving forward transform.
select id, bc, nc from pt_v2 order by id;
→ [{"id":1,"bc":"yo","nc":5},{"id":2,"bc":"world","nc":99}]

-- the opaque computed column stays read-only (concat has no inverse profile).
update pt_v2 set bo = 'X' where id = 1;
-- error: read-only

-- INSERT a passthrough column on the single-source spine: now ADMITTED (this ticket aligns
-- single-source INSERT up to the multi-source contract). `bc` is a passthrough of base `b`,
-- so the value is stored VERBATIM; the omitted `nc` base column `n` is nullable and takes null.
-- At this point pt_t = (1,'yo',5),(2,'world',99).
insert into pt_v2 (id, bc) values (3, 'new');
select id, b, n from pt_t order by id;
→ [{"id":1,"b":"yo","n":5},{"id":2,"b":"world","n":99},{"id":3,"b":"new","n":null}]

-- read back through the view: bc reads 'new' verbatim; nc is null; bo recomputes b || '!'.
select id, bc, nc, bo from pt_v2 order by id;
→ [{"id":1,"bc":"yo","nc":5,"bo":"yo!"},{"id":2,"bc":"world","nc":99,"bo":"world!"},{"id":3,"bc":"new","nc":null,"bo":"new!"}]

-- IMPLICIT insert (no column list): the insertable set is (id, bc, nc) in view order — the
-- opaque computed column `bo` (no base lineage) is OMITTED rather than erroring, proving the
-- implicit-set alignment with multi-source. The two passthrough columns store verbatim.
insert into pt_v2 values (4, 'imp', 7);
select id, b, n from pt_t order by id;
→ [{"id":1,"b":"yo","n":5},{"id":2,"b":"world","n":99},{"id":3,"b":"new","n":null},{"id":4,"b":"imp","n":7}]
select id, bc, nc, bo from pt_v2 order by id;
→ [{"id":1,"bc":"yo","nc":5,"bo":"yo!"},{"id":2,"bc":"world","nc":99,"bo":"world!"},{"id":3,"bc":"new","nc":null,"bo":"new!"},{"id":4,"bc":"imp","nc":7,"bo":"imp!"}]

-- Filtered view + passthrough: the writable-site SET routing is orthogonal to the
-- conjoined body WHERE, so the filter still gates a passthrough write exactly as it
-- does a rename write (cf. AliasView). At this point pt_t =
-- (1,'yo',5),(2,'world',99),(3,'new',null),(4,'imp',7) (after the inserts above).
create view pt_vf as select id, b collate nocase as bc from pt_t where n > 10;

-- a visible row (id=2, n=99 > 10): the passthrough write lands in the base column.
update pt_vf set bc = 'zz' where id = 2;
select id, b from pt_t order by id;
→ [{"id":1,"b":"yo"},{"id":2,"b":"zz"},{"id":3,"b":"new"},{"id":4,"b":"imp"}]

-- a row outside the filter (id=1, n=5): the conjoined predicate matches no base row.
update pt_vf set bc = 'nope' where id = 1;
select id, b from pt_t order by id;
→ [{"id":1,"b":"yo"},{"id":2,"b":"zz"},{"id":3,"b":"new"},{"id":4,"b":"imp"}]

-- ===================================
-- Single-source ↔ multi-source parity for a PASSTHROUGH (collate) column. The same
-- `note collate nocase as note` projection of a base column is writable on BOTH mutation
-- spines: through a single-source view over one table, AND through a two-table inner-join
-- view. Confirms the two spines agree on an identical passthrough projection — the
-- single↔multi divergence this ticket closes. docs § Scalar Invertibility, § Inner Join.
-- ===================================

create table par_p (pid integer primary key, label text);
create table par_c (cid integer primary key, pref integer, note text,
    foreign key (pref) references par_p(pid));
insert into par_p values (1, 'p1');
insert into par_c values (10, 1, 'alpha');

-- single-source view over par_c: the `note collate nocase` passthrough is writable.
create view par_ss as select cid, note collate nocase as note from par_c;
update par_ss set note = 'BETA' where cid = 10;
select cid, note from par_c order by cid;
→ [{"cid":10,"note":"BETA"}]

-- two-table inner-join view with the SAME passthrough projection: also writable.
create view par_mj as
    select c.cid as cid, c.note collate nocase as note, p.label as label
    from par_c c join par_p p on p.pid = c.pref;
update par_mj set note = 'gamma' where cid = 10;
select cid, note from par_c order by cid;
→ [{"cid":10,"note":"gamma"}]

-- ===================================
-- Single-source ↔ multi-source parity for a PASSTHROUGH (collate) column on INSERT.
-- The same `note collate nocase` passthrough is INSERTABLE on BOTH spines now — stored
-- VERBATIM — closing the single↔multi INSERT divergence this ticket targets (previously
-- single-source rejected the passthrough insert while multi-source admitted it). Fresh
-- tables keep the inserts free of the par_ss/par_mj seed rows above. An inverse-column
-- insert still rejects on single-source (the iv_v block, lines ~100), so the alignment is
-- precisely the inverse-absent subset. docs § Scalar Invertibility, § Inner Join.
-- ===================================

-- single-source: the passthrough `note` is inserted and stored verbatim in the base column.
create table pari_t (id integer primary key, note text);
create view pari_ss as select id, note collate nocase as note from pari_t;
insert into pari_ss (id, note) values (1, 'Alpha');
select id, note from pari_t order by id;
→ [{"id":1,"note":"Alpha"}]

-- two-table inner-join view exposing the SAME passthrough plus a directly-supplied shared
-- key: the passthrough `note` is likewise inserted verbatim into its owning base side.
create table pari_a (k integer primary key, note text);
create table pari_b (k integer primary key, bv text);
create view pari_mj as
    select a.k as k, a.note collate nocase as note, b.bv as bv
    from pari_a a join pari_b b on b.k = a.k;
insert into pari_mj (k, note, bv) values (1, 'Beta', 'x');
select k, note from pari_a order by k;
→ [{"k":1,"note":"Beta"}]
select k, bv from pari_b order by k;
→ [{"k":1,"bv":"x"}]
select k, note, bv from pari_mj order by k;
→ [{"k":1,"note":"Beta","bv":"x"}]

-- ===================================
-- Filter pass-through delete
-- ===================================

create table acct (id integer primary key, active integer, label text);
insert into acct values (5, 1, 'a'), (6, 0, 'b'), (7, 1, 'c');
create view ActiveUsers as select * from acct where active = 1;

delete from ActiveUsers where id = 5;

select id, active, label from acct order by id;
→ [{"id":6,"active":0,"label":"b"},{"id":7,"active":1,"label":"c"}]

-- ===================================
-- Filter pass-through update (the selection predicate is conjoined into WHERE)
-- ===================================

-- id=7 is visible (active=1): the update applies.
update ActiveUsers set label = 'C' where id = 7;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- id=6 is NOT visible (active=0): the conjoined predicate matches no base row.
update ActiveUsers set label = 'X' where id = 6;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- ===================================
-- Aliased base table + alias-qualified filter/projection: the alias qualifier
-- is normalized away when threading the body predicate into the base statement.
-- ===================================

create table al (id integer primary key, active integer, label text);
insert into al values (1, 1, 'a'), (2, 0, 'b'), (3, 1, 'c');
create view AliasView as select x.id as aid, x.label as alabel from al as x where x.active = 1;

-- visible row (active=1): update applies through the alias-qualified predicate.
update AliasView set alabel = 'Z' where aid = 1;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

-- invisible row (active=0): conjoined alias predicate matches no base row.
update AliasView set alabel = 'X' where aid = 2;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

delete from AliasView where aid = 3;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"}]

-- ===================================
-- Phase 1b: per-statement mutation context threaded through the view
-- (one captured value stamped onto every row of the statement).
-- ===================================

create table evt (id integer primary key, created integer default now_ms) using memory with context (now_ms integer);
create view evt_v as select id from evt;

insert into evt_v with context now_ms = 12345 values (1), (2);

select * from evt order by id;
→ [{"id":1,"created":12345},{"id":2,"created":12345}]

-- ===================================
-- Phase 2: Multi-source key-preserving inner join — update / delete write-through.
-- The body is a two-table inner equi-join; writes route per owning base side via
-- a subquery over the join body (the row-identifying predicate). The owning side
-- can be the table whose PK the projection hides (ms_parent below).
-- See docs/view-updateability.md § Inner Join, § Multi-Base-Table Mutations.
-- ===================================

create table ms_parent (pid integer primary key, label text);
create table ms_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ms_parent(pid));
insert into ms_parent values (10, 'P10'), (20, 'P20');
insert into ms_child values (1, 10, 'a'), (2, 10, 'b'), (3, 20, 'c');

create view ms_jv as
    select c.cid as cid, c.note as note, p.label as label
    from ms_child c join ms_parent p on p.pid = c.pref;

-- read-through over the join
select * from ms_jv order by cid;
→ [{"cid":1,"note":"a","label":"P10"},{"cid":2,"note":"b","label":"P10"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE routed to the child side only (note is owned by ms_child).
update ms_jv set note = 'A' where cid = 1;
select cid, pref, note from ms_child order by cid;
→ [{"cid":1,"pref":10,"note":"A"},{"cid":2,"pref":10,"note":"b"},{"cid":3,"pref":20,"note":"c"}]

-- UPDATE routed to the parent side (label is owned by ms_parent, whose PK is
-- hidden by the projection — identified through the join). cid=1 joins pid=10.
update ms_jv set label = 'P10x' where cid = 1;
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20"}]

-- the parent update is visible to every child row joining pid=10.
select * from ms_jv order by cid;
→ [{"cid":1,"note":"A","label":"P10x"},{"cid":2,"note":"b","label":"P10x"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE touching BOTH sides -> two ordered base ops (FK-parent before FK-child).
update ms_jv set note = 'C', label = 'P20x' where cid = 3;
select cid, note from ms_child order by cid;
→ [{"cid":1,"note":"A"},{"cid":2,"note":"b"},{"cid":3,"note":"C"}]
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20x"}]

-- DELETE routes to the FK-many (child) side by default; the parent stays in place.
delete from ms_jv where cid = 2;
select cid from ms_child order by cid;
→ [{"cid":1},{"cid":3}]
select pid from ms_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- the deleted child row is gone from the view.
select cid from ms_jv order by cid;
→ [{"cid":1},{"cid":3}]

-- BOTH-sides update predicated on the FK-PARENT's reassigned column, NO RETURNING —
-- the base-decomposition ordering clash. The FK-parent op runs first and rewrites
-- `label`; a live re-query of the join body would then find no 'P10' row, so the
-- FK-child op's identifying subquery would match nothing and silently drop the child
-- update. The up-front identity capture pins children 1,2 before any base op mutates,
-- so BOTH sides land. See view-mutation-multisource-both-sides-predicate-clash.
create table pc_parent (pid integer primary key, label text);
create table pc_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references pc_parent(pid));
insert into pc_parent values (10, 'P10'), (20, 'P20');
insert into pc_child values (1, 10, 'a'), (2, 10, 'a'), (3, 20, 'b');
create view pc_jv as
    select c.cid as cid, c.note as note, p.label as label
    from pc_child c join pc_parent p on p.pid = c.pref;

update pc_jv set note = 'B', label = 'PY' where label = 'P10';
-- children 1,2 (pref 10) get note 'B'; parent 10 gets label 'PY' — neither dropped.
select cid, note from pc_child order by cid;
→ [{"cid":1,"note":"B"},{"cid":2,"note":"B"},{"cid":3,"note":"b"}]
select pid, label from pc_parent order by pid;
→ [{"pid":10,"label":"PY"},{"pid":20,"label":"P20"}]
select cid, note, label from pc_jv order by cid;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":2,"note":"B","label":"PY"},{"cid":3,"note":"b","label":"P20"}]

-- BOTH-sides predicate clash through a view whose BODY carries its own WHERE.
-- The capture's identifying predicate is (user WHERE ∧ body WHERE), evaluated
-- BEFORE any base op mutates, so the body filter applies to the pre-mutation image.
-- bw_child 2 is hidden (active=0) yet shares parent pid 10 with the visible cid 1:
-- the capture pins per-CHILD-PK (only cid 1), so the FK-parent op rewriting `label`
-- on pid 10 leaves cid 2's note untouched even though both children share that parent.
create table bw_parent (pid integer primary key, label text);
create table bw_child (cid integer primary key, pref integer, note text, active integer,
    foreign key (pref) references bw_parent(pid));
insert into bw_parent values (10, 'P10'), (20, 'P20');
insert into bw_child values (1, 10, 'a', 1), (2, 10, 'a', 0), (3, 20, 'b', 1);
create view bw_jv as
    select c.cid as cid, c.note as note, p.label as label
    from bw_child c join bw_parent p on p.pid = c.pref
    where c.active = 1;

update bw_jv set note = 'B', label = 'PY' where label = 'P10';
-- Visible row matching label='P10' is only cid 1; cid 2 (active=0) is outside the
-- body filter so it is not captured and keeps note 'a'.
select cid, note from bw_child order by cid;
→ [{"cid":1,"note":"B"},{"cid":2,"note":"a"},{"cid":3,"note":"b"}]
select pid, label from bw_parent order by pid;
→ [{"pid":10,"label":"PY"},{"pid":20,"label":"P20"}]
select cid, note, label from bw_jv order by cid;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":3,"note":"b","label":"P20"}]

-- ===================================
-- Multi-source rejections (still diagnosed-and-rejected this phase).
-- ===================================

-- A computed (non-invertible) join column is read-only.
create view ms_jv_c as
    select c.cid as cid, p.label || '!' as banner
    from ms_child c join ms_parent p on p.pid = c.pref;
update ms_jv_c set banner = 'z' where cid = 1;
-- error: read-only

-- RETURNING through a multi-source (join) delete is SHIPPED. The view row spans
-- both base tables, so it is produced by a re-query of the view captured BEFORE
-- the base delete fires; the deleted view-projected row is returned. (cid=1 joins
-- pid=10 → label 'P10x' from the earlier parent update; note 'A' from the child
-- update.)
delete from ms_jv where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10x"}]

-- ===================================
-- Phase 2: adversarial coverage (qualifier rewriting, body-WHERE conjunction,
-- column-list overrides, and the remaining shape rejections).
-- ===================================

create table ax_parent (pid integer primary key, pv integer);
create table ax_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ax_parent(pid));
insert into ax_parent values (10, 100), (20, 200);
insert into ax_child values (1, 10, 'a'), (2, 20, 'b');

-- Swapped projection: the view column `pv` maps to the CHILD pk (ax_child.cid)
-- and the view column `cid` maps to the PARENT value (ax_parent.pv). A write must
-- route by lineage, not by name. `where cid = 100` filters on ax_parent.pv=100.
create view ax_swap as
    select p.pv as cid, c.cid as pv from ax_child c join ax_parent p on p.pid = c.pref;
select * from ax_swap order by pv;
→ [{"cid":100,"pv":1},{"cid":200,"pv":2}]
update ax_swap set pv = 7 where cid = 100;
select cid, pref from ax_child order by cid;
→ [{"cid":2,"pref":20},{"cid":7,"pref":10}]
select pid, pv from ax_parent order by pid;
→ [{"pid":10,"pv":100},{"pid":20,"pv":200}]

-- View-name-qualified predicate (jv.col) resolves to the base term.
create view ax_q as select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_q set note = 'z' where ax_q.cid = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"b"},{"cid":7,"note":"z"}]

-- The view body's own WHERE is conjoined: a predicate-less write only touches the
-- rows the body exposes (children whose parent pv > 150, i.e. pref = 20).
create view ax_filt as
    select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref where p.pv > 150;
select cid from ax_filt order by cid;
→ [{"cid":2}]
update ax_filt set note = 'F';
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"z"}]

-- Explicit view column-list override (create view v (a,b) as ...): writes route by
-- the override name to the underlying lineage.
create view ax_named (k, n) as select c.cid, c.note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_named set n = 'g' where k = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"g"}]

-- Composite-PK side -> accepted: the identity capture projects one column per PK
-- column (k0_0=x.c1, k0_1=x.c2) and the base op's EXISTS correlates on both, so a
-- predicate on part of the key (c1 = 1) binds every composite-keyed row it matches.
create table ax_comp (c1 integer, c2 integer, pref integer, note text,
    primary key (c1, c2), foreign key (pref) references ax_parent(pid));
insert into ax_comp values (1, 1, 10, 'a'), (1, 2, 20, 'b'), (2, 1, 10, 'c');
create view ax_jv_comp as
    select x.c1 as c1, x.note as note, p.pv as pv from ax_comp x join ax_parent p on p.pid = x.pref;
update ax_jv_comp set note = 'q' where c1 = 1;
select c1, c2, note from ax_comp order by c1, c2;
→ [{"c1":1,"c2":1,"note":"q"},{"c1":1,"c2":2,"note":"q"},{"c1":2,"c2":1,"note":"c"}]

-- ...but a single-side write to the SIMPLE-PK side is allowed even when the OTHER
-- (untouched) side has a COMPOSITE PK: only the touched side's PK backs the identity
-- capture, so the composite key on the untouched side is never required. (Parity the
-- per-side key capture preserves — view-mutation-retire-ast-roundtrip.)
create table ax_cpk_p (a integer, b integer, lbl text, primary key (a, b));
create table ax_spk_c (sid integer primary key, pa integer, note text);
insert into ax_cpk_p values (1, 1, 'L1');
insert into ax_spk_c values (10, 1, 'n');
create view ax_jv_simpside as
    select c.sid as sid, c.note as note, p.lbl as lbl
    from ax_spk_c c join ax_cpk_p p on p.a = c.pa;
-- run
update ax_jv_simpside set note = 'm' where sid = 10;
-- run
select sid, note, lbl from ax_jv_simpside order by sid;
→ [{"sid":10,"note":"m","lbl":"L1"}]

-- Cross-source SET value (assign from the OTHER base table) -> now ACCEPTED when the
-- read column has `base` lineage: the partner value (p.pv) is projected into the
-- __vmupd_keys capture under a `srcN` alias and read back correlated by the owning
-- side's PK (the child's cid). For cid=2 (joined parent pid=20, pv=200) the child's
-- cval becomes 200; cid=1 is untouched, and the parent base is unchanged.
create table ax_xs_p (pid integer primary key, pv integer);
create table ax_xs_c (cid integer primary key, pref integer, cval integer,
    foreign key (pref) references ax_xs_p(pid));
insert into ax_xs_p values (10, 100), (20, 200);
insert into ax_xs_c values (1, 10, 1), (2, 20, 2);
create view ax_jv_x as
    select c.cid as cid, c.cval as cval, p.pv as pv from ax_xs_c c join ax_xs_p p on p.pid = c.pref;
update ax_jv_x set cval = pv where cid = 2;
select cid, cval from ax_xs_c order by cid;
→ [{"cid":1,"cval":1},{"cid":2,"cval":200}]
select pid, pv from ax_xs_p order by pid;
→ [{"pid":10,"pv":100},{"pid":20,"pv":200}]

-- TWO distinct cross-source leaves in one statement -> each partner column mints its own
-- `srcN` projection, but all reads of `__vmupd_keys` within a base op resolve to ONE
-- injected key-ref instance (a shared DAG). Both shapes must lower correctly: a two-leaf
-- expression (`cw = pv + pw`) and two single-leaf assignments (`cv = pv, cw = pw`). For
-- cid=2 (joined parent pid=20: pv=200, pw=2000) the expression case sets cw=2200; the
-- two-assignment case sets cv=200, cw=2000.
create table ax_xs2_p (pid integer primary key, pv integer, pw integer);
create table ax_xs2_c (cid integer primary key, pref integer, cv integer, cw integer,
    foreign key (pref) references ax_xs2_p(pid));
insert into ax_xs2_p values (10, 100, 1000), (20, 200, 2000);
insert into ax_xs2_c values (1, 10, 0, 0), (2, 20, 0, 0);
create view ax_jv_x2 as
    select c.cid as cid, c.cv as cv, c.cw as cw, p.pv as pv, p.pw as pw
    from ax_xs2_c c join ax_xs2_p p on p.pid = c.pref;
update ax_jv_x2 set cw = pv + pw where cid = 1;
update ax_jv_x2 set cv = pv, cw = pw where cid = 2;
select cid, cv, cw from ax_xs2_c order by cid;
→ [{"cid":1,"cv":0,"cw":1100},{"cid":2,"cv":200,"cw":2000}]

-- Cross-source `set` on a COMPOSITE-PK owning side: the correlated read-back conjoins one
-- equality per owning PK column (k.k0_0 = k1 and k.k0_1 = k2), so only the identified row
-- (k1=1, k2=2 — joined parent pp=20, pv=200) takes the partner value; (1,1) is untouched.
create table ax_xscpk_k (k1 integer, k2 integer, v integer, ref integer, primary key (k1, k2));
create table ax_xscpk_p (pp integer primary key, pv integer);
insert into ax_xscpk_p values (10, 100), (20, 200);
insert into ax_xscpk_k values (1, 1, 0, 10), (1, 2, 0, 20);
create view ax_xscpk_v as
    select k.k1 as k1, k.k2 as k2, k.v as v, p.pv as pv from ax_xscpk_k k join ax_xscpk_p p on p.pp = k.ref;
update ax_xscpk_v set v = pv where k1 = 1 and k2 = 2;
select k1, k2, v from ax_xscpk_k order by k1, k2;
→ [{"k1":1,"k2":1,"v":0},{"k1":1,"k2":2,"v":200}]

-- Cross-source `set` on a SELF-JOIN owning side: the owning side is alias-keyed, so the
-- read-back correlates on the assigned alias's PK. `set sal = msal where id = 1` copies the
-- manager (alias `m`, id=2) salary onto employee id=1; id=2 is untouched.
create table ax_xs_emp (id integer primary key, mgr integer, sal integer);
insert into ax_xs_emp values (1, 2, 50), (2, 2, 90);
create view ax_xs_self as select e.id as id, e.sal as sal, m.sal as msal from ax_xs_emp e join ax_xs_emp m on e.mgr = m.id;
update ax_xs_self set sal = msal where id = 1;
select id, sal from ax_xs_emp order by id;
→ [{"id":1,"sal":90},{"id":2,"sal":90}]

-- ...but a cross-source value reading a COMPUTED (non-base) partner column stays
-- rejected: its value is not recoverable from a captured base column.
create view ax_jv_xc as
    select c.cid as cid, c.cval as cval, (p.pv * 2) as pvc from ax_xs_c c join ax_xs_p p on p.pid = c.pref;
update ax_jv_xc set cval = pvc where cid = 1;
-- error: cannot write through

-- Cross-source `set` in the 1:MANY direction -> REJECTED at PLAN TIME with a diagnostic
-- naming the cross-source ambiguity. The owning (assigned) side `p` joins TWO children, so
-- the partner read `cv` is multi-valued: __vmupd_keys holds one srcN row per joined pair and
-- the correlated read-back (keyed by the owner's pid) returns >1 row. The cardinality proof
-- fails — the join only pins xs1n_c.pref, which is no unique key of xs1n_c — so the write is
-- rejected here rather than failing at runtime with "Scalar subquery returned more than one
-- row".
create table xs1n_p (pid integer primary key, pv integer);
create table xs1n_c (cid integer primary key, pref integer, cv integer,
    foreign key (pref) references xs1n_p(pid));
insert into xs1n_p values (10, 100);
insert into xs1n_c values (1, 10, 11), (2, 10, 22);
create view xs1n_v as
    select p.pid as pid, p.pv as pv, c.cv as cv
    from xs1n_p p join xs1n_c c on c.pref = p.pid;
update xs1n_v set pv = cv where pid = 10;
-- error: assigned side joins more than one
-- ...and the statement never executed (plan-time reject): xs1n_p is unchanged.
select pid, pv from xs1n_p order by pid;
→ [{"pid":10,"pv":100}]

-- Cross-source `set` where the partner's join column is UNIQUE but NOT the primary key ->
-- ACCEPTED via the unique-constraint branch of the cardinality proof. The join pins
-- xs1u_p.pcode (a non-partial UNIQUE), so the owning child joins at most one parent. For
-- cid=1 (joined parent pcode=500, pv=100) cv becomes 100; cid=2 (pcode=600, pv=200) untouched.
create table xs1u_p (pid integer primary key, pcode integer unique, pv integer);
create table xs1u_c (cid integer primary key, cref integer, cv integer);
insert into xs1u_p values (10, 500, 100), (20, 600, 200);
insert into xs1u_c values (1, 500, 1), (2, 600, 2);
create view xs1u_v as
    select c.cid as cid, c.cv as cv, p.pv as pv
    from xs1u_c c join xs1u_p p on p.pcode = c.cref;
update xs1u_v set cv = pv where cid = 1;
select cid, cv from xs1u_c order by cid;
→ [{"cid":1,"cv":100},{"cid":2,"cv":2}]

-- Cross-source `set` where the partner's only unique key on the join column is a PARTIAL
-- UNIQUE index (it carries a predicate) -> REJECTED. A partial unique key bounds uniqueness
-- only within its predicate scope, so it cannot prove the owner joins at most one partner.
-- Here xs1pp_p has TWO rows with pcode=500 (one, pv=-5, outside the partial scope pv>0), so
-- the child cid=1 genuinely joins both parents -> the proof correctly fails and the write is
-- rejected at plan time rather than failing at runtime with "more than one row".
create table xs1pp_p (pid integer primary key, pcode integer, pv integer);
create table xs1pp_c (cid integer primary key, cref integer, cv integer);
create unique index xs1pp_ux on xs1pp_p(pcode) where pv > 0;
insert into xs1pp_p values (10, 500, 100), (20, 500, -5);
insert into xs1pp_c values (1, 500, 1);
create view xs1pp_v as
    select c.cid as cid, c.cv as cv, p.pv as pv
    from xs1pp_c c join xs1pp_p p on p.pcode = c.cref;
update xs1pp_v set cv = pv where cid = 1;
-- error: assigned side joins more than one
select cid, cv from xs1pp_c order by cid;
→ [{"cid":1,"cv":1}]

-- Self-join body -> accepted: `e` and `m` are distinct aliases of one base table,
-- routed by alias (the column's producing scan), not table name. `mv = m.v` routes to
-- alias `m`'s side; `where id = 1` identifies via alias `e` (id = e.id). For id=1
-- (mgr=2) the joined `m` is the row id=2, so its `v` is set to 9.
create table ax_emp (id integer primary key, mgr integer, v integer);
insert into ax_emp values (1, 2, 10), (2, 9, 20), (9, 9, 30);
create view ax_self as select e.id as id, m.v as mv from ax_emp e join ax_emp m on m.id = e.mgr;
update ax_self set mv = 9 where id = 1;
select id, mgr, v from ax_emp order by id;
→ [{"id":1,"mgr":2,"v":10},{"id":2,"mgr":9,"v":9},{"id":9,"mgr":9,"v":30}]

-- Three-table inner join -> accepted: the n-way fan-out routes each assignment to its
-- owning base. `bv = b.v` routes to the third side (ax_b); `where cid = 2` identifies
-- through the join (b.bid = c.cid = 2).
create table ax_b (bid integer primary key, v integer);
insert into ax_b values (2, 50), (7, 60);
create view ax_three as
    select c.cid as cid, p.pv as pv, b.v as bv
    from ax_child c join ax_parent p on p.pid = c.pref join ax_b b on b.bid = c.cid;
update ax_three set bv = 9 where cid = 2;
select bid, v from ax_b order by bid;
→ [{"bid":2,"v":9},{"bid":7,"v":60}]

-- MULTI-HOP cross-source `set` -> conservatively REJECTED. In ax_three the owner `p`
-- (ax_parent) and the partner `b` (ax_b) are not directly equi-joined — they connect only
-- transitively through `c` (ax_child). The cardinality proof pins no ax_b column to a
-- per-owner value, so it cannot prove the owner joins at most one ax_b row and rejects at
-- plan time (this only over-rejects; a transitive value-determinacy proof is a follow-up).
update ax_three set pv = bv where cid = 2;
-- error: assigned side joins more than one
-- ...plan-time reject: ax_parent is unchanged.
select pid, pv from ax_parent order by pid;
→ [{"pid":10,"pv":100},{"pid":20,"pv":200}]

-- n-way DELETE under FK enforcement (foreign_keys defaults ON here) -> the fan-out must
-- order the base deletes FK-child before FK-parent. The canonical columnar split has each
-- member's PK reference the anchor's (axd_b, axd_c -> axd_a); deleting the parent first
-- would trip the children's inbound RESTRICT/NO-ACTION and abort. The reverse FK-topo
-- order deletes the children first, so the joined row clears from every member cleanly.
create table axd_a (k integer primary key, av integer);
create table axd_b (k integer primary key references axd_a(k), bv integer);
create table axd_c (k integer primary key references axd_a(k), cv integer);
insert into axd_a values (1, 10), (2, 20);
insert into axd_b values (1, 11), (2, 21);
insert into axd_c values (1, 12), (2, 22);
create view axd_v as
    select a.k as k, a.av as av, b.bv as bv, c.cv as cv
    from axd_a a join axd_b b on b.k = a.k join axd_c c on c.k = a.k;
delete from axd_v where k = 1;
select k from axd_a order by k;
→ [{"k":2}]
select k from axd_b order by k;
→ [{"k":2}]
select k from axd_c order by k;
→ [{"k":2}]

-- n-way (3-table star) INSERT under FK enforcement -> the shared key is minted once from
-- the anchor's declared default (axi_a), FK-parent first, then threaded into the two
-- children's key columns via the equivalence class. One insert through the view produces
-- one row per member, all sharing the minted key.
create table axi_a (k integer primary key default (coalesce((select max(k) from axi_a), 0) + 1), av integer);
create table axi_b (k integer primary key references axi_a(k), bv integer);
create table axi_c (k integer primary key references axi_a(k), cv integer);
create view axi_v as
    select a.k as k, a.av as av, b.bv as bv, c.cv as cv
    from axi_a a join axi_b b on b.k = a.k join axi_c c on c.k = a.k;
insert into axi_v (av, bv, cv) values (100, 200, 300);
select k, av from axi_a order by k;
→ [{"k":1,"av":100}]
select k, bv from axi_b order by k;
→ [{"k":1,"bv":200}]
select k, cv from axi_c order by k;
→ [{"k":1,"cv":300}]
select k, av, bv, cv from axi_v order by k;
→ [{"k":1,"av":100,"bv":200,"cv":300}]

-- DELETE through a join with no provable FK -> the hardwired-lenient predicate-honest
-- multi-side fan-out deletes the joined row's contribution from EVERY candidate side
-- ("make this joined row not exist"). The two base deletes address rows via the
-- up-front captured key set, so the first side's delete cannot empty the join out from
-- under the second side's. (To pin a single non-default side, expose it as a per-row
-- presence/existence column and write it — routing is no longer a tag.)
create table ax_x (xid integer primary key, v integer);
create table ax_y (yid integer primary key, v integer);
insert into ax_x values (1, 5);
insert into ax_y values (5, 9);
create view ax_nofk as select x.xid as xid, y.yid as yid from ax_x x join ax_y y on y.yid = x.v;
delete from ax_nofk where xid = 1;
-- the joined row (xid=1 ⋈ yid=5) is gone from both base tables.
select xid from ax_x order by xid;
→ []
select yid from ax_y order by yid;
→ []

-- ===================================
-- Lenient multi-side DELETE fan-out (the predicate-honest "make this joined row not
-- exist"). An ambiguous join delete with two residual candidate sides, no provable
-- FK, and no resolving tag deletes from BOTH sides. The two base deletes read an
-- up-front captured key set, so the first side's delete cannot empty the join out
-- from under the second side's identifying subquery. The inner join hides unmatched
-- base rows on either side, which the fan-out must leave untouched.
-- See docs/view-updateability.md § Inner Join — Deletes.
-- ===================================

-- --- (fo-a) unmatched base rows on either side survive the fan-out ---
create table fo_x (xid integer primary key, v integer, lx text);
create table fo_y (yid integer primary key, ly text);
insert into fo_x values (1, 50, 'x1'), (2, 60, 'x2'), (3, 99, 'x3');  -- xid=3 (v=99) joins nothing
insert into fo_y values (50, 'a'), (60, 'b'), (70, 'c');             -- yid=70 joins nothing
create view fo_jv as select x.xid as xid, x.lx as lx, y.ly as ly
    from fo_x x join fo_y y on y.yid = x.v;
select xid, lx, ly from fo_jv order by xid;
→ [{"xid":1,"lx":"x1","ly":"a"},{"xid":2,"lx":"x2","ly":"b"}]

-- fan out: deletes fo_x xid=1 AND fo_y yid=50 (the joined row), leaving every other
-- base row — including the two unmatched rows the inner join hides — in place.
delete from fo_jv where xid = 1;
select xid, v from fo_x order by xid;
→ [{"xid":2,"v":60},{"xid":3,"v":99}]
select yid, ly from fo_y order by yid;
→ [{"yid":60,"ly":"b"},{"yid":70,"ly":"c"}]
select xid, lx, ly from fo_jv order by xid;
→ [{"xid":2,"lx":"x2","ly":"b"}]

-- --- (fo-b) fan-out + ON DELETE CASCADE: a cascade-removed row is a silent no-op ---
-- A MUTUAL FK pair (each side references the other) leaves no single provable FK
-- direction, so the delete fans out. Both edges are ON DELETE CASCADE: deleting the
-- first side (cas_a) cascades away the matching row on the second side (cas_b) BEFORE
-- the fan-out's own second base delete runs. Because each base delete is a
-- predicate-SCAN over the live table (not a key-addressed delete that errors on a
-- missing key), the already-removed row simply falls out of the scan — a no-op, not a
-- double-delete error. Seeded with nullable FK columns + back-fill updates so the
-- mutual FK can be created under enforcement (foreign_keys defaults on).
create table cas_a (aid integer primary key, bref integer null,
    foreign key (bref) references cas_b(bid) on delete cascade);
create table cas_b (bid integer primary key, aref integer null,
    foreign key (aref) references cas_a(aid) on delete cascade);
insert into cas_a (aid, bref) values (1, null), (2, null);
insert into cas_b (bid, aref) values (10, null), (20, null);
update cas_a set bref = 10 where aid = 1;
update cas_a set bref = 20 where aid = 2;
update cas_b set aref = 1 where bid = 10;
update cas_b set aref = 2 where bid = 20;
create view cas_jv as select a.aid as aid, b.bid as bid from cas_a a join cas_b b on b.aref = a.aid;
select aid, bid from cas_jv order by aid;
→ [{"aid":1,"bid":10},{"aid":2,"bid":20}]

-- delete the (aid=1 ⋈ bid=10) row: side cas_a deletes aid=1 first, whose ON DELETE
-- CASCADE removes cas_b bid=10; the fan-out's cas_b delete (bid in {10}) then no-ops.
delete from cas_jv where aid = 1;
select aid, bref from cas_a order by aid;
→ [{"aid":2,"bref":20}]
select bid, aref from cas_b order by bid;
→ [{"bid":20,"aref":2}]
select aid, bid from cas_jv order by aid;
→ [{"aid":2,"bid":20}]

-- --- (fo-c) fan-out + RETURNING: returns the deleted view rows AND deletes both sides ---
-- The delete RETURNING re-queries the view captured BEFORE the base ops fire (the
-- pre-delete image), independent of the captured key set the base ops read.
create table fr_x (xid integer primary key, v integer, lx text);
create table fr_y (yid integer primary key, ly text);
insert into fr_x values (1, 5, 'x1'), (2, 6, 'x2');
insert into fr_y values (5, 'y5'), (6, 'y6');
create view fr_jv as select x.xid as xid, x.lx as lx, y.ly as ly
    from fr_x x join fr_y y on y.yid = x.v;
delete from fr_jv where xid = 1 returning xid, lx, ly;
→ [{"xid":1,"lx":"x1","ly":"y5"}]
select xid, lx from fr_x order by xid;
→ [{"xid":2,"lx":"x2"}]
select yid, ly from fr_y order by yid;
→ [{"yid":6,"ly":"y6"}]
select xid, lx, ly from fr_jv order by xid;
→ [{"xid":2,"lx":"x2","ly":"y6"}]

-- --- (fo-d) fan-out + body WHERE: the capture honors (user WHERE ∧ body WHERE) ---
-- A view body WHERE further restricts which joined rows exist. The fan-out's
-- up-front capture identifies rows by (user WHERE ∧ body WHERE) via the shared
-- buildMultiSourceKeyCapture, so a delete only removes base rows whose joined row is
-- actually visible through the view; a row excluded by the body predicate is spared
-- on BOTH sides even when the user WHERE alone would match it.
create table bw_x (xid integer primary key, v integer, keep integer);
create table bw_y (yid integer primary key, ly text);
insert into bw_x values (1, 5, 1), (2, 6, 0);   -- xid=2 has keep=0 -> hidden by body WHERE
insert into bw_y values (5, 'y5'), (6, 'y6');
create view bw_dv as select x.xid as xid, y.ly as ly
    from bw_x x join bw_y y on y.yid = x.v where x.keep = 1;
-- xid=2 (keep=0) is not in the view, so deleting where xid in (1,2) only removes the
-- xid=1 joined row from both sides; xid=2 / yid=6 survive.
delete from bw_dv where xid in (1, 2);
select xid, v, keep from bw_x order by xid;
→ [{"xid":2,"v":6,"keep":0}]
select yid, ly from bw_y order by yid;
→ [{"yid":6,"ly":"y6"}]

-- --- (fo-e) a second no-FK two-candidate join still fans out (no tag needed) ---
-- With two candidate sides and no provable FK, the hardwired-lenient delete fans out
-- to both — the same maximal-lenient behavior the routing tags used to leave in place.
create table te_x (xid integer primary key, v integer);
create table te_y (yid integer primary key, w integer);
insert into te_x values (1, 5), (2, 7);
insert into te_y values (5, 50), (7, 70);
create view te_jv as select x.xid as xid, y.yid as yid from te_x x join te_y y on y.yid = x.v;
delete from te_jv where xid = 1;
select xid from te_x order by xid;
→ [{"xid":2}]
select yid from te_y order by yid;
→ [{"yid":7}]

-- --- (fo-f) no-FK ambiguous delete fans out (lenient is now unconditional) ---
-- The removed `quereus.update.policy='strict'` knob could once reject an ambiguous
-- multi-side delete; lenient fan-out is now the only behavior, so the same no-FK shape
-- deletes from BOTH sides rather than rejecting. To forbid a side, do not expose it.
create table ps_x (xid integer primary key, v integer);
create table ps_y (yid integer primary key, w integer);
insert into ps_x values (1, 5);
insert into ps_y values (5, 50);
create view ps_jv as select x.xid as xid, y.yid as yid
    from ps_x x join ps_y y on y.yid = x.v;
delete from ps_jv where xid = 1;
-- the joined row is gone from both base tables (lenient fan-out).
select xid from ps_x order by xid;
→ []
select yid from ps_y order by yid;
→ []

-- ===================================
-- ON-DELETE-aware fan-out ordering over an ASYMMETRIC mutual FK. The two-side
-- fan-out is reached only when no single-direction FK is provable — a mutual FK
-- (each side references the other) is one such case. When the two edges' ON DELETE
-- actions differ, a fixed [0,1] order is no longer order-independent: the fan-out
-- now orders the base deletes by ON DELETE action (delete the side whose removal
-- clears the other's reference first), and rejects at plan time the mutual shapes no
-- order can satisfy under immediate enforcement + the transitive RESTRICT pre-walk
-- (runtime/foreign-key-actions.ts). Seeded like (fo-b): nullable FK columns +
-- back-fill updates so the mutual FK can be established under enforcement.
-- See docs/view-updateability.md § Inner Join — Deletes.
-- ===================================

-- --- (fo-g) restrict+cascade mutual FK -> structured diagnostic (the headline) ---
-- Edge g_a.bref -> g_b ON DELETE CASCADE governs deleting side1 (g_b); edge
-- g_b.aref -> g_a ON DELETE RESTRICT governs deleting side0 (g_a). So inbound0 =
-- restrict, inbound1 = cascade. Deleting g_a first trips g_b's RESTRICT; deleting
-- g_b first cascades into g_a, whose deletion then trips g_b's RESTRICT via the
-- transitive pre-walk. Neither order is satisfiable, so the plan is rejected up front
-- with `mutual-fk-restrict-delete` instead of the raw transitive-FK runtime error.
create table g_a (aid integer primary key, bref integer null,
    foreign key (bref) references g_b(bid) on delete cascade);
create table g_b (bid integer primary key, aref integer null,
    foreign key (aref) references g_a(aid) on delete restrict);
insert into g_a (aid, bref) values (1, null), (2, null);
insert into g_b (bid, aref) values (10, null), (20, null);
update g_a set bref = 10 where aid = 1;
update g_a set bref = 20 where aid = 2;
update g_b set aref = 1 where bid = 10;
update g_b set aref = 2 where bid = 20;
create view g_jv as select a.aid as aid, b.bid as bid from g_a a join g_b b on b.aref = a.aid;
select aid, bid from g_jv order by aid;
→ [{"aid":1,"bid":10},{"aid":2,"bid":20}]
delete from g_jv where aid = 1;
-- error: mutual foreign key
-- the rejected delete is a no-op: both base rows survive.
select aid, bref from g_a order by aid;
→ [{"aid":1,"bref":10},{"aid":2,"bref":20}]
select bid, aref from g_b order by bid;
→ [{"bid":10,"aref":1},{"bid":20,"aref":2}]

-- --- (fo-h) restrict/restrict mutual FK -> same diagnostic ---
-- Both edges ON DELETE RESTRICT (inbound0 = inbound1 = restrict): deleting either
-- side trips the other's RESTRICT directly. Unsatisfiable in any order; rejected.
create table h_a (aid integer primary key, bref integer null,
    foreign key (bref) references h_b(bid) on delete restrict);
create table h_b (bid integer primary key, aref integer null,
    foreign key (aref) references h_a(aid) on delete restrict);
insert into h_a (aid, bref) values (1, null), (2, null);
insert into h_b (bid, aref) values (10, null), (20, null);
update h_a set bref = 10 where aid = 1;
update h_a set bref = 20 where aid = 2;
update h_b set aref = 1 where bid = 10;
update h_b set aref = 2 where bid = 20;
create view h_jv as select a.aid as aid, b.bid as bid from h_a a join h_b b on b.aref = a.aid;
delete from h_jv where aid = 1;
-- error: mutual foreign key
-- both base rows survive the rejected delete.
select aid, bref from h_a order by aid;
→ [{"aid":1,"bref":10},{"aid":2,"bref":20}]
select bid, aref from h_b order by bid;
→ [{"bid":10,"aref":1},{"bid":20,"aref":2}]

-- --- (fo-i) restrict+setNull mutual FK -> SUCCESS via reordering (the rescued case) ---
-- This is the ONLY asymmetric mutual shape a side ordering can satisfy. Edge
-- i_a.bref -> i_b ON DELETE SET NULL governs deleting side1 (i_b); edge i_b.aref ->
-- i_a ON DELETE RESTRICT governs deleting side0 (i_a). So inbound0 = restrict,
-- inbound1 = setNull. The as-is [0,1] order would delete i_a first and trip i_b's
-- RESTRICT (a latent runtime error before this change); the ON-DELETE-aware order
-- deletes i_b FIRST — its SET NULL clears i_a.bref, removing no row but no RESTRICT —
-- then deletes i_a cleanly (no i_b row references it any longer). Both base rows for
-- the joined identity end up gone.
create table i_a (aid integer primary key, bref integer null,
    foreign key (bref) references i_b(bid) on delete set null);
create table i_b (bid integer primary key, aref integer null,
    foreign key (aref) references i_a(aid) on delete restrict);
insert into i_a (aid, bref) values (1, null), (2, null);
insert into i_b (bid, aref) values (10, null), (20, null);
update i_a set bref = 10 where aid = 1;
update i_a set bref = 20 where aid = 2;
update i_b set aref = 1 where bid = 10;
update i_b set aref = 2 where bid = 20;
create view i_jv as select a.aid as aid, b.bid as bid from i_a a join i_b b on b.aref = a.aid;
select aid, bid from i_jv order by aid;
→ [{"aid":1,"bid":10},{"aid":2,"bid":20}]
-- reordered fan-out: i_b bid=10 deleted first (SET NULL clears i_a aid=1's bref),
-- then i_a aid=1 deleted cleanly. The aid=2 / bid=20 joined identity is untouched.
delete from i_jv where aid = 1;
select aid, bref from i_a order by aid;
→ [{"aid":2,"bref":20}]
select bid, aref from i_b order by bid;
→ [{"bid":20,"aref":2}]
select aid, bid from i_jv order by aid;
→ [{"aid":2,"bid":20}]

-- --- (fo-j) setNull+restrict mutual FK -> SUCCESS via the MIRRORED [0,1] order ---
-- The mirror of (fo-i): the SET NULL edge governs deleting side0 (not side1), so the
-- rescuing order is [0,1] rather than [1,0]. Edge j_a.bref -> j_b ON DELETE RESTRICT
-- governs deleting side1 (j_b); edge j_b.aref -> j_a ON DELETE SET NULL governs
-- deleting side0 (j_a). So inbound0 = setNull, inbound1 = restrict — `deletableFirst`
-- takes its SET NULL clause (not its cascade clause, which (fo-b) already pins), so the
-- fan-out keeps [0,1]: delete j_a FIRST (its SET NULL clears j_b's aref, tripping no
-- RESTRICT), then j_b cleanly (no j_a row references it any longer). This pins the
-- order-selection symmetry — the SET NULL-first rescue works in BOTH directions.
create table j_a (aid integer primary key, bref integer null,
    foreign key (bref) references j_b(bid) on delete restrict);
create table j_b (bid integer primary key, aref integer null,
    foreign key (aref) references j_a(aid) on delete set null);
insert into j_a (aid, bref) values (1, null), (2, null);
insert into j_b (bid, aref) values (10, null), (20, null);
update j_a set bref = 10 where aid = 1;
update j_a set bref = 20 where aid = 2;
update j_b set aref = 1 where bid = 10;
update j_b set aref = 2 where bid = 20;
create view j_jv as select a.aid as aid, b.bid as bid from j_a a join j_b b on b.aref = a.aid;
select aid, bid from j_jv order by aid;
→ [{"aid":1,"bid":10},{"aid":2,"bid":20}]
-- reordered fan-out keeps [0,1]: j_a aid=1 deleted first (SET NULL clears j_b bid=10's
-- aref), then j_b bid=10 deleted cleanly. The aid=2 / bid=20 identity is untouched.
delete from j_jv where aid = 1;
select aid, bref from j_a order by aid;
→ [{"aid":2,"bref":20}]
select bid, aref from j_b order by bid;
→ [{"bid":20,"aref":2}]
select aid, bid from j_jv order by aid;
→ [{"aid":2,"bid":20}]

-- --- (fo-k) restrict/restrict mutual FK, join on a NON-FK column -> SUCCESS ---
-- The plan-time `mutual-fk-restrict-delete` reject is gated on the join provably
-- correlating a mutual FK edge (the joined rows necessarily cross-reference). Here the
-- join is on a non-FK column (a.lbl = b.lbl) — it correlates NEITHER edge — and the FK
-- columns (bref/aref) are left NULL, so the joined rows do not in fact cross-reference.
-- The schema-only `orderDeleteFanout` still returns undefined (both edges RESTRICT), but
-- the reject no longer fires; the planner falls back to the fixed [0,1] fan-out and
-- defers to the runtime RESTRICT pre-check, which (FK columns NULL ⇒ MATCH SIMPLE: no
-- referencing row) finds nothing and lets the delete succeed. This is the over-rejection
-- repro from the ticket. See docs/view-updateability.md § Inner Join — Deletes.
create table k_a (aid integer primary key, lbl text, bref integer null,
    foreign key (bref) references k_b(bid) on delete restrict);
create table k_b (bid integer primary key, lbl text, aref integer null,
    foreign key (aref) references k_a(aid) on delete restrict);
insert into k_a (aid, lbl, bref) values (1, 'x', null), (2, 'y', null);
insert into k_b (bid, lbl, aref) values (10, 'x', null), (20, 'z', null);
create view k_jv as select a.aid as aid, b.bid as bid from k_a a join k_b b on a.lbl = b.lbl;
select aid, bid from k_jv order by aid;
→ [{"aid":1,"bid":10}]
-- fans out [0,1]; both base deletes succeed (FK columns NULL — runtime RESTRICT pre-check
-- finds no referencing row), removing both base rows of the joined identity (aid=1/bid=10).
delete from k_jv where aid = 1;
select aid from k_a order by aid;
→ [{"aid":2}]
select bid from k_b order by bid;
→ [{"bid":20}]

-- --- (fo-l) same non-FK join, but FK columns back-filled -> RAW FK-constraint error ---
-- The accepted residual tradeoff of (fo-k)'s relaxation: when the join correlates neither
-- edge, the actionable plan-time `mutual-fk-restrict-delete` diagnostic is no longer
-- raised — so when the joined rows *do* cross-reference in data (FK columns back-filled
-- here), the deferred [0,1] fan-out's per-base-op parent-side FK check raises the raw
-- FK-constraint error instead. A non-correlated join trades the actionable plan-time
-- diagnostic for the raw FK error when the data happens to reference.
-- See docs/view-updateability.md § Inner Join — Deletes.
create table l_a (aid integer primary key, lbl text, bref integer null,
    foreign key (bref) references l_b(bid) on delete restrict);
create table l_b (bid integer primary key, lbl text, aref integer null,
    foreign key (aref) references l_a(aid) on delete restrict);
insert into l_a (aid, lbl, bref) values (1, 'x', null), (2, 'y', null);
insert into l_b (bid, lbl, aref) values (10, 'x', null), (20, 'z', null);
-- back-fill so the joined identity (aid=1/bid=10) cross-references in data
update l_a set bref = 10 where aid = 1;
update l_b set aref = 1 where bid = 10;
create view l_jv as select a.aid as aid, b.bid as bid from l_a a join l_b b on a.lbl = b.lbl;
select aid, bid from l_jv order by aid;
→ [{"aid":1,"bid":10}]
-- deferred [0,1] fan-out: deleting l_a aid=1 first trips l_b's reference to aid=1 (l_b
-- bid=10 has aref=1) at the per-base-op parent-side FK check.
delete from l_jv where aid = 1;
-- error: CHECK constraint failed: _fk_l_b_aref
-- the rejected delete is a no-op: both base rows survive.
select aid, bref from l_a order by aid;
→ [{"aid":1,"bref":10},{"aid":2,"bref":null}]
select bid, aref from l_b order by bid;
→ [{"bid":10,"aref":1},{"bid":20,"aref":null}]

-- --- (fo-m) correlation expressed in the body WHERE (not the ON) -> REJECT ---
-- The correlation gate folds the view body's own WHERE conjuncts into the cross-side
-- equality set, not just the ON condition. Here the join's ON is on a non-FK column
-- (a.lbl = b.lbl, correlating neither edge), but the body WHERE `b.aref = a.aid`
-- correlates edge B (m_b.aref -> m_a.aid). So `joinCorrelatesMutualFk` still proves a
-- mutual FK edge correlated and the plan-time `mutual-fk-restrict-delete` reject fires
-- — the actionable diagnostic, not the deferred raw FK error. This pins the WHERE-fold
-- branch of the gate. See docs/view-updateability.md § Inner Join — Deletes.
create table m_a (aid integer primary key, lbl text, bref integer null,
    foreign key (bref) references m_b(bid) on delete restrict);
create table m_b (bid integer primary key, lbl text, aref integer null,
    foreign key (aref) references m_a(aid) on delete restrict);
insert into m_a (aid, lbl, bref) values (1, 'x', null), (2, 'y', null);
insert into m_b (bid, lbl, aref) values (10, 'x', null), (20, 'z', null);
-- back-fill after both rows exist (avoids the circular insert-time FK chicken-and-egg)
update m_a set bref = 10 where aid = 1;
update m_b set aref = 1 where bid = 10;
create view m_jv as select a.aid as aid, b.bid as bid from m_a a join m_b b on a.lbl = b.lbl where b.aref = a.aid;
select aid, bid from m_jv order by aid;
→ [{"aid":1,"bid":10}]
delete from m_jv where aid = 1;
-- error: mutual foreign key
-- both base rows survive the rejected delete.
select aid, bref from m_a order by aid;
→ [{"aid":1,"bref":10},{"aid":2,"bref":null}]
select bid, aref from m_b order by bid;
→ [{"bid":10,"aref":1},{"bid":20,"aref":null}]

-- ===================================
-- Phase 3.4: the `quereus.update.*` override surface + per-row routing.
-- The sole retained override tag is `default_for` (supply a value for an omitted
-- insert column), read + site-validated through the typed reserved-tag registry and
-- merged statement-over-view. Write *routing* is no longer a tag — predicates rule,
-- and a per-row writable presence/existence column states a non-default side
-- explicitly. The removed routing keys (target / exclude / delete_via / policy) are now
-- `unknown-reserved-tag` errors. See docs/view-updateability.md § Tags: The Override Surface.
-- ===================================

-- --- default_for: statement-level omitted-insert default (single-source) ---
create table df_t (id integer primary key, created integer, note text);
create view df_v as select id, note from df_t;

-- `created` is projected away by the view; the statement-level default_for tag
-- supplies it (ahead of the base column's own default).
insert into df_v with tags ("quereus.update.default_for.created" = '777') values (5, 'x');
select * from df_t order by id;
→ [{"id":5,"created":777,"note":"x"}]

-- --- default_for: view-level default, overridden statement-over-view ---
create table df2 (id integer primary key, created integer);
create view df2_v as select id from df2 with tags ("quereus.update.default_for.created" = '111');

-- view-level default_for supplies the omitted column.
insert into df2_v values (1);
select * from df2 order by id;
→ [{"id":1,"created":111}]

-- statement-level default_for overrides the view-level one for this statement.
insert into df2_v with tags ("quereus.update.default_for.created" = '222') values (2);
select * from df2 order by id;
→ [{"id":1,"created":111},{"id":2,"created":222}]

-- a default_for naming a column that is neither a view nor a base column -> error.
insert into df2_v with tags ("quereus.update.default_for.nope" = '0') values (3);
-- error: not a column

-- --- predicate/FK default: an FK join delete auto-routes to the FK-child side ---
-- A declared foreign key proves the child (FK-many) side, so the join delete routes
-- there unconditionally (deleting the child leaves the parent) — the predicate/FK
-- truth, no tag involved.
create table pol_parent (pid integer primary key, lbl text);
create table pol_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references pol_parent(pid));
insert into pol_parent values (10, 'P10'), (20, 'P20');
insert into pol_child values (1, 10, 'a'), (2, 20, 'b');
create view pol_fk as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from pol_child c join pol_parent p on p.pid = c.pref;
delete from pol_fk where cid = 1;
select cid from pol_child order by cid;
→ [{"cid":2}]
select pid from pol_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- --- explicit non-default side via a per-row existence column ---
-- The removed `delete_via='parent'` / `target` routing is now expressed per-row: a LEFT
-- join exposes the parent's match as `exists right as hasP`, and writing `hasP = false`
-- deletes the matched parent for the targeted rows (ON DELETE CASCADE clears the
-- now-orphaned child). This is the strictly-more-precise replacement — the side is named
-- in the data shape, per row, not by a statement-level tag.
create table er_parent (pid integer primary key, lbl text);
create table er_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references er_parent(pid) on delete cascade);
insert into er_parent values (10, 'P10'), (20, 'P20');
insert into er_child values (1, 10, 'a'), (2, 20, 'b');
create view er_jv as
    select c.cid as cid, c.note as note, p.lbl as lbl, hasP
    from er_child c left join er_parent p on p.pid = c.pref exists right as hasP;
update er_jv set hasP = false where cid = 1;
select pid from er_parent order by pid;
→ [{"pid":20}]
select cid from er_child order by cid;
→ [{"cid":2}]

-- --- the removed routing keys are now unknown-reserved-tag errors ---
-- target / exclude / delete_via / policy on a DML statement -> unknown reserved tag.
create table tg_x (xid integer primary key, v integer, lx text);
create table tg_y (yid integer primary key, ly text);
insert into tg_x values (1, 5, 'x1'), (2, 6, 'x2');
insert into tg_y values (5, 'y5'), (6, 'y6');
create view tg_jv as
    select x.xid as xid, x.lx as lx, y.ly as ly from tg_x x join tg_y y on y.yid = x.v;

delete from tg_jv with tags ("quereus.update.target" = 'tg_x') where xid = 1;
-- error: unknown reserved tag

delete from tg_jv with tags ("quereus.update.delete_via" = 'left_delete') where xid = 1;
-- error: unknown reserved tag

-- the rejected deletes left every base row intact.
select xid from tg_x order by xid;
→ [{"xid":1},{"xid":2}]
select yid from tg_y order by yid;
→ [{"yid":5},{"yid":6}]

-- --- sited diagnostics for malformed reserved tags ---

-- unknown reserved key (a typo) on a DML statement -> sited error.
update tg_jv with tags ("quereus.update.taget" = 'tg_x') set lx = 'z' where xid = 2;
-- error: unknown reserved tag

-- a removed routing key declared on the VIEW DDL -> surfaces (sited) at mutation.
create table bvu (id integer primary key, x integer);
create view bvu_v as select id from bvu with tags ("quereus.update.policy" = 'strict');
insert into bvu_v values (1);
-- error: unknown reserved tag

-- ===================================
-- Phase 3.4: adversarial edges (review pass) — default_for precedence and a
-- single-source view carrying a removed routing tag.
-- ===================================

-- --- default_for precedence: an explicit supply of the column wins ---
-- The view projects `created`, so a statement that supplies it explicitly must
-- override the view-level default_for; an omitted insert still takes the default.
create table dfp (id integer primary key, created integer);
create view dfp_v as select id, created from dfp
    with tags ("quereus.update.default_for.created" = '111');
insert into dfp_v (id, created) values (1, 999);
insert into dfp_v (id) values (2);
select * from dfp order by id;
→ [{"id":1,"created":999},{"id":2,"created":111}]

-- --- single-source view carrying a removed routing tag -> error at mutation ---
-- target/exclude/delete_via/policy were removed; a stray one declared on a view (single-
-- or multi-source) is no longer an inert no-op — it is an unknown-reserved-tag error
-- surfaced when the view is mutated, so nothing is written.
create table sst (id integer primary key, note text);
create view sst_v as select id, note from sst
    with tags ("quereus.update.target" = 'not_a_real_table');
insert into sst_v values (1, 'a');
-- error: unknown reserved tag
select * from sst order by id;
→ []

-- ===================================
-- View-column references nested inside subquery / exists / in-subquery operands
-- of a user predicate (or assigned value) are descended into and rewritten to
-- their base-term lineage — scope-aware, so a subquery-local same-named column is
-- left alone and an unresolvable source is rejected, not silently mis-bound.
-- See docs/view-updateability.md § Selection.
-- ===================================

-- --- (a) the repro: a correlated view-column ref inside EXISTS, over a base table
--         that ALSO has a same-named base column (silent-mis-bind hazard) ---
-- The view renames base `lbl` to the view column `note`; base table `sq_c` also
-- has a literal `note` column. `note` inside EXISTS is the VIEW column (= base
-- `lbl`); it must substitute to `lbl`, not re-bind to base `sq_c.note`.
create table sq_c (cid integer primary key, note text, lbl text);
create table sq_other (k text);
insert into sq_c values (1, 'BASE_NOTE_1', 'LBL_1'), (2, 'BASE_NOTE_2', 'LBL_2');
insert into sq_other values ('LBL_1');
create view sq_jv as select cid as cid, lbl as note from sq_c;

update sq_jv set note = 'CHANGED' where exists (select 1 from sq_other o where o.k = note);
-- cid=1 (lbl LBL_1, present in sq_other) matches -> its `lbl` becomes CHANGED; the
-- silent no-op (predicate re-bound to base `note`, absent from sq_other) is gone.
select cid, note, lbl from sq_c order by cid;
→ [{"cid":1,"note":"BASE_NOTE_1","lbl":"CHANGED"},{"cid":2,"note":"BASE_NOTE_2","lbl":"LBL_2"}]
-- the write is visible through the view (view col `note` = base `lbl`).
select * from sq_jv order by cid;
→ [{"cid":1,"note":"CHANGED"},{"cid":2,"note":"LBL_2"}]

-- --- (b) a correlated view-column ref inside an in (select ... where ...) ---
-- `category` is the view column (= base `grp`); referenced unqualified inside the
-- IN-subquery (whose source has no same-named column) it correlates to the outer
-- view row and must substitute to `grp`.
create table sq_in_t (id integer primary key, grp text, mark text);
create table sq_in_map (g text, allowed_id integer);
insert into sq_in_t values (1, 'G1', 'x'), (2, 'G2', 'y'), (3, 'G1', 'z');
insert into sq_in_map values ('G1', 1), ('G1', 3);
create view sq_in_v as select id as id, grp as category, mark as mark from sq_in_t;

update sq_in_v set mark = 'M' where id in (select allowed_id from sq_in_map where g = category);
select id, grp, mark from sq_in_t order by id;
→ [{"id":1,"grp":"G1","mark":"M"},{"id":2,"grp":"G2","mark":"y"},{"id":3,"grp":"G1","mark":"M"}]

-- --- (c) a subquery-local same-named column must NOT be substituted ---
-- The view renames base `lbl` to view column `note`; the subquery source
-- `sq_sh_src` has its OWN `note` column. `note` inside `in (select note from
-- sq_sh_src)` is sq_sh_src.note (subquery-local) — it must stay local. The
-- top-level left `note` is the view column and substitutes to base `lbl`.
create table sq_sh_t (tid integer primary key, lbl text, payload text);
create table sq_sh_src (note text);
insert into sq_sh_t values (1, 'L1', 'p1'), (2, 'L2', 'p2');
insert into sq_sh_src values ('L1');
create view sq_sh_v as select tid as tid, lbl as note, payload as payload from sq_sh_t;

update sq_sh_v set payload = 'P' where note in (select note from sq_sh_src);
-- lbl in ('L1') -> only tid=1; if the inner `note` had been wrongly substituted to
-- `lbl`, the subquery `select lbl from sq_sh_src` would not even resolve.
select tid, lbl, payload from sq_sh_t order by tid;
→ [{"tid":1,"lbl":"L1","payload":"P"},{"tid":2,"lbl":"L2","payload":"p2"}]

-- --- (d) a subquery referencing NO view column still works unchanged ---
create table sq_none_t (id integer primary key, val text);
create table sq_none_ok (flag integer);
insert into sq_none_t values (1, 'a'), (2, 'b');
insert into sq_none_ok values (1);
create view sq_none_v as select id as id, val as val from sq_none_t;

update sq_none_v set val = 'Z' where exists (select 1 from sq_none_ok where flag = 1);
select id, val from sq_none_t order by id;
→ [{"id":1,"val":"Z"},{"id":2,"val":"Z"}]

-- --- (e1) multi-source join view: a view-col ref nested in a subquery in the user
--          WHERE is routed to the correct (alias-qualified) base term ---
-- `label` is owned by the parent side (p.label); referenced inside EXISTS it
-- substitutes to `p.label`, correlating to the join body of the identifying
-- subquery. The update routes to the child side (note is owned by sq_jc).
create table sq_jp (pid integer primary key, label text);
create table sq_jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references sq_jp(pid));
create table sq_allow (lab text);
insert into sq_jp values (10, 'P10'), (20, 'P20');
insert into sq_jc values (1, 10, 'a'), (2, 20, 'b'), (3, 10, 'c');
insert into sq_allow values ('P10');
create view sq_jv2 as select c.cid as cid, c.note as note, p.label as label
    from sq_jc c join sq_jp p on p.pid = c.pref;

update sq_jv2 set note = 'HIT' where exists (select 1 from sq_allow where lab = label);
select cid, note from sq_jc order by cid;
→ [{"cid":1,"note":"HIT"},{"cid":2,"note":"b"},{"cid":3,"note":"HIT"}]

-- --- (e2) multi-source: a view-col ref nested in a subquery in a SET value ---
-- The SET value is a correlated scalar subquery keyed on the OWNING-side view
-- column `note` (= c.note); the descent substitutes it to `c.note` and the
-- owning-side qualifier is stripped through the subquery so it correlates to the
-- target row of the lowered child UPDATE.
create table sq_e2_jp (pid integer primary key, label text);
create table sq_e2_jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references sq_e2_jp(pid));
create table sq_e2_lookup (k text, v text);
insert into sq_e2_jp values (10, 'P10');
insert into sq_e2_jc values (1, 10, 'a'), (2, 10, 'b');
insert into sq_e2_lookup values ('a', 'AA'), ('b', 'BB');
create view sq_e2_v as select c.cid as cid, c.note as note, p.label as label
    from sq_e2_jc c join sq_e2_jp p on p.pid = c.pref;

update sq_e2_v set note = (select v from sq_e2_lookup where k = note) where cid = 1;
select cid, note from sq_e2_jc order by cid;
→ [{"cid":1,"note":"AA"},{"cid":2,"note":"b"}]

-- --- (f) conservative reject: a `select *` subquery source can't be resolved, so
--         a nested unqualified view-column ref can't be proven correlated ---
create table sq_f_t (id integer primary key, lbl text);
create table sq_f_aux (x text);
insert into sq_f_t values (1, 'L1');
insert into sq_f_aux values ('L1');
create view sq_f_v as select id as id, lbl as tag from sq_f_t;

update sq_f_v set tag = 'X' where exists (select 1 from (select * from sq_f_aux) as s where s.x = tag);
-- error: cannot write through

-- a table-valued-function subquery source is unresolvable the same way -> reject.
update sq_f_v set tag = 'X' where exists (select 1 from table_info('sq_f_t') as ti where ti.name = tag);
-- error: cannot write through

-- --- (g) the substituted base term itself collides with a subquery-local source ---
-- The view renames base `lbl` to view column `note`; the EXISTS subquery FROM
-- (p1_aux) ALSO has an `lbl` column. `note` is the view column = base `p1_t.lbl`,
-- correlated to the outer row. An UNQUALIFIED substituted base term (`lbl`) inside
-- the subquery would re-bind to p1_aux.lbl (innermost scope) — making the predicate
-- the uncorrelated p1_aux.k = p1_aux.lbl, true for the ('Q','Q') row, so EVERY outer
-- row would pass (a silent wrong write). Single-source descent qualifies the term to
-- p1_t.lbl, so the predicate is the correlated p1_aux.k = p1_t.lbl -> only row 1.
create table p1_t (id integer primary key, lbl text);
create table p1_aux (k text, lbl text);
insert into p1_t values (1, 'A'), (2, 'B');
insert into p1_aux values ('A', 'X'), ('Q', 'Q');
create view p1_v as select id as id, lbl as note from p1_t;

update p1_v set note = 'CHANGED' where exists (select 1 from p1_aux where k = note);
select id, lbl from p1_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (h) `where lbl = note`: the literal base name AND the substituted term collide ---
-- The literal `lbl` binds the subquery-local p2_aux.lbl (it is not a view column,
-- so it is never substituted); `note` is the view column = base p2_t.lbl. Without
-- qualification both collapse to p2_aux.lbl, making the predicate the always-true
-- p2_aux.lbl = p2_aux.lbl. The substituted term is qualified to p2_t.lbl, so the
-- predicate is the correlated p2_aux.lbl = p2_t.lbl -> only the matching row 1.
create table p2_t (id integer primary key, lbl text);
create table p2_aux (k text, lbl text);
insert into p2_t values (1, 'A'), (2, 'B');
insert into p2_aux values ('A', 'A'), ('Q', 'Q');
create view p2_v as select id as id, lbl as note from p2_t;

update p2_v set note = 'CHANGED' where exists (select 1 from p2_aux where lbl = note);
select id, lbl from p2_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (i) negative control on the BASE name: a bare base-name ref to a genuine
--          subquery-local source must STAY local (analogous to (c), on `lbl`) ---
-- The view renames base `lbl` to `note`; the EXISTS subquery source nc_src has its
-- OWN `lbl` column plus an `ok` flag. The bare `lbl` inside the subquery is
-- nc_src.lbl (never a view column, so never substituted/qualified); `note` is the
-- view column, qualified to the correlated nc_t.lbl. The predicate selects the
-- nc_src row whose lbl matches the outer row and tests its `ok`. If the fix wrongly
-- qualified the local `lbl` to nc_t.lbl, the predicate would degrade to the
-- always-true nc_t.lbl = nc_t.lbl and ok = 1 -> both rows would write.
create table nc_t (id integer primary key, lbl text);
create table nc_src (lbl text, ok integer);
insert into nc_t values (1, 'L1'), (2, 'L2');
insert into nc_src values ('L1', 1), ('L2', 0);
create view nc_v as select id as id, lbl as note from nc_t;

update nc_v set note = 'CHANGED' where exists (select 1 from nc_src where lbl = note and ok = 1);
select id, lbl from nc_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"L2"}]

-- --- (j) DELETE descent: same collision as (g) on the delete path ---
-- The delete rewrite threads the same base-table qualifier into the subquery
-- descent. The view renames base `lbl` to `note`; the EXISTS subquery FROM
-- (d1_aux) ALSO has an `lbl`. Without qualification the substituted base term
-- would re-bind to d1_aux.lbl, making the predicate the uncorrelated
-- d1_aux.k = d1_aux.lbl (true for ('Q','Q')) -> every outer row would delete (a
-- silent wrong delete). Qualified to d1_t.lbl, only the matching row 1 deletes.
create table d1_t (id integer primary key, lbl text);
create table d1_aux (k text, lbl text);
insert into d1_t values (1, 'A'), (2, 'B');
insert into d1_aux values ('A', 'X'), ('Q', 'Q');
create view d1_v as select id as id, lbl as note from d1_t;

delete from d1_v where exists (select 1 from d1_aux where k = note);
select id, lbl from d1_t order by id;
→ [{"id":2,"lbl":"B"}]

-- --- (k) computed lineage whose base term is itself a correlated subquery, the
--          DEEP collision: the substituted term must be qualified INSIDE its own
--          nested subquery, not just at its top level ---
-- The view column `note` is a correlated scalar subquery (select x from cv_oth
-- where fk = id); its correlation `id` is cv_base.id. Referenced inside the user
-- EXISTS subquery `select 1 from cv_src where tag = note` — and cv_src ALSO has an
-- `id` column — a SHALLOW qualifier left the lineage's own inner `id` unqualified,
-- so it re-bound to cv_src.id (=99); cv_oth has no fk=99, so `note` evaluated NULL
-- and the EXISTS was false for EVERY outer row (a silent no-op). The deep
-- scope-aware qualifier rewrites the term to (select x from cv_oth where fk =
-- cv_base.id), correlating to the outer target row regardless of the user FROM.
create table cv_base (id integer primary key, lbl text);
create table cv_oth (fk integer, x text);
create table cv_src (id integer, tag text);
insert into cv_base values (1, 'A'), (2, 'B');
insert into cv_oth values (1, 'AA'), (2, 'BB');
insert into cv_src values (99, 'AA');
create view cv_v as select id as id, lbl as lbl,
    (select x from cv_oth where fk = id) as note from cv_base;

update cv_v set lbl = 'CHANGED' where exists (select 1 from cv_src where tag = note);
-- cv_base.id=1 -> note 'AA', present in cv_src -> row 1 writes; id=2 -> 'BB', absent -> kept.
select id, lbl from cv_base order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (l) negative control — no over-qualify ---
-- Same computed-lineage view, but the user subquery FROM (cv_ok) has NO `id`, so
-- it does NOT shadow the lineage's correlation column. The lineage's genuinely-
-- local `fk` / `x` (owned by cv_oth, shadowed inside the lineage subquery, and not
-- base columns of cv_base) must stay local — if the deep qualifier wrongly
-- qualified them to cv_base.fk / cv_base.x the subquery would error (cv_base has no
-- such columns) or mis-evaluate. cv_ok holds only the row-1 match.
create table cv_ok (tag text);
insert into cv_ok values ('AA');

update cv_v set lbl = 'OK' where exists (select 1 from cv_ok where tag = note);
select id, lbl from cv_base order by id;
→ [{"id":1,"lbl":"OK"},{"id":2,"lbl":"B"}]

-- --- (m) DELETE variant — the delete path threads the same deep qualifier ---
-- The (k) repro shape on the delete path, confirming rewriteViewDelete threads the
-- correlation qualifier through its subquery descent too. Only row 1 deletes.
create table cd_base (id integer primary key, lbl text);
create table cd_oth (fk integer, x text);
create table cd_src (id integer, tag text);
insert into cd_base values (1, 'A'), (2, 'B');
insert into cd_oth values (1, 'AA'), (2, 'BB');
insert into cd_src values (99, 'AA');
create view cd_v as select id as id, lbl as lbl,
    (select x from cd_oth where fk = id) as note from cd_base;

delete from cd_v where exists (select 1 from cd_src where tag = note);
select id, lbl from cd_base order by id;
→ [{"id":2,"lbl":"B"}]

-- --- (n) lineage-subquery taint reject — unresolvable FROM *inside* the computed
--          lineage term itself (distinct from blocks (e)/(f), which taint the USER
--          subquery). The deep correlation-qualifier descends into the lineage
--          subquery and must prove which names its own FROM introduces in order to
--          know whether the bare `id` correlates out to the base row. The nested
--          `(select * from cn_oth)` source makes those names unresolvable, so the
--          qualifier rejects loudly rather than guess and risk a silent wrong write.
create table cn_base (id integer primary key, lbl text);
create table cn_oth (fk integer, x text);
create table cn_src (id integer, tag text);
insert into cn_base values (1, 'A');
create view cn_v as select id as id, lbl as lbl,
    (select x from (select * from cn_oth) as s where s.fk = id) as note from cn_base;

update cn_v set lbl = 'X' where exists (select 1 from cn_src where tag = note);
-- error: not statically resolvable

-- --- (o) the deep qualifier's SHADOW logic, isolated from its base-column gate ---
-- Blocks (k)/(l)/(m) only ever exercise the base-column GATE: the lineage subquery's
-- local columns (cv_oth.fk / .x) are excluded from qualification simply because they
-- are not columns of the base table. The `shadowed`-set accumulation inside
-- the base-qualify scope-transform descent (makeBaseQualifyScope) is only the *deciding* factor when a lineage-local
-- column name ALSO collides with a base column name — then the base-column gate alone
-- would wrongly qualify it, and only the shadow set keeps it local. Here so_oth has
-- its own `id` (colliding with so_base.id). The lineage `(select x from so_oth where
-- link = k and id = 1)` filters so_oth by its OWN id (=1) and correlates on `k`. The
-- shadow set must keep `id` bound to so_oth.id (local literal filter) while qualifying
-- only `k` to so_base.k. If `id` were (wrongly) qualified to so_base.id, the local
-- `id = 1` filter would vanish (becoming the per-row-constant so_base.id = 1) and the
-- subquery would select so_oth's first link-matching row ('Q') instead of 'P' — so the
-- EXISTS against so_src(tag='P') would no longer match row 1. Asserts row 1 writes.
create table so_base (id integer primary key, k integer, lbl text);
create table so_oth (id integer, link integer, x text);
create table so_src (id integer, tag text);
insert into so_base values (1, 10, 'A'), (2, 20, 'B');
insert into so_oth values (3, 10, 'Q'), (1, 10, 'P');
insert into so_src values (99, 'P');
create view so_v as select id as id, k as k, lbl as lbl,
    (select x from so_oth where link = k and id = 1) as note from so_base;

update so_v set lbl = 'HIT' where exists (select 1 from so_src where tag = note);
-- base row1 (k=10): so_oth where link=10 and so_oth.id=1 -> 'P', matches so_src -> writes.
-- base row2 (k=20): no link=20 row -> note NULL -> kept.
select id, lbl from so_base order by id;
→ [{"id":1,"lbl":"HIT"},{"id":2,"lbl":"B"}]

-- --- (p) same-base-table self-reference: the user subquery FROM names the view's OWN
--          base table — the corner the synthesised target alias closes ---
-- The view renames base `lbl` to view column `note`; the EXISTS subquery FROM is the
-- SAME base table (sr_t). `note` substitutes to base `lbl` and is correlation-qualified.
-- A bare-base-table-name qualifier (sr_t.lbl) would bind the INNER sr_t (innermost
-- scope) -> the predicate degrades to the uncorrelated sr_t.k = sr_t.lbl, true for the
-- ('A','A') row, so EVERY outer row would pass (a silent wrong write). The synthesised
-- alias on the lowered target (__vm_self.lbl) binds the OUTER row -> the predicate is
-- the correlated sr_t.k = <outer>.lbl -> only outer row 1 (lbl 'A', matched by k='A').
create table sr_t (id integer primary key, k text, lbl text);
insert into sr_t values (1, 'A', 'A'), (2, 'Z', 'B');
create view sr_v as select id as id, lbl as note from sr_t;

update sr_v set note = 'CHANGED' where exists (select 1 from sr_t where sr_t.k = note);
select id, lbl from sr_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- --- (q) DELETE variant — the delete path threads the same synthesised alias ---
create table dr_t (id integer primary key, k text, lbl text);
insert into dr_t values (1, 'A', 'A'), (2, 'Z', 'B');
create view dr_v as select id as id, lbl as note from dr_t;

delete from dr_v where exists (select 1 from dr_t where dr_t.k = note);
select id, lbl from dr_t order by id;
→ [{"id":2,"lbl":"B"}]

-- --- (r) RETURNING-subquery same-base-table correlation: SELF_ALIAS is threaded into
--          rewriteViewReturning, so a correlated subquery INSIDE a RETURNING clause binds
--          the outer target row the same way a WHERE subquery does. We mutate a NON-
--          correlation column (g) so the correlation column (note=lbl) is stable across
--          the write — the asserted count is unambiguous. The view renames base `lbl` to
--          `note`; the RETURNING subquery FROM is the SAME base table (rt_t). A bare-base-
--          table qualifier would de-correlate to `rt_t.k = rt_t.lbl` (matches only the one
--          ('A','A') row -> count 1); the synthesised alias binds the OUTER row's lbl 'A'
--          -> the correlated `rt_t.k = 'A'` matches BOTH rows -> count 2.
create table rt_t (id integer primary key, k text, grp text, lbl text);
insert into rt_t values (1, 'A', 'G', 'A'), (2, 'A', 'G', 'B');
create view rt_v as select id as id, grp as g, lbl as note from rt_t;

update rt_v set g = 'X' where id = 1 returning (select count(*) from rt_t where rt_t.k = note) as c;
→ [{"c":2}]

-- --- (s) `in (select ... where <correlation>)` descent form (the (p)/(q) blocks use
--          `exists`). The correlated `note` lives inside the IN-subquery's WHERE and FROMs
--          the SAME base table (ir_t). Correlated: for outer lbl 'A' the subquery yields
--          {'A'} so `'A' in (...)` holds (row 1 changes); for outer lbl 'B' it yields {} so
--          the row is untouched. De-correlated (`ir_t.k = ir_t.lbl`) would yield {'A'} for
--          EVERY outer row -> both rows would change (a silent wrong write).
create table ir_t (id integer primary key, k text, lbl text);
insert into ir_t values (1, 'A', 'A'), (2, 'Z', 'B');
create view ir_v as select id as id, lbl as note from ir_t;

update ir_v set note = 'CHANGED' where 'A' in (select ir_t.k from ir_t where ir_t.k = note);
select id, lbl from ir_t order by id;
→ [{"id":1,"lbl":"CHANGED"},{"id":2,"lbl":"B"}]

-- ===================================
-- Phase 2b: Multi-source key-preserving inner-join INSERT (shared-surrogate
-- envelope). The shared join key is not a view column, so its value is sourced
-- from the ANCHOR key column's declared `default`, evaluated ONCE per produced
-- logical row at the envelope (with `mutation_ordinal()` resolving to the row's
-- 1-based ordinal) and threaded into both base inserts via the equivalence class
-- (so the branches agree on identity). The engine itself mints nothing — the
-- basis author declares the policy. Sides are written FK-parent-before-FK-child.
-- See docs/view-updateability.md § Inner Join (Inserts), § Mutation Context.
-- ===================================

-- --- (a) the worked example: two base tables sharing a surrogate `rid` the view
--         hides. The anchor (u_core) declares a high-water-mark allocator default
--         `coalesce(max(rid),0) + mutation_ordinal()` — the user-authored
--         reconstruction of the retired zero-config `integer-auto` mint. One value
--         per row, shared across both base inserts ---
create table u_core (rid integer primary key default (coalesce((select max(rid) from u_core), 0) + mutation_ordinal()), name text);
create table u_contact (rid integer primary key, email text);
create view appuser as
    select c.name as name, k.email as email
    from u_core c join u_contact k on k.rid = c.rid;

insert into appuser (name, email) values ('Ada', 'ada@x.io'), ('Lin', 'lin@x.io');

-- Exactly one evaluation per row (rid 1 then 2), shared across both base inserts
-- of that row, distinct across rows.
select rid, name from u_core order by rid;
→ [{"rid":1,"name":"Ada"},{"rid":2,"name":"Lin"}]
select rid, email from u_contact order by rid;
→ [{"rid":1,"email":"ada@x.io"},{"rid":2,"email":"lin@x.io"}]

-- The write is visible through the view.
select name, email from appuser order by name;
→ [{"name":"Ada","email":"ada@x.io"},{"name":"Lin","email":"lin@x.io"}]

-- A second insert allocates ABOVE the existing keys (max(rid)=2 observed before any
-- base write), and the ordinal distinguishes rows of the multi-row insert.
insert into appuser (name, email) values ('Bo', 'bo@x.io'), ('Cy', 'cy@x.io');
select rid, name from u_core order by rid;
→ [{"rid":1,"name":"Ada"},{"rid":2,"name":"Lin"},{"rid":3,"name":"Bo"},{"rid":4,"name":"Cy"}]
select rid, email from u_contact order by rid;
→ [{"rid":1,"email":"ada@x.io"},{"rid":2,"email":"lin@x.io"},{"rid":3,"email":"bo@x.io"},{"rid":4,"email":"cy@x.io"}]

-- --- (b) the allocator default sits on the FK-PARENT anchor; FK-parent inserted
--         before the FK-child, so the child's shared key references a parent that
--         exists. The default allocates above a pre-existing parent row ---
create table msi_parent (pp integer primary key default (coalesce((select max(pp) from msi_parent), 0) + mutation_ordinal()), pv integer null);
create table msi_child (cc integer primary key, pr integer null, cv integer null,
    foreign key (pr) references msi_parent(pp));
create view msi_jv as
    select c.cc as cc, c.cv as cv, p.pv as pv
    from msi_child c join msi_parent p on p.pp = c.pr;
-- a pre-existing parent (explicit pp overrides the default) so the allocator must clear it.
insert into msi_parent values (40, 400);

insert into msi_jv (cc, cv, pv) values (1, 11, 111);
-- allocated pp = max(40)+1 = 41, shared as msi_child.pr.
select pp, pv from msi_parent order by pp;
→ [{"pp":40,"pv":400},{"pp":41,"pv":111}]
select cc, pr, cv from msi_child order by cc;
→ [{"cc":1,"pr":41,"cv":11}]
select cc, cv, pv from msi_jv order by cc;
→ [{"cc":1,"cv":11,"pv":111}]

-- a multi-row insert allocates a DISTINCT key per row, each shared across both sides.
insert into msi_jv (cc, cv, pv) values (2, 22, 222), (3, 33, 333);
select pp, pv from msi_parent order by pp;
→ [{"pp":40,"pv":400},{"pp":41,"pv":111},{"pp":42,"pv":222},{"pp":43,"pv":333}]
select cc, pr, cv from msi_child order by cc;
→ [{"cc":1,"pr":41,"cv":11},{"cc":2,"pr":42,"cv":22},{"cc":3,"pr":43,"cv":33}]

-- --- (c) a NON-DETERMINISTIC anchor default (a clock read) under
--         `nondeterministic_schema`: the value is captured ONCE per row at the
--         envelope and threaded to BOTH members, so they always agree on the key
--         (the load-bearing evaluate-once-and-thread guarantee). The ordinal makes
--         each row distinct even within one clock tick ---
pragma nondeterministic_schema = true;
create table ndc_core (rid integer primary key default (epoch_ms('now') * 1000 + mutation_ordinal()), name text);
create table ndc_contact (rid integer primary key, email text);
create view ndc_v as select c.name as name, k.email as email
    from ndc_core c join ndc_contact k on k.rid = c.rid;
insert into ndc_v (name, email) values ('Ada', 'a@x'), ('Lin', 'l@x');
-- The surrogate was evaluated once per row and threaded to both members, so every
-- core row joins exactly one contact row on the identical key, and the two rows are
-- distinct. (Exact rid values are non-deterministic, so we assert the invariants.)
select (select count(*) from ndc_core) as core_rows,
       (select count(*) from ndc_core c join ndc_contact k on k.rid = c.rid) as joined_rows,
       (select count(distinct rid) from ndc_core) as distinct_rids;
→ [{"core_rows":2,"joined_rows":2,"distinct_rids":2}]
pragma nondeterministic_schema = false;

-- --- (d) directly-supplied shared key: the view exposes the join key, so no
--         default is evaluated — the supplied value threads to both sides ---
create table dk_a (k integer primary key, av text);
create table dk_b (k integer primary key, bv text);
create view dk_v as select m.k as k, m.av as av, s.bv as bv
    from dk_a m join dk_b s on s.k = m.k;

insert into dk_v (k, av, bv) values (7, 'a7', 'b7'), (9, 'a9', 'b9');
select k, av from dk_a order by k;
→ [{"k":7,"av":"a7"},{"k":9,"av":"a9"}]
select k, bv from dk_b order by k;
→ [{"k":7,"bv":"b7"},{"k":9,"bv":"b9"}]
select k, av, bv from dk_v order by k;
→ [{"k":7,"av":"a7","bv":"b7"},{"k":9,"av":"a9","bv":"b9"}]

-- --- (e) a NOT NULL NON-KEY base column with no default and no supplied value ->
--         rejected (the anchor key has a default, so this isolates the must_have check) ---
create table nd_main (k integer primary key default (coalesce((select max(k) from nd_main), 0) + mutation_ordinal()), must_have text not null);
create table nd_side (k integer primary key, sv text);
create view nd_v as select m.k as k, s.sv as sv from nd_main m join nd_side s on s.k = m.k;
insert into nd_v (sv) values ('x');
-- error: no default

-- --- (f) a surrogate shared key whose anchor column declares NO default and is not
--         supplied -> rejected (the engine no longer invents one) ---
create table skn_core (rid integer primary key, name text);
create table skn_contact (rid integer primary key, email text);
create view skn_v as select c.name as name, k.email as email
    from skn_core c join skn_contact k on k.rid = c.rid;
insert into skn_v (name, email) values ('x', 'y');
-- error: neither supplied nor declares a default

-- --- (g) a computed (non-invertible) target column is not insertable ---
create table cm_a (k integer primary key, av integer);
create table cm_b (k integer primary key, bv integer);
create view cm_v as select a.k as k, a.av + 1 as bumped, b.bv as bv
    from cm_a a join cm_b b on b.k = a.k;
insert into cm_v (bumped, bv) values (5, 6);
-- error: non-invertible

-- --- (h) the shared key exposed by more than one view column (both sides of the
--         equi-join key) is over-specified: an insert cannot honor divergent
--         supplied values, so it is rejected rather than silently dropping one ---
create table bk_a (k integer primary key, av text);
create table bk_b (k integer primary key, bv text);
create view bk_v as select a.k as ka, b.k as kb, a.av as av, b.bv as bv
    from bk_a a join bk_b b on b.k = a.k;
insert into bk_v (ka, kb, av, bv) values (5, 7, 'a', 'b');
-- error: shared join key is exposed by more than one view column

-- --- (i) `mutation_ordinal()` is a general mutation-context primitive — it reaches
--         an ordinary single-source multi-row INSERT column default (not just the
--         decomposition envelope) and resolves to each row's 1-based ordinal, where a
--         window function cannot reach (the column-default position). NB: unlike the
--         envelope (which freezes a pre-mutation snapshot), a plain insert writes
--         incrementally, so compose the ordinal with deterministic state directly
--         rather than `max()` (which would already include prior rows of the same
--         statement) ---
create table mo_seq (id integer primary key, ord integer default (mutation_ordinal()), label text);
insert into mo_seq (id, label) values (10, 'a'), (20, 'b'), (30, 'c');
select id, ord, label from mo_seq order by id;
→ [{"id":10,"ord":1,"label":"a"},{"id":20,"ord":2,"label":"b"},{"id":30,"ord":3,"label":"c"}]

-- --- (j) the anchor key default reads a SUPPLIED sibling via `new.<col>`: the
--         minted shared key derives from a value the INSERT provides through the view
--         (the same `new.<col>` surface as the single-source insert path), evaluated
--         once per row at the envelope and threaded to both members. A member-table
--         column default also reads a supplied sibling via `new.<col>`. ---
create table ek_core (
    rid integer primary key default (coalesce((select max(rid) from ek_core), 0) + new.seq),
    seq integer,
    name text
);
create table ek_contact (rid integer primary key, email text, label text default (lower(new.email)));
create view ek_v as select c.seq as seq, c.name as name, k.email as email
    from ek_core c join ek_contact k on k.rid = c.rid;

-- max(rid)=0 frozen pre-mutation for BOTH rows, so each row's shared key derives from
-- its supplied `new.seq` (5 and 3 — distinct, and unequal to the 1,2 ordinals, proving
-- the value comes from the supplied sibling rather than the ordinal).
insert into ek_v (seq, name, email) values (5, 'Ada', 'A@X'), (3, 'Lin', 'L@X');
select rid, seq, name from ek_core order by rid;
→ [{"rid":3,"seq":3,"name":"Lin"},{"rid":5,"seq":5,"name":"Ada"}]
-- the member-table `label` default read its supplied sibling `new.email`.
select rid, email, label from ek_contact order by rid;
→ [{"rid":3,"email":"L@X","label":"l@x"},{"rid":5,"email":"A@X","label":"a@x"}]
-- every member agrees on the threaded identity (the join recovers both rows).
select seq, name, email from ek_v order by seq;
→ [{"seq":3,"name":"Lin","email":"L@X"},{"seq":5,"name":"Ada","email":"A@X"}]

-- a second insert observes the post-first-insert max(rid)=5 (pre-mutation for THIS
-- statement) and adds the supplied `new.seq`: 5 + 100 = 105.
insert into ek_v (seq, name, email) values (100, 'Bo', 'B@X');
select rid, seq from ek_core order by rid;
→ [{"rid":3,"seq":3},{"rid":5,"seq":5},{"rid":105,"seq":100}]

-- --- (k) a side default reads a CROSS-SIDE supplied sibling via `new.<col>`: the
--         FK-CHILD side carries a NOT NULL column `derived` whose default references a
--         logical column (`new.pv`) the PARENT side supplies — one the child's own base
--         table does NOT carry. This resolves only because the produced row's NEW
--         context threads into every side insert's default scope (the multi-source dual
--         of the decomposition cross-member case in 03.4-defaults). Before that threading
--         it raised `new.pv isn't a column` from the per-side buildInsertStmt. ---
create table msx_parent (pp integer primary key default (coalesce((select max(pp) from msx_parent), 0) + mutation_ordinal()), pv integer null);
create table msx_child (cc integer primary key, pr integer null, cv integer null,
    derived integer not null default (new.pv * 10),
    foreign key (pr) references msx_parent(pp));
create view msx_jv as
    select c.cc as cc, c.cv as cv, p.pv as pv
    from msx_child c join msx_parent p on p.pp = c.pr;

-- pv=7 is a PARENT-side supplied column; the CHILD's `derived` default reads it
-- (new.pv * 10 = 70), proving the cross-side resolution through the threaded NEW context.
insert into msx_jv (cc, cv, pv) values (1, 11, 7);
select cc, cv, derived from msx_child order by cc;
→ [{"cc":1,"cv":11,"derived":70}]
select pp, pv from msx_parent order by pp;
→ [{"pp":1,"pv":7}]

-- multi-row: each produced row resolves its OWN parent-side pv (per-row NEW context).
insert into msx_jv (cc, cv, pv) values (2, 22, 3), (3, 33, 9);
select cc, cv, derived from msx_child order by cc;
→ [{"cc":1,"cv":11,"derived":70},{"cc":2,"cv":22,"derived":30},{"cc":3,"cv":33,"derived":90}]

-- ===================================
-- RETURNING through a view (single- and multi-source).
-- The returned rows are projected through the VIEW's column list (not the base
-- tables'), evaluated against the post-mutation base state — so a computed view
-- column re-evaluates against the post-mutation base values, a renamed view column
-- keeps its view-spelling, and `returning *` expands to the view's columns.
-- See docs/view-updateability.md § `returning` Clauses.
-- ===================================

-- --- (a) single-source: rename + computed view columns, all three ops ---
-- empv renames base id/name, exposes base rate, and a computed `doubled` = rate*2.
create table emp (id integer primary key, name text, rate integer);
create view empv as
    select id as eid, name as ename, rate as ratev, rate * 2 as doubled from emp;
-- run

-- INSERT returns the view-projected NEW row; `doubled` evaluated post-insert.
insert into empv (eid, ename, ratev) values (1, 'Ann', 5)
    returning eid, ename, ratev, doubled;
→ [{"eid":1,"ename":"Ann","ratev":5,"doubled":10}]

-- UPDATE returns the view-projected NEW row; `doubled` re-evaluated post-update.
update empv set ratev = 7 where eid = 1 returning eid, ratev, doubled;
→ [{"eid":1,"ratev":7,"doubled":14}]

-- a multi-row insert returns one row per inserted row, in insertion order; the
-- computed column is evaluated per row.
insert into empv (eid, ename, ratev) values (2, 'B', 1), (3, 'C', 2)
    returning eid, doubled;
→ [{"eid":2,"doubled":2},{"eid":3,"doubled":4}]

-- DELETE returns the view-projected OLD (deleted) row; computed col over OLD vals.
delete from empv where eid = 1 returning eid, ename, doubled;
→ [{"eid":1,"ename":"Ann","doubled":14}]

-- the surviving rows confirm only eid=1 was deleted.
select eid, ratev from empv order by eid;
→ [{"eid":2,"ratev":1},{"eid":3,"ratev":2}]

-- --- (b) single-source filter view: a selection-predicate default appears in
--         RETURNING (the appended constant is part of the inserted NEW row), and
--         `returning *` expands to the view's column list ---
create table men2 (name text primary key, color text);
create view greenmen2 as select name, color from men2 where color = 'green';
-- run

insert into greenmen2 (name) values ('Bob') returning name, color;
→ [{"name":"Bob","color":"green"}]

insert into greenmen2 (name) values ('Carl') returning *;
→ [{"name":"Carl","color":"green"}]

-- --- (c) multi-source inner-join: update/delete RETURNING returns the joined,
--         view-projected rows (a re-query of the view; update reads the
--         post-mutation image, delete captures the pre-delete image) ---
create table rp (pid integer primary key, label text);
create table rc (cid integer primary key, pref integer, note text,
    foreign key (pref) references rp(pid));
insert into rp values (10, 'P10'), (20, 'P20');
insert into rc values (1, 10, 'a'), (2, 20, 'b');
create view rjoin as
    select c.cid as cid, c.note as note, p.label as label
    from rc c join rp p on p.pid = c.pref;
-- run

-- update a child-owned column; the returned view row reflects the post-update note.
update rjoin set note = 'A' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10"}]

-- update a parent-owned column (label is owned by rp, whose PK the projection
-- hides — identified through the join); the returned view row reflects it.
update rjoin set label = 'P20x' where cid = 2 returning cid, note, label;
→ [{"cid":2,"note":"b","label":"P20x"}]

-- update touching BOTH sides; the re-query returns the fully post-mutation row.
update rjoin set note = 'Z', label = 'P10z' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"Z","label":"P10z"}]

-- `returning *` through the join view expands to the view's columns.
delete from rjoin where cid = 1 returning *;
→ [{"cid":1,"note":"Z","label":"P10z"}]

-- the delete removed only the cid=1 child row; cid=2 remains.
select cid, note, label from rjoin order by cid;
→ [{"cid":2,"note":"b","label":"P20x"}]

-- A multi-source DELETE RETURNING of a body-COMPUTED view column (`banner`) is
-- recomputed in base terms over the planned join (NOT referenced by the optimizer-
-- eliminated intermediate output attribute id), mirroring the UPDATE RETURNING path.
create table dr_p (pid integer primary key, label text);
create table dr_c (cid integer primary key, pref integer, note text,
    foreign key (pref) references dr_p(pid));
insert into dr_p values (10, 'P10'), (20, 'P20');
insert into dr_c values (1, 10, 'a'), (2, 20, 'b'), (3, 10, 'c');
create view dr_jv as
    select c.cid as cid, c.note as note, p.label as label, c.note || '!' as banner
    from dr_c c join dr_p p on p.pid = c.pref;
-- run

-- a RETURNING ref to a hidden base column (`pref`, not a dr_jv output) is rejected by
-- the encapsulation guard — at plan time, before any row is deleted.
delete from dr_jv where cid = 1 returning pref;
-- error: is not a column of the view

-- the body-computed column `banner` (= note || '!') is recomputed for the deleted row.
delete from dr_jv where cid = 1 returning cid, banner;
→ [{"cid":1,"banner":"a!"}]

-- `returning *` over the join view with a computed column expands and computes it.
delete from dr_jv where cid = 2 returning *;
→ [{"cid":2,"note":"b","label":"P20","banner":"b!"}]

-- a computed RETURNING expression over a base-routed column stays green.
delete from dr_jv where cid = 3 returning note || '+' as notex;
→ [{"notex":"c+"}]

-- --- (d) multi-source update RETURNING where the predicate filters on a column the
--         update rewrites — per-row identity capture (the changed rows no longer
--         match the predicate, but their captured identity does). Two children per
--         parent so a parent-side update returns multiple rows; ascending memory-vtab
--         scan order is deterministic. See docs/view-updateability.md § `returning`.
create table rp2 (pid integer primary key, label text);
create table rc2 (cid integer primary key, pref integer, note text,
    foreign key (pref) references rp2(pid));
insert into rp2 values (10, 'P10'), (20, 'P20');
insert into rc2 values (1, 10, 'a'), (2, 10, 'a'), (3, 20, 'b');
create view rjoin2 as
    select c.cid as cid, c.note as note, p.label as label
    from rc2 c join rp2 p on p.pid = c.pref;
-- run

-- predicate on the rewritten CHILD column: cid 1,2 (note='a') update to 'A'.
update rjoin2 set note = 'A' where note = 'a' returning cid, note, label;
→ [{"cid":1,"note":"A","label":"P10"},{"cid":2,"note":"A","label":"P10"}]

-- predicate on a PARENT-owned column the update rewrites (label='P10' → pid 10 →
-- children 1,2). Parent label becomes 'PX'; both children re-projected.
update rjoin2 set label = 'PX' where label = 'P10' returning cid, note, label;
→ [{"cid":1,"note":"A","label":"PX"},{"cid":2,"note":"A","label":"PX"}]

-- BOTH sides assigned (child note + parent label), predicated on the PARENT's
-- reassigned column (`label = 'PX'`) — the clash this fix closes. The FK-parent op
-- rewrites `label` before the FK-child op's identifying subquery runs, so a live
-- re-query of the join body would find no 'PX' row and the child side would silently
-- no-op; the up-front identity capture pins cid 1,2 so BOTH per-side ops land and the
-- re-query re-projects the fully post-mutation rows.
update rjoin2 set note = 'B', label = 'PY' where label = 'PX' returning cid, note, label;
→ [{"cid":1,"note":"B","label":"PY"},{"cid":2,"note":"B","label":"PY"}]

-- BOTH sides assigned, predicated on the CHILD column the update also rewrites
-- (`note = 'B'` → 'C', plus `label` → 'PZ'); the capture identifies cid 1,2 the same
-- way regardless of which side's reassigned column the predicate filters on.
update rjoin2 set note = 'C', label = 'PZ' where note = 'B' returning cid, note, label;
→ [{"cid":1,"note":"C","label":"PZ"},{"cid":2,"note":"C","label":"PZ"}]

-- `returning *` through the join update, single-side child predicate-clash.
update rjoin2 set note = 'E' where note = 'C' returning *;
→ [{"cid":1,"note":"E","label":"PZ"},{"cid":2,"note":"E","label":"PZ"}]

-- --- (e) multi-source update RETURNING edge cases: push-out-of-filter (NEW
--         semantics), renamed + computed view columns through the capture re-query
--         projection, and empty-match. See docs/view-updateability.md § `returning`.

-- push-out-of-filter: a join view WITH a body WHERE. An update that moves a row
-- OUT of the view's filter must still be RETURNED (the capture matches by identity,
-- not the now-stale predicate — single-source NEW semantics; the re-query does not
-- re-apply the body/user WHERE).
create table fp (pid integer primary key, label text);
create table fc (cid integer primary key, pref integer, note text,
    foreign key (pref) references fp(pid));
insert into fp values (10, 'P10');
insert into fc values (1, 10, 'keep'), (2, 10, 'keep');
create view fjoin as
    select c.cid as cid, c.note as note, p.label as label
    from fc c join fp p on p.pid = c.pref where c.note = 'keep';
-- run

update fjoin set note = 'gone' where cid = 1 returning cid, note, label;
→ [{"cid":1,"note":"gone","label":"P10"}]

-- the row is now out of the view filter (note != 'keep'), so the view no longer
-- shows it; only cid=2 remains visible.
select cid, note, label from fjoin order by cid;
→ [{"cid":2,"note":"keep","label":"P10"}]

-- renamed (id←cid, quantity←qty, label←lbl) + computed (dbl = qty*2) view columns
-- surface under their VIEW spelling, computed re-evaluated post-update.
create table rp3 (pid integer primary key, lbl text);
create table rc3 (cid integer primary key, pref integer, qty integer,
    foreign key (pref) references rp3(pid));
insert into rp3 values (10, 'P10');
insert into rc3 values (1, 10, 5);
create view rjoin3 as
    select c.cid as id, c.qty as quantity, c.qty * 2 as dbl, p.lbl as label
    from rc3 c join rp3 p on p.pid = c.pref;
-- run

update rjoin3 set quantity = 8 where id = 1 returning id, quantity, dbl, label;
→ [{"id":1,"quantity":8,"dbl":16,"label":"P10"}]

-- empty match returns an empty set (EXISTS over zero captured identities), not an error.
update rjoin3 set quantity = 9 where id = 999 returning id, quantity;
→ []

-- ===================================
-- Top-level view-column scope (the encapsulation guard). A `where` / `set` /
-- `returning` reference must name a column the VIEW exposes; a base-only column the
-- view projects away must NOT silently resolve against the underlying base table.
-- See docs/view-updateability.md § Selection (Top-level view-column scope).
-- ===================================

create table t3 (id integer primary key, shown text not null, secret text);
create view sv as select id, shown from t3;          -- view exposes only (id, shown)
insert into t3 values (1, 'a', 'classified-1'), (2, 'b', 'classified-2');

-- (1) RETURNING leak: `secret` is a base-only column projected away by the view.
insert into sv (id, shown) values (3, 'g') returning id, secret;
-- error: not a column of the view

-- (2) WHERE leak: filtering on the projected-away base column.
update sv set shown = 'X' where secret = 'classified-2';
-- error: not a column of the view

-- (3) SET leak: assigning the projected-away base column.
update sv set secret = 'leaked' where id = 1;
-- error: not a column of the view

-- view-qualified reference to a projected-away base column rejects too.
update sv set shown = 'X' where sv.secret = 'classified-2';
-- error: not a column of the view

-- positive: where / set / returning on real view columns still succeed.
update sv set shown = 'Y' where id = 1 returning id, shown;
→ [{"id":1,"shown":"Y"}]
delete from sv where shown = 'b' returning id;
→ [{"id":2}]
select id, shown, secret from t3 order by id;
→ [{"id":1,"shown":"Y","secret":"classified-1"}]

-- (4) SET-value leak: the assigned RHS must also name view columns. A base-only
-- column on the RHS would otherwise READ a value the view hides (`secret`) into a
-- visible column — the same encapsulation leak as the where/set-target guard.
update sv set shown = secret where id = 1;
-- error: not a column of the view
update sv set shown = upper(secret) where id = 1;
-- error: not a column of the view

-- positive: a SET value that references a real view column (here inside a function)
-- passes the guard and is evaluated normally.
update sv set shown = 'lo' where id = 1;
update sv set shown = upper(shown) where id = 1 returning id, shown;
→ [{"id":1,"shown":"LO"}]

-- INSERT target-column list is guarded the same way (a base-only column is not an
-- insertable view column).
insert into sv (id, secret) values (5, 'x');
-- error: not a column of the view

-- renamed view column: the view spelling `note` is accepted; the base spelling
-- `label` is rejected (a renamed column's only legal reference is its view name).
create table pt (id integer primary key, label text);
insert into pt values (1, 'L1'), (2, 'L2');
create view pv as select id, label as note from pt;

update pv set note = 'L1x' where note = 'L1' returning id, note;
→ [{"id":1,"note":"L1x"}]

-- the base spelling `label` is not a view column -> rejected on where / set / returning.
update pv set note = 'Z' where label = 'L2';
-- error: not a column of the view
update pv set label = 'Z' where id = 2;
-- error: not a column of the view
-- the base spelling on the SET value (RHS) is rejected too.
update pv set note = label where id = 2;
-- error: not a column of the view
insert into pv (id, note) values (3, 'L3') returning id, label;
-- error: not a column of the view

-- computed view column: it IS a view column, so `returning <computed>` reads it,
-- but `set <computed>` still yields the existing no-inverse diagnostic (NOT the
-- unknown-view-column guard — the column exists, it is just not writable).
create table ct (id integer primary key, qty integer);
insert into ct values (1, 5);
create view cvv as select id, qty, qty * 2 as dbl from ct;

update cvv set qty = 7 where id = 1 returning id, qty, dbl;
→ [{"id":1,"qty":7,"dbl":14}]
update cvv set dbl = 99 where id = 1;
-- error: read-only

-- parity: a multi-source (join) view rejects an unknown top-level column the SAME
-- way (the guard reads consistently across the single- and multi-source spines).
create table jp (pid integer primary key, plabel text);
create table jc (cid integer primary key, pref integer, note text,
    foreign key (pref) references jp(pid));
insert into jp values (10, 'P10');
insert into jc values (1, 10, 'a');
create view jvscope as select c.cid as cid, c.note as note from jc c join jp p on p.pid = c.pref;

-- `plabel` is a base column owned by jp but projected away — not a view column.
update jvscope set note = 'X' where plabel = 'P10';
-- error: not a column of the view
delete from jvscope where plabel = 'P10';
-- error: not a column of the view
-- a SET target that is not a view column at all (vs. a computed one) -> same guard.
update jvscope set plabel = 'Z' where cid = 1;
-- error: not a column of the view
-- a SET value referencing a base-only column rejects the same way (previously a
-- generic "column not found"; now the structured unknown-view-column guard).
update jvscope set note = plabel where cid = 1;
-- error: not a column of the view

-- a multi-source UPDATE … RETURNING projecting a base-only column (the re-query
-- projects over the join body) is guarded the same way.
update jvscope set note = 'Y' where cid = 1 returning cid, plabel;
-- error: not a column of the view

-- ===================================
-- Outer joins (§ Outer Joins). A LEFT outer join is partially write-through-able:
-- the PRESERVED side (left) updates / deletes / inserts normally; the NON-preserved
-- (right) side is a presence-gated optional member of the insert fan-out and is
-- read-only on UPDATE (deferred — `unsupported-outer-join-update`). The preserved
-- anchor's partner declares the high-water-mark default the both-side insert mints
-- the shared key from. FK off so an unmatched (null-extended) child can exist.
-- ===================================
pragma foreign_keys = false;
create table ojp (pp integer primary key default (coalesce((select max(pp) from ojp), 0) + mutation_ordinal()), pv integer null);
create table ojc (cc integer primary key, pr integer null references ojp(pp), cv integer null);
create view ojv as select c.cc as cc, c.cv as cv, p.pv as pv from ojc c left join ojp p on p.pp = c.pr;

insert into ojp values (1, 10);
insert into ojc values (1, 1, 100);     -- joined row
insert into ojc values (2, null, 200);  -- null-extended row (no parent)

-- The view null-extends the unmatched child.
select cc, cv, pv from ojv order by cc;
→ [{"cc":1,"cv":100,"pv":10},{"cc":2,"cv":200,"pv":null}]

-- Preserved-side update propagates to the child — including the null-extended row,
-- which stays null-extended (the parent side is untouched).
update ojv set cv = 111 where cc = 1;
update ojv set cv = 222 where cc = 2;
select cc, cv, pv from ojv order by cc;
→ [{"cc":1,"cv":111,"pv":10},{"cc":2,"cv":222,"pv":null}]

-- A non-preserved-side update now propagates per row (the matched-update / null-extended-
-- insert materialization). cc=1 is matched (parent pp=1), so this updates the parent in
-- place; the null-extended materialization branch is exercised in property.spec.ts.
update ojv set pv = 99 where cc = 1;
select cc, pv from ojv where cc = 1;
→ [{"cc":1,"pv":99}]

-- Both-side insert: child + (presence-gated) parent under the minted shared key.
insert into ojv (cc, cv, pv) values (3, 33, 333);
select cc, cv, pv from ojv where cc = 3;
→ [{"cc":3,"cv":33,"pv":333}]

-- Preserved-only insert: a single child insert; the row reads back null-extended.
insert into ojv (cc, cv) values (4, 44);
select cc, cv, pv from ojv where cc = 4;
→ [{"cc":4,"cv":44,"pv":null}]

-- A non-preserved-only insert has no preserved anchor row to attach to — rejected.
insert into ojv (pv) values (999);
-- error: only non-preserved-side columns

-- Delete routes to the preserved (child) side: the joined row disappears and the
-- parent survives; a null-extended row is deletable too.
delete from ojv where cc = 1;
delete from ojv where cc = 2;
select cc, cv, pv from ojv order by cc;
→ [{"cc":3,"cv":33,"pv":333},{"cc":4,"cv":44,"pv":null}]
-- the parent of the deleted joined row survives (the delete hit only the child side),
-- carrying the pv=99 written through the matched non-preserved-side update above.
select pv from ojp order by pv;
→ [{"pv":99},{"pv":333}]

-- ===================================
-- Outer-join INSERT with FK ENFORCEMENT ON (the per-row conditional key thread).
-- The preserved (FK-child) side threads the minted shared key into its join column
-- only for rows whose non-preserved (FK-parent) partner is present that row; for a row
-- whose pv is null the partner insert is dropped and the child's `pr` is nulled — so
-- the FK never dangles (previously: `CHECK constraint failed: _fk_ojc2_pr`).
-- ===================================
pragma foreign_keys = true;
create table ojp2 (pp integer primary key default (coalesce((select max(pp) from ojp2), 0) + mutation_ordinal()), pv integer null);
create table ojc2 (cc integer primary key, pr integer null references ojp2(pp), cv integer null);
create view ojv2 as select c.cc as cc, c.cv as cv, p.pv as pv from ojc2 c left join ojp2 p on p.pp = c.pr;

-- Both-side insert with a NULL pv: the parent is dropped (presence-gated absent), the
-- child's `pr` is nulled, no FK violation. The row reads back null-extended.
insert into ojv2 (cc, cv, pv) values (5, 55, null);
select cc, cv, pv from ojv2 where cc = 5;
→ [{"cc":5,"cv":55,"pv":null}]
-- ojc2.pr is null (no dangling FK), and no parent was minted.
select pr from ojc2 where cc = 5;
→ [{"pr":null}]
select count(*) as n from ojp2;
→ [{"n":0}]

-- A non-null pv in the SAME multi-row insert still mints + threads the real key: the
-- parent materializes and the child's `pr` points at it (null pv row stays null-extended).
insert into ojv2 (cc, cv, pv) values (6, 66, null), (7, 77, 777);
select cc, cv, pv from ojv2 where cc in (6, 7) order by cc;
→ [{"cc":6,"cv":66,"pv":null},{"cc":7,"cv":77,"pv":777}]
-- cc=6 (null pv) reads pr null; cc=7 (non-null pv) reads pr = the minted parent key.
select cc, case when pr is null then 'null' else 'fk' end as pr_kind from ojc2 where cc in (6, 7) order by cc;
→ [{"cc":6,"pr_kind":"null"},{"cc":7,"pr_kind":"fk"}]
-- exactly one parent row materialized (for cc=7); its pv is the supplied 777.
select pv from ojp2 order by pv;
→ [{"pv":777}]

-- ===================================
-- SUPPLIED shared key (the join key is a writable view column, not minted): the per-row
-- key gate must NOT fire. The user's explicit key may reference a PRE-EXISTING parent the
-- insert never touches (pv left null because the parent already exists); nulling it would
-- silently discard the supplied key and orphan the child. FK enforcement validates a bad
-- reference instead. (Regression: the minted-key gate wrongly nulled the supplied key.)
-- ===================================
create table skp (pp integer primary key, pv integer null);
create table skc (cc integer primary key, pr integer null references skp(pp), cv integer null);
create view skv as select c.cc as cc, c.pr as k, c.cv as cv, p.pv as pv from skc c left join skp p on p.pp = c.pr;
-- A parent that already exists; the child points at it via the supplied key with pv null.
insert into skp (pp, pv) values (42, 4242);
insert into skv (cc, k, cv, pv) values (7, 42, 99, null);
-- The supplied key is preserved (pr = 42), so the child joins the pre-existing parent.
select cc, k, cv, pv from skv where cc = 7;
→ [{"cc":7,"k":42,"cv":99,"pv":4242}]
select pr from skc where cc = 7;
→ [{"pr":42}]
pragma foreign_keys = false;
