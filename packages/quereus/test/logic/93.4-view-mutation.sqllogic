-- View updateability — Phase 1 + 1b working cases.
-- Single-source projection-and-filter views are writeable; writes route to the
-- base table. See docs/view-updateability.md.

-- ===================================
-- GreenMen: constant-FD default from the selection predicate (select *)
-- ===================================

create table Men (Name text primary key, Color text);
create view GreenMen as select * from Men where Color = 'green';

insert into GreenMen (Name) values ('Bob');

select * from Men order by Name;
→ [{"Name":"Bob","Color":"green"}]

select * from GreenMen order by Name;
→ [{"Name":"Bob","Color":"green"}]

-- ===================================
-- AdultsBare: constant-FD default for a projected-away column
-- ===================================

create table Adults (Name text primary key, Age integer, Country text);
create view AdultsBare as select Name, Age from Adults where Country = 'US';

insert into AdultsBare values ('Bob', 30);

select * from Adults order by Name;
→ [{"Name":"Bob","Age":30,"Country":"US"}]

select * from AdultsBare order by Name;
→ [{"Name":"Bob","Age":30}]

-- ===================================
-- Base-column default survives projection
-- ===================================

create table u (id integer primary key, name text default 'unknown');
create view uv as select id from u;

insert into uv values (5);

select * from u order by id;
→ [{"id":5,"name":"unknown"}]

-- ===================================
-- Rename projection
-- ===================================

create table users (id integer primary key, name text);
create view RV as select id as user_id, name as full_name from users;

insert into RV (user_id, full_name) values (1, 'Bob');

select * from users order by id;
→ [{"id":1,"name":"Bob"}]

select * from RV order by user_id;
→ [{"user_id":1,"full_name":"Bob"}]

-- ===================================
-- Filter pass-through delete
-- ===================================

create table acct (id integer primary key, active integer, label text);
insert into acct values (5, 1, 'a'), (6, 0, 'b'), (7, 1, 'c');
create view ActiveUsers as select * from acct where active = 1;

delete from ActiveUsers where id = 5;

select id, active, label from acct order by id;
→ [{"id":6,"active":0,"label":"b"},{"id":7,"active":1,"label":"c"}]

-- ===================================
-- Filter pass-through update (the selection predicate is conjoined into WHERE)
-- ===================================

-- id=7 is visible (active=1): the update applies.
update ActiveUsers set label = 'C' where id = 7;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- id=6 is NOT visible (active=0): the conjoined predicate matches no base row.
update ActiveUsers set label = 'X' where id = 6;
select id, label from acct order by id;
→ [{"id":6,"label":"b"},{"id":7,"label":"C"}]

-- ===================================
-- Aliased base table + alias-qualified filter/projection: the alias qualifier
-- is normalized away when threading the body predicate into the base statement.
-- ===================================

create table al (id integer primary key, active integer, label text);
insert into al values (1, 1, 'a'), (2, 0, 'b'), (3, 1, 'c');
create view AliasView as select x.id as aid, x.label as alabel from al as x where x.active = 1;

-- visible row (active=1): update applies through the alias-qualified predicate.
update AliasView set alabel = 'Z' where aid = 1;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

-- invisible row (active=0): conjoined alias predicate matches no base row.
update AliasView set alabel = 'X' where aid = 2;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"},{"id":3,"label":"c"}]

delete from AliasView where aid = 3;
select id, label from al order by id;
→ [{"id":1,"label":"Z"},{"id":2,"label":"b"}]

-- ===================================
-- Phase 1b: per-statement mutation context threaded through the view
-- (one captured value stamped onto every row of the statement).
-- ===================================

create table evt (id integer primary key, created integer default now_ms) using memory with context (now_ms integer);
create view evt_v as select id from evt;

insert into evt_v with context now_ms = 12345 values (1), (2);

select * from evt order by id;
→ [{"id":1,"created":12345},{"id":2,"created":12345}]

-- ===================================
-- Phase 2: Multi-source key-preserving inner join — update / delete write-through.
-- The body is a two-table inner equi-join; writes route per owning base side via
-- a subquery over the join body (the row-identifying predicate). The owning side
-- can be the table whose PK the projection hides (ms_parent below).
-- See docs/view-updateability.md § Inner Join, § Multi-Base-Table Mutations.
-- ===================================

create table ms_parent (pid integer primary key, label text);
create table ms_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ms_parent(pid));
insert into ms_parent values (10, 'P10'), (20, 'P20');
insert into ms_child values (1, 10, 'a'), (2, 10, 'b'), (3, 20, 'c');

create view ms_jv as
    select c.cid as cid, c.note as note, p.label as label
    from ms_child c join ms_parent p on p.pid = c.pref;

-- read-through over the join
select * from ms_jv order by cid;
→ [{"cid":1,"note":"a","label":"P10"},{"cid":2,"note":"b","label":"P10"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE routed to the child side only (note is owned by ms_child).
update ms_jv set note = 'A' where cid = 1;
select cid, pref, note from ms_child order by cid;
→ [{"cid":1,"pref":10,"note":"A"},{"cid":2,"pref":10,"note":"b"},{"cid":3,"pref":20,"note":"c"}]

-- UPDATE routed to the parent side (label is owned by ms_parent, whose PK is
-- hidden by the projection — identified through the join). cid=1 joins pid=10.
update ms_jv set label = 'P10x' where cid = 1;
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20"}]

-- the parent update is visible to every child row joining pid=10.
select * from ms_jv order by cid;
→ [{"cid":1,"note":"A","label":"P10x"},{"cid":2,"note":"b","label":"P10x"},{"cid":3,"note":"c","label":"P20"}]

-- UPDATE touching BOTH sides -> two ordered base ops (FK-parent before FK-child).
update ms_jv set note = 'C', label = 'P20x' where cid = 3;
select cid, note from ms_child order by cid;
→ [{"cid":1,"note":"A"},{"cid":2,"note":"b"},{"cid":3,"note":"C"}]
select * from ms_parent order by pid;
→ [{"pid":10,"label":"P10x"},{"pid":20,"label":"P20x"}]

-- DELETE routes to the FK-many (child) side by default; the parent stays in place.
delete from ms_jv where cid = 2;
select cid from ms_child order by cid;
→ [{"cid":1},{"cid":3}]
select pid from ms_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- the deleted child row is gone from the view.
select cid from ms_jv order by cid;
→ [{"cid":1},{"cid":3}]

-- ===================================
-- Multi-source rejections (still diagnosed-and-rejected this phase).
-- ===================================

-- A computed (non-invertible) join column is read-only.
create view ms_jv_c as
    select c.cid as cid, p.label || '!' as banner
    from ms_child c join ms_parent p on p.pid = c.pref;
update ms_jv_c set banner = 'z' where cid = 1;
-- error: read-only

-- INSERT through a join view needs the shared-surrogate context (later phase).
insert into ms_jv (cid, note, label) values (9, 'q', 'P10x');
-- error: multi-source

-- RETURNING through a join view is not yet supported.
delete from ms_jv where cid = 1 returning cid;
-- error: RETURNING through view

-- ===================================
-- Phase 2: adversarial coverage (qualifier rewriting, body-WHERE conjunction,
-- column-list overrides, and the remaining shape rejections).
-- ===================================

create table ax_parent (pid integer primary key, pv integer);
create table ax_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references ax_parent(pid));
insert into ax_parent values (10, 100), (20, 200);
insert into ax_child values (1, 10, 'a'), (2, 20, 'b');

-- Swapped projection: the view column `pv` maps to the CHILD pk (ax_child.cid)
-- and the view column `cid` maps to the PARENT value (ax_parent.pv). A write must
-- route by lineage, not by name. `where cid = 100` filters on ax_parent.pv=100.
create view ax_swap as
    select p.pv as cid, c.cid as pv from ax_child c join ax_parent p on p.pid = c.pref;
select * from ax_swap order by pv;
→ [{"cid":100,"pv":1},{"cid":200,"pv":2}]
update ax_swap set pv = 7 where cid = 100;
select cid, pref from ax_child order by cid;
→ [{"cid":2,"pref":20},{"cid":7,"pref":10}]
select pid, pv from ax_parent order by pid;
→ [{"pid":10,"pv":100},{"pid":20,"pv":200}]

-- View-name-qualified predicate (jv.col) resolves to the base term.
create view ax_q as select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_q set note = 'z' where ax_q.cid = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"b"},{"cid":7,"note":"z"}]

-- The view body's own WHERE is conjoined: a predicate-less write only touches the
-- rows the body exposes (children whose parent pv > 150, i.e. pref = 20).
create view ax_filt as
    select c.cid as cid, c.note as note from ax_child c join ax_parent p on p.pid = c.pref where p.pv > 150;
select cid from ax_filt order by cid;
→ [{"cid":2}]
update ax_filt set note = 'F';
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"z"}]

-- Explicit view column-list override (create view v (a,b) as ...): writes route by
-- the override name to the underlying lineage.
create view ax_named (k, n) as select c.cid, c.note from ax_child c join ax_parent p on p.pid = c.pref;
update ax_named set n = 'g' where k = 7;
select cid, note from ax_child order by cid;
→ [{"cid":2,"note":"F"},{"cid":7,"note":"g"}]

-- Composite-PK side -> rejected (identifying predicate needs a single-column key).
create table ax_comp (c1 integer, c2 integer, pref integer, note text,
    primary key (c1, c2), foreign key (pref) references ax_parent(pid));
create view ax_jv_comp as
    select x.c1 as c1, x.note as note, p.pv as pv from ax_comp x join ax_parent p on p.pid = x.pref;
update ax_jv_comp set note = 'q' where c1 = 1;
-- error: cannot write through

-- Cross-source SET value (assign a column from the other base table) -> rejected.
create view ax_jv_x as
    select c.cid as cid, c.note as note, p.pv as pv from ax_child c join ax_parent p on p.pid = c.pref;
update ax_jv_x set note = pv where cid = 2;
-- error: cannot write through

-- Self-join body -> rejected.
create table ax_emp (id integer primary key, mgr integer, v integer);
create view ax_self as select e.id as id, m.v as mv from ax_emp e join ax_emp m on m.id = e.mgr;
update ax_self set mv = 9 where id = 1;
-- error: cannot write through

-- Three-table join -> rejected.
create table ax_b (bid integer primary key, v integer);
create view ax_three as
    select c.cid as cid, p.pv as pv, b.v as bv
    from ax_child c join ax_parent p on p.pid = c.pref join ax_b b on b.bid = c.cid;
update ax_three set pv = 9 where cid = 2;
-- error: cannot write through

-- DELETE through a join with no provable FK and no resolving tag -> ambiguous
-- under the default lenient policy (a delete_via / target override resolves it,
-- exercised in the override-surface section below).
create table ax_x (xid integer primary key, v integer);
create table ax_y (yid integer primary key, v integer);
insert into ax_x values (1, 5);
insert into ax_y values (5, 9);
create view ax_nofk as select x.xid as xid, y.yid as yid from ax_x x join ax_y y on y.yid = x.v;
delete from ax_nofk where xid = 1;
-- error: cannot delete through view

-- ===================================
-- Phase 3.4: the `quereus.update.*` tag override surface.
-- target / exclude / delete_via / policy / default_for — read + site-validated
-- through the typed reserved-tag registry, merged statement-over-view.
-- See docs/view-updateability.md § Tags: The Override Surface.
-- ===================================

-- --- default_for: statement-level omitted-insert default (single-source) ---
create table df_t (id integer primary key, created integer, note text);
create view df_v as select id, note from df_t;

-- `created` is projected away by the view; the statement-level default_for tag
-- supplies it (ahead of the base column's own default).
insert into df_v with tags ("quereus.update.default_for.created" = '777') values (5, 'x');
select * from df_t order by id;
→ [{"id":5,"created":777,"note":"x"}]

-- --- default_for: view-level default, overridden statement-over-view ---
create table df2 (id integer primary key, created integer);
create view df2_v as select id from df2 with tags ("quereus.update.default_for.created" = '111');

-- view-level default_for supplies the omitted column.
insert into df2_v values (1);
select * from df2 order by id;
→ [{"id":1,"created":111}]

-- statement-level default_for overrides the view-level one for this statement.
insert into df2_v with tags ("quereus.update.default_for.created" = '222') values (2);
select * from df2 order by id;
→ [{"id":1,"created":111},{"id":2,"created":222}]

-- a default_for naming a column that is neither a view nor a base column -> error.
insert into df2_v with tags ("quereus.update.default_for.nope" = '0') values (3);
-- error: not a column

-- --- target / exclude: narrow a multi-source delete to one side ---
create table tg_x (xid integer primary key, v integer, lx text);
create table tg_y (yid integer primary key, ly text);
insert into tg_x values (1, 5, 'x1'), (2, 6, 'x2');
insert into tg_y values (5, 'y5'), (6, 'y6');
create view tg_jv as
    select x.xid as xid, x.lx as lx, y.ly as ly from tg_x x join tg_y y on y.yid = x.v;
select * from tg_jv order by xid;
→ [{"xid":1,"lx":"x1","ly":"y5"},{"xid":2,"lx":"x2","ly":"y6"}]

-- target narrows the (no-FK ambiguous) delete to tg_x: only tg_x loses the row.
delete from tg_jv with tags ("quereus.update.target" = 'tg_x') where xid = 1;
select xid from tg_x order by xid;
→ [{"xid":2}]
select yid from tg_y order by yid;
→ [{"yid":5},{"yid":6}]

-- exclude tg_x routes the same shape to the OTHER side (tg_y); xid=2 joins y.yid=6.
delete from tg_jv with tags ("quereus.update.exclude" = 'tg_x') where xid = 2;
select yid from tg_y order by yid;
→ [{"yid":5}]
select xid from tg_x order by xid;
→ [{"xid":2}]

-- target naming a table not in the join -> sited tag-target-not-found.
delete from tg_jv with tags ("quereus.update.target" = 'nope') where xid = 2;
-- error: not a base table of the join

-- target/exclude excluding a side an UPDATE assigns -> structured conflict.
update tg_jv with tags ("quereus.update.exclude" = 'tg_x') set lx = 'z' where xid = 2;
-- error: excludes that table

-- --- delete_via: pick the deletion side explicitly ---
create table dv_l (lid integer primary key, v integer);
create table dv_r (rid integer primary key, w integer);
insert into dv_l values (1, 5), (2, 6);
insert into dv_r values (5, 50), (6, 60);
create view dv_jv as select l.lid as lid, r.rid as rid from dv_l l join dv_r r on r.rid = l.v;

-- delete_via='left_delete' picks the left join source (dv_l); dv_r is untouched.
delete from dv_jv with tags ("quereus.update.delete_via" = 'left_delete') where lid = 1;
select lid from dv_l order by lid;
→ [{"lid":2}]
select rid from dv_r order by rid;
→ [{"rid":5},{"rid":6}]

-- delete_via='parent' picks the FK-parent side; ON DELETE CASCADE removes the child.
create table dvp_parent (pid integer primary key, lbl text);
create table dvp_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references dvp_parent(pid) on delete cascade);
insert into dvp_parent values (10, 'P10'), (20, 'P20');
insert into dvp_child values (1, 10, 'a'), (2, 20, 'b');
create view dvp_jv as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from dvp_child c join dvp_parent p on p.pid = c.pref;
delete from dvp_jv with tags ("quereus.update.delete_via" = 'parent') where cid = 1;
select pid from dvp_parent order by pid;
→ [{"pid":20}]
select cid from dvp_child order by cid;
→ [{"cid":2}]

-- --- policy: strict refuses to guess; lenient auto-routes (FK-child default) ---
create table pol_parent (pid integer primary key, lbl text);
create table pol_child (cid integer primary key, pref integer, note text,
    foreign key (pref) references pol_parent(pid));
insert into pol_parent values (10, 'P10'), (20, 'P20');
insert into pol_child values (1, 10, 'a'), (2, 20, 'b');

-- lenient (default): the FK join delete auto-routes to the FK-child side.
create view pol_lenient as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from pol_child c join pol_parent p on p.pid = c.pref;
delete from pol_lenient where cid = 1;
select cid from pol_child order by cid;
→ [{"cid":2}]
select pid from pol_parent order by pid;
→ [{"pid":10},{"pid":20}]

-- strict (view-level policy tag): the same delete is rejected — strict will not
-- guess the deletion side even when an FK proves one.
create view pol_strict as
    select c.cid as cid, c.note as note, p.lbl as lbl
    from pol_child c join pol_parent p on p.pid = c.pref
    with tags ("quereus.update.policy" = 'strict');
delete from pol_strict where cid = 2;
-- error: policy

-- an explicit target (narrowing to one side) resolves the strict ambiguity.
delete from pol_strict with tags ("quereus.update.target" = 'pol_child') where cid = 2;
select cid from pol_child order by cid;
→ []

-- --- sited diagnostics for malformed reserved tags ---

-- unknown reserved key on a DML statement -> sited error.
update tg_jv with tags ("quereus.update.taget" = 'tg_x') set lx = 'z' where xid = 2;
-- error: unknown reserved tag

-- mis-sited reserved key on a DML statement (policy is view-DDL-only) -> error.
delete from tg_jv with tags ("quereus.update.policy" = 'strict') where xid = 2;
-- error: not allowed

-- unknown reserved key declared on the VIEW DDL -> surfaces (sited) at mutation.
create table bvu (id integer primary key, x integer);
create view bvu_v as select id from bvu with tags ("quereus.update.taget" = 'bvu');
insert into bvu_v values (1);
-- error: unknown reserved tag

-- ===================================
-- Phase 3.4: adversarial edges (review pass) — precedence, conflicting tags,
-- the except-only delete_via value on a join, and the single-source no-op.
-- ===================================

-- --- default_for precedence: an explicit supply of the column wins ---
-- The view projects `created`, so a statement that supplies it explicitly must
-- override the view-level default_for; an omitted insert still takes the default.
create table dfp (id integer primary key, created integer);
create view dfp_v as select id, created from dfp
    with tags ("quereus.update.default_for.created" = '111');
insert into dfp_v (id, created) values (1, 999);
insert into dfp_v (id) values (2);
select * from dfp order by id;
→ [{"id":1,"created":999},{"id":2,"created":111}]

-- --- delete_via='right_insert' is an except-only value -> rejected for a join ---
delete from dv_jv with tags ("quereus.update.delete_via" = 'right_insert') where lid = 2;
-- error: except

-- --- target + delete_via that disagree -> structured tag-conflict ---
-- target pins dv_r, but delete_via='left_delete' picks dv_l (excluded) -> conflict.
delete from dv_jv with tags ("quereus.update.target" = 'dv_r', "quereus.update.delete_via" = 'left_delete') where lid = 2;
-- error: excludes it

-- --- single-source view carrying a routing tag: a documented no-op ---
-- target/exclude only narrow a multi-source base set; on a single-source view the
-- tag is inert and an unknown name is NOT existence-checked (per the contract).
create table sst (id integer primary key, note text);
create view sst_v as select id, note from sst
    with tags ("quereus.update.target" = 'not_a_real_table');
insert into sst_v values (1, 'a');
select * from sst order by id;
→ [{"id":1,"note":"a"}]
