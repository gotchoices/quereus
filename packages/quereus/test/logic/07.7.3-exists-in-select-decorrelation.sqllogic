-- 07.7.3-exists-in-select-decorrelation.sqllogic
-- Correlated EXISTS / NOT EXISTS / IN in the SELECT list are decorrelated into
-- LEFT joins carrying an `exists right as` match flag (rule
-- exists-in-select-decorrelation). Every outer row must survive with the match
-- reported as a column — a semi/anti join cannot express that. These tests pin
-- the observable semantics of the decorrelated shapes AND the shapes the rule
-- must reject (which stay on the correlated per-row path).

-- Setup. c has THREE rows with fk = 10 — the fan-out hazard: a plain left join
-- would duplicate the outer row per match, so the rule must collapse the inner
-- side to one row per correlation key.
CREATE TABLE o (id INTEGER PRIMARY KEY, k INTEGER NULL, g INTEGER NULL);
CREATE TABLE c (id INTEGER PRIMARY KEY, fk INTEGER NULL, g INTEGER NULL, v INTEGER NULL);
INSERT INTO o VALUES (1, 10, 1), (2, 20, 1), (3, null, 2), (4, 30, 2);
INSERT INTO c VALUES (1, 10, 1, 5), (2, 10, 1, 6), (3, 10, 2, null), (4, 20, 2, 7), (5, null, 1, 8), (6, null, 1, 20);

-- EXISTS flag with inner fan-out (k=10 matches 3 inner rows): exactly one
-- output row per outer row; NULL outer key and no-match rows report false
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":true},{"id":3,"f":false},{"id":4,"f":false}]

-- NOT EXISTS: the NOT wrapper survives over the two-valued flag
SELECT o.id, NOT EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":false},{"id":3,"f":true},{"id":4,"f":true}]

-- Residual inner-only predicate alongside the correlation
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k AND c.v > 6) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":true},{"id":3,"f":false},{"id":4,"f":false}]

-- Composite (multi-conjunct) correlation
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k AND c.g = o.g) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":false},{"id":3,"f":false},{"id":4,"f":false}]

-- Multiple EXISTS in one SELECT list: one stacked join per subquery, flags distinct
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS a, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k AND c.v > 6) AS b FROM o ORDER BY o.id;
→ [{"id":1,"a":true,"b":false},{"id":2,"a":true,"b":true},{"id":3,"a":false,"b":false},{"id":4,"a":false,"b":false}]

-- EXISTS in the SELECT list AND in WHERE of the same query: the WHERE one
-- becomes a semi join (existing rule), the SELECT-list one a flag join
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k AND c.v > 6) AS f FROM o WHERE EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":true}]

-- EXISTS inside a CASE wrapper: only the inner node is substituted
SELECT o.id, CASE WHEN EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) THEN 'y' ELSE 'n' END AS b FROM o ORDER BY o.id;
→ [{"id":1,"b":"y"},{"id":2,"b":"y"},{"id":3,"b":"n"},{"id":4,"b":"n"}]

-- SELECT * inner body (multi-column projection is irrelevant to EXISTS)
SELECT o.id, EXISTS (SELECT * FROM c WHERE c.fk = o.k) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":true},{"id":3,"f":false},{"id":4,"f":false}]

-- Mixed with a correlated scalar-aggregate subquery in the same list (both
-- decorrelation rules fire on the same projection)
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f, (SELECT count(*) FROM c WHERE c.fk = o.k) AS n FROM o ORDER BY o.id;
→ [{"id":1,"f":true,"n":3},{"id":2,"f":true,"n":1},{"id":3,"f":false,"n":0},{"id":4,"f":false,"n":0}]

-- Correlated IN in the projection, both comparison sides non-nullable (o.id and
-- c.id are PKs): decorrelated; true / false / empty-inner-false all correct
SELECT o.id, (o.id IN (SELECT c.id FROM c WHERE c.fk = o.k)) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":false},{"id":3,"f":false},{"id":4,"f":false}]

-- NOT IN over the same non-nullable shape: NOT over the exact two-valued flag
SELECT o.id, (o.id NOT IN (SELECT c.id FROM c WHERE c.fk = o.k)) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":true},{"id":3,"f":true},{"id":4,"f":true}]

-- Rejected shapes: these stay on the correlated per-row path and must keep
-- today's (three-valued where applicable) semantics.

-- IN with a NULLABLE inner column: must bail — a no-match against a set
-- containing NULL yields NULL, not false (o.id 2: the only v=20 row has fk
-- NULL, so `2 IN (NULL)` is NULL)
SELECT o.id, (o.id IN (SELECT c.fk FROM c WHERE c.v = o.k)) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":null},{"id":3,"f":false},{"id":4,"f":false}]

-- NOT IN with inner NULLs: NULL propagates through the NOT (per-row path)
SELECT o.id, (o.id NOT IN (SELECT c.fk FROM c WHERE c.v = o.k)) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":null},{"id":3,"f":true},{"id":4,"f":true}]

-- Non-equi correlation: bail via the extraction gate; stays correlated but correct
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.v < o.k) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":true},{"id":3,"f":false},{"id":4,"f":true}]

-- Outer reference outside the equi-conjuncts (c.v = o.id + 4 is not a bare
-- column equality): bail; per-row result preserved
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k AND c.v = o.id + 4) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":true},{"id":2,"f":false},{"id":3,"f":false},{"id":4,"f":false}]

-- Uncorrelated EXISTS: not this rule's shape (cached per-statement already)
SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.v > 100) AS f FROM o ORDER BY o.id;
→ [{"id":1,"f":false},{"id":2,"f":false},{"id":3,"f":false},{"id":4,"f":false}]

-- Shape invariance: the decorrelated projection feeds a derived table consumed
-- by SELECT * — only the projected columns appear, no leaked join/flag columns
SELECT * FROM (SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o) sub ORDER BY sub.id;
→ [{"id":1,"f":true},{"id":2,"f":true},{"id":3,"f":false},{"id":4,"f":false}]

-- Flag consumed as a WHERE probe upstream (existence-flag recovery interaction):
-- results stay exact under any downstream semi/anti re-shaping
SELECT sub.id FROM (SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o) sub WHERE sub.f ORDER BY sub.id;
→ [{"id":1},{"id":2}]

SELECT sub.id FROM (SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o) sub WHERE NOT sub.f ORDER BY sub.id;
→ [{"id":3},{"id":4}]

-- Flag unused upstream (existence-flag pruning interaction): the outer query
-- never reads f; row count and values unchanged
SELECT sub.id FROM (SELECT o.id, EXISTS (SELECT 1 FROM c WHERE c.fk = o.k) AS f FROM o) sub ORDER BY sub.id;
→ [{"id":1},{"id":2},{"id":3},{"id":4}]
