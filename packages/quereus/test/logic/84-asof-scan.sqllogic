-- asof-scan.sqllogic — Streaming asof scan correctness via lateral-top-1 rule.
-- The rule fires only when the left input is monotonic on the match attribute,
-- so each query wraps the left side in `ORDER BY ts` (per partition or globally).
-- These cases run with the default `asof.mergeRowThreshold` (10000), keeping
-- the AsofScanNode on its `'hash'` strategy. The `'merge'` strategy's
-- equivalence is validated end-to-end in test/optimizer/asof-scan.spec.ts
-- (with `mergeRowThreshold = 0` forcing the promotion).

-- Setup: trades stream (left) and quotes stream (right, partitioned by symbol).
CREATE TABLE asof_trades (id INTEGER PRIMARY KEY, symbol TEXT, ts INTEGER);
CREATE TABLE asof_quotes (ts INTEGER PRIMARY KEY, symbol TEXT, bid REAL);

-- Trades inserted in ts order so the natural PK scan also yields ts-sorted rows
-- via id, but we still wrap the left in ORDER BY ts to keep the rule's
-- monotonicOn precondition explicit.
INSERT INTO asof_trades VALUES
  (1, 'A', 75),
  (2, 'A', 100),
  (3, 'A', 200),
  (4, 'B', 150),
  (5, 'C', 500);

INSERT INTO asof_quotes VALUES
  (50,  'A', 1.0),
  (150, 'A', 1.5),
  (180, 'B', 2.0),
  (250, 'A', 2.5);

-- Plan shape: ASOF SCAN must appear in the plan (when left is sorted on ts).
SELECT op FROM query_plan('select t.id, q.bid from (select id, symbol, ts from asof_trades order by ts) t left join lateral (select bid from asof_quotes q where q.symbol = t.symbol and q.ts <= t.ts order by q.ts desc limit 1) q on true') WHERE op = 'ASOFSCAN';
→ [{"op":"ASOFSCAN"}]

-- Partitioned non-strict left lateral. Left is sorted by ts.
-- t.id=1 (A,75): A quotes ≤ 75 are {50:1.0}. → 1.0
-- t.id=2 (A,100): {50:1.0}. → 1.0
-- t.id=3 (A,200): {50:1.0, 150:1.5}. → 1.5
-- t.id=4 (B,150): no B quote ≤ 150 (only ts=180 in B). → null
-- t.id=5 (C,500): no C quotes. → null
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":1.5},{"id":4,"bid":null},{"id":5,"bid":null}]

-- Inner cross join lateral drops left rows with no match.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t CROSS JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":1.5}]

-- Strict variant (q.ts < t.ts, no equality at the boundary).
-- t.id=1 (A,75): A quotes < 75 are {50:1.0}. → 1.0
-- t.id=2 (A,100): A quotes < 100 are {50:1.0}. → 1.0
-- t.id=3 (A,200): A quotes < 200 are {50, 150}. → 1.5
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts < t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":1.5},{"id":4,"bid":null},{"id":5,"bid":null}]

-- Boundary tie: when q.ts equals t.ts, non-strict matches; strict skips.
INSERT INTO asof_quotes VALUES (100, 'A', 9.9);

-- Non-strict (=): t.id=2 (ts=100) sees the tied 9.9.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true WHERE t.id = 2;
→ [{"id":2,"bid":9.9}]

-- Strict (<): t.id=2 (ts=100) skips the tie; falls back to ts=50, bid=1.0.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts < t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true WHERE t.id = 2;
→ [{"id":2,"bid":1}]

DELETE FROM asof_quotes WHERE ts = 100;

-- Empty right: outer left-pads, inner drops.
DELETE FROM asof_quotes;

SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":null},{"id":2,"bid":null},{"id":3,"bid":null},{"id":4,"bid":null},{"id":5,"bid":null}]

SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t CROSS JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ORDER BY t.id;
→ []

-- Restore quotes for the unpartitioned case.
INSERT INTO asof_quotes VALUES
  (50,  'A', 1.0),
  (150, 'A', 1.5),
  (180, 'B', 2.0),
  (250, 'A', 2.5);

-- Unpartitioned asof: any latest quote ≤ t.ts regardless of symbol.
-- Left sorted by ts: t.id=1(75), 2(100), 4(150), 3(200), 5(500)
-- t.id=1 (75):  ≤75  → 50  → 1.0
-- t.id=2 (100): ≤100 → 50  → 1.0
-- t.id=4 (150): ≤150 → 150 → 1.5
-- t.id=3 (200): ≤200 → 180 → 2.0
-- t.id=5 (500): ≤500 → 250 → 2.5
SELECT t.id, q.bid FROM (SELECT id, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":2},{"id":4,"bid":1.5},{"id":5,"bid":2.5}]

-- ASC variant plan-shape: ASOF SCAN must appear (left sorted on ts, q.ts >= t.ts ORDER BY q.ts ASC).
SELECT op FROM query_plan('select t.id, q.bid from (select id, symbol, ts from asof_trades order by ts) t left join lateral (select bid from asof_quotes q where q.symbol = t.symbol and q.ts >= t.ts order by q.ts asc limit 1) q on true') WHERE op = 'ASOFSCAN';
→ [{"op":"ASOFSCAN"}]

-- Partitioned non-strict ASC lateral. Left sorted by ts.
-- A quotes by ts: 50, 150, 250 ; B quotes by ts: 180
-- t.id=1 (A,75):  earliest A ≥ 75  → 150 → 1.5
-- t.id=2 (A,100): earliest A ≥ 100 → 150 → 1.5
-- t.id=4 (B,150): earliest B ≥ 150 → 180 → 2.0
-- t.id=3 (A,200): earliest A ≥ 200 → 250 → 2.5
-- t.id=5 (C,500): no C quote → null
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts >= t.ts ORDER BY q.ts ASC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1.5},{"id":2,"bid":1.5},{"id":3,"bid":2.5},{"id":4,"bid":2},{"id":5,"bid":null}]

-- Strict ASC variant (q.ts > t.ts) — boundary tie at q.ts = t.ts is excluded.
-- Add an exact-match quote to exercise the tie.
INSERT INTO asof_quotes VALUES (200, 'A', 7.7);

-- Non-strict ASC: t.id=3 (ts=200) sees the tied 7.7.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts >= t.ts ORDER BY q.ts ASC LIMIT 1
) q ON true WHERE t.id = 3;
→ [{"id":3,"bid":7.7}]

-- Strict ASC: t.id=3 (ts=200) skips the tie; falls through to ts=250 → 2.5.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts > t.ts ORDER BY q.ts ASC LIMIT 1
) q ON true WHERE t.id = 3;
→ [{"id":3,"bid":2.5}]

DELETE FROM asof_quotes WHERE ts = 200 AND bid = 7.7;

-- Inner cross-join lateral (ASC) drops left rows with no match.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades ORDER BY ts) t CROSS JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.symbol = t.symbol AND q.ts >= t.ts ORDER BY q.ts ASC LIMIT 1
) q ORDER BY t.id;
→ [{"id":1,"bid":1.5},{"id":2,"bid":1.5},{"id":3,"bid":2.5},{"id":4,"bid":2}]

-- Unpartitioned ASC: any earliest quote ≥ t.ts regardless of symbol.
-- All quotes by ts: 50, 150, 180, 250
-- t.id=1 (75):  earliest ≥ 75  → 150 → 1.5
-- t.id=2 (100): earliest ≥ 100 → 150 → 1.5
-- t.id=4 (150): earliest ≥ 150 → 150 → 1.5
-- t.id=3 (200): earliest ≥ 200 → 250 → 2.5
-- t.id=5 (500): earliest ≥ 500 → none → null
SELECT t.id, q.bid FROM (SELECT id, ts FROM asof_trades ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes q WHERE q.ts >= t.ts ORDER BY q.ts ASC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1.5},{"id":2,"bid":1.5},{"id":3,"bid":2.5},{"id":4,"bid":1.5},{"id":5,"bid":null}]

-- NOCASE partition: 'A' on the left must match the 'a' bucket on the right.
CREATE TABLE asof_trades_ci (id INTEGER PRIMARY KEY, symbol TEXT COLLATE NOCASE, ts INTEGER);
CREATE TABLE asof_quotes_ci (ts INTEGER PRIMARY KEY, symbol TEXT COLLATE NOCASE, bid REAL);

INSERT INTO asof_trades_ci VALUES
  (1, 'A', 100),
  (2, 'a', 200),
  (3, 'B', 150);

-- Right side uses lowercase; under NOCASE these must still bucket together.
INSERT INTO asof_quotes_ci VALUES
  (50,  'a', 1.0),
  (180, 'b', 2.0);

-- Partitioned non-strict desc: each left row finds the right bucket regardless of case.
-- t.id=1 (A,100): A/a quotes ≤ 100 → 50  → 1.0
-- t.id=2 (a,200): A/a quotes ≤ 200 → 50  → 1.0
-- t.id=3 (B,150): B/b quotes ≤ 150 → none (only ts=180) → null
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades_ci ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes_ci q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":null}]

DROP TABLE asof_trades_ci;
DROP TABLE asof_quotes_ci;

-- RTRIM partition: trailing-space differences must collapse into the same bucket.
CREATE TABLE asof_trades_rt (id INTEGER PRIMARY KEY, symbol TEXT COLLATE RTRIM, ts INTEGER);
CREATE TABLE asof_quotes_rt (ts INTEGER PRIMARY KEY, symbol TEXT COLLATE RTRIM, bid REAL);

INSERT INTO asof_trades_rt VALUES
  (1, 'B ',  100),
  (2, 'B  ', 200);

INSERT INTO asof_quotes_rt VALUES
  (50, 'B', 3.0);

-- Both left rows ('B ', 'B  ') match right bucket 'B' under COLLATE RTRIM.
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades_rt ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes_rt q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":3},{"id":2,"bid":3}]

DROP TABLE asof_trades_rt;
DROP TABLE asof_quotes_rt;

-- Asymmetric partition collation (ticket join-key-collation-resolution-alignment):
-- ONLY the right (quotes) side declares NOCASE; the left (trades) side defaults to
-- BINARY. The partition comparison resolves through the shared provenance lattice
-- to NOCASE (a declared collation outranks a defaulted BINARY) regardless of which
-- side spells it — so 'A' on the left still buckets with 'a' on the right. The
-- pre-alignment left-first `leftType.collationName ?? rightType.collationName`
-- picked the left's defaulted BINARY and the buckets diverged.
CREATE TABLE asof_trades_mix (id INTEGER PRIMARY KEY, symbol TEXT, ts INTEGER);
CREATE TABLE asof_quotes_mix (ts INTEGER PRIMARY KEY, symbol TEXT COLLATE NOCASE, bid REAL);

INSERT INTO asof_trades_mix VALUES (1, 'A', 100), (2, 'a', 200), (3, 'B', 150);
INSERT INTO asof_quotes_mix VALUES (50, 'a', 1.0), (180, 'b', 2.0);

-- This must remain an ASOFSCAN — the partition-collation resolution under review
-- only runs in the asof emitter; if the plan ever degraded to a generic correlated
-- subquery the result assertion below would pass vacuously without exercising it.
SELECT op FROM query_plan('select t.id, q.bid from (select id, symbol, ts from asof_trades_mix order by ts) t left join lateral (select bid from asof_quotes_mix q where q.symbol = t.symbol and q.ts <= t.ts order by q.ts desc limit 1) q on true') WHERE op = 'ASOFSCAN';
→ [{"op":"ASOFSCAN"}]

-- t.id=1 (A,100): A/a quotes ≤ 100 → ts=50 → 1.0
-- t.id=2 (a,200): A/a quotes ≤ 200 → ts=50 → 1.0
-- t.id=3 (B,150): B/b quotes ≤ 150 → none (only ts=180) → null
SELECT t.id, q.bid FROM (SELECT id, symbol, ts FROM asof_trades_mix ORDER BY ts) t LEFT JOIN LATERAL (
  SELECT bid FROM asof_quotes_mix q WHERE q.symbol = t.symbol AND q.ts <= t.ts ORDER BY q.ts DESC LIMIT 1
) q ON true ORDER BY t.id;
→ [{"id":1,"bid":1},{"id":2,"bid":1},{"id":3,"bid":null}]

DROP TABLE asof_trades_mix;
DROP TABLE asof_quotes_mix;

-- Cleanup
DROP TABLE asof_trades;
DROP TABLE asof_quotes;
