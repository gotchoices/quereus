-- ON CONFLICT (cols) DO UPDATE / DO NOTHING must match a conflict the targeted
-- constraint *enforces* — a collation-equal conflict (NOCASE case-variant, RTRIM
-- trailing-space) — and route it to the UPSERT arm instead of aborting with a
-- UNIQUE error. Ticket bug-upsert-conflict-target-collation-match.
-- Pre-fix, matchUpsertClause compared proposed vs stored by byte identity
-- (sqlValueIdentical), so every collation-variant scenario below wrongly aborted.
--
-- The affinity-coercion corner ('1' vs stored INTEGER 1) lives in the sibling
-- memory-only file 47.4-upsert-conflict-target-affinity.sqllogic — it exposes a
-- separate isolation-layer defect under the store backend (see that file's header
-- and fix/bug-store-isolation-upsert-affinity-coerced-pk).

-- ===================================
-- 1. NOCASE single-column UNIQUE — DO UPDATE runs on a case-variant conflict.
--    Proposed 'alice' collides with stored 'Alice' under NOCASE; the existing
--    row is updated (a new row is NOT inserted, and no UNIQUE abort).
-- ===================================

create table nc_u (id integer primary key, name text collate nocase unique, hits integer);
insert into nc_u values (1, 'Alice', 1);

insert into nc_u values (2, 'alice', 99) on conflict (name) do update set hits = hits + 1;
select id, name, hits from nc_u order by id;
→ [{"id":1,"name":"Alice","hits":2}]

-- ===================================
-- 2. NOCASE DO NOTHING arm — a case-variant conflict is SKIPPED, not aborted.
-- ===================================

insert into nc_u values (3, 'ALICE', 5) on conflict (name) do nothing;
select count(*) as cnt from nc_u;
→ [{"cnt":1}]
select id, name, hits from nc_u order by id;
→ [{"id":1,"name":"Alice","hits":2}]

-- Control: a genuinely different NOCASE value is NOT a conflict — it inserts.
insert into nc_u values (4, 'Bob', 1) on conflict (name) do update set hits = hits + 1;
select id, name, hits from nc_u order by id;
→ [{"id":1,"name":"Alice","hits":2},{"id":4,"name":"Bob","hits":1}]

drop table nc_u;

-- ===================================
-- 3. RTRIM UNIQUE — a trailing-space variant matches under RTRIM.
-- ===================================

create table rt_u (id integer primary key, code text collate rtrim unique, n integer);
insert into rt_u values (1, 'abc', 10);

insert into rt_u values (2, 'abc   ', 0) on conflict (code) do update set n = n + 1;
select id, code, n from rt_u order by id;
→ [{"id":1,"code":"abc","n":11}]

drop table rt_u;

-- ===================================
-- 4. Byte-identical regression control + different-constraint-still-aborts.
--    A BINARY key conflict still matches; a conflict on a DIFFERENT unique
--    constraint than the one named still aborts (the fix must not widen matching).
-- ===================================

create table scoped2 (id integer primary key, email text unique);
insert into scoped2 values (1, 'a@x');

-- byte-identical PK conflict still skipped (no regression)
insert into scoped2 values (1, 'a@x') on conflict (id) do nothing;
select count(*) as cnt from scoped2;
→ [{"cnt":1}]

-- conflict is on `email` (different PK), but the clause targets `id` → abort
insert into scoped2 values (2, 'a@x') on conflict (id) do nothing;
-- error: UNIQUE constraint failed

select id, email from scoped2 order by id;
→ [{"id":1,"email":"a@x"}]

drop table scoped2;

-- ===================================
-- 5. Composite target with per-column collations — each target column is
--    compared under its OWN column's collation. `a` matches exactly, `b`
--    matches under NOCASE.
-- ===================================

create table comp_coll (a integer, b text collate nocase, note text, unique (a, b));
insert into comp_coll values (1, 'Xy', 'orig');

insert into comp_coll values (1, 'XY', 'ignored') on conflict (a, b) do update set note = 'updated';
select a, b, note from comp_coll order by a;
→ [{"a":1,"b":"Xy","note":"updated"}]

-- A composite where only `a` collides (different `b` under NOCASE) is NOT a
-- conflict on (a, b) — it inserts as a new row.
insert into comp_coll values (1, 'Zz', 'second') on conflict (a, b) do update set note = 'updated';
select a, b, note from comp_coll order by b;
→ [{"a":1,"b":"Xy","note":"updated"},{"a":1,"b":"Zz","note":"second"}]

drop table comp_coll;

-- ===================================
-- 6. Index-derived UNIQUE with a per-column COLLATE on a BINARY column.
--    The enforcement collation is the INDEX's NOCASE, not the column's declared
--    BINARY — so 'HELLO' matches stored 'Hello'.
-- ===================================

create table idx_coll (id integer primary key, tag text);
create unique index idx_tag_nc on idx_coll (tag collate nocase);
insert into idx_coll values (1, 'Hello');

insert into idx_coll values (2, 'HELLO') on conflict (tag) do update set tag = 'seen';
select id, tag from idx_coll order by id;
→ [{"id":1,"tag":"seen"}]

drop table idx_coll;

-- ===================================
-- 7. WHERE guard on DO UPDATE combined with a collation-variant conflict. The
--    conflict is matched (NOCASE case-variant) so no new row inserts and no
--    UNIQUE abort, but the WHERE guard governs whether the update runs — a
--    false guard skips (DO NOTHING equivalent), a true guard updates.
-- ===================================

create table wg (id integer primary key, name text collate nocase unique, hits integer);
insert into wg values (1, 'Kite', 5);

-- guard false: conflict matched but update skipped, existing row untouched, no insert
insert into wg values (2, 'KITE', 0) on conflict (name) do update set hits = hits + 1 where hits > 100;
select id, name, hits from wg order by id;
→ [{"id":1,"name":"Kite","hits":5}]

-- guard true: same collation-variant conflict now updates
insert into wg values (3, 'kite', 0) on conflict (name) do update set hits = hits + 1 where hits < 100;
select id, name, hits from wg order by id;
→ [{"id":1,"name":"Kite","hits":6}]

drop table wg;

-- ===================================
-- 8. Multi-row INSERT mixing a collation-variant conflict row with clean rows
--    under a single statement — the variant row routes to DO UPDATE, the clean
--    rows insert, none abort.
-- ===================================

create table multi (id integer primary key, name text collate nocase unique, hits integer);
insert into multi values (1, 'Ada', 1);

insert into multi values (2, 'Bea', 1), (3, 'ADA', 0), (4, 'Cid', 1)
  on conflict (name) do update set hits = hits + 10;
select id, name, hits from multi order by id;
→ [{"id":1,"name":"Ada","hits":11},{"id":2,"name":"Bea","hits":1},{"id":4,"name":"Cid","hits":1}]

drop table multi;
