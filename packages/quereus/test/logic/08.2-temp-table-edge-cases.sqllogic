-- TEMP TABLE lifecycle: CREATE, INSERT, SELECT, UPDATE, DELETE, DROP.
-- Regression: relationTypeFromTableSchema previously marked temp tables
-- as isReadOnly, conflating them with views. Temp tables must remain
-- writable through the planner/runtime.

-- ===================================
-- 1. Full DML lifecycle on a TEMP TABLE
-- ===================================

create temp table tt (id integer primary key, val integer);

insert into tt values (1, 10), (2, 20);

select * from tt order by id;
→ [{"id": 1, "val": 10}, {"id": 2, "val": 20}]

-- Update a row
update tt set val = 25 where id = 2;

select * from tt order by id;
→ [{"id": 1, "val": 10}, {"id": 2, "val": 25}]

-- Delete a row
delete from tt where id = 1;

select * from tt order by id;
→ [{"id": 2, "val": 25}]

-- Insert again after delete to confirm the table is still mutable
insert into tt values (3, 30);

select count(*) as cnt from tt;
→ [{"cnt": 2}]

drop table tt;
