-- adapted from SQLite test/fkey1.test, test/fkey5.test, test/fkey7.test
-- FK target / shape variations beyond 41-foreign-keys.sqllogic.

pragma foreign_keys = true;

-- ===================================
-- 1. FK referencing a UNIQUE (non-PK) parent column
-- ===================================

create table p_uq (id integer primary key, code text not null unique);

create table c_uq (
	id integer primary key,
	p_code text,
	foreign key (p_code) references p_uq(code) on delete restrict
);

insert into p_uq values (1, 'AAA'), (2, 'BBB');

-- valid FK insert against UNIQUE-column parent target
insert into c_uq values (10, 'AAA');

-- invalid FK insert (no matching UNIQUE value)
insert into c_uq values (11, 'ZZZ');
-- error:

-- RESTRICT on parent UNIQUE column delete
delete from p_uq where code = 'AAA';
-- error:

-- delete unreferenced UNIQUE row succeeds
delete from p_uq where code = 'BBB';

select count(*) as cnt from p_uq;
→ [{"cnt":1}]

drop table c_uq;
drop table p_uq;

-- ===================================
-- 2. FK on a generated column
-- ===================================

create table p_gen (id integer primary key, code text generated always as ('K-' || id) virtual unique);

create table c_gen (
	id integer primary key,
	p_code text null,
	foreign key (p_code) references p_gen(code) on delete cascade
);

insert into p_gen (id) values (1), (2);

insert into c_gen values (10, 'K-1');

-- non-matching FK rejected
insert into c_gen values (11, 'K-9');
-- error:

-- cascade on parent delete
delete from p_gen where id = 1;

select id, p_code from c_gen;
→ []

drop table c_gen;
drop table p_gen;

-- ===================================
-- 3. COLLATE NOCASE on a TEXT parent-key column is accepted at DDL (the lowercase
--    `nocase` spelling normalizes to canonical NOCASE)
--    — unique-collation-name-case-insensitive-normalization.
-- ===================================

create table p_nc (id integer primary key, code text collate nocase unique not null);

drop table if exists p_nc;

-- ===================================
-- 4. Multiple distinct FK constraints on the same child table
-- ===================================

create table fa (id integer primary key, name text);
create table fb (id integer primary key, label text);

create table fc (
	id integer primary key,
	a_id integer null,
	b_id integer null,
	foreign key (a_id) references fa(id) on delete cascade,
	foreign key (b_id) references fb(id) on delete restrict
);

insert into fa values (1, 'A1');
insert into fb values (1, 'B1');
insert into fc values (10, 1, 1);

-- bad FK in a_id
insert into fc values (11, 99, 1);
-- error:

-- bad FK in b_id
insert into fc values (12, 1, 99);
-- error:

-- restrict on fb
delete from fb where id = 1;
-- error:

-- cascade on fa
delete from fa where id = 1;

select count(*) as cnt from fc;
→ [{"cnt":0}]

drop table fc;
drop table fb;
drop table fa;

-- ===================================
-- 5. FK with mismatched child / parent column count rejected at CREATE
-- ===================================

create table mp (a integer not null, b integer not null, primary key (a, b));

create table mc (id integer primary key, x integer null,
	foreign key (x) references mp(a, b));
-- error:

drop table if exists mc;
drop table mp;

-- ===================================
-- 6. FK to non-existent parent table errors when child row inserted
-- ===================================

create table c_orphan (id integer primary key, p_id integer null,
	foreign key (p_id) references no_such_parent(id));

-- NULL FK — MATCH SIMPLE allows insert into empty/missing parent
insert into c_orphan values (1, null);

-- non-NULL FK to missing parent table errors
insert into c_orphan values (2, 1);
-- error:

drop table c_orphan;

-- ===================================
-- 7. Multi-column FK with parent column order different from declaration
-- ===================================

create table mp2 (a integer not null, b integer not null, primary key (a, b));

-- FK lists parent columns in (b, a) order; child's (x, y) maps to parent's (b, a)
create table mc2 (
	id integer primary key,
	x integer null,
	y integer null,
	foreign key (x, y) references mp2(b, a)
);

insert into mp2 values (1, 100), (2, 200);

-- (x=100, y=1) → looks up parent (b=100, a=1) → exists
insert into mc2 values (10, 100, 1);

-- (x=1, y=100) → looks up parent (b=1, a=100) → no such row
insert into mc2 values (11, 1, 100);
-- error:

drop table mc2;
drop table mp2;
