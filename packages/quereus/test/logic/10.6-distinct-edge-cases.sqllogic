-- adapted from SQLite test/distinct.test, test/distinct2.test, test/select1.test
-- DISTINCT edge cases not covered in 10-distinct_datatypes: select-all
-- wildcards, joins, recursive CTEs, reordered SELECT lists, and explicit
-- COLLATE in the projection.

create table dt (id integer primary key, grp text, val integer);
insert into dt values
  (1, 'A', 100),
  (2, 'A', 100),
  (3, 'B', 200),
  (4, 'A', 100);

-- DISTINCT * — full row deduplication
select distinct * from dt order by id;
→ [{"id":1,"grp":"A","val":100},{"id":2,"grp":"A","val":100},{"id":3,"grp":"B","val":200},{"id":4,"grp":"A","val":100}]

-- DISTINCT * after dropping the unique key — duplicate rows collapse
select distinct grp, val from dt order by grp, val;
→ [{"grp":"A","val":100},{"grp":"B","val":200}]

-- DISTINCT with WHERE filter
select distinct * from dt where grp = 'A' order by id;
→ [{"id":1,"grp":"A","val":100},{"id":2,"grp":"A","val":100},{"id":4,"grp":"A","val":100}]

-- DISTINCT preserves dedup regardless of SELECT-list order
select distinct val, grp from dt order by val, grp;
→ [{"val":100,"grp":"A"},{"val":200,"grp":"B"}]

drop table dt;

-- =============================================================================
-- DISTINCT across CROSS JOIN — Cartesian product then dedup
-- =============================================================================

create table cj_a (id integer primary key, x integer);
create table cj_b (id integer primary key, y integer);
insert into cj_a values (1, 1), (2, 2);
insert into cj_b values (1, 10), (2, 20), (3, 10);

select distinct cj_a.x, cj_b.y
from cj_a cross join cj_b
order by cj_a.x, cj_b.y;
→ [{"x":1,"y":10},{"x":1,"y":20},{"x":2,"y":10},{"x":2,"y":20}]

drop table cj_b;
drop table cj_a;

-- =============================================================================
-- DISTINCT across LEFT JOIN — NULL-padded rows participate in dedup
-- =============================================================================

create table lj_l (id integer primary key, cat text);
create table lj_r (id integer primary key, lj_l_id integer, tag text);
insert into lj_l values (1, 'A'), (2, 'B'), (3, 'A');
insert into lj_r values (10, 1, 'x'), (20, 2, 'y');

-- DISTINCT on the parent column: LEFT JOIN's NULL-padded right side doesn't
-- duplicate the parent — categories collapse to A, B.
select distinct lj_l.cat
from lj_l left join lj_r on lj_l.id = lj_r.lj_l_id
order by lj_l.cat;
→ [{"cat":"A"},{"cat":"B"}]

-- DISTINCT including the joined column — NULL appears once for unmatched parent (lj_l.id=3)
select distinct lj_l.cat, lj_r.tag
from lj_l left join lj_r on lj_l.id = lj_r.lj_l_id
order by lj_l.cat, lj_r.tag;
→ [{"cat":"A","tag":null},{"cat":"A","tag":"x"},{"cat":"B","tag":"y"}]

drop table lj_r;
drop table lj_l;

-- =============================================================================
-- DISTINCT inside a recursive CTE
-- =============================================================================

with recursive cnt(n) as (
  select 1
  union all
  select n + 1 from cnt where n < 4
)
select distinct n from cnt order by n;
→ [{"n":1},{"n":2},{"n":3},{"n":4}]

-- DISTINCT applied to the body of a non-recursive CTE that emits dups
with src(v) as (
  select 1 union all select 2 union all select 1 union all select 3 union all select 2
)
select distinct v from src order by v;
→ [{"v":1},{"v":2},{"v":3}]

-- =============================================================================
-- DISTINCT with explicit COLLATE in the projection
-- =============================================================================

create table cs (id integer primary key, name text);
insert into cs values (1, 'Bob'), (2, 'bob'), (3, 'Alice'), (4, 'BOB');

-- COLLATE BINARY (default) keeps case-distinct values
select distinct name from cs order by name;
→ [{"name":"Alice"},{"name":"BOB"},{"name":"Bob"},{"name":"bob"}]

-- COLLATE NOCASE in the projection collapses case-equivalent strings
select distinct name collate nocase as name from cs order by name collate nocase;
→ [{"name":"Alice"},{"name":"Bob"}]

drop table cs;

-- =============================================================================
-- DISTINCT with duplicate column reference — same column projected twice
-- =============================================================================

create table dc (id integer primary key, x integer);
insert into dc values (1, 100), (2, 100), (3, 200);

select distinct x, x from dc order by x;
→ [{"x":100,"x:1":100},{"x":200,"x:1":200}]

drop table dc;
