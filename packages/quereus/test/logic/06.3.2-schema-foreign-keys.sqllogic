-- schema-foreign-keys.sqllogic - Testing foreign_key_info() TVF

-- ===================================================================
-- Setup: Parent tables
-- ===================================================================

CREATE TABLE authors (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL
);

CREATE TABLE categories (
    id INTEGER PRIMARY KEY,
    label TEXT NOT NULL
);

-- ===================================================================
-- Test 1: Basic single-column FK
-- ===================================================================

CREATE TABLE books (
    id INTEGER PRIMARY KEY,
    title TEXT NOT NULL,
    author_id INTEGER,
    FOREIGN KEY (author_id) REFERENCES authors(id)
);

SELECT id, "table", "from", referenced_table, "to", on_update, on_delete, "deferred", seq
FROM foreign_key_info('books');
→ [{"id":0,"table":"books","from":"author_id","referenced_table":"authors","to":"id","on_update":"restrict","on_delete":"restrict","deferred":0,"seq":0}]

-- ===================================================================
-- Test 2: Table with no FKs returns empty result
-- ===================================================================

SELECT count(*) as cnt FROM foreign_key_info('authors');
→ [{"cnt":0}]

-- ===================================================================
-- Test 3: Named constraint
-- ===================================================================

CREATE TABLE articles (
    id INTEGER PRIMARY KEY,
    author_id INTEGER,
    CONSTRAINT fk_article_author FOREIGN KEY (author_id) REFERENCES authors(id)
);

SELECT id, name, "from", "to" FROM foreign_key_info('articles');
→ [{"id":0,"name":"fk_article_author","from":"author_id","to":"id"}]

DROP TABLE articles;

-- ===================================================================
-- Test 4: ON DELETE/UPDATE actions
-- ===================================================================

CREATE TABLE posts (
    id INTEGER PRIMARY KEY,
    author_id INTEGER,
    FOREIGN KEY (author_id) REFERENCES authors(id) ON DELETE CASCADE ON UPDATE RESTRICT
);

SELECT on_update, on_delete FROM foreign_key_info('posts');
→ [{"on_update":"restrict","on_delete":"cascade"}]

DROP TABLE posts;

-- ===================================================================
-- Test 5: Multiple FKs on one table — distinct id values
-- ===================================================================

CREATE TABLE tagged_books (
    id INTEGER PRIMARY KEY,
    author_id INTEGER,
    category_id INTEGER,
    FOREIGN KEY (author_id) REFERENCES authors(id),
    FOREIGN KEY (category_id) REFERENCES categories(id)
);

SELECT id, "from", referenced_table FROM foreign_key_info('tagged_books') ORDER BY id;
→ [{"id":0,"from":"author_id","referenced_table":"authors"},{"id":1,"from":"category_id","referenced_table":"categories"}]

DROP TABLE tagged_books;

-- ===================================================================
-- Test 6: Composite FK — multiple rows with same id, different seq
-- ===================================================================

CREATE TABLE composite_parent (
    a INTEGER,
    b INTEGER,
    PRIMARY KEY (a, b)
);

CREATE TABLE composite_child (
    id INTEGER PRIMARY KEY,
    ref_a INTEGER,
    ref_b INTEGER,
    FOREIGN KEY (ref_a, ref_b) REFERENCES composite_parent(a, b)
);

SELECT id, "from", "to", seq FROM foreign_key_info('composite_child') ORDER BY seq;
→ [{"id":0,"from":"ref_a","to":"a","seq":0},{"id":0,"from":"ref_b","to":"b","seq":1}]

DROP TABLE composite_child;
DROP TABLE composite_parent;

-- ===================================================================
-- Test 7: Auto-generated constraint name for unnamed constraints
-- ===================================================================

SELECT name FROM foreign_key_info('books');
→ [{"name":"_fk_books_author_id"}]

-- ===================================================================
-- Test 8: Nonexistent table throws error
-- ===================================================================

SELECT * FROM foreign_key_info('nonexistent_table');
-- error: Table 'nonexistent_table' not found

-- ===================================================================
-- Cleanup
-- ===================================================================

DROP TABLE books;
DROP TABLE categories;
DROP TABLE authors;
