-- where-extras.sqllogic - WHERE-clause shapes not exercised by 100-predicate-normalization
-- Distilled from SQLite test/where.test, where4.test, where7.test, where8.test, where9.test

create table we (id integer primary key, a integer null, b integer null, c integer null);
insert into we values
  (1, 10, 100, 1),
  (2, 20, 200, 2),
  (3, 30, 300, 3),
  (4, 40, 400, 4),
  (5, 50, 500, 5),
  (6, null, null, null);

-- =============================================================================
-- Constant WHERE: short-circuit always-true / always-false predicates
-- =============================================================================

select count(*) as cnt from we where 1;
→ [{"cnt":6}]

select count(*) as cnt from we where 0;
→ [{"cnt":0}]

select count(*) as cnt from we where true;
→ [{"cnt":6}]

select count(*) as cnt from we where false;
→ [{"cnt":0}]

select count(*) as cnt from we where 1 = 1;
→ [{"cnt":6}]

select count(*) as cnt from we where 1 = 0;
→ [{"cnt":0}]

-- Constant comparison combined with column predicate
select id from we where 1 = 1 and a > 30 order by id;
→ [{"id":4},{"id":5}]

select id from we where 1 = 0 or a = 10 order by id;
→ [{"id":1}]

-- =============================================================================
-- AND combined with multi-branch OR (x AND (y OR z))
-- =============================================================================

select id from we where a > 15 and (b = 200 or b = 400) order by id;
→ [{"id":2},{"id":4}]

select id from we where a > 15 and (b = 200 or c >= 4) order by id;
→ [{"id":2},{"id":4},{"id":5}]

-- (x OR y) AND z: distributes correctly
select id from we where (a = 10 or a = 30) and b > 50 order by id;
→ [{"id":1},{"id":3}]

-- =============================================================================
-- Composite OR over (a AND b) tuples
-- =============================================================================

select id from we where (a = 10 and b = 100) or (a = 30 and b = 300) order by id;
→ [{"id":1},{"id":3}]

-- Tuple OR where one disjunct fails the b test
select id from we where (a = 10 and b = 999) or (a = 30 and b = 300) order by id;
→ [{"id":3}]

-- =============================================================================
-- Multi-range OR (BETWEEN inside OR)
-- =============================================================================

select id from we where a between 10 and 20 or a between 40 and 50 order by id;
→ [{"id":1},{"id":2},{"id":4},{"id":5}]

select id from we where (a between 10 and 20) or (b between 300 and 400) order by id;
→ [{"id":1},{"id":2},{"id":3},{"id":4}]

-- BETWEEN inside OR mixed with equality
select id from we where a = 50 or a between 15 and 25 order by id;
→ [{"id":2},{"id":5}]

-- =============================================================================
-- Three-column AND/OR composite
-- =============================================================================

select id from we where a > 10 and (b = 100 or b = 200 or c >= 4) order by id;
→ [{"id":2},{"id":4},{"id":5}]

select id from we where a > 10 and (b > 250 and c < 5) order by id;
→ [{"id":3},{"id":4}]

-- =============================================================================
-- OR with IS NULL: non-null disjunct wins, null rows kept via IS NULL
-- =============================================================================

select id from we where a > 25 or a is null order by id;
→ [{"id":3},{"id":4},{"id":5},{"id":6}]

-- IS NULL combined with AND
select id from we where a is null or (b > 100 and c < 4) order by id;
→ [{"id":2},{"id":3},{"id":6}]

-- =============================================================================
-- IN list deduplication: duplicate values produce no duplicate rows
-- =============================================================================

select id from we where a in (10, 10, 30, 30, 30) order by id;
→ [{"id":1},{"id":3}]

-- =============================================================================
-- Reordered ON-clause conjunction equivalence (LEFT JOIN)
-- =============================================================================

create table wj_l (id integer primary key, k integer);
create table wj_r (id integer primary key, k integer, tag integer);
insert into wj_l values (1, 1), (2, 2);
insert into wj_r values (10, 1, 1), (20, 1, 3), (30, 2, 1), (40, 2, 3);

-- ON term order should not affect result
select wj_l.id as lid, wj_r.id as rid from wj_l left join wj_r on wj_l.k = wj_r.k and wj_r.tag = 1 order by lid, rid;
→ [{"lid":1,"rid":10},{"lid":2,"rid":30}]

select wj_l.id as lid, wj_r.id as rid from wj_l left join wj_r on wj_r.tag = 1 and wj_r.k = wj_l.k order by lid, rid;
→ [{"lid":1,"rid":10},{"lid":2,"rid":30}]

-- Index presence on the ON columns must not change results
create index wj_r_k_tag on wj_r(k, tag);

select wj_l.id as lid, wj_r.id as rid from wj_l left join wj_r on wj_l.k = wj_r.k and wj_r.tag = 1 order by lid, rid;
→ [{"lid":1,"rid":10},{"lid":2,"rid":30}]

drop index wj_r_k_tag;
drop table wj_l;
drop table wj_r;

drop table we;

-- =============================================================================
-- same-table column-column equality: must not crash (regression: seek crash)
-- A col = same_col predicate is a per-row filter, never a seek key.
-- =============================================================================

create table samecolpk (b text primary key, c text);
insert into samecolpk values ('u', 'u'), ('v', 'w'), ('x', 'x');

-- simple PK: matching rows returned, no crash
select b from samecolpk where b = c order by b;
→ [{"b":"u"},{"b":"x"}]

-- with inequality too
select b from samecolpk where b = c and c != 'x';
→ [{"b":"u"}]

drop table samecolpk;

-- composite PK: b=c with the other key column pinned must not crash
create table samecolcomp (b text, c text, x integer, primary key (b, x));
insert into samecolcomp values ('u','u',1), ('u','u',2), ('v','v',1), ('w','v',1);

-- both pk columns specified but b=c is still a per-row filter
select b, c, x from samecolcomp where b = c and x = 1 order by b;
→ [{"b":"u","c":"u","x":1},{"b":"v","c":"v","x":1}]

-- without x pin: b=c alone as filter
select b, c, x from samecolcomp where b = c order by b, x;
→ [{"b":"u","c":"u","x":1},{"b":"u","c":"u","x":2},{"b":"v","c":"v","x":1}]

drop table samecolcomp;
