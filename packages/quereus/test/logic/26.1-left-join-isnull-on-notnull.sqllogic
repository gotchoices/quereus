-- adapted from SQLite test/notnull2.test
-- LEFT JOIN with IS NULL predicates over NOT NULL columns.
-- Most of notnull2.test asserts planner step-counts (internal); the
-- observable subset is LEFT JOIN behavior — captured here.

create table lj_t1 (a integer primary key, b text);
create table lj_t2 (c integer not null, d integer not null);

insert into lj_t1 values (1, 'x'), (2, 'y'), (3, 'z');
insert into lj_t2 values (1, 10), (2, 20);

-- d is NOT NULL; predicate `d is null` filters to no rows
select count(*) as cnt from lj_t1 left join lj_t2 on a = c where d is null;
→ [{"cnt":1}]

-- ON IS NULL against NOT NULL left-side column never matches → all left rows
-- get NULL right-side
select a, c, d from lj_t1 left join lj_t2 on a is null order by a;
→ [{"a":1,"c":null,"d":null},{"a":2,"c":null,"d":null},{"a":3,"c":null,"d":null}]

-- LEFT JOIN on derived NOT-NULL constant column; IS NULL never matches
select t.c, d from (select 3 as c) t left join lj_t2 on t.c is null;
→ [{"c":3,"d":null}]

drop table lj_t2;
drop table lj_t1;
