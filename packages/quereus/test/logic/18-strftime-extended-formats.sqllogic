-- 18-strftime-extended-formats.sqllogic
-- adapted from SQLite test/date4.test
-- Extended strftime format specifiers beyond what 16-epoch.sqllogic and
-- 24-builtin-branches.sqllogic exercise. Per docs/datetime.md %W is documented
-- as the ISO 8601 week number; we also probe the SQLite-aliased forms %U
-- (Sunday-first week), %V (ISO week), %G (ISO week-numbering year), and
-- %g (two-digit ISO year).

-- ============================================================
-- %W — ISO 8601 week number (already documented)
-- ============================================================

-- 2024-01-01 is a Monday → ISO week 01
SELECT strftime('%W', '2024-01-01');
→ ["01"]

-- 2024-12-30 is a Monday → ISO week 53? No: 2024 W01 = 2024-01-01..07; 2024-12-30 is W53? Actually 2024 has 52 ISO weeks, week 1 starts on 2024-01-01. 2024-12-30 falls in W01 of 2025.
SELECT strftime('%W', '2024-12-30');
→ ["01"]

-- ============================================================
-- %V — ISO 8601 week of year (01-53). Often equal to %W.
-- ============================================================

-- 2024-01-01 (Monday) is ISO week 01
SELECT strftime('%V', '2024-01-01');
→ ["01"]

-- 2023-01-01 (Sunday) is ISO week 52 of year 2022
SELECT strftime('%V', '2023-01-01');
→ ["52"]

-- ============================================================
-- %G — ISO 8601 week-numbering year (4-digit)
-- ============================================================

-- 2023-01-01 is in ISO year 2022
SELECT strftime('%G', '2023-01-01');
→ ["2022"]

-- 2024-12-30 is in ISO year 2025
SELECT strftime('%G', '2024-12-30');
→ ["2025"]

-- ============================================================
-- %g — ISO 8601 week-numbering year (2-digit)
-- ============================================================

-- 2023-01-01 → ISO year 22
SELECT strftime('%g', '2023-01-01');
→ ["22"]

-- 2024-12-30 → ISO year 25
SELECT strftime('%g', '2024-12-30');
→ ["25"]

-- ============================================================
-- %U — Sunday-first week of year (00-53)
-- Quereus does not implement %U; per docs/datetime.md unsupported
-- specifiers are output literally.
-- ============================================================

SELECT strftime('%U', '2024-01-01');
→ ["%U"]

SELECT strftime('%U', '2024-01-07');
→ ["%U"]

