-- adapted from SQLite test/join5.test, joinF.test
-- Constant predicates in ON clause: 1, 0, NULL, true, false in INNER and LEFT JOINs.

create table cc_l (id integer primary key, val text);
create table cc_r (id integer primary key, ref integer, val text);

insert into cc_l values (1, 'a'), (2, 'b'), (3, 'c');
insert into cc_r values (10, 1, 'r1'), (20, 1, 'r2'), (30, 3, 'r3');

-- INNER JOIN ON 1 (always true) is a cartesian product
select count(*) as cnt from cc_l join cc_r on 1;
→ [{"cnt":9}]

-- INNER JOIN ON 0 (always false) yields no rows
select count(*) as cnt from cc_l join cc_r on 0;
→ [{"cnt":0}]

-- INNER JOIN ON NULL (unknown -> false) yields no rows
select count(*) as cnt from cc_l join cc_r on null;
→ [{"cnt":0}]

-- LEFT JOIN ON 1 = full cartesian, all left rows match
select cc_l.id as lid, cc_r.id as rid
  from cc_l left join cc_r on 1
  order by lid, rid;
→ [{"lid":1,"rid":10},{"lid":1,"rid":20},{"lid":1,"rid":30},{"lid":2,"rid":10},{"lid":2,"rid":20},{"lid":2,"rid":30},{"lid":3,"rid":10},{"lid":3,"rid":20},{"lid":3,"rid":30}]

-- LEFT JOIN ON 0 = no right matches, all left rows preserved with NULL
select cc_l.id as lid, cc_r.id as rid
  from cc_l left join cc_r on 0
  order by lid;
→ [{"lid":1,"rid":null},{"lid":2,"rid":null},{"lid":3,"rid":null}]

-- LEFT JOIN ON NULL = same as ON 0 (unknown is not a match)
select cc_l.id as lid, cc_r.id as rid
  from cc_l left join cc_r on null
  order by lid;
→ [{"lid":1,"rid":null},{"lid":2,"rid":null},{"lid":3,"rid":null}]

-- LEFT JOIN ON true (literal) behaves like ON 1
select count(*) as cnt from cc_l left join cc_r on true;
→ [{"cnt":9}]

-- LEFT JOIN ON false (literal) behaves like ON 0
select count(*) as cnt from cc_l left join cc_r on false;
→ [{"cnt":3}]

-- Three-way LEFT JOIN with constant ON in the middle
create table cc_t3 (id integer primary key, w integer);
insert into cc_t3 values (1000, 1);

select cc_l.id as lid, cc_r.id as rid, cc_t3.id as tid
  from cc_l
  left join cc_r on cc_l.id = cc_r.ref
  left join cc_t3 on 1
  order by lid, rid, tid;
→ [{"lid":1,"rid":10,"tid":1000},{"lid":1,"rid":20,"tid":1000},{"lid":2,"rid":null,"tid":1000},{"lid":3,"rid":30,"tid":1000}]

drop table cc_l;
drop table cc_r;
drop table cc_t3;
