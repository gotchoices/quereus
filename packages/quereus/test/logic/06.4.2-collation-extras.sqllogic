-- adapted from SQLite test/collate1-9.test
-- Collation propagation across query parts: ORDER BY, JOIN, DISTINCT, set operations,
-- aggregates, indexes. Quereus supports BINARY (default), NOCASE, and RTRIM on TEXT.
-- Existing 06.4.1-schema-case-insensitive covers schema-name case handling.
-- Existing 03-expressions, 03.6-type-system, 07.5-window, 07.3-group-by-extras cover
-- basic WHERE / BETWEEN / GROUP BY / PARTITION BY usage. This file fills the gaps.

-- =============================================================================
-- ORDER BY with column-level COLLATE NOCASE
-- =============================================================================

create table coll_ord (id integer primary key, name text collate NOCASE);
insert into coll_ord values (1, 'charlie'), (2, 'Alice'), (3, 'bob'), (4, 'BANANA');

-- NOCASE column ordering: case-insensitive
select name from coll_ord order by name;
→ [{"name":"Alice"},{"name":"BANANA"},{"name":"bob"},{"name":"charlie"}]

-- Explicit COLLATE BINARY in ORDER BY overrides column collation
select name from coll_ord order by name collate BINARY;
→ [{"name":"Alice"},{"name":"BANANA"},{"name":"bob"},{"name":"charlie"}]

drop table coll_ord;

-- =============================================================================
-- ORDER BY with explicit COLLATE override on a BINARY-default column
-- =============================================================================

create table coll_bin (id integer primary key, name text);
insert into coll_bin values (1, 'charlie'), (2, 'Alice'), (3, 'bob'), (4, 'BANANA');

-- Default BINARY: uppercase letters sort before lowercase
select name from coll_bin order by name;
→ [{"name":"Alice"},{"name":"BANANA"},{"name":"bob"},{"name":"charlie"}]

-- Force NOCASE: reorders alphabetically ignoring case
select name from coll_bin order by name collate NOCASE;
→ [{"name":"Alice"},{"name":"BANANA"},{"name":"bob"},{"name":"charlie"}]

drop table coll_bin;

-- =============================================================================
-- RTRIM collation: trailing spaces ignored
-- =============================================================================

create table coll_rtrim (id integer primary key, val text collate RTRIM);
insert into coll_rtrim values (1, 'cat'), (2, 'cat '), (3, 'cat  '), (4, 'dog'), (5, 'dog ');

-- Equality treats 'cat', 'cat ', 'cat  ' as equal
select id from coll_rtrim where val = 'cat' order by id;
→ [{"id":1},{"id":2},{"id":3}]

-- ORDER BY groups RTRIM-equal values
select id from coll_rtrim order by val, id;
→ [{"id":1},{"id":2},{"id":3},{"id":4},{"id":5}]

-- DISTINCT under RTRIM dedups trailing-space variants
select distinct val from coll_rtrim order by val;
→ [{"val":"cat"},{"val":"dog"}]

drop table coll_rtrim;

-- =============================================================================
-- JOIN ON with COLLATE NOCASE — explicit collation on predicate
-- =============================================================================

create table jt1 (id integer primary key, name text);
create table jt2 (id integer primary key, name text);
insert into jt1 values (1, 'Alice'), (2, 'Bob');
insert into jt2 values (10, 'ALICE'), (20, 'bob');

-- Explicit COLLATE NOCASE on the join predicate matches case-insensitively
select jt1.id as l, jt2.id as r from jt1 join jt2 on jt1.name = jt2.name collate NOCASE order by jt1.id;
→ [{"l":1,"r":10},{"l":2,"r":20}]

-- Default BINARY: case-sensitive, no matches
select jt1.id as l, jt2.id as r from jt1 join jt2 on jt1.name = jt2.name order by jt1.id;
→ []

drop table jt1;
drop table jt2;

-- =============================================================================
-- DISTINCT with COLLATE NOCASE column
-- =============================================================================

create table coll_dist (id integer primary key, name text collate NOCASE);
insert into coll_dist values (1, 'Bob'), (2, 'bob'), (3, 'BOB'), (4, 'Alice'), (5, 'alice');

-- DISTINCT under NOCASE merges case-equal values
select distinct name from coll_dist order by name;
→ [{"name":"Alice"},{"name":"Bob"}]

drop table coll_dist;

-- =============================================================================
-- UNION / INTERSECT / EXCEPT with COLLATE NOCASE
-- =============================================================================

create table set_a (name text collate NOCASE);
create table set_b (name text collate NOCASE);
insert into set_a values ('Alice'), ('Bob');
insert into set_b values ('ALICE'), ('charlie');

-- UNION dedups using column collation: 'Alice' and 'ALICE' merge
select name from set_a union select name from set_b order by name;
→ [{"name":"Alice"},{"name":"Bob"},{"name":"charlie"}]

-- UNION ALL keeps duplicates as-is (no dedup)
select name from set_a union all select name from set_b order by name;
→ [{"name":"Alice"},{"name":"ALICE"},{"name":"Bob"},{"name":"charlie"}]

-- INTERSECT under NOCASE matches case-insensitively
select name from set_a intersect select name from set_b order by name;
→ [{"name":"Alice"}]

-- EXCEPT under NOCASE removes case-equal rows
select name from set_a except select name from set_b order by name;
→ [{"name":"Bob"}]

drop table set_a;
drop table set_b;

-- =============================================================================
-- MIN / MAX aggregates respect column collation
-- =============================================================================

create table coll_agg (id integer primary key, val text collate NOCASE);
insert into coll_agg values (1, 'apple'), (2, 'APPLE'), (3, 'Banana'), (4, 'banana'), (5, 'cherry');

-- MIN/MAX under NOCASE: comparison is case-insensitive, so first/last by case-folded order
-- (NOCASE-equal values may resolve to any of the case-equal members; engine picks first encountered)
select min(val) as mn, max(val) as mx from coll_agg;
→ [{"mn":"APPLE","mx":"cherry"}]

drop table coll_agg;

-- =============================================================================
-- INDEX with an explicit per-column COLLATE
-- =============================================================================
-- The parser folds `name COLLATE NOCASE` into a collate expression over the column;
-- the live CREATE INDEX path resolves it to a per-column collation (it is NOT a
-- genuine expression index). A non-column operand like lower(name) is still rejected.

create table coll_idx (id integer primary key, name text);
insert into coll_idx values (1, 'Alice'), (2, 'BOB'), (3, 'charlie'), (4, 'Bob');

create index idx_name_nc on coll_idx (name collate NOCASE);

-- index_info reports the resolved per-column collation.
select column_name, collation from index_info('coll_idx');
→ [{"column_name":"name","collation":"NOCASE"}]

-- A genuine expression index (non-column operand) is still rejected.
create index idx_name_lower on coll_idx (lower(name));
-- error: Indices on expressions are not supported

-- Equality search whose predicate carries its own COLLATE NOCASE matches
-- case-insensitively (consistent with the NOCASE index, so correct either way).
select id from coll_idx where name = 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

-- A plain BINARY equality (`where name = 'BOB'`) over the coarser NOCASE index
-- must re-apply the BINARY predicate as a residual filter above the seek, so the
-- collation-equal-but-BINARY-distinct 'Bob' (id 4) is discarded. (Previously a
-- latent planner bug returned id 2 AND 4, fixed by access-path collation cover.)
select id from coll_idx where name = 'BOB' order by id;
→ [{"id":2}]

-- A BINARY range over the NOCASE index must not walk the reordered index window;
-- the access path declines the seek and falls back to a scan + residual so the
-- BINARY-correct rows are returned ('charlie' id 3 and 'Bob' id 4 are both
-- BINARY-greater than 'BOB', while a NOCASE index seek would have missed 'Bob').
select id from coll_idx where name > 'BOB' order by id;
→ [{"id":3},{"id":4}]

drop table coll_idx;

-- =============================================================================
-- Symmetric case: BINARY index, NOCASE-collated predicate (finer index)
-- =============================================================================
-- A BINARY index cannot satisfy a NOCASE equality (it UNDER-fetches: a residual
-- cannot recover the rows the seek never visited), so the access path declines the
-- index and scans + residual — all case variants are returned.

create table coll_idx_bin (id integer primary key, name text);
insert into coll_idx_bin values (1, 'Alice'), (2, 'BOB'), (3, 'charlie'), (4, 'Bob');
create index idx_name_bin on coll_idx_bin (name);

select id from coll_idx_bin where name = 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

-- Plain BINARY equality over the matching BINARY index is unaffected (no residual).
select id from coll_idx_bin where name = 'Bob' order by id;
→ [{"id":4}]

drop table coll_idx_bin;

-- =============================================================================
-- COLLATE in CASE expression
-- =============================================================================

create table coll_case (id integer primary key, status text);
insert into coll_case values (1, 'active'), (2, 'PENDING'), (3, 'closed'), (4, 'ACTIVE');

select id, case when status = 'active' collate NOCASE then 'match' else 'other' end as r
  from coll_case order by id;
→ [{"id":1,"r":"match"},{"id":2,"r":"other"},{"id":3,"r":"other"},{"id":4,"r":"match"}]

drop table coll_case;

-- =============================================================================
-- COLLATE on a BETWEEN *bound* (scan form)
-- =============================================================================
-- BETWEEN desugars to `expr >= lo AND expr <= hi`; each comparison resolves its
-- collation independently through the provenance lattice (explicit COLLATE >
-- declared column collation > defaults), so a COLLATE on a bound governs that
-- bound's comparison. The tested column's implicit BINARY default must NOT
-- shadow an explicit bound COLLATE. Regression for `collate-on-between-bound`.

create table btw (id integer primary key, name text);
insert into btw values (1, 'Alice'), (2, 'BOB'), (3, 'charlie'), (4, 'Bob');

-- Lower bound carries COLLATE NOCASE: `name >= 'bob' (NOCASE) AND name <= 'bob' (BINARY)`.
-- 'BOB'/'Bob' are NOCASE-equal to 'bob' (lower passes) and BINARY-less-or-equal to 'bob'
-- (upper passes). Previously returned [] because the BINARY column collation clobbered
-- the bound's NOCASE.
select id from btw where name between 'bob' collate NOCASE and 'bob' order by id;
→ [{"id":2},{"id":4}]

-- expr-side COLLATE stays correct (both comparisons inherit NOCASE).
select id from btw where name collate NOCASE between 'bob' and 'bob' order by id;
→ [{"id":2},{"id":4}]

-- Desugared parity: the two-comparison form resolves identically per-bound.
select id from btw where name >= 'bob' collate NOCASE and name <= 'bob' order by id;
→ [{"id":2},{"id":4}]

-- Upper bound carries the COLLATE: `name >= 'BOB' (BINARY) AND name <= 'bob' (NOCASE)`.
select id from btw where name between 'BOB' and 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

-- Desugared parity for the upper-collated form.
select id from btw where name >= 'BOB' and name <= 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

-- NOT BETWEEN with a collated lower bound = `v < 'bob' (NOCASE) OR v > 'bob' (BINARY)`:
-- the complement of the between rows, so 'Alice' (id 1) and 'charlie' (id 3).
select id from btw where name not between 'bob' collate NOCASE and 'bob' order by id;
→ [{"id":1},{"id":3}]

drop table btw;

-- =============================================================================
-- COLLATE on a BETWEEN bound over an index (access-path cover classification)
-- =============================================================================
-- The access path resolves each bound's effective collation per-constraint
-- (lower → `>=`, upper → `<=`) and either keeps the seek (collations match) or
-- declines to a scan + residual (mismatch). All forms must agree with the scan.

create table btw_nc (id integer primary key, name text);
insert into btw_nc values (1, 'Alice'), (2, 'BOB'), (3, 'charlie'), (4, 'Bob');
create index idx_btw_nc on btw_nc (name collate NOCASE);

-- Both bounds NOCASE over a NOCASE index: collations match on both bounds, so the
-- seek is usable and returns the NOCASE-'bob'-equal rows directly.
select id from btw_nc where name between 'bob' collate NOCASE and 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

-- Mixed bounds over the NOCASE index (lower NOCASE matches, upper BINARY does not):
-- the access path declines the seek and scans + residual, matching the scan form.
select id from btw_nc where name between 'bob' collate NOCASE and 'bob' order by id;
→ [{"id":2},{"id":4}]

drop table btw_nc;

-- BINARY index, both bounds NOCASE: the NOCASE bound collations do not match the
-- BINARY index, so the seek is declined (it would under-fetch in BINARY order) and
-- the scan + residual returns the NOCASE-correct rows. Previously the bound collation
-- was ignored and the seek silently returned the wrong rows.
create table btw_bin (id integer primary key, name text);
insert into btw_bin values (1, 'Alice'), (2, 'BOB'), (3, 'charlie'), (4, 'Bob');
create index idx_btw_bin on btw_bin (name);

select id from btw_bin where name between 'bob' collate NOCASE and 'bob' collate NOCASE order by id;
→ [{"id":2},{"id":4}]

drop table btw_bin;

-- =============================================================================
-- Collation-matched non-BINARY range / BETWEEN over a matching-collation index
-- =============================================================================
-- A NOCASE (or RTRIM) range whose predicate collation matches the index collation
-- uses an index seek on BOTH backends: the in-memory vtab threads the index collation
-- into the bound filter + early-termination, and the store compares pushed bounds
-- under the column's declared collation in its post-fetch row filter
-- (StoreTable.compareValues) — both advertise `honorsCollatedRangeBounds`. The seek
-- drops the residual Filter, so these rows are produced by the module's own bound
-- filter. Result-only here so both backends are asserted identically; plan-shape
-- assertions live in test/optimizer/range-seek-collation-bounds.spec.ts (memory) and
-- packages/quereus-store/test/pushdown.spec.ts (store). Regression for
-- `memory-range-seek-collation-bounds` and `store-range-seek-collation-bounds`.

-- NOCASE primary-key range. PK values are NOCASE-distinct, but their BINARY order
-- ('Banana','CHERRY','apple','date') differs from NOCASE order ('apple','Banana',
-- 'CHERRY','date'), so a BINARY bound filter would under-fetch.
create table rng_pk_nc (name text collate NOCASE primary key, n integer);
insert into rng_pk_nc values ('apple', 1), ('Banana', 2), ('CHERRY', 3), ('date', 4);

select n from rng_pk_nc where name > 'banana' order by n;
→ [{"n":3},{"n":4}]

select n from rng_pk_nc where name between 'banana' and 'cherry' order by n;
→ [{"n":2},{"n":3}]

-- Mismatch negative control: an explicit BINARY bound collation does not match the
-- NOCASE PK, so the access path still declines the seek (scan + residual) on both
-- backends and returns the BINARY-correct rows (only 'date' is BINARY-> 'banana').
select n from rng_pk_nc where name > 'banana' collate BINARY order by n;
→ [{"n":4}]

drop table rng_pk_nc;

-- RTRIM primary-key range / BETWEEN. The bounds carry trailing spaces, so a raw
-- BINARY bound filter would both over-fetch ('cat ' > 'cat' in bytes, but they are
-- RTRIM-equal) and under-fetch ('cat ' < 'cat  ' in bytes, but RTRIM-equal).
create table rng_pk_rt (val text collate RTRIM primary key, n integer);
insert into rng_pk_rt values ('ant', 1), ('cat ', 2), ('dog', 3);

-- 'cat ' RTRIM-equals the bound 'cat', so > excludes it.
select n from rng_pk_rt where val > 'cat' order by n;
→ [{"n":3}]

-- The bound's trailing spaces are ignored: >= 'cat  ' includes the RTRIM-equal 'cat '.
select n from rng_pk_rt where val >= 'cat  ' order by n;
→ [{"n":2},{"n":3}]

-- Both BETWEEN bounds trim: ['ant','cat'] keeps 'ant' and 'cat ', excludes 'dog'.
select n from rng_pk_rt where val between 'ant  ' and 'cat  ' order by n;
→ [{"n":1},{"n":2}]

drop table rng_pk_rt;

-- BINARY negative control: an EXPLICIT `collate BINARY` PK (explicit so the store
-- does not reconcile the column to its NOCASE key-collation default) keeps plain
-- BINARY range semantics on both backends — uppercase sorts before lowercase, so
-- 'apple' and 'date' are BINARY-greater than 'CHERRY' while 'Banana' is not.
create table rng_pk_b (name text collate BINARY primary key, n integer);
insert into rng_pk_b values ('Banana', 1), ('apple', 2), ('CHERRY', 3), ('date', 4);

select n from rng_pk_b where name > 'CHERRY' order by n;
→ [{"n":2},{"n":4}]

drop table rng_pk_b;

-- NOCASE secondary index over case-variant rows (non-unique index): the >= bound
-- includes both 'Banana' and 'BANANA'.
create table rng_sec_nc (id integer primary key, name text collate NOCASE);
insert into rng_sec_nc values (1, 'apple'), (2, 'Banana'), (3, 'CHERRY'), (4, 'date'), (5, 'BANANA');
create index idx_rng_sec_nc on rng_sec_nc (name);

select id from rng_sec_nc where name >= 'banana' order by id;
→ [{"id":2},{"id":3},{"id":4},{"id":5}]

drop table rng_sec_nc;

-- RTRIM range: trailing spaces ignored on both the bound and the stored values.
create table rng_rtrim (id integer primary key, val text collate RTRIM);
insert into rng_rtrim values (1, 'cat'), (2, 'cat  '), (3, 'dog'), (4, 'doe '), (5, 'ant');
create index idx_rng_rtrim on rng_rtrim (val);

select id from rng_rtrim where val > 'cat' order by id;
→ [{"id":3},{"id":4}]

drop table rng_rtrim;
