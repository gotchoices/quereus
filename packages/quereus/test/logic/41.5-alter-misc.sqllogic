-- adapted from SQLite test/alter.test
-- ALTER TABLE: UTF-8 identifier handling and transaction interaction.

-- ===================================
-- 1. RENAME / ADD COLUMN with non-ASCII identifiers
-- ===================================

create table t_utf (id integer primary key, "naïve" text null);
insert into t_utf values (1, 'x');

alter table t_utf rename column "naïve" to "café";

select "café" from t_utf where id = 1;
→ [{"café":"x"}]

alter table t_utf rename to "tüble";

select count(*) as cnt from "tüble";
→ [{"cnt":1}]

drop table "tüble";

-- ===================================
-- 2. ALTER inside an explicit transaction
-- ===================================
-- Quereus DDL changes are applied immediately and are NOT rolled back by
-- transaction rollback (see 10.1-ddl-lifecycle).

create table t_tx (id integer primary key, a integer null);
insert into t_tx values (1, 10);

begin;
alter table t_tx add column b integer default 0;
insert into t_tx (id, a, b) values (2, 20, 200);
commit;

select * from t_tx order by id;
→ [{"id":1,"a":10,"b":0},{"id":2,"a":20,"b":200}]

-- rollback path: schema change persists per documented Quereus DDL semantics
begin;
alter table t_tx rename column a to alpha;
rollback;

select alpha from t_tx where id = 1;
→ [{"alpha":10}]

drop table t_tx;
