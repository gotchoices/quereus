-- adapted from SQLite test/join4.test, join5.test
-- Distinction between ON-clause and WHERE-clause filtering on LEFT JOIN.
-- ON-clause restricts which right rows match (left rows always preserved);
-- WHERE-clause runs after the join and filters out NULL-padded rows.

create table ow_l (id integer primary key, grp integer);
create table ow_r (id integer primary key, l_id integer, val text);

insert into ow_l values (1, 10), (2, 20), (3, 30);
insert into ow_r values (100, 1, 'r1'), (101, 2, 'r2');
-- run

-- ON-clause filter: left rows preserved, right side is NULL when filter excludes them
select ow_l.id as lid, ow_r.id as rid from ow_l left join ow_r on ow_l.id = ow_r.l_id and ow_r.val = 'r1' order by lid;
→ [{"lid":1,"rid":100},{"lid":2,"rid":null},{"lid":3,"rid":null}]

-- WHERE-clause filter: NULL-padded rows where val is null are removed
select ow_l.id as lid, ow_r.id as rid from ow_l left join ow_r on ow_l.id = ow_r.l_id where ow_r.val = 'r1' order by lid;
→ [{"lid":1,"rid":100}]

-- ON-clause inequality: still preserves left rows
select ow_l.id as lid, ow_r.id as rid from ow_l left join ow_r on ow_l.id = ow_r.l_id and ow_r.id > 100 order by lid;
→ [{"lid":1,"rid":null},{"lid":2,"rid":101},{"lid":3,"rid":null}]

-- WHERE IS NULL on right side: keeps only unmatched left rows (anti-join idiom)
select ow_l.id as lid from ow_l left join ow_r on ow_l.id = ow_r.l_id where ow_r.id is null order by lid;
→ [{"lid":3}]

-- WHERE IS NOT NULL on right side: keeps only matched rows (essentially inner join)
select ow_l.id as lid, ow_r.id as rid from ow_l left join ow_r on ow_l.id = ow_r.l_id where ow_r.id is not null order by lid;
→ [{"lid":1,"rid":100},{"lid":2,"rid":101}]

-- ON-clause filter combined with WHERE on left-side column
select ow_l.id as lid, ow_r.id as rid from ow_l left join ow_r on ow_l.id = ow_r.l_id and ow_r.val = 'r1' where ow_l.grp >= 20 order by lid;
→ [{"lid":2,"rid":null},{"lid":3,"rid":null}]

-- HAVING on count post-LEFT JOIN: zero-count groups excluded.
-- SELECT-list aliases survive on grouped column references too.
select ow_l.id as lid, count(ow_r.id) as cnt from ow_l left join ow_r on ow_l.id = ow_r.l_id group by ow_l.id having count(ow_r.id) > 0 order by ow_l.id;
→ [{"lid":1,"cnt":1},{"lid":2,"cnt":1}]

drop table ow_l;
drop table ow_r;
