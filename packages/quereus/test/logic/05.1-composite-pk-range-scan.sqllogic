-- 05.1-composite-pk-range-scan.sqllogic
-- Regression: a range scan with a lower bound on the leading column of a
-- COMPOSITE primary key (or multi-column secondary index) must return every
-- matching row, not just the last one. Previously the memory-table scanner
-- built a scalar seek key against array-shaped composite keys, mispositioning
-- the cursor so the ascending scan collapsed to the final row.

PRAGMA default_vtab_module='memory';

-- Composite PK (a, b). BTree keys are arrays [a, b].
CREATE TABLE t (a INTEGER, b INTEGER, v TEXT, PRIMARY KEY (a, b));
INSERT INTO t VALUES (10, 0, 'x'), (20, 0, 'y'), (30, 0, 'z');

-- Lower bound below all keys: all rows.
SELECT a FROM t WHERE a >= 5 ORDER BY a;
→ [{"a":10},{"a":20},{"a":30}]

-- Lower bound on an exact key (inclusive): all rows from that key.
SELECT a FROM t WHERE a >= 10 ORDER BY a;
→ [{"a":10},{"a":20},{"a":30}]

-- Lower bound between keys.
SELECT a FROM t WHERE a >= 15 ORDER BY a;
→ [{"a":20},{"a":30}]

-- Exclusive lower bound on an exact key.
SELECT a FROM t WHERE a > 10 ORDER BY a;
→ [{"a":20},{"a":30}]

-- Combined lower + upper bound.
SELECT a FROM t WHERE a >= 10 AND a < 30 ORDER BY a;
→ [{"a":10},{"a":20}]

-- Upper-bound-only (control: was always correct).
SELECT a FROM t WHERE a <= 25 ORDER BY a;
→ [{"a":10},{"a":20}]

DROP TABLE t;

-- Three-column composite PK.
CREATE TABLE t3 (hlc_ts INTEGER, node_id TEXT, seq INTEGER, v TEXT, PRIMARY KEY (hlc_ts, node_id, seq));
INSERT INTO t3 VALUES (100, 'n', 0, 'a'), (300, 'n', 0, 'a'), (500, 'n', 0, 'a'), (700, 'n', 0, 'a');

SELECT hlc_ts FROM t3 WHERE hlc_ts >= 0 ORDER BY hlc_ts;
→ [{"hlc_ts":100},{"hlc_ts":300},{"hlc_ts":500},{"hlc_ts":700}]

SELECT hlc_ts FROM t3 WHERE hlc_ts >= 0 AND hlc_ts < 1000 ORDER BY hlc_ts;
→ [{"hlc_ts":100},{"hlc_ts":300},{"hlc_ts":500},{"hlc_ts":700}]

SELECT count(*) AS n FROM t3 WHERE hlc_ts >= 0 AND hlc_ts < 1000;
→ [{"n":4}]

DROP TABLE t3;

-- Single-column PK (control: scalar seek key matches scalar stored keys).
CREATE TABLE s (id INTEGER PRIMARY KEY, v TEXT);
INSERT INTO s VALUES (10, 'a'), (20, 'b'), (30, 'c');

SELECT id FROM s WHERE id >= 0 ORDER BY id;
→ [{"id":10},{"id":20},{"id":30}]

DROP TABLE s;

-- Multi-column SECONDARY index, leading-column range scan. The PK is a single
-- scalar column so the primary path is unaffected; force the secondary index
-- to drive the scan via a leading-column range on a composite index.
CREATE TABLE idx_t (id INTEGER PRIMARY KEY, k INTEGER, name TEXT, v TEXT);
CREATE INDEX idx_kn ON idx_t (k, name);
INSERT INTO idx_t VALUES (1, 10, 'a', 'p'), (2, 20, 'b', 'q'), (3, 30, 'c', 'r');

SELECT id FROM idx_t WHERE k >= 10 ORDER BY k;
→ [{"id":1},{"id":2},{"id":3}]

SELECT id FROM idx_t WHERE k >= 15 ORDER BY k;
→ [{"id":2},{"id":3}]

SELECT id FROM idx_t WHERE k >= 10 AND k < 30 ORDER BY k;
→ [{"id":1},{"id":2}]

DROP TABLE idx_t;

-- Multi-column SECONDARY index with a DESC leading column. The secondary
-- branch carries isDescFirstColumn handling (the lower-bound wrap is
-- direction-independent), so a leading-column range still returns every row.
-- (The primary branch lacks this handling — tracked separately.)
CREATE TABLE idx_d (id INTEGER PRIMARY KEY, k INTEGER, name TEXT, v TEXT);
CREATE INDEX idx_kn_d ON idx_d (k DESC, name);
INSERT INTO idx_d VALUES (1, 10, 'a', 'p'), (2, 20, 'b', 'q'), (3, 30, 'c', 'r');

SELECT id FROM idx_d WHERE k >= 15 ORDER BY k;
→ [{"id":2},{"id":3}]

-- Upper-bound range on the DESC-leading secondary index. An ascending physical
-- walk over a DESC-leading composite index seeks from the upper bound; that
-- scalar bound is wrapped in a single-element array so the comparator positions
-- the seek at the bound rather than at a tree extreme. NOTE: the pre-wrap scalar
-- form was inefficient (a bare scalar sorts to one tree end, forcing a full
-- forward scan) but still correct here — it landed at the start of the walk, so
-- this case is a result-correctness assertion, not a row-drop regression guard.
SELECT id FROM idx_d WHERE k <= 25 ORDER BY k;
→ [{"id":1},{"id":2}]

DROP TABLE idx_d;

-- Composite PRIMARY KEY with a DESC leading column. The primary BTree is
-- physically ordered with the leading column descending, so an ascending
-- physical scan must seek from the upper bound and terminate at the lower
-- bound. Previously the primary branch lacked this handling and dropped every
-- matching row for a leading-column lower-bound range.
CREATE TABLE td (a INTEGER, b INTEGER, v TEXT, PRIMARY KEY (a DESC, b));
INSERT INTO td VALUES (10, 0, 'x'), (20, 0, 'y'), (30, 0, 'z');

-- The originally reported failing query.
SELECT a FROM td WHERE a >= 15 ORDER BY a;
→ [{"a":20},{"a":30}]

-- Inclusive lower bound on an exact key.
SELECT a FROM td WHERE a >= 20 ORDER BY a;
→ [{"a":20},{"a":30}]

-- Exclusive lower bound on an exact key.
SELECT a FROM td WHERE a > 20 ORDER BY a;
→ [{"a":30}]

-- Leading-column range (lower + upper bound).
SELECT a FROM td WHERE a >= 15 AND a < 30 ORDER BY a;
→ [{"a":20}]

-- Descending output over a DESC-leading PK with a leading-column bound.
SELECT a FROM td WHERE a >= 15 ORDER BY a DESC;
→ [{"a":30},{"a":20}]

-- Descending output combined with a leading-column range.
SELECT a FROM td WHERE a >= 15 AND a < 30 ORDER BY a DESC;
→ [{"a":20}]

DROP TABLE td;

-- Three-column composite PRIMARY KEY with a DESC leading column.
CREATE TABLE td3 (a INTEGER, b TEXT, c INTEGER, v TEXT, PRIMARY KEY (a DESC, b, c));
INSERT INTO td3 VALUES (100, 'n', 0, 'a'), (300, 'n', 0, 'a'), (500, 'n', 0, 'a'), (700, 'n', 0, 'a');

SELECT a FROM td3 WHERE a >= 250 ORDER BY a;
→ [{"a":300},{"a":500},{"a":700}]

SELECT a FROM td3 WHERE a >= 250 AND a < 600 ORDER BY a;
→ [{"a":300},{"a":500}]

SELECT count(*) AS n FROM td3 WHERE a >= 250 AND a < 600;
→ [{"n":2}]

DROP TABLE td3;

-- DESC-leading PK with DUPLICATE leading-column values. The early-termination
-- break keys off the leading column only, so it must not truncate sibling rows
-- that share the boundary value, nor break early while still inside the range.
CREATE TABLE tdup (a INTEGER, b INTEGER, v TEXT, PRIMARY KEY (a DESC, b));
INSERT INTO tdup VALUES (20, 1, 'p'), (20, 2, 'q'), (10, 1, 'r'), (30, 1, 's');

-- Lower bound only: both a=20 rows must come through (no premature break at the
-- first a=20 row), and the scan must stop once it drops below 15.
SELECT a, b FROM tdup WHERE a >= 15 ORDER BY a, b;
→ [{"a":20,"b":1},{"a":20,"b":2},{"a":30,"b":1}]

-- Exclusive lower bound landing on a duplicated leading value: every a=20 row is
-- excluded, the break fires only after exhausting them.
SELECT a, b FROM tdup WHERE a > 20 ORDER BY a, b;
→ [{"a":30,"b":1}]

-- Inclusive lower bound on the duplicated value keeps all a=20 rows.
SELECT count(*) AS n FROM tdup WHERE a >= 20;
→ [{"n":3}]

-- Upper-bound-only range over a DESC-leading PK (no lower bound → the DESC
-- early-termination guard never fires; correctness rests on planAppliesToKey).
SELECT a, b FROM tdup WHERE a < 25 ORDER BY a, b;
→ [{"a":10,"b":1},{"a":20,"b":1},{"a":20,"b":2}]

-- Inclusive upper bound on an exact (duplicated) key.
SELECT a, b FROM tdup WHERE a <= 20 ORDER BY a, b;
→ [{"a":10,"b":1},{"a":20,"b":1},{"a":20,"b":2}]

DROP TABLE tdup;
