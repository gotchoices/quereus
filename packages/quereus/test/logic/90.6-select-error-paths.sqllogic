-- adapted from SQLite test/select1.test, test/select5.test, test/e_select.test
-- SELECT-side error paths: wrong-arity aggregate calls, ORDER BY positional
-- references that are out of range, and aggregate references in disallowed
-- contexts.

create table eptab (id integer primary key, a integer, b integer);
insert into eptab values (1, 11, 22), (2, 33, 44);

-- count() with two arguments is rejected
select count(a, b) from eptab;
-- error: count

-- sum() with two arguments is rejected
select sum(a, b) from eptab;
-- error: sum

-- min(*) and max(*) — the star form is reserved for count() only
select min(*) from eptab;
-- error: min

select max(*) from eptab;
-- error: max

-- Out-of-range / zero / negative ordinal references in GROUP BY and ORDER BY
-- raise an error at planning time.
select a from eptab group by 0;
-- error: GROUP BY position 0

select a from eptab group by 2;
-- error: GROUP BY position 2

select a from eptab order by -1;
-- error: ORDER BY position -1

select a from eptab order by 99;
-- error: ORDER BY position 99

drop table eptab;

-- =============================================================================
-- Compound SELECT column-count mismatch — branches must agree
-- =============================================================================

select 1
union
select 1, 2;
-- error: column

select 1, 2
intersect
select 1;
-- error: column

select 1, 2
except
select 1;
-- error: column
