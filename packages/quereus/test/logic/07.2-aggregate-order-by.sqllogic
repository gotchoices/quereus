-- adapted from SQLite test/aggfunc.test (aggorderby)
-- ORDER BY inside an aggregate function call (e.g. group_concat(... ORDER BY ...))
-- is not currently supported by the Quereus parser. Document the rejection.

create table ob (id integer primary key, grp text, val text, pri integer);
insert into ob values (1, 'a', 'x', 2), (2, 'a', 'y', 1);

select group_concat(val order by pri) as gc from ob;
-- error: order

drop table ob;
