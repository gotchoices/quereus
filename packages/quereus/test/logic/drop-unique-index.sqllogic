-- DROP INDEX on a UNIQUE index must also remove the synthesized
-- UniqueConstraintSchema (tagged with derivedFromIndex). Without that, the
-- mutation manager keeps enforcing the unique check after the index is gone.

-- =====================================================
-- 1. Happy path: DROP UNIQUE INDEX clears the uniqueness check
-- =====================================================
create table dui_basic (a integer, b integer);
create unique index ix_dui_basic_a on dui_basic(a);

insert into dui_basic values (1, 10);

-- Duplicate fails while index exists
insert into dui_basic values (1, 20);
-- error: UNIQUE constraint failed

select a, b from dui_basic order by a, b;
→ [{"a":1,"b":10}]

drop index ix_dui_basic_a;

-- After drop, the duplicate is allowed (no stale uniqueConstraint enforcement)
insert into dui_basic values (1, 20);

select a, b from dui_basic order by a, b;
→ [{"a":1,"b":10},{"a":1,"b":20}]

drop table dui_basic;

-- =====================================================
-- 2. Coincident-name preservation: dropping a UNIQUE index does NOT
--    remove a CREATE-TABLE-time UNIQUE constraint on a different column,
--    even when their names sit in adjacent namespaces.
-- =====================================================
create table dui_coincident (a integer, b integer, constraint u unique(b));
create unique index u_idx on dui_coincident(a);

insert into dui_coincident values (1, 2);

-- Pre-drop: both constraints enforced
insert into dui_coincident values (1, 3);
-- error: UNIQUE constraint failed

insert into dui_coincident values (4, 2);
-- error: UNIQUE constraint failed

drop index u_idx;

-- After dropping the index, UNIQUE(a) is gone but the declared UNIQUE(b) survives
insert into dui_coincident values (1, 5);

select a, b from dui_coincident order by a, b;
→ [{"a":1,"b":2},{"a":1,"b":5}]

-- Declared UNIQUE(b) still rejects duplicates
insert into dui_coincident values (9, 2);
-- error: UNIQUE constraint failed

drop table dui_coincident;

-- =====================================================
-- 3. Partial UNIQUE index round-trip: drop must clear the synthesized
--    partial constraint, including its predicate.
-- =====================================================
create table dui_partial (id integer primary key, status text, code text);
create unique index ix_dui_partial on dui_partial(code) where status = 'active';

insert into dui_partial values (1, 'active', 'A');

-- Inside scope: duplicate code 'A' is rejected
insert into dui_partial values (2, 'active', 'A');
-- error: UNIQUE

-- Outside scope: same code allowed
insert into dui_partial values (3, 'inactive', 'A');

drop index ix_dui_partial;

-- After drop, the partial unique constraint is gone — duplicate 'A' inside
-- the (formerly) active scope is allowed.
insert into dui_partial values (4, 'active', 'A');

select id, status, code from dui_partial order by id;
→ [{"id":1,"status":"active","code":"A"},{"id":3,"status":"inactive","code":"A"},{"id":4,"status":"active","code":"A"}]

drop table dui_partial;
