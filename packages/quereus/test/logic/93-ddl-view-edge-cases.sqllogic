-- ddl-view-edge-cases.sqllogic - View DDL and constraint edge cases
-- Targets: create-view.ts, drop-view.ts, add-constraint.ts

-- ===== VIEW DDL EDGE CASES =====

CREATE TABLE v_base (id INTEGER PRIMARY KEY, name TEXT, val INTEGER);
INSERT INTO v_base VALUES (1, 'Alpha', 10), (2, 'Beta', 20), (3, 'Gamma', 30);

-- Basic view creation and query
CREATE VIEW v_test AS SELECT id, name FROM v_base WHERE val > 15;
SELECT * FROM v_test ORDER BY id;
→ [{"id":2,"name":"Beta"},{"id":3,"name":"Gamma"}]

-- expect error: duplicate view name without IF NOT EXISTS
CREATE VIEW v_test AS SELECT id FROM v_base;
-- error: already exists

-- CREATE VIEW IF NOT EXISTS on existing view → no-op, original definition preserved
CREATE VIEW IF NOT EXISTS v_test AS SELECT id FROM v_base;
SELECT * FROM v_test ORDER BY id;
→ [{"id":2,"name":"Beta"},{"id":3,"name":"Gamma"}]

-- DROP VIEW (normal success case)
DROP VIEW v_test;
-- run

-- expect error: DROP VIEW on nonexistent without IF EXISTS
DROP VIEW v_test;
-- error: does not exist

-- DROP VIEW IF EXISTS on nonexistent → no-op (no error)
DROP VIEW IF EXISTS v_test;
SELECT 1 AS ok;
→ [{"ok":1}]

-- CREATE VIEW IF NOT EXISTS when view doesn't exist → creates it
CREATE VIEW IF NOT EXISTS v_new AS SELECT id, val FROM v_base;
SELECT * FROM v_new ORDER BY id;
→ [{"id":1,"val":10},{"id":2,"val":20},{"id":3,"val":30}]

-- DROP VIEW IF EXISTS on existing → drops it
DROP VIEW IF EXISTS v_new;
SELECT 1 AS ok;
→ [{"ok":1}]

-- Verify it's actually gone
SELECT * FROM v_new;
-- error: not found

-- Drop and recreate with different definition
CREATE VIEW v_redef AS SELECT name FROM v_base;
SELECT * FROM v_redef ORDER BY name;
→ [{"name":"Alpha"},{"name":"Beta"},{"name":"Gamma"}]

DROP VIEW v_redef;
CREATE VIEW v_redef AS SELECT val FROM v_base WHERE val < 25;
SELECT * FROM v_redef ORDER BY val;
→ [{"val":10},{"val":20}]

DROP VIEW v_redef;
DROP TABLE v_base;

-- ===== CONSTRAINT EDGE CASES =====

-- Named CHECK constraint via ALTER TABLE ADD CONSTRAINT
CREATE TABLE t_chk (id INTEGER PRIMARY KEY, val INTEGER NULL);
INSERT INTO t_chk VALUES (1, 10);

ALTER TABLE t_chk ADD CONSTRAINT val_nonneg CHECK (val >= 0);

-- Valid insert passes constraint
INSERT INTO t_chk VALUES (2, 5);
SELECT * FROM t_chk ORDER BY id;
→ [{"id":1,"val":10},{"id":2,"val":5}]

-- Violating insert fails
INSERT INTO t_chk VALUES (3, -1);
-- error: CHECK constraint failed

-- NULL should pass CHECK (SQL standard: NULL is UNKNOWN, not FALSE)
INSERT INTO t_chk VALUES (4, null);
SELECT id, val FROM t_chk WHERE id = 4;
→ [{"id":4,"val":null}]

DROP TABLE t_chk;

-- Multiple named constraints on same table
CREATE TABLE t_multi_chk (id INTEGER PRIMARY KEY, a INTEGER NULL, b INTEGER NULL);
ALTER TABLE t_multi_chk ADD CONSTRAINT chk_a CHECK (a > 0);
ALTER TABLE t_multi_chk ADD CONSTRAINT chk_b CHECK (b > 0);

INSERT INTO t_multi_chk VALUES (1, 10, 20);
SELECT * FROM t_multi_chk;
→ [{"id":1,"a":10,"b":20}]

-- Violates first constraint
INSERT INTO t_multi_chk VALUES (2, -1, 20);
-- error: CHECK constraint failed

-- Violates second constraint
INSERT INTO t_multi_chk VALUES (3, 10, -1);
-- error: CHECK constraint failed

DROP TABLE t_multi_chk;
