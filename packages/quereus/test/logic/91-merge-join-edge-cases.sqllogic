-- merge-join-edge-cases.sqllogic - Edge cases for join emitters (merge/hash)
-- Targets: merge-join.ts branches — self-joins, residual conditions, NULL keys, many-to-many

-- Self-join: cross-product within each group
CREATE TABLE mj_self (id INTEGER PRIMARY KEY, grp INTEGER, label TEXT);
INSERT INTO mj_self VALUES (1, 1, 'a'), (2, 1, 'b'), (3, 2, 'c'), (4, 2, 'd'), (5, 3, 'e');

SELECT a.id AS aid, b.id AS bid
FROM mj_self a JOIN mj_self b ON a.grp = b.grp
ORDER BY aid, bid;
→ [{"aid":1,"bid":1},{"aid":1,"bid":2},{"aid":2,"bid":1},{"aid":2,"bid":2},{"aid":3,"bid":3},{"aid":3,"bid":4},{"aid":4,"bid":3},{"aid":4,"bid":4},{"aid":5,"bid":5}]

-- Self LEFT JOIN with residual condition: equi on grp, residual a.id != b.id
-- id=5 (grp=3) is the only row in its group, so residual filters out the self-match → NULL padded
SELECT a.id AS aid, b.id AS bid
FROM mj_self a LEFT JOIN mj_self b ON a.grp = b.grp AND a.id != b.id
ORDER BY aid, bid;
→ [{"aid":1,"bid":2},{"aid":2,"bid":1},{"aid":3,"bid":4},{"aid":4,"bid":3},{"aid":5,"bid":null}]

-- JOIN with residual inequality: only pairs where left label < right label
SELECT a.id AS aid, b.id AS bid
FROM mj_self a JOIN mj_self b ON a.grp = b.grp AND a.label < b.label
ORDER BY aid, bid;
→ [{"aid":1,"bid":2},{"aid":3,"bid":4}]

-- All-NULL join keys: NULLs never match per SQL standard
CREATE TABLE mj_allnull (id INTEGER PRIMARY KEY, val INTEGER NULL);
INSERT INTO mj_allnull VALUES (1, null), (2, null), (3, null);

SELECT a.id, b.id FROM mj_allnull a JOIN mj_allnull b ON a.val = b.val;
→ []

-- LEFT JOIN with all-NULL keys: every left row is unmatched
SELECT a.id, b.id FROM mj_allnull a LEFT JOIN mj_allnull b ON a.val = b.val ORDER BY a.id;
→ [{"id":1,"id:1":null},{"id":2,"id:1":null},{"id":3,"id:1":null}]

-- Mixed NULL and non-NULL join keys
CREATE TABLE mj_mixed (id INTEGER PRIMARY KEY, val INTEGER NULL);
INSERT INTO mj_mixed VALUES (1, 10), (2, null), (3, 20), (4, null), (5, 10);

-- INNER JOIN: NULLs excluded, matching non-NULLs produce cross-product
SELECT a.id AS aid, b.id AS bid
FROM mj_mixed a JOIN mj_mixed b ON a.val = b.val
ORDER BY aid, bid;
→ [{"aid":1,"bid":1},{"aid":1,"bid":5},{"aid":3,"bid":3},{"aid":5,"bid":1},{"aid":5,"bid":5}]

-- LEFT JOIN: NULL-keyed rows get NULL padding, matched rows get cross-product
SELECT a.id AS aid, b.id AS bid
FROM mj_mixed a LEFT JOIN mj_mixed b ON a.val = b.val
ORDER BY aid, bid;
→ [{"aid":1,"bid":1},{"aid":1,"bid":5},{"aid":2,"bid":null},{"aid":3,"bid":3},{"aid":4,"bid":null},{"aid":5,"bid":1},{"aid":5,"bid":5}]

-- Many-to-many with asymmetric cardinality
CREATE TABLE mj_m2m_l (id INTEGER PRIMARY KEY, key INTEGER);
CREATE TABLE mj_m2m_r (id INTEGER PRIMARY KEY, key INTEGER);
INSERT INTO mj_m2m_l VALUES (1, 10), (2, 10), (3, 10), (4, 20);
INSERT INTO mj_m2m_r VALUES (10, 10), (20, 10), (30, 20), (40, 20), (50, 20);

-- 3×2=6 for key=10, 1×3=3 for key=20 → total 9
SELECT count(*) AS cnt FROM mj_m2m_l l JOIN mj_m2m_r r ON l.key = r.key;
→ [{"cnt":9}]

-- LEFT JOIN preserves all left rows with correct match counts
SELECT l.id, count(r.id) AS matches
FROM mj_m2m_l l LEFT JOIN mj_m2m_r r ON l.key = r.key
GROUP BY l.id ORDER BY l.id;
→ [{"id":1,"matches":2},{"id":2,"matches":2},{"id":3,"matches":2},{"id":4,"matches":3}]

-- Join where one side is empty (inner and left)
CREATE TABLE mj_populated (id INTEGER PRIMARY KEY, val INTEGER);
CREATE TABLE mj_empty (id INTEGER PRIMARY KEY, val INTEGER);
INSERT INTO mj_populated VALUES (1, 10), (2, 20);

SELECT p.id FROM mj_populated p JOIN mj_empty e ON p.val = e.val;
→ []

SELECT p.id, e.id AS eid FROM mj_populated p LEFT JOIN mj_empty e ON p.val = e.val ORDER BY p.id;
→ [{"id":1,"eid":null},{"id":2,"eid":null}]

-- Both sides empty
SELECT a.id FROM mj_empty a JOIN mj_empty b ON a.val = b.val;
→ []

-- Multi-column join with partial key matches
CREATE TABLE mj_mc_l (a INTEGER, b INTEGER, v TEXT, PRIMARY KEY (a, b));
CREATE TABLE mj_mc_r (x INTEGER, y INTEGER, w TEXT, PRIMARY KEY (x, y));

INSERT INTO mj_mc_l VALUES (1, 10, 'p'), (1, 20, 'q'), (2, 10, 'r');
INSERT INTO mj_mc_r VALUES (1, 10, 's'), (1, 30, 't'), (2, 10, 'u');

-- Only (1,10) and (2,10) match on both columns
SELECT l.v, r.w FROM mj_mc_l l JOIN mj_mc_r r ON l.a = r.x AND l.b = r.y ORDER BY l.a, l.b;
→ [{"v":"p","w":"s"},{"v":"r","w":"u"}]

-- LEFT JOIN: (1,20) has no match on both columns → NULL padded
SELECT l.a, l.b, r.w FROM mj_mc_l l LEFT JOIN mj_mc_r r ON l.a = r.x AND l.b = r.y ORDER BY l.a, l.b;
→ [{"a":1,"b":10,"w":"s"},{"a":1,"b":20,"w":null},{"a":2,"b":10,"w":"u"}]

-- Cleanup
DROP TABLE mj_self;
DROP TABLE mj_allnull;
DROP TABLE mj_mixed;
DROP TABLE mj_m2m_l;
DROP TABLE mj_m2m_r;
DROP TABLE mj_populated;
DROP TABLE mj_empty;
DROP TABLE mj_mc_l;
DROP TABLE mj_mc_r;
