-- Memory-only: DDL is not transactional, so a `DROP INDEX` inside a transaction is NOT undone
-- by `rollback to savepoint`.
--
-- `adoptSchemaOnOpenLayers` rewrites EVERY layer in the savepoint chain (that is what makes the
-- additive case survive `rollback to savepoint`); applied to a removal, the dropped index stays
-- dropped in the restored snapshot too. This pins current intended memory behavior so a future
-- reader does not mistake it for a regression. Making DROP reversible belongs to the larger
-- feature `feat-ddl-transaction-capability`, alongside making CREATE reversible.
--
-- Memory-only: the store backend implements savepoint/DDL interaction differently (this exact
-- sequence diverges under store), so this quirk is not asserted cross-backend — see
-- 10.1.3-ddl-drop-in-transaction.sqllogic for the cross-backend enforcement coverage.

create table drop_sp (id integer primary key, v text);
-- run
create unique index drop_sp_ix on drop_sp (v);
-- run
begin;
-- run
insert into drop_sp values (1, 'a');
-- run
savepoint s;
-- run
drop index drop_sp_ix;
-- run
rollback to savepoint s;
-- run

-- Under SQL the index would be enforced again after the rollback; here it stays dropped,
-- so a would-be duplicate is still accepted (DDL is not rolled back).
insert into drop_sp values (2, 'a');
-- run
commit;
-- run

select id, v from drop_sp order by id;
→ [{ "id": 1, "v": "a" }, { "id": 2, "v": "a" }]

-- Cleanup
drop table drop_sp;
-- run
