-- 90.4-dml-errors.sqllogic - DML error paths (INSERT, UPDATE, DELETE edge cases)

-- VALUES clause column count mismatch (fewer values than columns)
CREATE TABLE t_vals (a INTEGER, b INTEGER, c INTEGER);
-- run

INSERT INTO t_vals VALUES (1, 2);
-- error: Column count mismatch

-- VALUES clause column count mismatch (more values than columns)
INSERT INTO t_vals VALUES (1, 2, 3, 4);
-- error: Column count mismatch

DROP TABLE t_vals;
-- run

-- INSERT with explicit column referencing non-existent column
CREATE TABLE t_insert_col (id INTEGER PRIMARY KEY, name TEXT);
-- run

INSERT INTO t_insert_col (id, missing_col) VALUES (1, 'x');
-- error: not found

DROP TABLE t_insert_col;
-- run

-- ON CONFLICT target with non-existent column
CREATE TABLE t_upsert_bad (id INTEGER PRIMARY KEY, val INTEGER);
-- run

INSERT INTO t_upsert_bad (id, val) VALUES (1, 10) ON CONFLICT (missing_col) DO NOTHING;
-- error: not found

DROP TABLE t_upsert_bad;
-- run

-- Mutating subquery without RETURNING clause
CREATE TABLE t_mut_src (id INTEGER PRIMARY KEY, val INTEGER);
CREATE TABLE t_mut_dst (id INTEGER PRIMARY KEY, val INTEGER);
INSERT INTO t_mut_src VALUES (1, 10);
-- run

INSERT INTO t_mut_dst SELECT * FROM (DELETE FROM t_mut_src WHERE id = 1);
-- error: must have a RETURNING clause

DROP TABLE t_mut_src;
DROP TABLE t_mut_dst;
