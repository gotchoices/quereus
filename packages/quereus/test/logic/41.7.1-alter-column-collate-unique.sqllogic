-- ALTER COLUMN ... SET COLLATE — PRIMARY KEY re-key collision (memory-only).
--
-- MEMORY-ONLY (registered in MEMORY_ONLY_FILES in logic.spec.ts): the single fixture
-- here ('a'/'A') is PHYSICALLY IMPOSSIBLE on the store, so it cannot be cross-module.
-- The memory module re-keys its primary tree under the new per-column collation and
-- re-validates the PRIMARY KEY, so a pair distinct under BINARY but colliding under
-- NOCASE rejects the ALTER with CONSTRAINT. The store encodes PK key bytes under a
-- single fixed table-level key collation (`StoreTable.encodeOptions`, default NOCASE),
-- so 'a'/'A' map to the same NOCASE key and cannot even coexist in the store — there
-- is nothing to re-key, hence this stays memory-only.
--
-- The store does NOT silently diverge on a PK SET COLLATE. It rejects a DIVERGENT PK
-- collation (target != its fixed key collation) with UNSUPPORTED — asserted in
-- packages/quereus-store/test/alter-table-conformance.spec.ts — and honors a CONSISTENT
-- one (target == its fixed key collation) schema-only, exercised cross-module in
-- 41.7.2-alter-column-collate-unique-store.sqllogic §9. The non-PK UNIQUE / CREATE
-- UNIQUE INDEX sections (identical across both modules) also live in 41.7.2. The
-- cross-module query-layer behavior lives in 41.7-alter-column-collate.sqllogic.

-- ===================================
-- 1. PK column collation change re-keys the primary structure; a PK that is
--    unique under BINARY but collides under NOCASE is rejected. (Memory-only: under
--    the store's fixed NOCASE key encoding the 'a'/'A' pair cannot coexist at all.)
-- ===================================

create table pkc (k text primary key);
insert into pkc values ('a'), ('A');
-- run

alter table pkc alter column k set collate nocase;
-- error: UNIQUE constraint failed

-- rollback: both rows survive, column still BINARY (BINARY order: A before a)
select k from pkc order by k;
→ [{"k":"A"},{"k":"a"}]

drop table pkc;
