-- query-expr-dml-gates.sqllogic — pins the remaining gates around DML in
-- relation positions after the dml-in-expression-position ticket landed.
--
-- The parser-side gate (DML in a non-top-level relation position must carry
-- RETURNING) survives untouched. The planner-side gate that blocked DML in
-- scalar / IN / EXISTS / compound-leg / CTE-body positions is gone — those
-- positions now execute under full-drain + run-once semantics (see the
-- companion 01.9-query-expr-dml.sqllogic file for executable cases).
-- The only remaining planner-side gate is "DML as a view body", which is
-- permanently rejected (a view re-evaluates per reference; replaying writes
-- on every read is incoherent with view semantics).

create table t (id integer primary key, name text);

-- ===================================
-- Parser-side gate: DML in a relation position without RETURNING
-- ===================================

select * from (insert into t values (1, 'a')) as s;
-- error: must have a RETURNING clause

select 1 + (insert into t values (2, 'b'));
-- error: must have a RETURNING clause

-- ===================================
-- Planner-side gate: DML as a view body is rejected at creation time
-- ===================================

create view v_dml as insert into t values (6, 'f') returning id;
-- error: cannot be used as a view body

drop table t;
