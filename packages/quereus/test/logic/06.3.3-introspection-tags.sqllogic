-- introspection-tags.sqllogic - Tag and rich-metadata exposure through introspection TVFs

-- ===================================================================
-- Setup
-- ===================================================================

CREATE TABLE Orders (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL
) WITH TAGS (display_name = 'Customer Orders', audit = true);

CREATE TABLE PlainTable (
    id INTEGER PRIMARY KEY,
    val TEXT
);

CREATE VIEW ActiveOrders AS SELECT * FROM Orders WHERE id > 0
    WITH TAGS (cacheable = true, purpose = 'active orders filter');

CREATE VIEW PlainView AS SELECT * FROM PlainTable;

CREATE INDEX idx_orders_name ON Orders (name)
    WITH TAGS (purpose = 'name lookup');

CREATE INDEX idx_orders_plain ON Orders (id);

-- ===================================================================
-- schema() — tags on tables / views / indexes; null for untagged & functions
-- ===================================================================

SELECT name, json_extract(tags, '$.display_name') AS display_name
    FROM schema() WHERE type = 'table' AND name = 'Orders';
→ [{"name":"Orders","display_name":"Customer Orders"}]

SELECT tags FROM schema() WHERE type = 'table' AND name = 'PlainTable';
→ [{"tags":null}]

SELECT json_extract(tags, '$.cacheable') AS cacheable,
       json_extract(tags, '$.purpose') AS purpose
    FROM schema() WHERE type = 'view' AND name = 'ActiveOrders';
→ [{"cacheable":true,"purpose":"active orders filter"}]

SELECT tags FROM schema() WHERE type = 'view' AND name = 'PlainView';
→ [{"tags":null}]

SELECT name, json_extract(tags, '$.purpose') AS purpose
    FROM schema() WHERE type = 'index' AND name = 'idx_orders_name';
→ [{"name":"idx_orders_name","purpose":"name lookup"}]

SELECT tags FROM schema() WHERE type = 'index' AND name = 'idx_orders_plain';
→ [{"tags":null}]

-- Functions never carry tags
SELECT count(*) AS bad FROM schema() WHERE type = 'function' AND tags IS NOT NULL;
→ [{"bad":0}]

-- ===================================================================
-- table_info() — column-level tags, collation, generated flag
-- ===================================================================

CREATE TABLE Products (
    id INTEGER PRIMARY KEY WITH TAGS (display_name = 'Product ID'),
    name TEXT NOT NULL COLLATE NOCASE WITH TAGS (searchable = true),
    price REAL NOT NULL,
    discounted REAL GENERATED ALWAYS AS (price * 0.9),
    snapshot REAL GENERATED ALWAYS AS (price + 1) STORED
);

SELECT name, json_extract(tags, '$.display_name') AS display_name,
       json_extract(tags, '$.searchable') AS searchable
    FROM table_info('Products') ORDER BY cid;
→ [{"name":"id","display_name":"Product ID","searchable":null},{"name":"name","display_name":null,"searchable":true},{"name":"price","display_name":null,"searchable":null},{"name":"discounted","display_name":null,"searchable":null},{"name":"snapshot","display_name":null,"searchable":null}]

SELECT name, collation FROM table_info('Products') ORDER BY cid;
→ [{"name":"id","collation":"BINARY"},{"name":"name","collation":"NOCASE"},{"name":"price","collation":"BINARY"},{"name":"discounted","collation":"BINARY"},{"name":"snapshot","collation":"BINARY"}]

SELECT name, "generated" FROM table_info('Products') ORDER BY cid;
→ [{"name":"id","generated":0},{"name":"name","generated":0},{"name":"price","generated":0},{"name":"discounted","generated":1},{"name":"snapshot","generated":2}]

-- ===================================================================
-- foreign_key_info() — tags on FKs, repeated per seq row
-- ===================================================================

CREATE TABLE FkChild (
    id INTEGER PRIMARY KEY,
    order_id INTEGER,
    CONSTRAINT fk_child_order FOREIGN KEY (order_id) REFERENCES Orders(id)
        WITH TAGS (audit = true, purpose = 'links to orders')
);

SELECT name, json_extract(tags, '$.audit') AS audit,
       json_extract(tags, '$.purpose') AS purpose
    FROM foreign_key_info('FkChild');
→ [{"name":"fk_child_order","audit":true,"purpose":"links to orders"}]

-- Composite FK: tags repeat across all seq rows
CREATE TABLE CompositeParent (
    a INTEGER,
    b INTEGER,
    PRIMARY KEY (a, b)
);

CREATE TABLE CompositeChild (
    id INTEGER PRIMARY KEY,
    ref_a INTEGER,
    ref_b INTEGER,
    CONSTRAINT fk_composite FOREIGN KEY (ref_a, ref_b) REFERENCES CompositeParent(a, b)
        WITH TAGS (kind = 'composite')
);

SELECT seq, json_extract(tags, '$.kind') AS kind
    FROM foreign_key_info('CompositeChild') ORDER BY seq;
→ [{"seq":0,"kind":"composite"},{"seq":1,"kind":"composite"}]

-- Untagged FK
SELECT tags FROM foreign_key_info('CompositeChild')
    WHERE tags IS NOT NULL LIMIT 0;
→ []

-- ===================================================================
-- index_info() — column-by-column index layout, partial/unique/tags
-- ===================================================================

CREATE TABLE IdxTable (
    id INTEGER PRIMARY KEY,
    a TEXT,
    b INTEGER,
    status TEXT
);

CREATE INDEX idx_a_asc ON IdxTable (a) WITH TAGS (purpose = 'lookup');
CREATE INDEX idx_b_desc ON IdxTable (b DESC);
CREATE UNIQUE INDEX idx_a_unique ON IdxTable (a);
CREATE INDEX idx_a_partial ON IdxTable (a) WHERE status = 'active';

SELECT index_name, seq, column_name, "desc", "unique", partial,
       json_extract(tags, '$.purpose') AS purpose
    FROM index_info('IdxTable') ORDER BY index_name, seq;
→ [{"index_name":"idx_a_asc","seq":0,"column_name":"a","desc":0,"unique":0,"partial":0,"purpose":"lookup"},{"index_name":"idx_a_partial","seq":0,"column_name":"a","desc":0,"unique":0,"partial":1,"purpose":null},{"index_name":"idx_a_unique","seq":0,"column_name":"a","desc":0,"unique":1,"partial":0,"purpose":null},{"index_name":"idx_b_desc","seq":0,"column_name":"b","desc":1,"unique":0,"partial":0,"purpose":null}]

-- Empty result on a table with no indexes
SELECT count(*) AS cnt FROM index_info('PlainTable') WHERE index_name LIKE 'idx_%';
→ [{"cnt":0}]

-- ===================================================================
-- check_constraint_info() — named CHECK with tags, unnamed without
-- ===================================================================

CREATE TABLE ChkTable (
    id INTEGER PRIMARY KEY,
    qty INTEGER,
    CONSTRAINT chk_qty_positive CHECK (qty > 0) WITH TAGS (error_message = 'must be positive'),
    CHECK (qty < 1000)
);

SELECT name, "deferrable", initially_deferred,
       json_extract(tags, '$.error_message') AS msg
    FROM check_constraint_info('ChkTable') ORDER BY id;
→ [{"name":"chk_qty_positive","deferrable":0,"initially_deferred":0,"msg":"must be positive"},{"name":null,"deferrable":0,"initially_deferred":0,"msg":null}]

-- expr text round-trips through the AST stringifier
SELECT expr FROM check_constraint_info('ChkTable') WHERE name = 'chk_qty_positive';
→ [{"expr":"qty > 0"}]

-- ===================================================================
-- unique_constraint_info() — named UNIQUE with tags, multi-column
-- ===================================================================

CREATE TABLE UqTable (
    id INTEGER PRIMARY KEY,
    email TEXT NOT NULL,
    region TEXT NOT NULL,
    code TEXT NOT NULL,
    CONSTRAINT uq_email UNIQUE (email) WITH TAGS (error_message = 'email must be unique'),
    UNIQUE (region, code)
);

SELECT id, name, seq, column_name, partial,
       json_extract(tags, '$.error_message') AS msg
    FROM unique_constraint_info('UqTable') ORDER BY id, seq;
→ [{"id":0,"name":"uq_email","seq":0,"column_name":"email","partial":0,"msg":"email must be unique"},{"id":1,"name":null,"seq":0,"column_name":"region","partial":0,"msg":null},{"id":1,"name":null,"seq":1,"column_name":"code","partial":0,"msg":null}]

-- Partial unique index synthesizes a partial unique constraint
CREATE TABLE PuTable (
    id INTEGER PRIMARY KEY,
    code TEXT NOT NULL,
    status TEXT NOT NULL
);
CREATE UNIQUE INDEX uq_pu_active ON PuTable (code) WHERE status = 'active';

SELECT name, partial FROM unique_constraint_info('PuTable');
→ [{"name":"uq_pu_active","partial":1}]

-- ===================================================================
-- assertion_info() — CREATE ASSERTION listing
-- ===================================================================

CREATE TABLE AssertData (id INTEGER PRIMARY KEY, val INTEGER);
-- run

CREATE ASSERTION val_positive CHECK (NOT EXISTS (SELECT 1 FROM AssertData WHERE val < 0));
CREATE ASSERTION val_bounded CHECK (NOT EXISTS (SELECT 1 FROM AssertData WHERE val > 100));
-- run

SELECT name, "deferrable", initially_deferred FROM assertion_info() ORDER BY name;
→ [{"name":"val_bounded","deferrable":1,"initially_deferred":1},{"name":"val_positive","deferrable":1,"initially_deferred":1}]

-- violation_sql is non-empty
SELECT count(*) AS cnt FROM assertion_info() WHERE length(violation_sql) > 0;
→ [{"cnt":2}]

-- dependent_tables is JSON (may be an empty array if discovery hasn't run yet,
-- so we only check that the column is parseable JSON)
SELECT count(*) AS cnt FROM assertion_info() WHERE json_valid(dependent_tables) = 1;
→ [{"cnt":2}]

-- ===================================================================
-- Cleanup
-- ===================================================================
DROP ASSERTION val_bounded;
DROP ASSERTION val_positive;
DROP TABLE AssertData;
DROP TABLE PuTable;
DROP TABLE UqTable;
DROP TABLE ChkTable;
DROP TABLE IdxTable;
DROP TABLE CompositeChild;
DROP TABLE CompositeParent;
DROP TABLE FkChild;
DROP TABLE Products;
DROP VIEW PlainView;
DROP VIEW ActiveOrders;
DROP TABLE PlainTable;
DROP TABLE Orders;
