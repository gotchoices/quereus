-- adapted from SQLite test/aggfunc.test, test/window4.test, test/window6.test
-- FILTER (WHERE …) clause restricts which rows feed an aggregate or window aggregate.
-- Quereus parser does not currently accept FILTER (WHERE ...) on aggregates.
-- Document the rejection.

create table af (id integer primary key, grp text, val integer null, flag integer);
insert into af values (1, 'a', 10, 1), (2, 'a', 20, 0);

select count(*) filter (where val > 15) as c from af;
-- error: filter

drop table af;
