-- adapted from SQLite test/bind.test
-- Bind parameter syntax and binding semantics across statement types.
-- Quereus parameter forms: `?` (positional), `:name`, `:N` (numeric named),
-- `$name`, `$N` (numeric named).  `@name` and `?N` are NOT supported.

create table bp (id integer primary key, val integer null, name text);
insert into bp values (1, 10, 'alpha'), (2, 20, 'beta'), (3, 30, 'gamma'), (4, null, 'delta');

-- ===================================
-- Positional `?` in basic SELECT
-- ===================================

-- params: [1]
select val from bp where id = ?;
→ [{"val":10}]

-- Two positional parameters, both bound from one params array
-- params: [1, 25]
select id from bp where id = ? or val > ?;
→ [{"id":1},{"id":3}]

-- ===================================
-- Named `:name` in basic SELECT
-- ===================================

-- params: {"id": 2}
select val from bp where id = :id;
→ [{"val":20}]

-- params: {"min": 15, "name": "gamma"}
select id from bp where val >= :min and name = :name;
→ [{"id":3}]

-- Same named parameter referenced twice
-- params: {"target": 2}
select id from bp where id = :target or id = :target + 1;
→ [{"id":2},{"id":3}]

-- ===================================
-- Named `$name` in basic SELECT
-- ===================================

-- params: {"id": 3}
select val from bp where id = $id;
→ [{"val":30}]

-- ===================================
-- Numeric named `:N` and `$N`
-- ===================================

-- params: {"1": 1}
select val from bp where id = :1;
→ [{"val":10}]

-- params: {"1": 2}
select val from bp where id = $1;
→ [{"val":20}]

-- ===================================
-- Parameter type variation
-- ===================================

-- Integer
-- params: [10]
select id from bp where val = ?;
→ [{"id":1}]

-- Real
-- params: [20.0]
select id from bp where val = ?;
→ [{"id":2}]

-- Text
-- params: ["alpha"]
select id from bp where name = ?;
→ [{"id":1}]

-- NULL
-- IS-as-equality (val IS ?) is SQLite-only; Quereus restricts IS to IS NULL/IS NOT NULL.
-- Use explicit null check instead.
-- params: []
select id from bp where val is null;
→ [{"id":4}]

-- ===================================
-- Parameter in INSERT / UPDATE / DELETE
-- ===================================

-- params: [5, 50, "epsilon"]
insert into bp (id, val, name) values (?, ?, ?);
→ []

select val, name from bp where id = 5;
→ [{"val":50,"name":"epsilon"}]

-- params: [99, 5]
update bp set val = ? where id = ?;
→ []

select val from bp where id = 5;
→ [{"val":99}]

-- params: [5]
delete from bp where id = ?;
→ []

select count(*) as cnt from bp where id = 5;
→ [{"cnt":0}]

-- ===================================
-- Parameter in expression contexts
-- ===================================

-- Arithmetic — text-order binding.
-- Positional `?` bind in SOURCE-TEXT order, NOT plan/resolution order. Here the
-- projection `?` (first in the text) takes 100 and the WHERE `?` (second) takes 1,
-- so we boost row id=1 (val 10) by 100. Under the OLD plan-order behaviour the
-- WHERE `?` would have bound first (=100, no such id) yielding []; this case pins
-- the text-order contract.
-- params: [100, 1]
select val + ? as boosted from bp where id = ?;
→ [{"boosted":110}]

-- Discriminator — a projection `?` AND a WHERE `?` whose values differ, so the two
-- binding orders give visibly different results. Text order: projection `?`=7,
-- WHERE `?`=2 → boost row id=2 (val 20) → 27. Plan order would bind WHERE first
-- (=7, no row) → [].
-- params: [7, 2]
select val + ? as boosted from bp where id = ?;
→ [{"boosted":27}]

-- Projection `?` mixed with a FROM/WHERE `in (?, ?)` — mirrors the codec import/
-- export shape (a TVF/aggregate projection arg preceding WHERE-list args). Text
-- order: tag `?`='T', then the in-list `?`s = 1, 3.
-- params: ["T", 1, 3]
select ? as tag, id from bp where id in (?, ?) order by id;
→ [{"tag":"T","id":1},{"tag":"T","id":3}]

-- Function call
-- params: ["alp"]
select id from bp where name like ? || '%';
→ [{"id":1}]

-- CASE expression
-- params: [2]
select case when id = ? then 'match' else 'miss' end as r from bp order by id;
→ [{"r":"miss"},{"r":"match"},{"r":"miss"},{"r":"miss"}]

-- IN list with multiple parameters
-- params: [1, 3]
select id from bp where id in (?, ?) order by id;
→ [{"id":1},{"id":3}]

-- ===================================
-- Single-placeholder IN over the PK
-- ===================================
-- Regression: `col in (?)` with exactly one placeholder over an indexed/PK column
-- reduced to a point-seek on Literal(undefined) and degraded to a full-index walk,
-- so the predicate silently matched (and, for DELETE, wiped) every row. It must
-- match exactly the bound row. See quereus-single-element-in-list-matches-all.

-- params: [2]
select id from bp where id in (?) order by id;
→ [{"id":2}]

-- Re-bound with a different value (the placeholder must not be constant-folded)
-- params: [3]
select id from bp where id in (?) order by id;
→ [{"id":3}]

-- One-, two-, three-placeholder IN and `= ?` agree on the bound rows
-- params: [1]
select id from bp where id = ? order by id;
→ [{"id":1}]

-- params: [1, 4]
select id from bp where id in (?, ?) order by id;
→ [{"id":1},{"id":4}]

-- params: [1, 2, 4]
select id from bp where id in (?, ?, ?) order by id;
→ [{"id":1},{"id":2},{"id":4}]

-- A non-matching single placeholder matches nothing (not everything)
-- params: [99]
select id from bp where id in (?) order by id;
→ []

-- ===================================
-- Parameter in LIMIT / OFFSET
-- ===================================

-- params: [2]
select id from bp order by id limit ?;
→ [{"id":1},{"id":2}]

-- params: [2, 1]
select id from bp order by id limit ? offset ?;
→ [{"id":2},{"id":3}]

-- ===================================
-- Repeated execution with different parameter values
-- ===================================
-- Same prepared shape, different bind values — verifies parameters are
-- not constant-folded into the plan.

-- params: [1]
select val from bp where id = ?;
→ [{"val":10}]

-- params: [2]
select val from bp where id = ?;
→ [{"val":20}]

-- params: [99]
select val from bp where id = ?;
→ []

-- ===================================
-- Cleanup
-- ===================================

drop table bp;
