-- 02-filters.sqllogic — Behavioural regression for WHERE-clause optimizer rules.
-- Initial focus: rulePredicateInferenceEquivalence (EC × constant binding → inferred eq).

-- ---------------------------------------------------------------------------
-- Predicate inference (EC × constant binding) — semantic equivalence.
-- ---------------------------------------------------------------------------

create table t (k int primary key, v text);
create table u (k int primary key, v text);

insert into t values (1, 'a'), (5, 'e'), (10, 'j');
insert into u values (5, 'E'), (7, 'G'), (10, 'J');

-- Literal: inference should produce u.k = 5 on the u-side; result is the
-- single matched row.
select t.v as tv, u.v as uv from t join u on t.k = u.k where t.k = 5;
→ [{"tv":"e","uv":"E"}]

-- Parameter: inference threads the same parameter through to the u-side
-- access path. Result must match the literal form for the same value.
-- params: [10]
select t.v as tv, u.v as uv from t join u on t.k = u.k where t.k = ?;
→ [{"tv":"j","uv":"J"}]

-- LEFT JOIN safety: outer's t.k = 5 must NOT propagate to the right side as
-- an EC-derived restriction (that would prune null-padded rows). Unmatched
-- left rows survive with NULL on the right.
select t.k as tk, u.k as uk from t left join u on t.k = u.k where t.k <= 5 order by t.k;
→ [{"tk":1,"uk":null},{"tk":5,"uk":5}]

-- Multi-hop chain: a.x = 7 should propagate through both equi-joins so the
-- chain returns rows only when every joined side has x = 7.
create table ta (id int primary key, x int);
create table tb (id int primary key, x int);
create table tc (id int primary key, x int);

insert into ta values (1, 7), (2, 8);
insert into tb values (1, 7), (2, 8);
insert into tc values (1, 7), (2, 8);

select ta.x as ax, tb.x as bx, tc.x as cx
  from ta join tb on ta.x = tb.x
          join tc on tb.x = tc.x
 where ta.x = 7;
→ [{"ax":7,"bx":7,"cx":7}]

drop table tc;
drop table tb;
drop table ta;
drop table u;

-- Prefix-NOT precedence (issue #22) is covered by the full predicate
-- matrix in 03.8-not-precedence.sqllogic.
drop table t;
