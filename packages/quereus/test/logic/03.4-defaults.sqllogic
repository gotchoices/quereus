-- Test default value expressions
CREATE TABLE t_defaults(
  id INTEGER PRIMARY KEY,
  name TEXT DEFAULT 'unnamed',
  created_timestamp INTEGER DEFAULT (1000 + 500),
  computed TEXT DEFAULT ('prefix_' || 'suffix')
);

-- Insert with all columns - should not use defaults
INSERT INTO t_defaults VALUES (1, 'test1', 9999, 'custom');
SELECT * FROM t_defaults WHERE id = 1;
→ [{"id":1,"name":"test1","created_timestamp":9999,"computed":"custom"}]

-- Insert with some columns omitted - should use default expressions
INSERT INTO t_defaults (id, name) VALUES (2, 'test2');
SELECT * FROM t_defaults WHERE id = 2;
→ [{"id":2,"name":"test2","created_timestamp":1500,"computed":"prefix_suffix"}]

-- Insert with different columns omitted
INSERT INTO t_defaults (id, created_timestamp) VALUES (3, 2000);
SELECT * FROM t_defaults WHERE id = 3;
→ [{"id":3,"name":"unnamed","created_timestamp":2000,"computed":"prefix_suffix"}]

-- Insert with only primary key - should use all defaults
INSERT INTO t_defaults (id) VALUES (4);
SELECT * FROM t_defaults WHERE id = 4;
→ [{"id":4,"name":"unnamed","created_timestamp":1500,"computed":"prefix_suffix"}]

-- Verify all rows
SELECT * FROM t_defaults ORDER BY id;
→ [{"id":1,"name":"test1","created_timestamp":9999,"computed":"custom"},{"id":2,"name":"test2","created_timestamp":1500,"computed":"prefix_suffix"},{"id":3,"name":"unnamed","created_timestamp":2000,"computed":"prefix_suffix"},{"id":4,"name":"unnamed","created_timestamp":1500,"computed":"prefix_suffix"}]

DROP TABLE t_defaults;

-- ===================================
-- DEFAULT deriving from a populated sibling via new.<column>
-- A default may read a value the INSERT actually supplies; only INSERT-supplied
-- columns are visible, so a default never depends on another column's default
-- (which would impose an evaluation-order race).
-- ===================================

CREATE TABLE t_newref (
  id INTEGER PRIMARY KEY,
  base INTEGER,
  title TEXT,
  doubled INTEGER DEFAULT (new.base * 2),
  slug TEXT DEFAULT (lower(new.title))
);

-- Siblings populated → the defaults derive from them
INSERT INTO t_newref (id, base, title) VALUES (1, 10, 'Hello');
SELECT id, base, title, doubled, slug FROM t_newref WHERE id = 1;
→ [{"id":1,"base":10,"title":"Hello","doubled":20,"slug":"hello"}]

-- An explicitly supplied value overrides the default (new.* unused)
INSERT INTO t_newref (id, base, title, doubled) VALUES (2, 10, 'X', 999);
SELECT doubled FROM t_newref WHERE id = 2;
→ [{"doubled":999}]

-- Referencing a column the INSERT did not supply → clear resolution error
-- (here `title` is omitted, so `new.title` in slug's default has no value).
INSERT INTO t_newref (id, base) VALUES (3, 7);
-- error: isn't a column

DROP TABLE t_newref;

-- ===================================
-- new.<column> through a single-source VIEW insert
-- A view INSERT re-plans through the same row-expansion path, so the default
-- still derives from the supplied sibling.
-- ===================================

CREATE TABLE base_nv (
  id INTEGER PRIMARY KEY,
  base INTEGER,
  doubled INTEGER DEFAULT (new.base * 2)
);
CREATE VIEW v_nv AS SELECT id, base, doubled FROM base_nv;

INSERT INTO v_nv (id, base) VALUES (1, 10);
SELECT base, doubled FROM base_nv WHERE id = 1;
→ [{"base":10,"doubled":20}]

DROP VIEW v_nv;
DROP TABLE base_nv;

-- ===================================
-- new.<column> nested inside a subquery in a DEFAULT resolves as a correlated
-- read of the row being inserted.
-- ===================================

CREATE TABLE t_sub (
  id INTEGER PRIMARY KEY,
  x INTEGER,
  y INTEGER DEFAULT (coalesce((SELECT new.x), 0))
);
INSERT INTO t_sub (id, x) VALUES (1, 7);
SELECT y FROM t_sub WHERE id = 1;
→ [{"y":7}]

DROP TABLE t_sub;

-- ===================================
-- new.<column> alongside GENERATED columns
-- A `new.` default coexists with generated columns (the two-pass expansion is
-- unaffected); but `new.<generated_col>` is NOT a source-supplied value, so it
-- raises a resolution error.
-- ===================================

CREATE TABLE t_gen (
  id INTEGER PRIMARY KEY,
  base INTEGER,
  dbl INTEGER DEFAULT (new.base * 2),
  g INTEGER GENERATED ALWAYS AS (base + 1) STORED
);
INSERT INTO t_gen (id, base) VALUES (1, 10);
SELECT dbl, g FROM t_gen WHERE id = 1;
→ [{"dbl":20,"g":11}]

DROP TABLE t_gen;

CREATE TABLE t_gen_ref (
  id INTEGER PRIMARY KEY,
  x INTEGER,
  g INTEGER GENERATED ALWAYS AS (x * 2) STORED,
  y INTEGER DEFAULT (new.g)
);
INSERT INTO t_gen_ref (id, x) VALUES (1, 5);
-- error: isn't a column

DROP TABLE t_gen_ref;

-- ===================================
-- Identity-resolving default: new.<column> inside a correlated subquery over
-- ANOTHER base table resolves an existing parent row's key from a supplied
-- value (the PK-is-FK extension-table / lens basis pattern). The default reads
-- new.value and looks the matching parent rowId up, rather than minting a fresh
-- surrogate.
-- ===================================

CREATE TABLE h0_users_id (
  rowId INTEGER PRIMARY KEY,
  value INTEGER
);
INSERT INTO h0_users_id (rowId, value) VALUES (10, 100), (20, 200);

CREATE TABLE h2_uprof (
  rowId INTEGER PRIMARY KEY DEFAULT (SELECT rowId FROM h0_users_id h0 WHERE h0.value = new.value),
  value INTEGER
);

-- value=200 resolves the parent's rowId=20 through the correlated subquery
INSERT INTO h2_uprof (value) VALUES (200);
SELECT rowId, value FROM h2_uprof WHERE value = 200;
→ [{"rowId":20,"value":200}]

-- a second resolution against a different supplied value
INSERT INTO h2_uprof (value) VALUES (100);
SELECT rowId, value FROM h2_uprof ORDER BY rowId;
→ [{"rowId":10,"value":100},{"rowId":20,"value":200}]

DROP TABLE h2_uprof;
DROP TABLE h0_users_id;
