-- adapted from SQLite test/descidx1.test, descidx2.test, descidx3.test
-- DESC indexes for output ordering. Companion to 40.1-pk-desc-direction (PK DESC)
-- and 10.5-indexes (single-column DESC creation). Pins composite mixed-direction
-- indexes, NULL ordering through DESC indexes, and range queries on DESC indexes.

-- =====================================================
-- 1. Single-column DESC index — descending traversal
-- =====================================================
create table d_one (id integer primary key, score integer);
insert into d_one values (1, 30);
insert into d_one values (2, 10);
insert into d_one values (3, 50);
insert into d_one values (4, 20);
insert into d_one values (5, 40);

create index ix_d_one_score on d_one(score desc);

-- ORDER BY DESC matches the index direction
select id, score from d_one order by score desc;
→ [{"id":3,"score":50},{"id":5,"score":40},{"id":1,"score":30},{"id":4,"score":20},{"id":2,"score":10}]

-- ORDER BY ASC also correct (engine may reverse-scan or sort, either way result is right)
select id, score from d_one order by score;
→ [{"id":2,"score":10},{"id":4,"score":20},{"id":1,"score":30},{"id":5,"score":40},{"id":3,"score":50}]

drop table d_one;

-- =====================================================
-- 2. Composite mixed-direction index (ASC, DESC)
-- =====================================================
create table d_mix (id integer primary key, category text, score integer);
insert into d_mix values (1, 'a', 10);
insert into d_mix values (2, 'a', 30);
insert into d_mix values (3, 'a', 20);
insert into d_mix values (4, 'b', 5);
insert into d_mix values (5, 'b', 25);

create index ix_d_mix on d_mix(category asc, score desc);

-- ORDER BY matching the index direction exactly
select id, category, score from d_mix order by category asc, score desc;
→ [{"id":2,"category":"a","score":30},{"id":3,"category":"a","score":20},{"id":1,"category":"a","score":10},{"id":5,"category":"b","score":25},{"id":4,"category":"b","score":5}]

-- Equality on the leading key followed by DESC scan of the trailing key
select id, score from d_mix where category = 'a' order by score desc;
→ [{"id":2,"score":30},{"id":3,"score":20},{"id":1,"score":10}]

drop table d_mix;

-- =====================================================
-- 3. DESC index with NULLs
-- =====================================================
create table d_null (id integer primary key, val text null);
insert into d_null values (1, 'z');
insert into d_null values (2, null);
insert into d_null values (3, 'a');
insert into d_null values (4, null);
insert into d_null values (5, 'm');

create index ix_d_null on d_null(val desc);

-- DESC sort with default NULL placement (Quereus default: NULLs last for DESC if specified that way; assert without forcing)
select val from d_null where val is not null order by val desc;
→ [{"val":"z"},{"val":"m"},{"val":"a"}]

-- Explicit NULLs FIRST under DESC
select val from d_null order by val desc nulls first;
→ [{"val":null},{"val":null},{"val":"z"},{"val":"m"},{"val":"a"}]

-- Explicit NULLs LAST under DESC
select val from d_null order by val desc nulls last;
→ [{"val":"z"},{"val":"m"},{"val":"a"},{"val":null},{"val":null}]

drop table d_null;

-- =====================================================
-- 4. Range scan on DESC index
-- =====================================================
create table d_range (id integer primary key, n integer);
insert into d_range values (1, 100);
insert into d_range values (2, 50);
insert into d_range values (3, 75);
insert into d_range values (4, 25);
insert into d_range values (5, 90);

create index ix_d_range on d_range(n desc);

-- Half-bounded range, DESC ordering
select n from d_range where n >= 60 order by n desc;
→ [{"n":100},{"n":90},{"n":75}]

-- Bounded range, DESC ordering
select n from d_range where n between 30 and 80 order by n desc;
→ [{"n":75},{"n":50}]

-- Same bounded range, ASC ordering still correct
select n from d_range where n between 30 and 80 order by n;
→ [{"n":50},{"n":75}]

drop table d_range;

-- =====================================================
-- 5. DESC index on TEXT — lexicographic descending
-- =====================================================
create table d_text (id integer primary key, name text);
insert into d_text values (1, 'banana');
insert into d_text values (2, 'apple');
insert into d_text values (3, 'cherry');
insert into d_text values (4, 'date');

create index ix_d_text on d_text(name desc);

select name from d_text order by name desc;
→ [{"name":"date"},{"name":"cherry"},{"name":"banana"},{"name":"apple"}]

-- Range on TEXT DESC index
select name from d_text where name >= 'b' order by name desc;
→ [{"name":"date"},{"name":"cherry"},{"name":"banana"}]

drop table d_text;
