{
  "name": "@quereus/quoomb-cli",
  "version": "4.4.0",
  "type": "module",
  "description": "Quoomb CLI - Interactive REPL for Quereus SQL engine",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "quoomb": "./dist/bin/quoomb.js"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "dev": "tsc && node dist/bin/quoomb.js",
    "lint": "echo 'No lint configured'",
    "//test": "NOTE: test/dot-commands.spec.ts smoke-tests table listing, schema display, CSV import type-inference, and export — the non-trivial logic here. --passWithNoTests stays as a safety net (not because this package is meant to stay test-free) so an empty glob doesn't fail the build.",
    "test": "vitest run --passWithNoTests",
    "prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/papaparse": "^5.5.2",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@quereus/plugin-loader": "workspace:^",
    "@quereus/quereus": "workspace:^",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "papaparse": "^5.5.3"
  }
}
