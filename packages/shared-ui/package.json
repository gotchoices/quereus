{
  "name": "@quereus/shared-ui",
  "version": "4.0.0",
  "type": "module",
  "description": "Quoomb UI Kit - Shared UI components for Quoomb applications",
  "publisher": "Got Choices Foundation",
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/quereus.git",
    "directory": "packages/shared-ui"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc && vite build --mode lib",
    "dev": "vite build --mode lib --watch",
    "lint": "echo 'No lint configured'",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/react": "10.4.5",
    "@storybook/react-vite": "10.4.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
